// Test that many keys don't degrade to O(n^2) with keyed hash
main() I {
  m = M()
  // Insert 1000 keys
  i := 0
  while i < 1000 {
    k = "key_" + str(i)
    m.set(k i)
    i += 1
    0
  }
  // Verify all retrievable
  ok := 0
  j := 0
  while j < 1000 {
    k = "key_" + str(j)
    v = m.get(k)!
    if v == j { ok += 1 }
    j += 1
    0
  }
  // All 1000 should match
  ok == 1000 ? 1 : 0
}
