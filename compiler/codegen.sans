cg_fmt_assert_some(cg:I) S {
  pool = cg_string_pool(cg)
  if mhas(pool, "__fmt_assert_some") { return mget(pool, "__fmt_assert_some") }
  name = "@fmt.assert_some"
  mset(pool, "__fmt_assert_some", ptr(name))
  emit_global_const(cg, name + " = private unnamed_addr constant [42 x i8] c\"assert_some failed: got none at line %ld\\0A\\00\"")
  name
}

cg_fmt_assert_none(cg:I) S {
  pool = cg_string_pool(cg)
  if mhas(pool, "__fmt_assert_none") { return mget(pool, "__fmt_assert_none") }
  name = "@fmt.assert_none"
  mset(pool, "__fmt_assert_none", ptr(name))
  emit_global_const(cg, name + " = private unnamed_addr constant [42 x i8] c\"assert_none failed: got some at line %ld\\0A\\00\"")
  name
}

// Generate a unique label suffix from a separate label counter
// (must NOT consume SSA register numbers)
cg_label_id(cg:I) S {
  n = load64(cg + 72)
  store64(cg + 72, n + 1)
  "L" + str(n)
}

// ------ Generic runtime call helpers ---------------------------------------------------------------------------------------------------

// 0-arg: dest = call i64 @fname()
compile_rt0(cg:I inst:I fname:S) I {
  d = cg_fresh_reg(cg)
  emit(cg, "  " + d + " = call i64 @" + fname + "()")
  cg_set_val(cg, ir_dest(inst), d)
  0
}

// 1-arg: dest = call i64 @fname(i64 arg1)
compile_rt1(cg:I inst:I fname:S) I {
  a = cg_get_val(cg, ir_field(inst, 16))
  d = cg_fresh_reg(cg)
  emit(cg, "  " + d + " = call i64 @" + fname + "(i64 " + a + ")")
  cg_set_val(cg, ir_dest(inst), d)
  0
}

// 2-arg: dest = call i64 @fname(i64 arg1, i64 arg2)
compile_rt2(cg:I inst:I fname:S) I {
  a = cg_get_val(cg, ir_field(inst, 16))
  b = cg_get_val(cg, ir_field(inst, 24))
  d = cg_fresh_reg(cg)
  emit(cg, "  " + d + " = call i64 @" + fname + "(i64 " + a + ", i64 " + b + ")")
  cg_set_val(cg, ir_dest(inst), d)
  0
}

// 3-arg: dest = call i64 @fname(i64 arg1, i64 arg2, i64 arg3)
compile_rt3(cg:I inst:I fname:S) I {
  a = cg_get_val(cg, ir_field(inst, 16))
  b = cg_get_val(cg, ir_field(inst, 24))
  c = cg_get_val(cg, ir_field(inst, 32))
  d = cg_fresh_reg(cg)
  emit(cg, "  " + d + " = call i64 @" + fname + "(i64 " + a + ", i64 " + b + ", i64 " + c + ")")
  cg_set_val(cg, ir_dest(inst), d)
  0
}

// 4-arg: dest = call i64 @fname(i64 a1, i64 a2, i64 a3, i64 a4)
compile_rt4(cg:I inst:I fname:S) I {
  a = cg_get_val(cg, ir_field(inst, 16))
  b = cg_get_val(cg, ir_field(inst, 24))
  c = cg_get_val(cg, ir_field(inst, 32))
  e = cg_get_val(cg, ir_field(inst, 40))
  d = cg_fresh_reg(cg)
  emit(cg, "  " + d + " = call i64 @" + fname + "(i64 " + a + ", i64 " + b + ", i64 " + c + ", i64 " + e + ")")
  cg_set_val(cg, ir_dest(inst), d)
  0
}

// Emit scope_track call for heap allocations in user code
// val = the LLVM register holding the pointer, tag = SCOPE_TAG_* constant
emit_scope_track(cg:I val:S tag:I) I {
  if cg_is_runtime_flag == 0 {
    st = cg_fresh_reg(cg)
    emit(cg, "  " + st + " = call i64 @sans_scope_track(i64 " + val + ", i64 " + str(tag) + ")")
  }
  0
}

// ------ Closure-aware indirect call helpers -----------------------------------------------
// These generate LLVM IR that checks if a function pointer is a tagged closure object.
// Tagged closures have bit 0 set (ptr + 1). If tagged, the closure object layout is:
//   [fn_ptr:i64, ncaps:i64, cap0:i64, cap1:i64, ...]
// Captures are prepended to the explicit args when calling the underlying function.

emit_closure_aware_call1(cg:I dest:I fp_val:S arg:S) I {
  // Check tag bit
  uid = cg_reg_counter(cg)
  tag = cg_fresh_reg(cg)
  emit(cg, "  " + tag + " = and i64 " + fp_val + ", 1")
  is_clo = cg_fresh_reg(cg)
  emit(cg, "  " + is_clo + " = icmp eq i64 " + tag + ", 1")
  lbl_clo = "fcall1_clo_" + str(uid)
  lbl_dir = "fcall1_dir_" + str(uid)
  lbl_sw = "fcall1_sw_" + str(uid)
  lbl_c0 = "fcall1_c0_" + str(uid)
  lbl_c1 = "fcall1_c1_" + str(uid)
  lbl_c2 = "fcall1_c2_" + str(uid)
  lbl_c3 = "fcall1_c3_" + str(uid)
  lbl_c4 = "fcall1_c4_" + str(uid)
  lbl_c5 = "fcall1_c5_" + str(uid)
  lbl_c6 = "fcall1_c6_" + str(uid)
  lbl_c7 = "fcall1_c7_" + str(uid)
  lbl_c8 = "fcall1_c8_" + str(uid)
  lbl_cerr = "fcall1_cerr_" + str(uid)
  lbl_merge = "fcall1_merge_" + str(uid)
  emit(cg, "  br i1 " + is_clo + ", label %" + lbl_clo + ", label %" + lbl_dir)
  // Direct path
  emit(cg, lbl_dir + ":")
  fp_d = cg_fresh_reg(cg)
  emit(cg, "  " + fp_d + " = inttoptr i64 " + fp_val + " to ptr")
  r_d = cg_fresh_reg(cg)
  emit(cg, "  " + r_d + " = call i64 " + fp_d + "(i64 " + arg + ")")
  emit(cg, "  br label %" + lbl_merge)
  // Closure path: unpack object
  emit(cg, lbl_clo + ":")
  obj = cg_fresh_reg(cg)
  emit(cg, "  " + obj + " = sub i64 " + fp_val + ", 1")
  obj_ptr = cg_fresh_reg(cg)
  emit(cg, "  " + obj_ptr + " = inttoptr i64 " + obj + " to ptr")
  fn_slot = cg_fresh_reg(cg)
  emit(cg, "  " + fn_slot + " = load i64, ptr " + obj_ptr)
  fn_ptr = cg_fresh_reg(cg)
  emit(cg, "  " + fn_ptr + " = inttoptr i64 " + fn_slot + " to ptr")
  ncaps_gep = cg_fresh_reg(cg)
  emit(cg, "  " + ncaps_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 1")
  ncaps = cg_fresh_reg(cg)
  emit(cg, "  " + ncaps + " = load i64, ptr " + ncaps_gep)
  emit(cg, "  br label %" + lbl_sw)
  // Switch on ncaps
  emit(cg, lbl_sw + ":")
  emit(cg, "  switch i64 " + ncaps + ", label %" + lbl_cerr + " [i64 0, label %" + lbl_c0 + " i64 1, label %" + lbl_c1 + " i64 2, label %" + lbl_c2 + " i64 3, label %" + lbl_c3 + " i64 4, label %" + lbl_c4 + " i64 5, label %" + lbl_c5 + " i64 6, label %" + lbl_c6 + " i64 7, label %" + lbl_c7 + " i64 8, label %" + lbl_c8 + "]")
  // 0 captures
  emit(cg, lbl_c0 + ":")
  r_c0 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c0 + " = call i64 " + fn_ptr + "(i64 " + arg + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 1 capture
  emit(cg, lbl_c1 + ":")
  c1_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c1_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c1_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c1_0 + " = load i64, ptr " + c1_0_gep)
  r_c1 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c1 + " = call i64 " + fn_ptr + "(i64 " + c1_0 + ", i64 " + arg + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 2 captures
  emit(cg, lbl_c2 + ":")
  c2_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c2_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c2_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c2_0 + " = load i64, ptr " + c2_0_gep)
  c2_1_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c2_1_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 3")
  c2_1 = cg_fresh_reg(cg)
  emit(cg, "  " + c2_1 + " = load i64, ptr " + c2_1_gep)
  r_c2 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c2 + " = call i64 " + fn_ptr + "(i64 " + c2_0 + ", i64 " + c2_1 + ", i64 " + arg + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 3 captures
  emit(cg, lbl_c3 + ":")
  c3_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c3_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c3_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c3_0 + " = load i64, ptr " + c3_0_gep)
  c3_1_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c3_1_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 3")
  c3_1 = cg_fresh_reg(cg)
  emit(cg, "  " + c3_1 + " = load i64, ptr " + c3_1_gep)
  c3_2_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c3_2_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 4")
  c3_2 = cg_fresh_reg(cg)
  emit(cg, "  " + c3_2 + " = load i64, ptr " + c3_2_gep)
  r_c3 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c3 + " = call i64 " + fn_ptr + "(i64 " + c3_0 + ", i64 " + c3_1 + ", i64 " + c3_2 + ", i64 " + arg + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 4 captures
  emit(cg, lbl_c4 + ":")
  c4_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c4_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c4_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c4_0 + " = load i64, ptr " + c4_0_gep)
  c4_1_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c4_1_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 3")
  c4_1 = cg_fresh_reg(cg)
  emit(cg, "  " + c4_1 + " = load i64, ptr " + c4_1_gep)
  c4_2_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c4_2_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 4")
  c4_2 = cg_fresh_reg(cg)
  emit(cg, "  " + c4_2 + " = load i64, ptr " + c4_2_gep)
  c4_3_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c4_3_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 5")
  c4_3 = cg_fresh_reg(cg)
  emit(cg, "  " + c4_3 + " = load i64, ptr " + c4_3_gep)
  r_c4 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c4 + " = call i64 " + fn_ptr + "(i64 " + c4_0 + ", i64 " + c4_1 + ", i64 " + c4_2 + ", i64 " + c4_3 + ", i64 " + arg + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 5 captures
  emit(cg, lbl_c5 + ":")
  c5_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c5_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c5_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c5_0 + " = load i64, ptr " + c5_0_gep)
  c5_1_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c5_1_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 3")
  c5_1 = cg_fresh_reg(cg)
  emit(cg, "  " + c5_1 + " = load i64, ptr " + c5_1_gep)
  c5_2_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c5_2_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 4")
  c5_2 = cg_fresh_reg(cg)
  emit(cg, "  " + c5_2 + " = load i64, ptr " + c5_2_gep)
  c5_3_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c5_3_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 5")
  c5_3 = cg_fresh_reg(cg)
  emit(cg, "  " + c5_3 + " = load i64, ptr " + c5_3_gep)
  c5_4_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c5_4_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 6")
  c5_4 = cg_fresh_reg(cg)
  emit(cg, "  " + c5_4 + " = load i64, ptr " + c5_4_gep)
  r_c5 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c5 + " = call i64 " + fn_ptr + "(i64 " + c5_0 + ", i64 " + c5_1 + ", i64 " + c5_2 + ", i64 " + c5_3 + ", i64 " + c5_4 + ", i64 " + arg + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 6 captures
  emit(cg, lbl_c6 + ":")
  c6_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c6_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c6_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c6_0 + " = load i64, ptr " + c6_0_gep)
  c6_1_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c6_1_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 3")
  c6_1 = cg_fresh_reg(cg)
  emit(cg, "  " + c6_1 + " = load i64, ptr " + c6_1_gep)
  c6_2_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c6_2_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 4")
  c6_2 = cg_fresh_reg(cg)
  emit(cg, "  " + c6_2 + " = load i64, ptr " + c6_2_gep)
  c6_3_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c6_3_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 5")
  c6_3 = cg_fresh_reg(cg)
  emit(cg, "  " + c6_3 + " = load i64, ptr " + c6_3_gep)
  c6_4_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c6_4_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 6")
  c6_4 = cg_fresh_reg(cg)
  emit(cg, "  " + c6_4 + " = load i64, ptr " + c6_4_gep)
  c6_5_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c6_5_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 7")
  c6_5 = cg_fresh_reg(cg)
  emit(cg, "  " + c6_5 + " = load i64, ptr " + c6_5_gep)
  r_c6 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c6 + " = call i64 " + fn_ptr + "(i64 " + c6_0 + ", i64 " + c6_1 + ", i64 " + c6_2 + ", i64 " + c6_3 + ", i64 " + c6_4 + ", i64 " + c6_5 + ", i64 " + arg + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 7 captures
  emit(cg, lbl_c7 + ":")
  c7_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c7_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_0 + " = load i64, ptr " + c7_0_gep)
  c7_1_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_1_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 3")
  c7_1 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_1 + " = load i64, ptr " + c7_1_gep)
  c7_2_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_2_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 4")
  c7_2 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_2 + " = load i64, ptr " + c7_2_gep)
  c7_3_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_3_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 5")
  c7_3 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_3 + " = load i64, ptr " + c7_3_gep)
  c7_4_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_4_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 6")
  c7_4 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_4 + " = load i64, ptr " + c7_4_gep)
  c7_5_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_5_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 7")
  c7_5 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_5 + " = load i64, ptr " + c7_5_gep)
  c7_6_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_6_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 8")
  c7_6 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_6 + " = load i64, ptr " + c7_6_gep)
  r_c7 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c7 + " = call i64 " + fn_ptr + "(i64 " + c7_0 + ", i64 " + c7_1 + ", i64 " + c7_2 + ", i64 " + c7_3 + ", i64 " + c7_4 + ", i64 " + c7_5 + ", i64 " + c7_6 + ", i64 " + arg + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 8 captures
  emit(cg, lbl_c8 + ":")
  c8_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c8_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_0 + " = load i64, ptr " + c8_0_gep)
  c8_1_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_1_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 3")
  c8_1 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_1 + " = load i64, ptr " + c8_1_gep)
  c8_2_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_2_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 4")
  c8_2 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_2 + " = load i64, ptr " + c8_2_gep)
  c8_3_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_3_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 5")
  c8_3 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_3 + " = load i64, ptr " + c8_3_gep)
  c8_4_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_4_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 6")
  c8_4 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_4 + " = load i64, ptr " + c8_4_gep)
  c8_5_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_5_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 7")
  c8_5 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_5 + " = load i64, ptr " + c8_5_gep)
  c8_6_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_6_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 8")
  c8_6 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_6 + " = load i64, ptr " + c8_6_gep)
  c8_7_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_7_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 9")
  c8_7 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_7 + " = load i64, ptr " + c8_7_gep)
  r_c8 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c8 + " = call i64 " + fn_ptr + "(i64 " + c8_0 + ", i64 " + c8_1 + ", i64 " + c8_2 + ", i64 " + c8_3 + ", i64 " + c8_4 + ", i64 " + c8_5 + ", i64 " + c8_6 + ", i64 " + c8_7 + ", i64 " + arg + ")")
  emit(cg, "  br label %" + lbl_merge)
  // Error: too many captures
  emit(cg, lbl_cerr + ":")
  cerr_r = cg_fresh_reg(cg)
  emit(cg, "  " + cerr_r + " = call i64 (ptr, ...) @printf(ptr @.str.too_many_caps)")
  emit(cg, "  call void @exit(i64 1)")
  emit(cg, "  unreachable")
  // Merge
  emit(cg, lbl_merge + ":")
  result = cg_fresh_reg(cg)
  emit(cg, "  " + result + " = phi i64 [" + r_d + ", %" + lbl_dir + "], [" + r_c0 + ", %" + lbl_c0 + "], [" + r_c1 + ", %" + lbl_c1 + "], [" + r_c2 + ", %" + lbl_c2 + "], [" + r_c3 + ", %" + lbl_c3 + "], [" + r_c4 + ", %" + lbl_c4 + "], [" + r_c5 + ", %" + lbl_c5 + "], [" + r_c6 + ", %" + lbl_c6 + "], [" + r_c7 + ", %" + lbl_c7 + "], [" + r_c8 + ", %" + lbl_c8 + "]")
  cg_set_val(cg, dest, result)
  cg_set_current_block(cg, lbl_merge)
  0
}

emit_closure_aware_call2(cg:I dest:I fp_val:S a1:S a2:S) I {
  uid = cg_reg_counter(cg)
  tag = cg_fresh_reg(cg)
