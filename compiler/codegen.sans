  emit(cg, "declare i64 @sans_map_vals(i64)")
  emit(cg, "declare i64 @sans_map_set_int(i64, i64, i64)")
  emit(cg, "declare i64 @sans_map_get_int(i64, i64)")
  emit(cg, "declare i64 @sans_map_has_int(i64, i64)")
  emit(cg, "declare i64 @sans_map_keys_int(i64)")
  emit(cg, "declare i64 @sans_map_delete_int(i64, i64)")

  // ------ Sans runtime: Arena ------
  emit(cg, "declare i64 @sans_arena_begin()")
  emit(cg, "declare i64 @sans_arena_alloc(i64)")
  emit(cg, "declare i64 @sans_arena_end()")

  // ------ Sans runtime: Range, Sort, Reverse, Join ------
  emit(cg, "declare i64 @sans_range1(i64)")
  emit(cg, "declare i64 @sans_range2(i64, i64)")
  emit(cg, "declare i64 @sans_array_sort(i64)")
  emit(cg, "declare i64 @sans_array_reverse(i64)")
  emit(cg, "declare i64 @sans_array_join(i64, i64)")

  // ------ Sans runtime: String upper/lower/index_of/char_at ------
  emit(cg, "declare i64 @sans_string_upper(i64)")
  emit(cg, "declare i64 @sans_string_lower(i64)")
  emit(cg, "declare i64 @sans_string_index_of(i64, i64)")
  emit(cg, "declare i64 @sans_string_char_at(i64, i64)")
  emit(cg, "declare i64 @sans_string_to_float(i64)")
  emit(cg, "declare i64 @sans_string_repeat(i64, i64)")

  // ------ Sans runtime: Math ------
  emit(cg, "declare i64 @sans_abs(i64)")
  emit(cg, "declare i64 @sans_min(i64, i64)")
  emit(cg, "declare i64 @sans_max(i64, i64)")

  // ------ Sans runtime: System ------
  emit(cg, "declare i64 @sans_sleep(i64)")
  emit(cg, "declare i64 @sans_time()")
  emit(cg, "declare i64 @sans_random(i64)")

  // ------ Sans runtime: Array reduce/each/flat_map ------
  emit(cg, "declare i64 @sans_array_reduce(i64, i64, i64)")
  emit(cg, "declare i64 @sans_array_each(i64, i64)")
  emit(cg, "declare i64 @sans_array_flat_map(i64, i64)")

  // ------ Sans runtime: Array slice, Map delete ------
  emit(cg, "declare i64 @sans_array_slice(i64, i64, i64)")
  emit(cg, "declare i64 @sans_map_delete(i64, i64)")

  // ------ Sans runtime: Array sum/min/max/flat ------
  emit(cg, "declare i64 @sans_array_sum(i64)")
  emit(cg, "declare i64 @sans_array_min(i64)")
  emit(cg, "declare i64 @sans_array_max(i64)")
  emit(cg, "declare i64 @sans_array_flat(i64)")

  // ------ Sans runtime: String pad/bytes ------
  emit(cg, "declare i64 @sans_string_pad_left(i64, i64, i64)")
  emit(cg, "declare i64 @sans_string_pad_right(i64, i64, i64)")
  emit(cg, "declare i64 @sans_string_bytes(i64)")

  // ------ Sans runtime: Map entries ------
  emit(cg, "declare i64 @sans_map_entries(i64)")

  // ------ Sans runtime: Filesystem ------
  emit(cg, "declare i64 @sans_mkdir(i64)")
  emit(cg, "declare i64 @sans_is_dir(i64)")
  emit(cg, "declare i64 @sans_listdir(i64)")

  // ------ Sans runtime: Process ------
  emit(cg, "declare i64 @sans_sh(i64)")

  // ------ Sans runtime: Reference Counting ------
  emit(cg, "declare i64 @sans_rc_alloc(i64)")
  emit(cg, "declare i64 @sans_rc_retain(i64)")
  emit(cg, "declare i64 @sans_rc_release(i64)")
  emit(cg, "declare i64 @sans_rc_count(i64)")

  // ------ Sans runtime: Scope-based memory management ------
  emit(cg, "declare i64 @sans_scope_enter()")
  emit(cg, "declare i64 @sans_scope_exit(i64)")
  emit(cg, "declare i64 @sans_scope_track(i64, i64)")
  emit(cg, "declare i64 @sans_scope_untrack(i64)")
  emit(cg, "declare i64 @sans_scope_disable()")
  emit(cg, "declare i64 @sans_scope_enable()")

  // ------ Sans runtime: Socket helper ------
  emit(cg, "declare i64 @sans_bind_port(i64, i64)")

  // ------ Sans runtime: HTTPS / SSL ------
  emit(cg, "declare i64 @sans_https_listen(i64, i64, i64)")
  emit(cg, "declare i64 @sans_https_accept(i64)")
  emit(cg, "declare i64 @sans_https_respond(i64, i64, i64, i64)")
  emit(cg, "declare i64 @sans_http_request_header(i64, i64)")
  emit(cg, "declare i64 @sans_http_request_set_header(i64, i64, i64)")
  emit(cg, "declare i64 @sans_http_request_cookie(i64, i64)")
  emit(cg, "declare i64 @sans_cors(i64, i64)")
  emit(cg, "declare i64 @sans_cors_all(i64)")
  emit(cg, "declare i64 @sans_http_request_query(i64, i64)")
  emit(cg, "declare i64 @sans_http_request_path_only(i64)")
  emit(cg, "declare i64 @sans_http_request_content_length(i64)")
  emit(cg, "declare i64 @sans_http_respond_json(i64, i64, i64)")
  emit(cg, "declare i64 @sans_url_decode(i64)")
  emit(cg, "declare i64 @sans_path_segment(i64, i64)")
  emit(cg, "declare i64 @sans_serve_file(i64, i64)")
  emit(cg, "declare i64 @sans_serve(i64, i64)")
  emit(cg, "declare i64 @sans_serve_tls(i64, i64, i64, i64)")
  emit(cg, "declare i64 @sans_respond_stream(i64, i64)")
  emit(cg, "declare i64 @sans_stream_write(i64, i64)")
  emit(cg, "declare i64 @sans_stream_end(i64)")
  emit(cg, "declare i64 @sans_http_request_form(i64, i64)")

  // ------ WebSocket ------
  emit(cg, "declare i64 @sans_ws_is_upgrade(i64)")
  emit(cg, "declare i64 @sans_ws_upgrade(i64)")
  emit(cg, "declare i64 @sans_ws_send(i64, i64)")
  emit(cg, "declare i64 @sans_ws_recv(i64)")
  emit(cg, "declare i64 @sans_ws_close(i64)")

  // ------ Signal / Poll ------
  emit(cg, "declare i64 @signal(i32, ptr)")
  emit(cg, "declare i32 @poll(ptr, i32, i32)")

  // ------ Signal handler global + function ------
  emit(cg, "@__sans_signal_flag = global i64 0")
  emit(cg, "define void @__sans_signal_handler(i32 %sig) {")
  emit(cg, "  store i64 1, ptr @__sans_signal_flag")
  emit(cg, "  ret void")
  emit(cg, "}")

  // ------ OpenSSL ------
  emit(cg, "declare ptr @TLS_server_method()")
  emit(cg, "declare ptr @SSL_CTX_new(ptr)")
  emit(cg, "declare i32 @SSL_CTX_use_certificate_file(ptr, ptr, i32)")
  emit(cg, "declare i32 @SSL_CTX_use_PrivateKey_file(ptr, ptr, i32)")
  emit(cg, "declare ptr @SSL_new(ptr)")
  emit(cg, "declare i32 @SSL_set_fd(ptr, i32)")
  emit(cg, "declare i32 @SSL_accept(ptr)")
  emit(cg, "declare i32 @SSL_read(ptr, ptr, i32)")
  emit(cg, "declare i32 @SSL_write(ptr, ptr, i32)")
  emit(cg, "declare i32 @SSL_shutdown(ptr)")
  emit(cg, "declare void @SSL_free(ptr)")

  // __sans_args is defined inline (not declared as external)

  // ------ zlib ------
  emit(cg, "declare i32 @deflateInit2_(ptr, i32, i32, i32, i32, i32, ptr, i32)")
  emit(cg, "declare i32 @deflate(ptr, i32)")
  emit(cg, "declare i32 @deflateEnd(ptr)")
  emit(cg, "declare i64 @deflateBound(ptr, i64)")

  // ------ LLVM intrinsics ------
  emit(cg, "declare i16 @llvm.bswap.i16(i16)")

  emit(cg, "@.empty_str = private unnamed_addr constant [1 x i8] zeroinitializer")
  emit(cg, "@.str.too_many_caps = private unnamed_addr constant [36 x i8] c\"closure: too many captures (max 8)\\0a\\00\"")

  emit(cg, "")
  0
}

// ------ SSL-aware dispatch helpers ------------------------------------------------------------------------------------------------------------

// server.accept() --- check if server has SSL context at offset 16
// If non-zero: call sans_https_accept, else call sans_http_accept
compile_http_accept(cg:I inst:I) I {
  dest = ir_dest(inst)
  a = cg_get_val(cg, ir_field(inst, 16))
  uid = cg_label_id(cg)
  // Load offset 16 of server struct (SSL context ptr)
  sp = cg_fresh_reg(cg)
  emit(cg, "  " + sp + " = inttoptr i64 " + a + " to ptr")
  ssl_ptr = cg_fresh_reg(cg)
  emit(cg, "  " + ssl_ptr + " = getelementptr i8, ptr " + sp + ", i64 16")
  ssl_val = cg_fresh_reg(cg)
  emit(cg, "  " + ssl_val + " = load i64, ptr " + ssl_ptr)
  cmp = cg_fresh_reg(cg)
  emit(cg, "  " + cmp + " = icmp ne i64 " + ssl_val + ", 0")
  ssl_lbl = "accept_ssl_" + uid
  plain_lbl = "accept_plain_" + uid
  merge_lbl = "accept_merge_" + uid
  emit(cg, "  br i1 " + cmp + ", label %" + ssl_lbl + ", label %" + plain_lbl)
  // SSL path
  emit(cg, ssl_lbl + ":")
  r_ssl = cg_fresh_reg(cg)
  emit(cg, "  " + r_ssl + " = call i64 @sans_https_accept(i64 " + a + ")")
  emit(cg, "  br label %" + merge_lbl)
  // Plain path
  emit(cg, plain_lbl + ":")
  r_plain = cg_fresh_reg(cg)
  emit(cg, "  " + r_plain + " = call i64 @sans_http_accept(i64 " + a + ")")
  emit(cg, "  br label %" + merge_lbl)
  // Merge
  emit(cg, merge_lbl + ":")
  r = cg_fresh_reg(cg)
  emit(cg, "  " + r + " = phi i64 [" + r_ssl + ", %" + ssl_lbl + "], [" + r_plain + ", %" + plain_lbl + "]")
  cg_set_val(cg, dest, r)
  cg_set_current_block(cg, merge_lbl)
  0
}

// map.get() returning Option --- calls has/get then wraps in Some/None
compile_map_get_opt(cg:I inst:I) I {
  dest = ir_dest(inst)
  m_val = cg_get_val(cg, ir_field(inst, 16))
  k_val = cg_get_val(cg, ir_field(inst, 24))
  uid = cg_label_id(cg)
  has_r = cg_fresh_reg(cg)
  emit(cg, "  " + has_r + " = call i64 @sans_map_has(i64 " + m_val + ", i64 " + k_val + ")")
  cmp_r = cg_fresh_reg(cg)
  emit(cg, "  " + cmp_r + " = icmp ne i64 " + has_r + ", 0")
  found_lbl = "mgo_found_" + uid
  miss_lbl = "mgo_miss_" + uid
  merge_lbl = "mgo_merge_" + uid
  emit(cg, "  br i1 " + cmp_r + ", label %" + found_lbl + ", label %" + miss_lbl)
  emit(cg, found_lbl + ":")
  raw_r = cg_fresh_reg(cg)
  emit(cg, "  " + raw_r + " = call i64 @sans_map_get(i64 " + m_val + ", i64 " + k_val + ")")
  some_r = cg_fresh_reg(cg)
  emit(cg, "  " + some_r + " = call i64 @sans_option_some(i64 " + raw_r + ")")
  emit(cg, "  br label %" + merge_lbl)
  emit(cg, miss_lbl + ":")
  none_r = cg_fresh_reg(cg)
  emit(cg, "  " + none_r + " = call i64 @sans_option_none()")
  emit(cg, "  br label %" + merge_lbl)
  emit(cg, merge_lbl + ":")
  phi_r = cg_fresh_reg(cg)
  emit(cg, "  " + phi_r + " = phi i64 [" + some_r + ", %" + found_lbl + "], [" + none_r + ", %" + miss_lbl + "]")
  cg_set_val(cg, dest, phi_r)
  cg_set_current_block(cg, merge_lbl)
  emit_scope_track(cg, phi_r, 6)
  0
}

compile_map_get_opt_int(cg:I inst:I) I {
  dest = ir_dest(inst)
  m_val = cg_get_val(cg, ir_field(inst, 16))
  k_val = cg_get_val(cg, ir_field(inst, 24))
  uid = cg_label_id(cg)
  has_r = cg_fresh_reg(cg)
  emit(cg, "  " + has_r + " = call i64 @sans_map_has_int(i64 " + m_val + ", i64 " + k_val + ")")
  cmp_r = cg_fresh_reg(cg)
  emit(cg, "  " + cmp_r + " = icmp ne i64 " + has_r + ", 0")
  found_lbl = "mgoi_found_" + uid
  miss_lbl = "mgoi_miss_" + uid
  merge_lbl = "mgoi_merge_" + uid
  emit(cg, "  br i1 " + cmp_r + ", label %" + found_lbl + ", label %" + miss_lbl)
  emit(cg, found_lbl + ":")
  raw_r = cg_fresh_reg(cg)
  emit(cg, "  " + raw_r + " = call i64 @sans_map_get_int(i64 " + m_val + ", i64 " + k_val + ")")
  some_r = cg_fresh_reg(cg)
  emit(cg, "  " + some_r + " = call i64 @sans_option_some(i64 " + raw_r + ")")
  emit(cg, "  br label %" + merge_lbl)
  emit(cg, miss_lbl + ":")
  none_r = cg_fresh_reg(cg)
  emit(cg, "  " + none_r + " = call i64 @sans_option_none()")
  emit(cg, "  br label %" + merge_lbl)
  emit(cg, merge_lbl + ":")
  phi_r = cg_fresh_reg(cg)
  emit(cg, "  " + phi_r + " = phi i64 [" + some_r + ", %" + found_lbl + "], [" + none_r + ", %" + miss_lbl + "]")
  cg_set_val(cg, dest, phi_r)
  cg_set_current_block(cg, merge_lbl)
  emit_scope_track(cg, phi_r, 6)
  0
}

// req.respond() --- check if request has SSL at offset 48
// If non-zero: call sans_https_respond, else call sans_http_respond
compile_http_respond(cg:I req_v:S status_v:S body_v:S ct_v:S) I {
  uid = cg_label_id(cg)
  // Load offset 48 of request struct (SSL ptr)
  rp = cg_fresh_reg(cg)
  emit(cg, "  " + rp + " = inttoptr i64 " + req_v + " to ptr")
  ssl_ptr = cg_fresh_reg(cg)
  emit(cg, "  " + ssl_ptr + " = getelementptr i8, ptr " + rp + ", i64 48")
  ssl_val = cg_fresh_reg(cg)
  emit(cg, "  " + ssl_val + " = load i64, ptr " + ssl_ptr)
  cmp = cg_fresh_reg(cg)
  emit(cg, "  " + cmp + " = icmp ne i64 " + ssl_val + ", 0")
  ssl_lbl = "respond_ssl_" + uid
  plain_lbl = "respond_plain_" + uid
  merge_lbl = "respond_merge_" + uid
  emit(cg, "  br i1 " + cmp + ", label %" + ssl_lbl + ", label %" + plain_lbl)
  // SSL path
  emit(cg, ssl_lbl + ":")
  r_ssl = cg_fresh_reg(cg)
  emit(cg, "  " + r_ssl + " = call i64 @sans_https_respond(i64 " + req_v + ", i64 " + status_v + ", i64 " + body_v + ", i64 " + ct_v + ")")
  emit(cg, "  br label %" + merge_lbl)
  // Plain path
  emit(cg, plain_lbl + ":")
  r_plain = cg_fresh_reg(cg)
  emit(cg, "  " + r_plain + " = call i64 @sans_http_respond(i64 " + req_v + ", i64 " + status_v + ", i64 " + body_v + ", i64 " + ct_v + ")")
  emit(cg, "  br label %" + merge_lbl)
  // Merge
  emit(cg, merge_lbl + ":")
  r = cg_fresh_reg(cg)
  emit(cg, "  " + r + " = phi i64 [" + r_ssl + ", %" + ssl_lbl + "], [" + r_plain + ", %" + plain_lbl + "]")
  cg_set_current_block(cg, merge_lbl)
  r
}

// ------ Format string globals (emitted once, lazily) ------------------------------------------------

cg_fmt_int(cg:I) S {
  pool = cg_string_pool(cg)
  if mhas(pool, "__fmt_int") { return mget(pool, "__fmt_int") }
  name = "@fmt.int"
  mset(pool, "__fmt_int", ptr(name))
  emit_global_const(cg, name + " = private unnamed_addr constant [5 x i8] c\"%ld\\0A\\00\"")
  name
}

cg_fmt_float(cg:I) S {
  pool = cg_string_pool(cg)
  if mhas(pool, "__fmt_float") { return mget(pool, "__fmt_float") }
  name = "@fmt.float"
  mset(pool, "__fmt_float", ptr(name))
  emit_global_const(cg, name + " = private unnamed_addr constant [4 x i8] c\"%g\\0A\\00\"")
  name
}

