  emit(cg, "  " + c3_1 + " = load i64, ptr " + c3_1_gep)
  c3_2_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c3_2_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 4")
  c3_2 = cg_fresh_reg(cg)
  emit(cg, "  " + c3_2 + " = load i64, ptr " + c3_2_gep)
  r_c3 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c3 + " = call i64 " + fn_ptr + "(i64 " + c3_0 + ", i64 " + c3_1 + ", i64 " + c3_2 + ", i64 " + a1 + ", i64 " + a2 + ", i64 " + a3 + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 4 captures
  emit(cg, lbl_c4 + ":")
  c4_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c4_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c4_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c4_0 + " = load i64, ptr " + c4_0_gep)
  c4_1_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c4_1_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 3")
  c4_1 = cg_fresh_reg(cg)
  emit(cg, "  " + c4_1 + " = load i64, ptr " + c4_1_gep)
  c4_2_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c4_2_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 4")
  c4_2 = cg_fresh_reg(cg)
  emit(cg, "  " + c4_2 + " = load i64, ptr " + c4_2_gep)
  c4_3_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c4_3_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 5")
  c4_3 = cg_fresh_reg(cg)
  emit(cg, "  " + c4_3 + " = load i64, ptr " + c4_3_gep)
  r_c4 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c4 + " = call i64 " + fn_ptr + "(i64 " + c4_0 + ", i64 " + c4_1 + ", i64 " + c4_2 + ", i64 " + c4_3 + ", i64 " + a1 + ", i64 " + a2 + ", i64 " + a3 + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 5 captures
  emit(cg, lbl_c5 + ":")
  c5_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c5_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c5_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c5_0 + " = load i64, ptr " + c5_0_gep)
  c5_1_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c5_1_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 3")
  c5_1 = cg_fresh_reg(cg)
  emit(cg, "  " + c5_1 + " = load i64, ptr " + c5_1_gep)
  c5_2_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c5_2_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 4")
  c5_2 = cg_fresh_reg(cg)
  emit(cg, "  " + c5_2 + " = load i64, ptr " + c5_2_gep)
  c5_3_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c5_3_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 5")
  c5_3 = cg_fresh_reg(cg)
  emit(cg, "  " + c5_3 + " = load i64, ptr " + c5_3_gep)
  c5_4_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c5_4_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 6")
  c5_4 = cg_fresh_reg(cg)
  emit(cg, "  " + c5_4 + " = load i64, ptr " + c5_4_gep)
  r_c5 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c5 + " = call i64 " + fn_ptr + "(i64 " + c5_0 + ", i64 " + c5_1 + ", i64 " + c5_2 + ", i64 " + c5_3 + ", i64 " + c5_4 + ", i64 " + a1 + ", i64 " + a2 + ", i64 " + a3 + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 6 captures
  emit(cg, lbl_c6 + ":")
  c6_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c6_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c6_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c6_0 + " = load i64, ptr " + c6_0_gep)
  c6_1_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c6_1_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 3")
  c6_1 = cg_fresh_reg(cg)
  emit(cg, "  " + c6_1 + " = load i64, ptr " + c6_1_gep)
  c6_2_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c6_2_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 4")
  c6_2 = cg_fresh_reg(cg)
  emit(cg, "  " + c6_2 + " = load i64, ptr " + c6_2_gep)
  c6_3_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c6_3_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 5")
  c6_3 = cg_fresh_reg(cg)
  emit(cg, "  " + c6_3 + " = load i64, ptr " + c6_3_gep)
  c6_4_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c6_4_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 6")
  c6_4 = cg_fresh_reg(cg)
  emit(cg, "  " + c6_4 + " = load i64, ptr " + c6_4_gep)
  c6_5_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c6_5_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 7")
  c6_5 = cg_fresh_reg(cg)
  emit(cg, "  " + c6_5 + " = load i64, ptr " + c6_5_gep)
  r_c6 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c6 + " = call i64 " + fn_ptr + "(i64 " + c6_0 + ", i64 " + c6_1 + ", i64 " + c6_2 + ", i64 " + c6_3 + ", i64 " + c6_4 + ", i64 " + c6_5 + ", i64 " + a1 + ", i64 " + a2 + ", i64 " + a3 + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 7 captures
  emit(cg, lbl_c7 + ":")
  c7_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c7_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_0 + " = load i64, ptr " + c7_0_gep)
  c7_1_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_1_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 3")
  c7_1 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_1 + " = load i64, ptr " + c7_1_gep)
  c7_2_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_2_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 4")
  c7_2 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_2 + " = load i64, ptr " + c7_2_gep)
  c7_3_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_3_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 5")
  c7_3 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_3 + " = load i64, ptr " + c7_3_gep)
  c7_4_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_4_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 6")
  c7_4 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_4 + " = load i64, ptr " + c7_4_gep)
  c7_5_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_5_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 7")
  c7_5 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_5 + " = load i64, ptr " + c7_5_gep)
  c7_6_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c7_6_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 8")
  c7_6 = cg_fresh_reg(cg)
  emit(cg, "  " + c7_6 + " = load i64, ptr " + c7_6_gep)
  r_c7 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c7 + " = call i64 " + fn_ptr + "(i64 " + c7_0 + ", i64 " + c7_1 + ", i64 " + c7_2 + ", i64 " + c7_3 + ", i64 " + c7_4 + ", i64 " + c7_5 + ", i64 " + c7_6 + ", i64 " + a1 + ", i64 " + a2 + ", i64 " + a3 + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 8 captures
  emit(cg, lbl_c8 + ":")
  c8_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c8_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_0 + " = load i64, ptr " + c8_0_gep)
  c8_1_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_1_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 3")
  c8_1 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_1 + " = load i64, ptr " + c8_1_gep)
  c8_2_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_2_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 4")
  c8_2 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_2 + " = load i64, ptr " + c8_2_gep)
  c8_3_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_3_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 5")
  c8_3 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_3 + " = load i64, ptr " + c8_3_gep)
  c8_4_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_4_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 6")
  c8_4 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_4 + " = load i64, ptr " + c8_4_gep)
  c8_5_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_5_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 7")
  c8_5 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_5 + " = load i64, ptr " + c8_5_gep)
  c8_6_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_6_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 8")
  c8_6 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_6 + " = load i64, ptr " + c8_6_gep)
  c8_7_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c8_7_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 9")
  c8_7 = cg_fresh_reg(cg)
  emit(cg, "  " + c8_7 + " = load i64, ptr " + c8_7_gep)
  r_c8 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c8 + " = call i64 " + fn_ptr + "(i64 " + c8_0 + ", i64 " + c8_1 + ", i64 " + c8_2 + ", i64 " + c8_3 + ", i64 " + c8_4 + ", i64 " + c8_5 + ", i64 " + c8_6 + ", i64 " + c8_7 + ", i64 " + a1 + ", i64 " + a2 + ", i64 " + a3 + ")")
  emit(cg, "  br label %" + lbl_merge)
  // Error: too many captures
  emit(cg, lbl_cerr + ":")
  cerr_r = cg_fresh_reg(cg)
  emit(cg, "  " + cerr_r + " = call i64 (ptr, ...) @printf(ptr @.str.too_many_caps)")
  emit(cg, "  call void @exit(i64 1)")
  emit(cg, "  unreachable")
  // Merge
  emit(cg, lbl_merge + ":")
  result = cg_fresh_reg(cg)
  emit(cg, "  " + result + " = phi i64 [" + r_d + ", %" + lbl_dir + "], [" + r_c0 + ", %" + lbl_c0 + "], [" + r_c1 + ", %" + lbl_c1 + "], [" + r_c2 + ", %" + lbl_c2 + "], [" + r_c3 + ", %" + lbl_c3 + "], [" + r_c4 + ", %" + lbl_c4 + "], [" + r_c5 + ", %" + lbl_c5 + "], [" + r_c6 + ", %" + lbl_c6 + "], [" + r_c7 + ", %" + lbl_c7 + "], [" + r_c8 + ", %" + lbl_c8 + "]")
  cg_set_val(cg, dest, result)
  0
}

// ------ Compile a single IR instruction to LLVM IR text ---------------------------------------

compile_dyn_trait_create(cg:I inst:I) I {
  dtc_dest = ir_dest(inst)
  dtc_src_val = cg_get_val(cg, ir_field(inst, 16))
  dtc_type_name = ir_field(inst, 24)
  dtc_trait_name = ir_field(inst, 32)
  dtc_fp = cg_fresh_reg(cg)
  emit(cg, "  " + dtc_fp + " = call ptr @malloc(i64 16)")
  emit(cg, "  store i64 " + dtc_src_val + ", ptr " + dtc_fp)
  dtc_vt_name = cg_str(dtc_type_name) + "." + cg_str(dtc_trait_name)
  dtc_vt_ref = cg_fresh_reg(cg)
  emit(cg, "  " + dtc_vt_ref + " = ptrtoint ptr @vtable." + dtc_vt_name + " to i64")
  dtc_vt_gep = cg_fresh_reg(cg)
  emit(cg, "  " + dtc_vt_gep + " = getelementptr i8, ptr " + dtc_fp + ", i64 8")
  emit(cg, "  store i64 " + dtc_vt_ref + ", ptr " + dtc_vt_gep)
  dtc_r = cg_fresh_reg(cg)
  emit(cg, "  " + dtc_r + " = ptrtoint ptr " + dtc_fp + " to i64")
  cg_set_val(cg, dtc_dest, dtc_r)
  emit_scope_track(cg, dtc_r, 7)
  0
}

// Helper: look up method index in trait registry by comparing method names
// Build arg string for dyn trait call: "i64 data, i64 arg0, i64 arg1, ..."
build_dyn_call_args(cg:I data_val:S args:I) S {
  result := "i64 " + data_val
  nargs = args.len()
  ai := 0
  while ai < nargs {
    result = result + ", i64 " + cg_get_val(cg, args.get(ai))
    ai += 1
  }
  result
}

dyn_lookup_method_idx(trait_name:I method_name:I) I {
  0
}

compile_dyn_trait_call(cg:I inst:I) I {
  dtcl_dest = ir_dest(inst)
  dtcl_obj_val = cg_get_val(cg, ir_field(inst, 16))
  dtcl_method_name = ir_field(inst, 24)
  dtcl_args = ir_field(inst, 32)
  dtcl_trait_name = ir_field(inst, 40)
  dtcl_method_idx = dyn_lookup_method_idx(dtcl_trait_name, dtcl_method_name)
  dtcl_fp = cg_fresh_reg(cg)
  emit(cg, "  " + dtcl_fp + " = inttoptr i64 " + dtcl_obj_val + " to ptr")
  dtcl_data = cg_fresh_reg(cg)
  emit(cg, "  " + dtcl_data + " = load i64, ptr " + dtcl_fp)
  dtcl_vgep = cg_fresh_reg(cg)
  emit(cg, "  " + dtcl_vgep + " = getelementptr i8, ptr " + dtcl_fp + ", i64 8")
  dtcl_vi64 = cg_fresh_reg(cg)
  emit(cg, "  " + dtcl_vi64 + " = load i64, ptr " + dtcl_vgep)
  dtcl_vptr = cg_fresh_reg(cg)
  emit(cg, "  " + dtcl_vptr + " = inttoptr i64 " + dtcl_vi64 + " to ptr")
  dtcl_fgep = cg_fresh_reg(cg)
  emit(cg, "  " + dtcl_fgep + " = getelementptr ptr, ptr " + dtcl_vptr + ", i64 " + str(dtcl_method_idx))
  dtcl_fptr = cg_fresh_reg(cg)
  emit(cg, "  " + dtcl_fptr + " = load ptr, ptr " + dtcl_fgep)
  dtcl_arg_str = build_dyn_call_args(cg, dtcl_data, dtcl_args)
  dtcl_r = cg_fresh_reg(cg)
  emit(cg, "  " + dtcl_r + " = call i64 " + dtcl_fptr + "(" + dtcl_arg_str + ")")
  cg_set_val(cg, dtcl_dest, dtcl_r)
  0
}

compile_inst(cg:I inst:I) I {
  op = ir_op(inst)
  dest = ir_dest(inst)

  // ------ IR_CONST (0): [op, dest, value] ------
  if op == IR_CONST {
    val = ir_field(inst, 16)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = add i64 " + str(val) + ", 0")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_FLOAT_CONST (1): [op, dest, float_str_ptr] ------
  if op == IR_FLOAT_CONST {
    float_str = ir_field(inst, 16)
    // float_str is a string pointer containing the float text (e.g. "3.14")
    // Emit LLVM bitcast from double to i64
    ftmp = cg_fresh_reg(cg)
    emit(cg, "  " + ftmp + " = bitcast double " + float_str + " to i64")
    cg_set_val(cg, dest, ftmp)
    return 0
  }

  // ------ IR_BOOL_CONST (2): [op, dest, value] ------
  if op == IR_BOOL_CONST {
    val = ir_field(inst, 16)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = add i64 " + str(val) + ", 0")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_STRING_CONST (3): [op, dest, string_ptr] ------
  if op == IR_STRING_CONST {
    str_raw = ir_field(inst, 16)
    str_val = if str_raw == 0 { ptr("") } else { str_raw }
    global_name = emit_string_const(cg, str_val)
    len = slen(str_val) + 1
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + global_name + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    return 0
  }

  // ------ IR_BINOP (4): [op, dest, binop, left, right] ------
  if op == IR_BINOP {
    binop = ir_field(inst, 16)
    left = cg_get_val(cg, ir_field(inst, 24))
    right = cg_get_val(cg, ir_field(inst, 32))
    r = cg_fresh_reg(cg)
    op_str = if binop == 0 { "add" } else { if binop == 1 { "sub" } else { if binop == 2 { "mul" } else { if binop == 3 { "sdiv" } else { "srem" } } } }
    emit(cg, "  " + r + " = " + op_str + " i64 " + left + ", " + right)
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_FLOAT_BINOP (5): [op, dest, binop, left, right] ------
  if op == IR_FLOAT_BINOP {
    binop = ir_field(inst, 16)
    left = cg_get_val(cg, ir_field(inst, 24))
    right = cg_get_val(cg, ir_field(inst, 32))
    fl = cg_fresh_reg(cg)
    emit(cg, "  " + fl + " = bitcast i64 " + left + " to double")
    fr = cg_fresh_reg(cg)
    emit(cg, "  " + fr + " = bitcast i64 " + right + " to double")
    fres = cg_fresh_reg(cg)
    fop = if binop == 0 { "fadd" } else { if binop == 1 { "fsub" } else { if binop == 2 { "fmul" } else { if binop == 3 { "fdiv" } else { "frem" } } } }
    emit(cg, "  " + fres + " = " + fop + " double " + fl + ", " + fr)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = bitcast double " + fres + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_CMPOP (6): [op, dest, cmpop, left, right] ------
  if op == IR_CMPOP {
    cmpop = ir_field(inst, 16)
    left = cg_get_val(cg, ir_field(inst, 24))
    right = cg_get_val(cg, ir_field(inst, 32))
    pred = if cmpop == 0 { "eq" } else { if cmpop == 1 { "ne" } else { if cmpop == 2 { "slt" } else { if cmpop == 3 { "sgt" } else { if cmpop == 4 { "sle" } else { "sge" } } } } }
    tmp = cg_fresh_reg(cg)
    emit(cg, "  " + tmp + " = icmp " + pred + " i64 " + left + ", " + right)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = zext i1 " + tmp + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_FLOAT_CMPOP (7): [op, dest, cmpop, left, right] ------
  if op == IR_FLOAT_CMPOP {
    cmpop = ir_field(inst, 16)
    left = cg_get_val(cg, ir_field(inst, 24))
    right = cg_get_val(cg, ir_field(inst, 32))
    fl = cg_fresh_reg(cg)
    emit(cg, "  " + fl + " = bitcast i64 " + left + " to double")
    fr = cg_fresh_reg(cg)
    emit(cg, "  " + fr + " = bitcast i64 " + right + " to double")
    pred = if cmpop == 0 { "oeq" } else { if cmpop == 1 { "one" } else { if cmpop == 2 { "olt" } else { if cmpop == 3 { "ogt" } else { if cmpop == 4 { "ole" } else { "oge" } } } } }
    tmp = cg_fresh_reg(cg)
    emit(cg, "  " + tmp + " = fcmp " + pred + " double " + fl + ", " + fr)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = zext i1 " + tmp + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_STRING_CMPOP (8): [op, dest, cmpop, left, right] ------
  if op == IR_STRING_CMPOP {
    cmpop = ir_field(inst, 16)
    left = cg_get_val(cg, ir_field(inst, 24))
    right = cg_get_val(cg, ir_field(inst, 32))
    p1 = cg_fresh_reg(cg)
    emit(cg, "  " + p1 + " = inttoptr i64 " + left + " to ptr")
    p2 = cg_fresh_reg(cg)
    emit(cg, "  " + p2 + " = inttoptr i64 " + right + " to ptr")
    cmp = cg_fresh_reg(cg)
    emit(cg, "  " + cmp + " = call i32 @strcmp(ptr " + p1 + ", ptr " + p2 + ")")
    pred = if cmpop == 0 { "eq" } else { if cmpop == 1 { "ne" } else { if cmpop == 2 { "slt" } else { if cmpop == 3 { "sgt" } else { if cmpop == 4 { "sle" } else { "sge" } } } } }
    res = cg_fresh_reg(cg)
    emit(cg, "  " + res + " = icmp " + pred + " i32 " + cmp + ", 0")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = zext i1 " + res + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_NOT (9): [op, dest, src] ------
  if op == IR_NOT {
    src = cg_get_val(cg, ir_field(inst, 16))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = xor i64 " + src + ", 1")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_NEG (10): [op, dest, src] ------
  if op == IR_NEG {
    src = cg_get_val(cg, ir_field(inst, 16))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = sub i64 0, " + src)
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_COPY (11): [op, dest, src] ------
  if op == IR_COPY {
    src_reg = ir_field(inst, 16)
    cg_set_val(cg, dest, cg_get_val(cg, src_reg))
    if cg_is_ptr(cg, src_reg) { cg_set_ptr(cg, dest) }
    return 0
  }

  // ------ IR_CALL (12): [op, dest, fname, args_array] ------
  if op == IR_CALL {
    fname_ptr = ir_field(inst, 16)
    fname = resolve_fn_alias(fname_ptr)
    args = ir_field(inst, 24)
    nargs = args.len()
    // Build arg list string: "i64 %a, i64 %b, ..."
    arg_str := ""
    i := 0
    while i < nargs {
      if i > 0 { arg_str = arg_str + ", " }
      arg_str = arg_str + "i64 " + cg_get_val(cg, args.get(i))
      i = i + 1
      0
    }
    // Use __sans_main for "main"
    llvm_fname = if fname == "main" { "__sans_main" } else { fname }
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @" + llvm_fname + "(" + arg_str + ")")
    cg_set_val(cg, dest, r)
    // Track return value if function returns a heap type
    if cg_is_runtime_flag == 0 {
      if cg_fn_ret_types != 0 {
        frt = mget(cg_fn_ret_types, fname)
        if frt != 0 {
          stag := 0
          if frt == IRTY_ARRAY { stag = 1 }
          else if frt == IRTY_MAP { stag = 2 }
          else if frt == IRTY_MAP_INT { stag = 2 }
          else if frt == IRTY_JSON { stag = 3 }
          else if frt == IRTY_RESULT { stag = 4 }
          else if frt == IRTY_STR { stag = 5 }
          else if frt == IRTY_OPTION { stag = 6 }
          emit_scope_track(cg, r, stag)
        }
      }
    }
    return 0
  }

  // ------ IR_RET (13): [op, value_reg] ------
  if op == IR_RET {
    val = cg_get_val(cg, dest)
    // Emit scope_exit before return for user code
    if cg_is_runtime_flag == 0 {
      sx = cg_fresh_reg(cg)
      emit(cg, "  " + sx + " = call i64 @sans_scope_exit(i64 " + val + ")")
    }
    emit(cg, "  ret i64 " + val)
    // Record that the current label's block ends with ret (for PHI filtering)
    cur_lbl = cg_current_label(cg)
    rl = load64(cg + 128)
    mset(rl, cur_lbl, 1)
    return 0
  }

  // ------ IR_LABEL (14): [op, label_name] ------
  if op == IR_LABEL {
    label_name = dest
    cg_set_current_label(cg, label_name)
    cg_set_current_block(cg, label_name)
    emit(cg, label_name + ":")
    return 0
  }

  // ------ IR_BRANCH (15): [op, cond, then_label, else_label] ------
  if op == IR_BRANCH {
    cond_val = cg_get_val(cg, dest)
    then_label = ir_field(inst, 16)
    else_label = ir_field(inst, 24)
    // Record parent relationships: then_label and else_label are children of current label
    ir_lbl = cg_current_label(cg)
    lp = cg_label_parent(cg)
    mset(lp, then_label, ir_lbl)
    mset(lp, else_label, ir_lbl)
    tmp = cg_fresh_reg(cg)
    emit(cg, "  " + tmp + " = trunc i64 " + cond_val + " to i1")
    emit(cg, "  br i1 " + tmp + ", label %" + then_label + ", label %" + else_label)
    return 0
  }

  // ------ IR_JUMP (16): [op, target_label] ------
  if op == IR_JUMP {
    target = dest
    // Record that the current IR label ends at the actual LLVM block
    ir_lbl = cg_current_label(cg)
    cur_blk = cg_current_block(cg)
    cg_record_label_end(cg, ir_lbl, cur_blk)
    // Propagate parent: the jump target inherits this label's parent chain
    // This handles: L_3 (child of L_0) jumps to L_5 --- L_5 becomes child of L_0
    lp = cg_label_parent(cg)
    if mhas(lp, ir_lbl) {
      // Set target's parent to the jumping label itself (not the parent's parent).
      // Only set if target doesn't already have a parent --- avoids loop back-edge
      // overwriting (which would create cycles in the parent chain).
      if mhas(lp, target) == 0 {
        mset(lp, target, ir_lbl)
        0
      } else { 0 }
      // Walk up the parent chain, updating label_end for ALL ancestors
      ancestor := ir_lbl
      depth := 0
      while mhas(lp, ancestor) && depth < 20 {
        parent = mget(lp, ancestor)
        cg_record_label_end(cg, parent, cur_blk)
        ancestor = parent
        depth = depth + 1
        0
      }
    }
    emit(cg, "  br label %" + target)
    return 0
  }

  // ------ IR_PHI (17): [op, dest, a_val, a_label, b_val, b_label] ------
  if op == IR_PHI {
    a_val = cg_get_val(cg, ir_field(inst, 16))
    a_label_ir = ir_field(inst, 24)
    b_val = cg_get_val(cg, ir_field(inst, 32))
    b_label_ir = ir_field(inst, 40)
    // Use the actual end labels (handles nested if/else creating extra blocks)
    a_label = cg_get_label_end(cg, a_label_ir)
    b_label = cg_get_label_end(cg, b_label_ir)
    // Check if either predecessor was terminated by ret (dead branch)
    rl = load64(cg + 128)
    a_dead = mhas(rl, a_label)
    b_dead = mhas(rl, b_label)
    r = cg_fresh_reg(cg)
    if a_dead && b_dead {
      // Both branches return - this merge is dead code, emit constant
      emit(cg, "  " + r + " = add i64 0, 0")
    } else { if a_dead {
      // Only else branch reaches merge
      emit(cg, "  " + r + " = add i64 " + b_val + ", 0")
    } else { if b_dead {
      // Only then branch reaches merge
      emit(cg, "  " + r + " = add i64 " + a_val + ", 0")
    } else {
      // Both branches reach merge - normal PHI
      emit(cg, "  " + r + " = phi i64 [" + a_val + ", %" + a_label + "], [" + b_val + ", %" + b_label + "]")
    } } }
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_PRINT_INT (18): [op, value_reg] ------
  if op == IR_PRINT_INT {
    val = cg_get_val(cg, dest)
    fmt = cg_fmt_int(cg)
    pr = cg_fresh_reg(cg)
    emit(cg, "  " + pr + " = call i64 (ptr, ...) @printf(ptr " + fmt + ", i64 " + val + ")")
    return 0
  }

  // ------ IR_PRINT_FLOAT (19): [op, value_reg] ------
  if op == IR_PRINT_FLOAT {
    val = cg_get_val(cg, dest)
    fl = cg_fresh_reg(cg)
    emit(cg, "  " + fl + " = bitcast i64 " + val + " to double")
    fmt = cg_fmt_float(cg)
    pr = cg_fresh_reg(cg)
    emit(cg, "  " + pr + " = call i64 (ptr, ...) @printf(ptr " + fmt + ", double " + fl + ")")
    return 0
  }

  // ------ IR_PRINT_STRING (20): [op, value_reg] ------
  if op == IR_PRINT_STRING {
    val = cg_get_val(cg, dest)
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + val + " to ptr")
    fmt = cg_fmt_str(cg)
    pr = cg_fresh_reg(cg)
    emit(cg, "  " + pr + " = call i64 (ptr, ...) @printf(ptr " + fmt + ", ptr " + p + ")")
    return 0
  }

  // ------ IR_PRINT_BOOL (21): [op, value_reg] ------
  if op == IR_PRINT_BOOL {
    val = cg_get_val(cg, dest)
    tname = cg_bool_true(cg)
    fname = cg_bool_false(cg)
    cond = cg_fresh_reg(cg)
    emit(cg, "  " + cond + " = trunc i64 " + val + " to i1")
    sel = cg_fresh_reg(cg)
    emit(cg, "  " + sel + " = select i1 " + cond + ", ptr " + tname + ", ptr " + fname)
    pr = cg_fresh_reg(cg)
    emit(cg, "  " + pr + " = call i64 (ptr, ...) @printf(ptr " + sel + ")")
    return 0
  }

  // ------ IR_ALLOCA (22): [op, dest] ------
  // Already hoisted to entry block in pre-scan pass
  if op == IR_ALLOCA {
    return 0
  }

  // ------ IR_STORE (23): [op, ptr_reg, value_reg] ------
  if op == IR_STORE {
    ptr_val = cg_get_val(cg, dest)
    val = cg_get_val(cg, ir_field(inst, 16))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + ptr_val + " to ptr")
    emit(cg, "  store i64 " + val + ", ptr " + p)
    return 0
  }

  // ------ IR_LOAD (24): [op, dest, ptr_reg] ------
  if op == IR_LOAD {
    ptr_val = cg_get_val(cg, ir_field(inst, 16))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + ptr_val + " to ptr")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = load i64, ptr " + p)
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_STRUCT_ALLOC (25): [op, dest, num_fields] ------
  if op == IR_STRUCT_ALLOC {
    nf = ir_field(inst, 16)
    sz = cg_fresh_reg(cg)
    emit(cg, "  " + sz + " = mul i64 " + str(nf) + ", 8")
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = call ptr @malloc(i64 " + sz + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + p + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 0)
    return 0
  }

  // ------ IR_FIELD_STORE (26): [op, ptr_reg, field_idx, value_reg] ------
  if op == IR_FIELD_STORE {
    ptr_val = cg_get_val(cg, dest)
    fidx = ir_field(inst, 16)
    val = cg_get_val(cg, ir_field(inst, 24))
    base = cg_fresh_reg(cg)
    emit(cg, "  " + base + " = inttoptr i64 " + ptr_val + " to ptr")
    gep = cg_fresh_reg(cg)
    emit(cg, "  " + gep + " = getelementptr i64, ptr " + base + ", i64 " + str(fidx))
    emit(cg, "  store i64 " + val + ", ptr " + gep)
    return 0
  }

  // ------ IR_FIELD_LOAD (27): [op, dest, ptr_reg, field_idx, num_fields] ------
  if op == IR_FIELD_LOAD {
    ptr_val = cg_get_val(cg, ir_field(inst, 16))
    fidx = ir_field(inst, 24)
    base = cg_fresh_reg(cg)
    emit(cg, "  " + base + " = inttoptr i64 " + ptr_val + " to ptr")
    gep = cg_fresh_reg(cg)
    emit(cg, "  " + gep + " = getelementptr i64, ptr " + base + ", i64 " + str(fidx))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = load i64, ptr " + gep)
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    return 0
  }

  // ------ IR_ENUM_ALLOC (28): [op, dest, tag, num_data_fields] ------
  if op == IR_ENUM_ALLOC {
    tag = ir_field(inst, 16)
    ndata = ir_field(inst, 24)
    total = ndata + 1
    sz = cg_fresh_reg(cg)
    emit(cg, "  " + sz + " = mul i64 " + str(total) + ", 8")
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = call ptr @malloc(i64 " + sz + ")")
    // Store tag at field 0
    emit(cg, "  store i64 " + str(tag) + ", ptr " + p)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + p + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 0)
    return 0
  }

  // ------ IR_ENUM_TAG (29): [op, dest, ptr_reg] ------
  if op == IR_ENUM_TAG {
    ptr_val = cg_get_val(cg, ir_field(inst, 16))
    base = cg_fresh_reg(cg)
    emit(cg, "  " + base + " = inttoptr i64 " + ptr_val + " to ptr")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = load i64, ptr " + base)
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_ENUM_DATA (30): [op, dest, ptr_reg, field_idx] ------
  if op == IR_ENUM_DATA {
    ptr_val = cg_get_val(cg, ir_field(inst, 16))
    fidx = ir_field(inst, 24) + 1
    base = cg_fresh_reg(cg)
    emit(cg, "  " + base + " = inttoptr i64 " + ptr_val + " to ptr")
    gep = cg_fresh_reg(cg)
    emit(cg, "  " + gep + " = getelementptr i64, ptr " + base + ", i64 " + str(fidx))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = load i64, ptr " + gep)
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_GLOBAL_LOAD (31): [op, dest, name] ------
  if op == IR_GLOBAL_LOAD {
    gname = ir_field(inst, 16)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = load i64, ptr @" + gname)
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_GLOBAL_STORE (32): [op, name, value_reg] ------
  if op == IR_GLOBAL_STORE {
    gname = dest
    val = cg_get_val(cg, ir_field(inst, 16))
    emit(cg, "  store i64 " + val + ", ptr @" + gname)
    if cg_is_runtime_flag == 0 {
      ut = cg_fresh_reg(cg)
      emit(cg, "  " + ut + " = call i64 @sans_scope_untrack(i64 " + val + ")")
    }
    return 0
  }

  // ------ IR_ALLOC (33): [op, dest, size_reg] ------
  if op == IR_ALLOC {
    size_val = cg_get_val(cg, ir_field(inst, 16))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = call ptr @malloc(i64 " + size_val + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + p + " to i64")
    emit_scope_track(cg, r, 0)
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    return 0
  }

  // ------ IR_DEALLOC (34): [op, dest, ptr_reg] ------
  if op == IR_DEALLOC {
    ptr_val = cg_get_val(cg, ir_field(inst, 16))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + ptr_val + " to ptr")
    emit(cg, "  call void @free(ptr " + p + ")")
    cg_set_val(cg, dest, "0")
    return 0
  }

  // ------ IR_RC_ALLOC (212): [op, dest, size_reg] ------
  if op == IR_RC_ALLOC {
    size_val = cg_get_val(cg, ir_field(inst, 16))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_rc_alloc(i64 " + size_val + ")")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    return 0
  }

  // ------ IR_RC_RETAIN (213): [op, dest, ptr_reg] ------
  if op == IR_RC_RETAIN {
    ptr_val = cg_get_val(cg, ir_field(inst, 16))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_rc_retain(i64 " + ptr_val + ")")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_RC_RELEASE (214): [op, dest, ptr_reg] ------
  if op == IR_RC_RELEASE {
    ptr_val = cg_get_val(cg, ir_field(inst, 16))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_rc_release(i64 " + ptr_val + ")")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_RC_COUNT (215): [op, dest, ptr_reg] ------
  if op == IR_RC_COUNT {
    ptr_val = cg_get_val(cg, ir_field(inst, 16))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_rc_count(i64 " + ptr_val + ")")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_RALLOC (35): [op, dest, ptr_reg, size_reg] ------
  if op == IR_RALLOC {
    ptr_val = cg_get_val(cg, ir_field(inst, 16))
    size_val = cg_get_val(cg, ir_field(inst, 24))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + ptr_val + " to ptr")
    np = cg_fresh_reg(cg)
    emit(cg, "  " + np + " = call ptr @realloc(ptr " + p + ", i64 " + size_val + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + np + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    return 0
  }

  // ------ IR_ARRAY_CREATE (36): [op, dest] ------
  if op == IR_ARRAY_CREATE {
    // malloc(24) for struct [data_ptr, len, capacity]
    sp = cg_fresh_reg(cg)
    emit(cg, "  " + sp + " = call ptr @malloc(i64 24)")
    // malloc(64) for initial buffer (8 elements * 8 bytes)
    dp = cg_fresh_reg(cg)
    emit(cg, "  " + dp + " = call ptr @malloc(i64 64)")
    // Store data_ptr as i64 at offset 0
    di = cg_fresh_reg(cg)
    emit(cg, "  " + di + " = ptrtoint ptr " + dp + " to i64")
    emit(cg, "  store i64 " + di + ", ptr " + sp)
    // Store len=0 at offset 1
    lp = cg_fresh_reg(cg)
    emit(cg, "  " + lp + " = getelementptr i64, ptr " + sp + ", i64 1")
    emit(cg, "  store i64 0, ptr " + lp)
    // Store capacity=8 at offset 2
    cp = cg_fresh_reg(cg)
    emit(cg, "  " + cp + " = getelementptr i64, ptr " + sp + ", i64 2")
    emit(cg, "  store i64 8, ptr " + cp)
    // Result
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + sp + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 1)
    return 0
  }

  // ------ IR_ARRAY_PUSH (37): [op, array_reg, value_reg] ------
  if op == IR_ARRAY_PUSH {
    arr_val = cg_get_val(cg, dest)
    val = cg_get_val(cg, ir_field(inst, 16))
    uid = cg_label_id(cg)
    // inttoptr array
    ap = cg_fresh_reg(cg)
    emit(cg, "  " + ap + " = inttoptr i64 " + arr_val + " to ptr")
    // Load len from offset 1
    lp = cg_fresh_reg(cg)
    emit(cg, "  " + lp + " = getelementptr i64, ptr " + ap + ", i64 1")
    ln = cg_fresh_reg(cg)
    emit(cg, "  " + ln + " = load i64, ptr " + lp)
    // Load cap from offset 2
    kp = cg_fresh_reg(cg)
    emit(cg, "  " + kp + " = getelementptr i64, ptr " + ap + ", i64 2")
    kv = cg_fresh_reg(cg)
    emit(cg, "  " + kv + " = load i64, ptr " + kp)
    // Compare len == cap
    ng = cg_fresh_reg(cg)
    emit(cg, "  " + ng + " = icmp eq i64 " + ln + ", " + kv)
    grow_lbl = "ap_grow_" + uid
    write_lbl = "ap_write_" + uid
    emit(cg, "  br i1 " + ng + ", label %" + grow_lbl + ", label %" + write_lbl)
    // Grow block
    emit(cg, grow_lbl + ":")
    nc = cg_fresh_reg(cg)
    emit(cg, "  " + nc + " = mul i64 " + kv + ", 2")
    nbs = cg_fresh_reg(cg)
    emit(cg, "  " + nbs + " = mul i64 " + nc + ", 8")
    nb = cg_fresh_reg(cg)
    emit(cg, "  " + nb + " = call ptr @malloc(i64 " + nbs + ")")
    // Load old data ptr
    odi = cg_fresh_reg(cg)
    emit(cg, "  " + odi + " = load i64, ptr " + ap)
    odp = cg_fresh_reg(cg)
    emit(cg, "  " + odp + " = inttoptr i64 " + odi + " to ptr")
    // memcpy old to new (len * 8)
    csz = cg_fresh_reg(cg)
    emit(cg, "  " + csz + " = mul i64 " + ln + ", 8")
    mc1 = cg_fresh_reg(cg)
    emit(cg, "  " + mc1 + " = call ptr @memcpy(ptr " + nb + ", ptr " + odp + ", i64 " + csz + ")")
    // Free old
    emit(cg, "  call void @free(ptr " + odp + ")")
    // Update data ptr and capacity
    nbi = cg_fresh_reg(cg)
    emit(cg, "  " + nbi + " = ptrtoint ptr " + nb + " to i64")
    emit(cg, "  store i64 " + nbi + ", ptr " + ap)
    emit(cg, "  store i64 " + nc + ", ptr " + kp)
    emit(cg, "  br label %" + write_lbl)
    // Write block: reload len and data (may have changed after grow)
    emit(cg, write_lbl + ":")
    ln2 = cg_fresh_reg(cg)
    emit(cg, "  " + ln2 + " = load i64, ptr " + lp)
    di2 = cg_fresh_reg(cg)
    emit(cg, "  " + di2 + " = load i64, ptr " + ap)
    dp2 = cg_fresh_reg(cg)
    emit(cg, "  " + dp2 + " = inttoptr i64 " + di2 + " to ptr")
    // Store value at data[len]
    ep = cg_fresh_reg(cg)
    emit(cg, "  " + ep + " = getelementptr i64, ptr " + dp2 + ", i64 " + ln2)
    emit(cg, "  store i64 " + val + ", ptr " + ep)
    // Increment len
    nl = cg_fresh_reg(cg)
    emit(cg, "  " + nl + " = add i64 " + ln2 + ", 1")
    emit(cg, "  store i64 " + nl + ", ptr " + lp)
    // Update: record that the original IR label now ends at write_lbl
    
    cg_set_current_block(cg, write_lbl)
    return 0
  }

  // ------ IR_ARRAY_GET (38): [op, dest, array_reg, index_reg] ------
  if op == IR_ARRAY_GET {
    arr_val = cg_get_val(cg, ir_field(inst, 16))
    idx_val = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    // inttoptr array
    ap = cg_fresh_reg(cg)
    emit(cg, "  " + ap + " = inttoptr i64 " + arr_val + " to ptr")
    // Load len from offset 1
    lp = cg_fresh_reg(cg)
    emit(cg, "  " + lp + " = getelementptr i64, ptr " + ap + ", i64 1")
    ln = cg_fresh_reg(cg)
    emit(cg, "  " + ln + " = load i64, ptr " + lp)
    // Bounds check
    ib = cg_fresh_reg(cg)
    emit(cg, "  " + ib + " = icmp slt i64 " + idx_val + ", " + ln)
    nn = cg_fresh_reg(cg)
    emit(cg, "  " + nn + " = icmp sge i64 " + idx_val + ", 0")
    ok = cg_fresh_reg(cg)
    emit(cg, "  " + ok + " = and i1 " + ib + ", " + nn)
    then_lbl = "ag_then_" + uid
    else_lbl = "ag_else_" + uid
    merge_lbl = "ag_merge_" + uid
    emit(cg, "  br i1 " + ok + ", label %" + then_lbl + ", label %" + else_lbl)
    // In-bounds path
    emit(cg, then_lbl + ":")
    di = cg_fresh_reg(cg)
    emit(cg, "  " + di + " = load i64, ptr " + ap)
    dp = cg_fresh_reg(cg)
    emit(cg, "  " + dp + " = inttoptr i64 " + di + " to ptr")
    ep = cg_fresh_reg(cg)
    emit(cg, "  " + ep + " = getelementptr i64, ptr " + dp + ", i64 " + idx_val)
    lv = cg_fresh_reg(cg)
    emit(cg, "  " + lv + " = load i64, ptr " + ep)
    emit(cg, "  br label %" + merge_lbl)
    // Out-of-bounds path
    emit(cg, else_lbl + ":")
    emit(cg, "  br label %" + merge_lbl)
    // Merge
    emit(cg, merge_lbl + ":")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = phi i64 [" + lv + ", %" + then_lbl + "], [0, %" + else_lbl + "]")
    cg_set_val(cg, dest, r)
    // Update current_label --- we're now in merge_lbl
    
    cg_set_current_block(cg, merge_lbl)
    return 0
  }

  // ------ IR_ARRAY_SET (39): [op, array_reg, index_reg, value_reg] ------
  if op == IR_ARRAY_SET {
    arr_val = cg_get_val(cg, dest)
    idx_val = cg_get_val(cg, ir_field(inst, 16))
    val = cg_get_val(cg, ir_field(inst, 24))
    ap = cg_fresh_reg(cg)
    emit(cg, "  " + ap + " = inttoptr i64 " + arr_val + " to ptr")
    di = cg_fresh_reg(cg)
    emit(cg, "  " + di + " = load i64, ptr " + ap)
    dp = cg_fresh_reg(cg)
    emit(cg, "  " + dp + " = inttoptr i64 " + di + " to ptr")
    ep = cg_fresh_reg(cg)
    emit(cg, "  " + ep + " = getelementptr i64, ptr " + dp + ", i64 " + idx_val)
    emit(cg, "  store i64 " + val + ", ptr " + ep)
    return 0
  }

  // ------ IR_ARRAY_LEN (40): [op, dest, array_reg] ------
  if op == IR_ARRAY_LEN {
    arr_val = cg_get_val(cg, ir_field(inst, 16))
    ap = cg_fresh_reg(cg)
    emit(cg, "  " + ap + " = inttoptr i64 " + arr_val + " to ptr")
    lp = cg_fresh_reg(cg)
    emit(cg, "  " + lp + " = getelementptr i64, ptr " + ap + ", i64 1")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = load i64, ptr " + lp)
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_ARRAY_MAP (41): call i64 @sans_array_map(i64, i64) ------
  if op == IR_ARRAY_MAP {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_array_map(i64 " + a1 + ", i64 " + a2 + ")")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 1)
    return 0
  }

  // ------ IR_ARRAY_FILTER (42): call i64 @sans_array_filter(i64, i64) ------
  if op == IR_ARRAY_FILTER {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_array_filter(i64 " + a1 + ", i64 " + a2 + ")")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 1)
    return 0
  }

  // ------ IR_ARRAY_ANY (43): call i64 @sans_array_any(i64, i64) ------
  if op == IR_ARRAY_ANY {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_array_any(i64 " + a1 + ", i64 " + a2 + ")")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_ARRAY_FIND (44): call sans_array_find_raw, wrap result in Option<T> ------
  if op == IR_ARRAY_FIND {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    // allocate stack slot for the found flag
    has_ptr = cg_fresh_reg(cg)
    emit(cg, "  " + has_ptr + " = alloca i64")
    emit(cg, "  store i64 0, ptr " + has_ptr)
    has_ptr_i = cg_fresh_reg(cg)
    emit(cg, "  " + has_ptr_i + " = ptrtoint ptr " + has_ptr + " to i64")
    raw_r = cg_fresh_reg(cg)
    emit(cg, "  " + raw_r + " = call i64 @sans_array_find_raw(i64 " + a1 + ", i64 " + a2 + ", i64 " + has_ptr_i + ")")
    has_r = cg_fresh_reg(cg)
    emit(cg, "  " + has_r + " = load i64, ptr " + has_ptr)
    cmp_r = cg_fresh_reg(cg)
    emit(cg, "  " + cmp_r + " = icmp ne i64 " + has_r + ", 0")
    found_lbl = "afo_found_" + uid
    miss_lbl = "afo_miss_" + uid
    merge_lbl = "afo_merge_" + uid
    emit(cg, "  br i1 " + cmp_r + ", label %" + found_lbl + ", label %" + miss_lbl)
    emit(cg, found_lbl + ":")
    some_r = cg_fresh_reg(cg)
    emit(cg, "  " + some_r + " = call i64 @sans_option_some(i64 " + raw_r + ")")
    emit(cg, "  br label %" + merge_lbl)
    emit(cg, miss_lbl + ":")
    none_r = cg_fresh_reg(cg)
    emit(cg, "  " + none_r + " = call i64 @sans_option_none()")
    emit(cg, "  br label %" + merge_lbl)
    emit(cg, merge_lbl + ":")
    phi_r = cg_fresh_reg(cg)
    emit(cg, "  " + phi_r + " = phi i64 [" + some_r + ", %" + found_lbl + "], [" + none_r + ", %" + miss_lbl + "]")
    cg_set_val(cg, dest, phi_r)
    cg_set_current_block(cg, merge_lbl)
    emit_scope_track(cg, phi_r, 6)
    return 0
  }

  // ------ IR_ARRAY_ENUMERATE (45): call i64 @sans_array_enumerate(i64) ------
  if op == IR_ARRAY_ENUMERATE {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_array_enumerate(i64 " + a1 + ")")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 1)
    return 0
  }

  // ------ IR_ARRAY_ZIP (46): call i64 @sans_array_zip(i64, i64) ------
  if op == IR_ARRAY_ZIP {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_array_zip(i64 " + a1 + ", i64 " + a2 + ")")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 1)
    return 0
  }

  // ------ IR_ARRAY_POP (47): call i64 @sans_array_pop(i64) ------
  if op == IR_ARRAY_POP {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_array_pop(i64 " + a1 + ")")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_ARRAY_CONTAINS (48): call i64 @sans_array_contains(i64, i64) ------
  if op == IR_ARRAY_CONTAINS {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_array_contains(i64 " + a1 + ", i64 " + a2 + ")")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_ARRAY_REMOVE (49): call i64 @sans_array_remove(i64, i64) ------
  if op == IR_ARRAY_REMOVE {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_array_remove(i64 " + a1 + ", i64 " + a2 + ")")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_STRING_LEN (50): [op, dest, string_reg] ------
  if op == IR_STRING_LEN {
    sv = cg_get_val(cg, ir_field(inst, 16))
    sp = cg_fresh_reg(cg)
    emit(cg, "  " + sp + " = inttoptr i64 " + sv + " to ptr")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @strlen(ptr " + sp + ")")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_STRING_CONCAT (51): [op, dest, left_reg, right_reg] ------
  if op == IR_STRING_CONCAT {
    lv = cg_get_val(cg, ir_field(inst, 16))
    rv = cg_get_val(cg, ir_field(inst, 24))
    p1 = cg_fresh_reg(cg)
    emit(cg, "  " + p1 + " = inttoptr i64 " + lv + " to ptr")
    p2 = cg_fresh_reg(cg)
    emit(cg, "  " + p2 + " = inttoptr i64 " + rv + " to ptr")
    l1 = cg_fresh_reg(cg)
    emit(cg, "  " + l1 + " = call i64 @strlen(ptr " + p1 + ")")
    l2 = cg_fresh_reg(cg)
    emit(cg, "  " + l2 + " = call i64 @strlen(ptr " + p2 + ")")
    tot = cg_fresh_reg(cg)
    emit(cg, "  " + tot + " = add i64 " + l1 + ", " + l2)
    asz = cg_fresh_reg(cg)
    emit(cg, "  " + asz + " = add i64 " + tot + ", 1")
    buf = cg_fresh_reg(cg)
    emit(cg, "  " + buf + " = call ptr @malloc(i64 " + asz + ")")
    // memcpy left
    mc2 = cg_fresh_reg(cg)
    emit(cg, "  " + mc2 + " = call ptr @memcpy(ptr " + buf + ", ptr " + p1 + ", i64 " + l1 + ")")
    // GEP buf+len1
    mid = cg_fresh_reg(cg)
    emit(cg, "  " + mid + " = getelementptr i8, ptr " + buf + ", i64 " + l1)
    // memcpy right
    mc3 = cg_fresh_reg(cg)
    emit(cg, "  " + mc3 + " = call ptr @memcpy(ptr " + mid + ", ptr " + p2 + ", i64 " + l2 + ")")
    // null-terminate
    endp = cg_fresh_reg(cg)
    emit(cg, "  " + endp + " = getelementptr i8, ptr " + buf + ", i64 " + tot)
    emit(cg, "  store i8 0, ptr " + endp)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + buf + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 5)
    return 0
  }

  // ------ IR_STRING_SUBSTRING (52): [op, dest, string_reg, start_reg, end_reg] ------
  if op == IR_STRING_SUBSTRING {
    sv = cg_get_val(cg, ir_field(inst, 16))
    st = cg_get_val(cg, ir_field(inst, 24))
    en = cg_get_val(cg, ir_field(inst, 32))
    ln = cg_fresh_reg(cg)
    emit(cg, "  " + ln + " = sub i64 " + en + ", " + st)
    asz = cg_fresh_reg(cg)
    emit(cg, "  " + asz + " = add i64 " + ln + ", 1")
    buf = cg_fresh_reg(cg)
    emit(cg, "  " + buf + " = call ptr @malloc(i64 " + asz + ")")
    sp = cg_fresh_reg(cg)
    emit(cg, "  " + sp + " = inttoptr i64 " + sv + " to ptr")
    src = cg_fresh_reg(cg)
    emit(cg, "  " + src + " = getelementptr i8, ptr " + sp + ", i64 " + st)
    mc4 = cg_fresh_reg(cg)
    emit(cg, "  " + mc4 + " = call ptr @memcpy(ptr " + buf + ", ptr " + src + ", i64 " + ln + ")")
    endp = cg_fresh_reg(cg)
    emit(cg, "  " + endp + " = getelementptr i8, ptr " + buf + ", i64 " + ln)
    emit(cg, "  store i8 0, ptr " + endp)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + buf + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 5)
    return 0
  }

  // ------ IR_INT_TO_STRING (53): [op, dest, value_reg] ------
  if op == IR_INT_TO_STRING {
    val = cg_get_val(cg, ir_field(inst, 16))
    buf = cg_fresh_reg(cg)
    emit(cg, "  " + buf + " = call ptr @malloc(i64 21)")
    fmt = cg_fmt_ld(cg)
    sn = cg_fresh_reg(cg)
    emit(cg, "  " + sn + " = call i32 (ptr, i64, ptr, ...) @snprintf(ptr " + buf + ", i64 21, ptr " + fmt + ", i64 " + val + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + buf + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 5)
    return 0
  }

  // ------ IR_STRING_TO_INT (54): [op, dest, string_reg] ------
  if op == IR_STRING_TO_INT {
    sv = cg_get_val(cg, ir_field(inst, 16))
    sp = cg_fresh_reg(cg)
    emit(cg, "  " + sp + " = inttoptr i64 " + sv + " to ptr")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @strtol(ptr " + sp + ", ptr null, i64 10)")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_FLOAT_TO_STRING (55): [op, dest, value_reg] ------
  if op == IR_FLOAT_TO_STRING {
    val = cg_get_val(cg, ir_field(inst, 16))
    fv = cg_fresh_reg(cg)
    emit(cg, "  " + fv + " = bitcast i64 " + val + " to double")
    buf = cg_fresh_reg(cg)
    emit(cg, "  " + buf + " = call ptr @malloc(i64 32)")
    fmt = cg_fmt_g(cg)
    sn = cg_fresh_reg(cg)
    emit(cg, "  " + sn + " = call i32 (ptr, i64, ptr, ...) @snprintf(ptr " + buf + ", i64 32, ptr " + fmt + ", double " + fv + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + buf + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 5)
    return 0
  }

  // ------ IR_STRING_TRIM (56): call i64 @sans_string_trim(i64) ------
  if op == IR_STRING_TRIM {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_string_trim(i64 " + a1 + ")")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 5)
    return 0
  }

  // ------ IR_STRING_STARTS_WITH (57): call i64 @sans_string_starts_with(i64, i64) ------
  if op == IR_STRING_STARTS_WITH {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_string_starts_with(i64 " + a1 + ", i64 " + a2 + ")")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_STRING_ENDS_WITH (58): call i64 @sans_string_ends_with(i64, i64) ------
  if op == IR_STRING_ENDS_WITH {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_string_ends_with(i64 " + a1 + ", i64 " + a2 + ")")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_STRING_CONTAINS (59): call i64 @sans_string_contains(i64, i64) ------
  if op == IR_STRING_CONTAINS {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_string_contains(i64 " + a1 + ", i64 " + a2 + ")")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_STRING_SPLIT (60): call i64 @sans_string_split(i64, i64) ------
  if op == IR_STRING_SPLIT {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_string_split(i64 " + a1 + ", i64 " + a2 + ")")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 1)
    return 0
  }

  // ------ IR_STRING_REPLACE (61): call i64 @sans_string_replace(i64, i64, i64) ------
  if op == IR_STRING_REPLACE {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    a3 = cg_get_val(cg, ir_field(inst, 32))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_string_replace(i64 " + a1 + ", i64 " + a2 + ", i64 " + a3 + ")")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, r, 5)
    return 0
  }

  // ------ IR_FILE_READ (62): [op, dest, path_reg] ------
  if op == IR_FILE_READ {
    pv = cg_get_val(cg, ir_field(inst, 16))
    uid = cg_label_id(cg)
    pp = cg_fresh_reg(cg)
    emit(cg, "  " + pp + " = inttoptr i64 " + pv + " to ptr")
    mode = cg_fmode_r(cg)
    fp = cg_fresh_reg(cg)
    emit(cg, "  " + fp + " = call ptr @fopen(ptr " + pp + ", ptr " + mode + ")")
    // Null check
    fi = cg_fresh_reg(cg)
    emit(cg, "  " + fi + " = ptrtoint ptr " + fp + " to i64")
    isn = cg_fresh_reg(cg)
    emit(cg, "  " + isn + " = icmp eq i64 " + fi + ", 0")
    err_lbl = "fr_err_" + uid
    ok_lbl = "fr_ok_" + uid
    merge_lbl = "fr_merge_" + uid
    emit(cg, "  br i1 " + isn + ", label %" + err_lbl + ", label %" + ok_lbl)
    // Error path: return empty string
    emit(cg, err_lbl + ":")
    eb = cg_fresh_reg(cg)
    emit(cg, "  " + eb + " = call ptr @malloc(i64 1)")
    emit(cg, "  store i8 0, ptr " + eb)
    ei = cg_fresh_reg(cg)
    emit(cg, "  " + ei + " = ptrtoint ptr " + eb + " to i64")
    emit(cg, "  br label %" + merge_lbl)
    // Success path: fseek/ftell/fread
    emit(cg, ok_lbl + ":")
    fs1 = cg_fresh_reg(cg)
    emit(cg, "  " + fs1 + " = call i32 @fseek(ptr " + fp + ", i64 0, i32 2)")
    fsz = cg_fresh_reg(cg)
    emit(cg, "  " + fsz + " = call i64 @ftell(ptr " + fp + ")")
    fs2 = cg_fresh_reg(cg)
    emit(cg, "  " + fs2 + " = call i32 @fseek(ptr " + fp + ", i64 0, i32 0)")
    bsz = cg_fresh_reg(cg)
    emit(cg, "  " + bsz + " = add i64 " + fsz + ", 1")
    buf = cg_fresh_reg(cg)
    emit(cg, "  " + buf + " = call ptr @malloc(i64 " + bsz + ")")
    frd = cg_fresh_reg(cg)
    emit(cg, "  " + frd + " = call i64 @fread(ptr " + buf + ", i64 1, i64 " + fsz + ", ptr " + fp + ")")
    // null-terminate
    endp = cg_fresh_reg(cg)
    emit(cg, "  " + endp + " = getelementptr i8, ptr " + buf + ", i64 " + fsz)
    emit(cg, "  store i8 0, ptr " + endp)
    // fclose
    fcl = cg_fresh_reg(cg)
    emit(cg, "  " + fcl + " = call i32 @fclose(ptr " + fp + ")")
    bi = cg_fresh_reg(cg)
    emit(cg, "  " + bi + " = ptrtoint ptr " + buf + " to i64")
    emit(cg, "  br label %" + merge_lbl)
    // Merge
    emit(cg, merge_lbl + ":")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = phi i64 [" + ei + ", %" + err_lbl + "], [" + bi + ", %" + ok_lbl + "]")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    // Update current_label --- we're now in merge_lbl

    cg_set_current_block(cg, merge_lbl)
    emit_scope_track(cg, cg_get_val(cg, dest), 5)
    return 0
  }

  // ------ IR_FILE_WRITE (63): [op, dest, path_reg, content_reg] ------
  if op == IR_FILE_WRITE {
    pv = cg_get_val(cg, ir_field(inst, 16))
    cv = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    pp = cg_fresh_reg(cg)
    emit(cg, "  " + pp + " = inttoptr i64 " + pv + " to ptr")
    cp = cg_fresh_reg(cg)
    emit(cg, "  " + cp + " = inttoptr i64 " + cv + " to ptr")
    // strlen(content)
    cl = cg_fresh_reg(cg)
    emit(cg, "  " + cl + " = call i64 @strlen(ptr " + cp + ")")
    // fopen(path, "w")
    mode = cg_fmode_w(cg)
    fp = cg_fresh_reg(cg)
    emit(cg, "  " + fp + " = call ptr @fopen(ptr " + pp + ", ptr " + mode + ")")
    // Null check
    fi = cg_fresh_reg(cg)
    emit(cg, "  " + fi + " = ptrtoint ptr " + fp + " to i64")
    isn = cg_fresh_reg(cg)
    emit(cg, "  " + isn + " = icmp eq i64 " + fi + ", 0")
    chk_lbl = "fw_chk_" + uid
    ok_lbl = "fw_ok_" + uid
    merge_lbl = "fw_merge_" + uid
    emit(cg, "  br label %" + chk_lbl)
    emit(cg, chk_lbl + ":")
    emit(cg, "  br i1 " + isn + ", label %" + merge_lbl + ", label %" + ok_lbl)
    // Success path
    emit(cg, ok_lbl + ":")
    fw1 = cg_fresh_reg(cg)
    emit(cg, "  " + fw1 + " = call i64 @fwrite(ptr " + cp + ", i64 1, i64 " + cl + ", ptr " + fp + ")")
    fc1 = cg_fresh_reg(cg)
    emit(cg, "  " + fc1 + " = call i32 @fclose(ptr " + fp + ")")
    emit(cg, "  br label %" + merge_lbl)
    // Merge: phi(0 on null, 1 on success)
    emit(cg, merge_lbl + ":")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = phi i64 [0, %" + chk_lbl + "], [1, %" + ok_lbl + "]")
    cg_set_val(cg, dest, r)
    
    cg_set_current_block(cg, merge_lbl)
    return 0
  }

  // ------ IR_FILE_APPEND (64): [op, dest, path_reg, content_reg] ------
  if op == IR_FILE_APPEND {
    pv = cg_get_val(cg, ir_field(inst, 16))
    cv = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    pp = cg_fresh_reg(cg)
    emit(cg, "  " + pp + " = inttoptr i64 " + pv + " to ptr")
    cp = cg_fresh_reg(cg)
    emit(cg, "  " + cp + " = inttoptr i64 " + cv + " to ptr")
    // strlen(content)
    cl = cg_fresh_reg(cg)
    emit(cg, "  " + cl + " = call i64 @strlen(ptr " + cp + ")")
    // fopen(path, "a")
    mode = cg_fmode_a(cg)
    fp = cg_fresh_reg(cg)
    emit(cg, "  " + fp + " = call ptr @fopen(ptr " + pp + ", ptr " + mode + ")")
    // Null check
    fi = cg_fresh_reg(cg)
    emit(cg, "  " + fi + " = ptrtoint ptr " + fp + " to i64")
    isn = cg_fresh_reg(cg)
    emit(cg, "  " + isn + " = icmp eq i64 " + fi + ", 0")
    chk_lbl = "fa_chk_" + uid
    ok_lbl = "fa_ok_" + uid
    merge_lbl = "fa_merge_" + uid
    emit(cg, "  br label %" + chk_lbl)
    emit(cg, chk_lbl + ":")
    emit(cg, "  br i1 " + isn + ", label %" + merge_lbl + ", label %" + ok_lbl)
    // Success path
    emit(cg, ok_lbl + ":")
    fw2 = cg_fresh_reg(cg)
    emit(cg, "  " + fw2 + " = call i64 @fwrite(ptr " + cp + ", i64 1, i64 " + cl + ", ptr " + fp + ")")
    fc2 = cg_fresh_reg(cg)
    emit(cg, "  " + fc2 + " = call i32 @fclose(ptr " + fp + ")")
    emit(cg, "  br label %" + merge_lbl)
    // Merge
    emit(cg, merge_lbl + ":")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = phi i64 [0, %" + chk_lbl + "], [1, %" + ok_lbl + "]")
    cg_set_val(cg, dest, r)
    
    cg_set_current_block(cg, merge_lbl)
    return 0
  }

  // ------ IR_FILE_EXISTS (65): [op, dest, path_reg] ------
  if op == IR_FILE_EXISTS {
    pv = cg_get_val(cg, ir_field(inst, 16))
    pp = cg_fresh_reg(cg)
    emit(cg, "  " + pp + " = inttoptr i64 " + pv + " to ptr")
    ar = cg_fresh_reg(cg)
    emit(cg, "  " + ar + " = call i32 @access(ptr " + pp + ", i32 0)")
    ok = cg_fresh_reg(cg)
    emit(cg, "  " + ok + " = icmp eq i32 " + ar + ", 0")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = zext i1 " + ok + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_GETENV (246): [op, dest, name_reg] ------
  if op == IR_GETENV {
    nv = cg_get_val(cg, ir_field(inst, 16))
    np = cg_fresh_reg(cg)
    emit(cg, "  " + np + " = inttoptr i64 " + nv + " to ptr")
    rp = cg_fresh_reg(cg)
    emit(cg, "  " + rp + " = call ptr @getenv(ptr " + np + ")")
    is_null = cg_fresh_reg(cg)
    emit(cg, "  " + is_null + " = icmp eq ptr " + rp + ", null")
    safe_ptr = cg_fresh_reg(cg)
    emit(cg, "  " + safe_ptr + " = select i1 " + is_null + ", ptr @.empty_str, ptr " + rp)
    slen = cg_fresh_reg(cg)
    emit(cg, "  " + slen + " = call i64 @strlen(ptr " + safe_ptr + ")")
    sz = cg_fresh_reg(cg)
    emit(cg, "  " + sz + " = add i64 " + slen + ", 1")
    buf = cg_fresh_reg(cg)
    emit(cg, "  " + buf + " = call ptr @malloc(i64 " + sz + ")")
    mcr = cg_fresh_reg(cg)
    emit(cg, "  " + mcr + " = call ptr @memcpy(ptr " + buf + ", ptr " + safe_ptr + ", i64 " + sz + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + buf + " to i64")
    cg_set_val(cg, dest, r)
    emit_scope_track(cg, r, 0)
    return 0
  }

  // ------ IR_RMDIR (248): [op, dest, path_reg] ------
  if op == IR_RMDIR {
    pv = cg_get_val(cg, ir_field(inst, 16))
    pp = cg_fresh_reg(cg)
    emit(cg, "  " + pp + " = inttoptr i64 " + pv + " to ptr")
    rv = cg_fresh_reg(cg)
    emit(cg, "  " + rv + " = call i32 @rmdir(ptr " + pp + ")")
    is_ok = cg_fresh_reg(cg)
    emit(cg, "  " + is_ok + " = icmp eq i32 " + rv + ", 0")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = select i1 " + is_ok + ", i64 1, i64 0")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ IR_REMOVE (249): [op, dest, path_reg] ------
  if op == IR_REMOVE {
    pv = cg_get_val(cg, ir_field(inst, 16))
    pp = cg_fresh_reg(cg)
    emit(cg, "  " + pp + " = inttoptr i64 " + pv + " to ptr")
    rv = cg_fresh_reg(cg)
    emit(cg, "  " + rv + " = call i32 @remove(ptr " + pp + ")")
    is_ok = cg_fresh_reg(cg)
    emit(cg, "  " + is_ok + " = icmp eq i32 " + rv + ", 0")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = select i1 " + is_ok + ", i64 1, i64 0")
    cg_set_val(cg, dest, r)
    return 0
  }

  if op == IR_MKDIR {
    compile_rt1(cg, inst, "sans_mkdir")
    return 0
  }

  if op == IR_IS_DIR {
    compile_rt1(cg, inst, "sans_is_dir")
    return 0
  }

  if op == IR_LISTDIR {
    compile_rt1(cg, inst, "sans_listdir")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 1)
    return 0
  }

  if op == IR_SH {
    compile_rt1(cg, inst, "sans_sh")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 0)
    return 0
  }

  if op == IR_SCOPE_DISABLE {
    d = cg_fresh_reg(cg)
    emit(cg, "  " + d + " = call i64 @sans_scope_disable()")
    cg_set_val(cg, dest, d)
    return 0
  }

  if op == IR_SCOPE_ENABLE {
    d = cg_fresh_reg(cg)
    emit(cg, "  " + d + " = call i64 @sans_scope_enable()")
    cg_set_val(cg, dest, d)
    return 0
  }

  // ------ JSON (66-82) --- runtime calls ------
  if op == IR_JSON_PARSE {
    compile_rt1(cg, inst, "sans_json_parse")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 3)
    return 0
  }
  if op == IR_JSON_OBJECT {
    compile_rt0(cg, inst, "sans_json_object")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 3)
    return 0
  }
  if op == IR_JSON_ARRAY {
    compile_rt0(cg, inst, "sans_json_array")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 3)
    return 0
  }
  if op == IR_JSON_STRING {
    compile_rt1(cg, inst, "sans_json_string")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 3)
    return 0
  }
  if op == IR_JSON_INT {
    compile_rt1(cg, inst, "sans_json_int")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 3)
    return 0
  }
  if op == IR_JSON_BOOL {
    compile_rt1(cg, inst, "sans_json_bool")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 3)
    return 0
  }
  if op == IR_JSON_NULL {
    compile_rt0(cg, inst, "sans_json_null")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 3)
    return 0
  }
  if op == IR_JSON_GET { return compile_rt2(cg, inst, "sans_json_get") }
  if op == IR_JSON_GET_INDEX { return compile_rt2(cg, inst, "sans_json_get_index") }
  if op == IR_JSON_GET_STRING {
    compile_rt1(cg, inst, "sans_json_get_string")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 5)
    return 0
  }
  if op == IR_JSON_GET_INT { return compile_rt1(cg, inst, "sans_json_get_int") }
  if op == IR_JSON_GET_BOOL { return compile_rt1(cg, inst, "sans_json_get_bool") }
  if op == IR_JSON_LEN { return compile_rt1(cg, inst, "sans_json_len") }
  if op == IR_JSON_TYPE_OF {
    compile_rt1(cg, inst, "sans_json_type_of")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 5)
    return 0
  }
  if op == IR_JSON_SET { return compile_rt3(cg, inst, "sans_json_set") }
  if op == IR_JSON_PUSH { return compile_rt2(cg, inst, "sans_json_push") }
  if op == IR_JSON_STRINGIFY {
    compile_rt1(cg, inst, "sans_json_stringify")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 5)
    return 0
  }
  if op == IR_JSON_KEYS {
    compile_rt1(cg, inst, "sans_json_keys")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 1)
    return 0
  }
  if op == IR_JSON_HAS { return compile_rt2(cg, inst, "sans_json_has") }
  if op == IR_JSON_DELETE { return compile_rt2(cg, inst, "sans_json_delete") }

  // ------ HTTP Server (83-89) ------
  if op == IR_HTTP_LISTEN { return compile_rt1(cg, inst, "sans_http_listen") }
  if op == IR_HTTP_ACCEPT { return compile_http_accept(cg, inst) }
  if op == IR_HTTP_REQUEST_PATH { return compile_rt1(cg, inst, "sans_http_request_path") }
  if op == IR_HTTP_REQUEST_METHOD { return compile_rt1(cg, inst, "sans_http_request_method") }
  if op == IR_HTTP_REQUEST_BODY { return compile_rt1(cg, inst, "sans_http_request_body") }
  if op == IR_HTTPS_LISTEN { return compile_rt3(cg, inst, "sans_https_listen") }
  if op == IR_HTTP_REQUEST_HEADER { return compile_rt2(cg, inst, "sans_http_request_header") }
  if op == IR_HTTP_REQUEST_SET_HEADER { return compile_rt3(cg, inst, "sans_http_request_set_header") }
  if op == IR_HTTP_REQUEST_COOKIE { return compile_rt2(cg, inst, "sans_http_request_cookie") }
  if op == IR_CORS { return compile_rt2(cg, inst, "sans_cors") }
  if op == IR_CORS_ALL { return compile_rt1(cg, inst, "sans_cors_all") }
  if op == IR_HTTP_REQUEST_QUERY { return compile_rt2(cg, inst, "sans_http_request_query") }
  if op == IR_HTTP_REQUEST_PATH_ONLY { return compile_rt1(cg, inst, "sans_http_request_path_only") }
  if op == IR_HTTP_REQUEST_CONTENT_LENGTH { return compile_rt1(cg, inst, "sans_http_request_content_length") }
  if op == IR_HTTP_RESPOND_JSON { return compile_rt3(cg, inst, "sans_http_respond_json") }
  if op == IR_URL_DECODE {
    compile_rt1(cg, inst, "sans_url_decode")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 5)
    return 0
  }
  if op == IR_PATH_SEGMENT {
    compile_rt2(cg, inst, "sans_path_segment")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 5)
    return 0
  }
  if op == IR_SERVE_FILE { return compile_rt2(cg, inst, "sans_serve_file") }
  if op == IR_SERVE { return compile_rt2(cg, inst, "sans_serve") }
  if op == IR_SERVE_TLS { return compile_rt4(cg, inst, "sans_serve_tls") }
  if op == IR_RESPOND_STREAM { return compile_rt2(cg, inst, "sans_respond_stream") }
  if op == IR_STREAM_WRITE { return compile_rt2(cg, inst, "sans_stream_write") }
  if op == IR_STREAM_END { return compile_rt1(cg, inst, "sans_stream_end") }
  if op == IR_HTTP_REQUEST_FORM { return compile_rt2(cg, inst, "sans_http_request_form") }

  // ------ WebSocket ------
  if op == IR_WS_IS_UPGRADE { return compile_rt1(cg, inst, "sans_ws_is_upgrade") }
  if op == IR_WS_UPGRADE { return compile_rt1(cg, inst, "sans_ws_upgrade") }
  if op == IR_WS_SEND { return compile_rt2(cg, inst, "sans_ws_send") }
  if op == IR_WS_RECV { return compile_rt1(cg, inst, "sans_ws_recv") }
  if op == IR_WS_CLOSE { return compile_rt1(cg, inst, "sans_ws_close") }

  // ------ Signal handler: call signal(signum_i32, @__sans_signal_handler) ------
  if op == IR_SIGNAL_HANDLER {
    a = cg_get_val(cg, ir_field(inst, 16))
    t = cg_fresh_reg(cg)
    emit(cg, "  " + t + " = trunc i64 " + a + " to i32")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @signal(i32 " + t + ", ptr @__sans_signal_handler)")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ Signal check: load @__sans_signal_flag ------
  if op == IR_SIGNAL_CHECK {
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = load i64, ptr @__sans_signal_flag")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ spoll(fd, timeout_ms): alloca pollfd, call poll, return >0?1:0 ------
  if op == IR_SPOLL {
    fd_val = cg_get_val(cg, ir_field(inst, 16))
    to_val = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    pfd = cg_fresh_reg(cg)
    emit(cg, "  " + pfd + " = alloca i64")
    // Store fd as i32 at offset 0
    fd32 = cg_fresh_reg(cg)
    emit(cg, "  " + fd32 + " = trunc i64 " + fd_val + " to i32")
    emit(cg, "  store i32 " + fd32 + ", ptr " + pfd)
    // Store events=1 (POLLIN) as i16 at offset 4
    ep = cg_fresh_reg(cg)
    emit(cg, "  " + ep + " = getelementptr i8, ptr " + pfd + ", i64 4")
    emit(cg, "  store i16 1, ptr " + ep)
    // Call poll(pfd, 1, timeout_i32)
    to32 = cg_fresh_reg(cg)
    emit(cg, "  " + to32 + " = trunc i64 " + to_val + " to i32")
    pr = cg_fresh_reg(cg)
    emit(cg, "  " + pr + " = call i32 @poll(ptr " + pfd + ", i32 1, i32 " + to32 + ")")
    // result > 0 ? 1 : 0
    cmp = cg_fresh_reg(cg)
    emit(cg, "  " + cmp + " = icmp sgt i32 " + pr + ", 0")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = zext i1 " + cmp + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ SSL low-level ------
  if op == IR_SSL_METHOD {
    rp = cg_fresh_reg(cg)
    emit(cg, "  " + rp + " = call ptr @TLS_server_method()")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + rp + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SSL_CTX_NEW {
    a = cg_get_val(cg, ir_field(inst, 16))
    ap = cg_fresh_reg(cg)
    emit(cg, "  " + ap + " = inttoptr i64 " + a + " to ptr")
    rp = cg_fresh_reg(cg)
    emit(cg, "  " + rp + " = call ptr @SSL_CTX_new(ptr " + ap + ")")
    r2 = cg_fresh_reg(cg)
    emit(cg, "  " + r2 + " = ptrtoint ptr " + rp + " to i64")
    cg_set_val(cg, dest, r2)
    return 0
  }
  if op == IR_SSL_CTX_CERT {
    ctx_v = cg_get_val(cg, ir_field(inst, 16))
    file_v = cg_get_val(cg, ir_field(inst, 24))
    typ_v = cg_get_val(cg, ir_field(inst, 32))
    cp = cg_fresh_reg(cg)
    emit(cg, "  " + cp + " = inttoptr i64 " + ctx_v + " to ptr")
    fp = cg_fresh_reg(cg)
    emit(cg, "  " + fp + " = inttoptr i64 " + file_v + " to ptr")
    ti = cg_fresh_reg(cg)
    emit(cg, "  " + ti + " = trunc i64 " + typ_v + " to i32")
    ri = cg_fresh_reg(cg)
    emit(cg, "  " + ri + " = call i32 @SSL_CTX_use_certificate_file(ptr " + cp + ", ptr " + fp + ", i32 " + ti + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = sext i32 " + ri + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SSL_CTX_KEY {
    ctx_v = cg_get_val(cg, ir_field(inst, 16))
    file_v = cg_get_val(cg, ir_field(inst, 24))
    typ_v = cg_get_val(cg, ir_field(inst, 32))
    cp = cg_fresh_reg(cg)
    emit(cg, "  " + cp + " = inttoptr i64 " + ctx_v + " to ptr")
    fp = cg_fresh_reg(cg)
    emit(cg, "  " + fp + " = inttoptr i64 " + file_v + " to ptr")
    ti = cg_fresh_reg(cg)
    emit(cg, "  " + ti + " = trunc i64 " + typ_v + " to i32")
    ri = cg_fresh_reg(cg)
    emit(cg, "  " + ri + " = call i32 @SSL_CTX_use_PrivateKey_file(ptr " + cp + ", ptr " + fp + ", i32 " + ti + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = sext i32 " + ri + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SSL_NEW {
    a = cg_get_val(cg, ir_field(inst, 16))
    ap = cg_fresh_reg(cg)
    emit(cg, "  " + ap + " = inttoptr i64 " + a + " to ptr")
    rp = cg_fresh_reg(cg)
    emit(cg, "  " + rp + " = call ptr @SSL_new(ptr " + ap + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + rp + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SSL_SET_FD {
    ssl_v = cg_get_val(cg, ir_field(inst, 16))
    fd_v = cg_get_val(cg, ir_field(inst, 24))
    sp = cg_fresh_reg(cg)
    emit(cg, "  " + sp + " = inttoptr i64 " + ssl_v + " to ptr")
    fi = cg_fresh_reg(cg)
    emit(cg, "  " + fi + " = trunc i64 " + fd_v + " to i32")
    ri = cg_fresh_reg(cg)
    emit(cg, "  " + ri + " = call i32 @SSL_set_fd(ptr " + sp + ", i32 " + fi + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = sext i32 " + ri + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SSL_DO_ACCEPT {
    a = cg_get_val(cg, ir_field(inst, 16))
    ap = cg_fresh_reg(cg)
    emit(cg, "  " + ap + " = inttoptr i64 " + a + " to ptr")
    ri = cg_fresh_reg(cg)
    emit(cg, "  " + ri + " = call i32 @SSL_accept(ptr " + ap + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = sext i32 " + ri + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SSL_READ {
    ssl_v = cg_get_val(cg, ir_field(inst, 16))
    buf_v = cg_get_val(cg, ir_field(inst, 24))
    len_v = cg_get_val(cg, ir_field(inst, 32))
    sp = cg_fresh_reg(cg)
    emit(cg, "  " + sp + " = inttoptr i64 " + ssl_v + " to ptr")
    bp = cg_fresh_reg(cg)
    emit(cg, "  " + bp + " = inttoptr i64 " + buf_v + " to ptr")
    li = cg_fresh_reg(cg)
    emit(cg, "  " + li + " = trunc i64 " + len_v + " to i32")
    ri = cg_fresh_reg(cg)
    emit(cg, "  " + ri + " = call i32 @SSL_read(ptr " + sp + ", ptr " + bp + ", i32 " + li + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = sext i32 " + ri + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SSL_WRITE {
    ssl_v = cg_get_val(cg, ir_field(inst, 16))
    buf_v = cg_get_val(cg, ir_field(inst, 24))
    len_v = cg_get_val(cg, ir_field(inst, 32))
    sp = cg_fresh_reg(cg)
    emit(cg, "  " + sp + " = inttoptr i64 " + ssl_v + " to ptr")
    bp = cg_fresh_reg(cg)
    emit(cg, "  " + bp + " = inttoptr i64 " + buf_v + " to ptr")
    li = cg_fresh_reg(cg)
    emit(cg, "  " + li + " = trunc i64 " + len_v + " to i32")
    ri = cg_fresh_reg(cg)
    emit(cg, "  " + ri + " = call i32 @SSL_write(ptr " + sp + ", ptr " + bp + ", i32 " + li + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = sext i32 " + ri + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SSL_SHUTDOWN {
    a = cg_get_val(cg, ir_field(inst, 16))
    ap = cg_fresh_reg(cg)
    emit(cg, "  " + ap + " = inttoptr i64 " + a + " to ptr")
    ri = cg_fresh_reg(cg)
    emit(cg, "  " + ri + " = call i32 @SSL_shutdown(ptr " + ap + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = sext i32 " + ri + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SSL_FREE {
    a = cg_get_val(cg, ir_field(inst, 16))
    ap = cg_fresh_reg(cg)
    emit(cg, "  " + ap + " = inttoptr i64 " + a + " to ptr")
    emit(cg, "  call void @SSL_free(ptr " + ap + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = add i64 0, 0")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_HTTP_RESPOND {
    // 3 IR args + default content type = 4 C args
    a = cg_get_val(cg, ir_field(inst, 16))
    b = cg_get_val(cg, ir_field(inst, 24))
    c = cg_get_val(cg, ir_field(inst, 32))
    ct_name = emit_string_const(cg, "text/html; charset=utf-8")
    ct = cg_fresh_reg(cg)
    emit(cg, "  " + ct + " = ptrtoint ptr " + ct_name + " to i64")
    d = compile_http_respond(cg, a, b, c, ct)
    cg_set_val(cg, dest, d)
    return 0
  }
  if op == IR_HTTP_RESPOND_CT {
    // 4 IR args: request, status, body, content_type
    a = cg_get_val(cg, ir_field(inst, 16))
    b = cg_get_val(cg, ir_field(inst, 24))
    c = cg_get_val(cg, ir_field(inst, 32))
    e = cg_get_val(cg, ir_field(inst, 40))
    d = compile_http_respond(cg, a, b, c, e)
    cg_set_val(cg, dest, d)
    return 0
  }

  // ------ HTTP Client (90-95) ------
  if op == IR_HTTP_GET { return compile_rt1(cg, inst, "sans_http_get") }
  if op == IR_HTTP_POST { return compile_rt3(cg, inst, "sans_http_post") }
  if op == IR_HTTP_STATUS { return compile_rt1(cg, inst, "sans_http_status") }
  if op == IR_HTTP_BODY { return compile_rt1(cg, inst, "sans_http_body") }
  if op == IR_HTTP_HEADER { return compile_rt2(cg, inst, "sans_http_header") }
  if op == IR_HTTP_OK { return compile_rt1(cg, inst, "sans_http_ok") }

  // ------ Concurrency (96-104) ------
  if op == IR_THREAD_SPAWN {
    // Layout: [op@0, dest@8, func_name@16, args_array@24]
    func_name = ir_field(inst, 16)
    arg_regs = ir_field(inst, 24)
    num_args = arg_regs.len()
    llvm_fname = if func_name == "main" { "__sans_main" } else { func_name }

    // Malloc arg struct (num_args * 8 bytes)
    ap = cg_fresh_reg(cg)
    if num_args > 0 {
      sz = num_args * 8
      emit(cg, "  " + ap + " = call ptr @malloc(i64 " + str(sz) + ")")
    }
    if num_args == 0 {
      emit(cg, "  " + ap + " = inttoptr i64 0 to ptr")
    }

    // Store each arg into the arg struct
    ai := 0
    while ai < num_args {
      av = cg_get_val(cg, arg_regs.get(ai))
      sp = cg_fresh_reg(cg)
      emit(cg, "  " + sp + " = getelementptr i64, ptr " + ap + ", i64 " + str(ai))
      emit(cg, "  store i64 " + av + ", ptr " + sp)
      ai = ai + 1
      0
    }

    // Emit trampoline function (global scope, via emit_global_const)
    tramp_name = "__trampoline_" + func_name
    pool = cg_string_pool(cg)
    if mhas(pool, tramp_name) == 0 {
      mset(pool, tramp_name, 1)
      emit_global_const(cg, "define ptr @" + tramp_name + "(ptr %arg) {")
      emit_global_const(cg, "entry:")
      // Load each arg from struct and call target
      call_args := ""
      ti := 0
      while ti < num_args {
        emit_global_const(cg, "  %sp" + str(ti) + " = getelementptr i64, ptr %arg, i64 " + str(ti))
        emit_global_const(cg, "  %a" + str(ti) + " = load i64, ptr %sp" + str(ti))
        if ti > 0 { call_args = call_args + ", " }
        call_args = call_args + "i64 %a" + str(ti)
        ti = ti + 1
        0
      }
      emit_global_const(cg, "  call i64 @" + llvm_fname + "(" + call_args + ")")
      if num_args > 0 {
        emit_global_const(cg, "  call void @free(ptr %arg)")
      }
      emit_global_const(cg, "  ret ptr null")
      emit_global_const(cg, "}")
    }

    // Alloca for thread id, call pthread_create
    tid = cg_fresh_reg(cg)
    emit(cg, "  " + tid + " = alloca i64")
    pc = cg_fresh_reg(cg)
    emit(cg, "  " + pc + " = call i32 @pthread_create(ptr " + tid + ", ptr null, ptr @" + tramp_name + ", ptr " + ap + ")")
    handle = cg_fresh_reg(cg)
    emit(cg, "  " + handle + " = load i64, ptr " + tid)
    cg_set_val(cg, dest, handle)
    return 0
  }
  if op == IR_THREAD_JOIN {
    // dest field holds the handle register
    hv = cg_get_val(cg, dest)
    tj = cg_fresh_reg(cg)
    emit(cg, "  " + tj + " = call i32 @pthread_join(i64 " + hv + ", ptr null)")
    return 0
  }
  if op == IR_CHANNEL_CREATE {
    // Layout: [op@0, tx_dest@8, rx_dest@16]
    // Allocate channel struct: 26 * 8 = 208 bytes
    chan = cg_fresh_reg(cg)
    emit(cg, "  " + chan + " = call ptr @malloc(i64 208)")
    // Allocate buffer: 16 * 8 = 128 bytes
    buf = cg_fresh_reg(cg)
    emit(cg, "  " + buf + " = call ptr @malloc(i64 128)")
    bufi = cg_fresh_reg(cg)
    emit(cg, "  " + bufi + " = ptrtoint ptr " + buf + " to i64")
    // offset 0: buffer pointer
    emit(cg, "  store i64 " + bufi + ", ptr " + chan)
    // offset 1: capacity = 16
    p1 = cg_fresh_reg(cg)
    emit(cg, "  " + p1 + " = getelementptr i64, ptr " + chan + ", i64 1")
    emit(cg, "  store i64 16, ptr " + p1)
    // offset 2: count = 0
    p2 = cg_fresh_reg(cg)
    emit(cg, "  " + p2 + " = getelementptr i64, ptr " + chan + ", i64 2")
    emit(cg, "  store i64 0, ptr " + p2)
    // offset 3: head = 0
    p3 = cg_fresh_reg(cg)
    emit(cg, "  " + p3 + " = getelementptr i64, ptr " + chan + ", i64 3")
    emit(cg, "  store i64 0, ptr " + p3)
    // offset 4: tail = 0
    p4 = cg_fresh_reg(cg)
    emit(cg, "  " + p4 + " = getelementptr i64, ptr " + chan + ", i64 4")
    emit(cg, "  store i64 0, ptr " + p4)
    // offset 5: mutex init
    mtx = cg_fresh_reg(cg)
    emit(cg, "  " + mtx + " = getelementptr i64, ptr " + chan + ", i64 5")
    mi = cg_fresh_reg(cg)
    emit(cg, "  " + mi + " = call i32 @pthread_mutex_init(ptr " + mtx + ", ptr null)")
    // offset 13: recv condvar init
    rcv = cg_fresh_reg(cg)
    emit(cg, "  " + rcv + " = getelementptr i64, ptr " + chan + ", i64 13")
    ri = cg_fresh_reg(cg)
    emit(cg, "  " + ri + " = call i32 @pthread_cond_init(ptr " + rcv + ", ptr null)")
    // offset 19: send condvar init
    snd = cg_fresh_reg(cg)
    emit(cg, "  " + snd + " = getelementptr i64, ptr " + chan + ", i64 19")
    si = cg_fresh_reg(cg)
    emit(cg, "  " + si + " = call i32 @pthread_cond_init(ptr " + snd + ", ptr null)")
    // offset 25: is_bounded = 0
    p25 = cg_fresh_reg(cg)
    emit(cg, "  " + p25 + " = getelementptr i64, ptr " + chan + ", i64 25")
    emit(cg, "  store i64 0, ptr " + p25)
    // Convert to i64 for both tx and rx
    chan_i = cg_fresh_reg(cg)
    emit(cg, "  " + chan_i + " = ptrtoint ptr " + chan + " to i64")
    cg_set_val(cg, dest, chan_i)
    rx_dest = ir_field(inst, 16)
    cg_set_val(cg, rx_dest, chan_i)
    return 0
  }
  if op == IR_CHANNEL_CREATE_BOUNDED {
    // Layout: [op@0, tx_dest@8, rx_dest@16, cap_reg@24]
    cap_val = cg_get_val(cg, ir_field(inst, 24))
    // Allocate channel struct: 26 * 8 = 208 bytes
    chan = cg_fresh_reg(cg)
    emit(cg, "  " + chan + " = call ptr @malloc(i64 208)")
    // Buffer size = capacity * 8
    bsz = cg_fresh_reg(cg)
    emit(cg, "  " + bsz + " = mul i64 " + cap_val + ", 8")
    buf = cg_fresh_reg(cg)
    emit(cg, "  " + buf + " = call ptr @malloc(i64 " + bsz + ")")
    bufi = cg_fresh_reg(cg)
    emit(cg, "  " + bufi + " = ptrtoint ptr " + buf + " to i64")
    // offset 0: buffer
    emit(cg, "  store i64 " + bufi + ", ptr " + chan)
    // offset 1: capacity
    p1 = cg_fresh_reg(cg)
    emit(cg, "  " + p1 + " = getelementptr i64, ptr " + chan + ", i64 1")
    emit(cg, "  store i64 " + cap_val + ", ptr " + p1)
    // offset 2: count = 0
    p2 = cg_fresh_reg(cg)
    emit(cg, "  " + p2 + " = getelementptr i64, ptr " + chan + ", i64 2")
    emit(cg, "  store i64 0, ptr " + p2)
    // offset 3: head = 0
    p3 = cg_fresh_reg(cg)
    emit(cg, "  " + p3 + " = getelementptr i64, ptr " + chan + ", i64 3")
    emit(cg, "  store i64 0, ptr " + p3)
    // offset 4: tail = 0
    p4 = cg_fresh_reg(cg)
    emit(cg, "  " + p4 + " = getelementptr i64, ptr " + chan + ", i64 4")
    emit(cg, "  store i64 0, ptr " + p4)
    // offset 5: mutex init
    mtx = cg_fresh_reg(cg)
    emit(cg, "  " + mtx + " = getelementptr i64, ptr " + chan + ", i64 5")
    mi = cg_fresh_reg(cg)
    emit(cg, "  " + mi + " = call i32 @pthread_mutex_init(ptr " + mtx + ", ptr null)")
    // offset 13: recv condvar init
    rcv = cg_fresh_reg(cg)
    emit(cg, "  " + rcv + " = getelementptr i64, ptr " + chan + ", i64 13")
    ri = cg_fresh_reg(cg)
    emit(cg, "  " + ri + " = call i32 @pthread_cond_init(ptr " + rcv + ", ptr null)")
    // offset 19: send condvar init
    snd = cg_fresh_reg(cg)
    emit(cg, "  " + snd + " = getelementptr i64, ptr " + chan + ", i64 19")
    si = cg_fresh_reg(cg)
    emit(cg, "  " + si + " = call i32 @pthread_cond_init(ptr " + snd + ", ptr null)")
    // offset 25: is_bounded = 1
    p25 = cg_fresh_reg(cg)
    emit(cg, "  " + p25 + " = getelementptr i64, ptr " + chan + ", i64 25")
    emit(cg, "  store i64 1, ptr " + p25)
    // Convert to i64 for both tx and rx
    chan_i = cg_fresh_reg(cg)
    emit(cg, "  " + chan_i + " = ptrtoint ptr " + chan + " to i64")
    cg_set_val(cg, dest, chan_i)
    rx_dest = ir_field(inst, 16)
    cg_set_val(cg, rx_dest, chan_i)
    return 0
  }
  if op == IR_CHANNEL_SEND {
    // Layout: [op@0, tx_reg@8, value_reg@16]
    tx_val = cg_get_val(cg, dest)
    val = cg_get_val(cg, ir_field(inst, 16))
    // inttoptr tx to channel pointer
    chanp = cg_fresh_reg(cg)
    emit(cg, "  " + chanp + " = inttoptr i64 " + tx_val + " to ptr")
    // Lock mutex at offset 5
    mtx = cg_fresh_reg(cg)
    emit(cg, "  " + mtx + " = getelementptr i64, ptr " + chanp + ", i64 5")
    ml = cg_fresh_reg(cg)
    emit(cg, "  " + ml + " = call i32 @pthread_mutex_lock(ptr " + mtx + ")")
    // Load count, tail, capacity, buffer
    cnt_p = cg_fresh_reg(cg)
    emit(cg, "  " + cnt_p + " = getelementptr i64, ptr " + chanp + ", i64 2")
    count = cg_fresh_reg(cg)
    emit(cg, "  " + count + " = load i64, ptr " + cnt_p)
    tail_p = cg_fresh_reg(cg)
    emit(cg, "  " + tail_p + " = getelementptr i64, ptr " + chanp + ", i64 4")
    tail = cg_fresh_reg(cg)
    emit(cg, "  " + tail + " = load i64, ptr " + tail_p)
    cap_p = cg_fresh_reg(cg)
    emit(cg, "  " + cap_p + " = getelementptr i64, ptr " + chanp + ", i64 1")
    cap = cg_fresh_reg(cg)
    emit(cg, "  " + cap + " = load i64, ptr " + cap_p)
    buf_i = cg_fresh_reg(cg)
    emit(cg, "  " + buf_i + " = load i64, ptr " + chanp)
    bufp = cg_fresh_reg(cg)
    emit(cg, "  " + bufp + " = inttoptr i64 " + buf_i + " to ptr")
    // Store value at buf[tail]
    slot = cg_fresh_reg(cg)
    emit(cg, "  " + slot + " = getelementptr i64, ptr " + bufp + ", i64 " + tail)
    emit(cg, "  store i64 " + val + ", ptr " + slot)
    // tail = (tail + 1) % cap
    t1 = cg_fresh_reg(cg)
    emit(cg, "  " + t1 + " = add i64 " + tail + ", 1")
    nt = cg_fresh_reg(cg)
    emit(cg, "  " + nt + " = srem i64 " + t1 + ", " + cap)
    emit(cg, "  store i64 " + nt + ", ptr " + tail_p)
    // count += 1
    nc = cg_fresh_reg(cg)
    emit(cg, "  " + nc + " = add i64 " + count + ", 1")
    emit(cg, "  store i64 " + nc + ", ptr " + cnt_p)
    // Signal recv condvar at offset 13
    rcv = cg_fresh_reg(cg)
    emit(cg, "  " + rcv + " = getelementptr i64, ptr " + chanp + ", i64 13")
    cs = cg_fresh_reg(cg)
    emit(cg, "  " + cs + " = call i32 @pthread_cond_signal(ptr " + rcv + ")")
    // Unlock mutex
    mu = cg_fresh_reg(cg)
    emit(cg, "  " + mu + " = call i32 @pthread_mutex_unlock(ptr " + mtx + ")")
    return 0
  }
  if op == IR_CHANNEL_RECV {
    // Layout: [op@0, dest@8, rx_reg@16]
    rx_val = cg_get_val(cg, ir_field(inst, 16))
    // inttoptr rx to channel pointer
    chanp = cg_fresh_reg(cg)
    emit(cg, "  " + chanp + " = inttoptr i64 " + rx_val + " to ptr")
    // Lock mutex at offset 5
    mtx = cg_fresh_reg(cg)
    emit(cg, "  " + mtx + " = getelementptr i64, ptr " + chanp + ", i64 5")
    ml = cg_fresh_reg(cg)
    emit(cg, "  " + ml + " = call i32 @pthread_mutex_lock(ptr " + mtx + ")")
    // Wait loop: while count == 0, wait on recv condvar
    lid = cg_label_id(cg)
    lbl_wait = "recv_wait_" + lid
    lbl_sleep = "recv_sleep_" + lid
    lbl_read = "recv_read_" + lid
    emit(cg, "  br label %" + lbl_wait)
    emit(cg, lbl_wait + ":")
    cnt_p = cg_fresh_reg(cg)
    emit(cg, "  " + cnt_p + " = getelementptr i64, ptr " + chanp + ", i64 2")
    count = cg_fresh_reg(cg)
    emit(cg, "  " + count + " = load i64, ptr " + cnt_p)
    empty = cg_fresh_reg(cg)
    emit(cg, "  " + empty + " = icmp eq i64 " + count + ", 0")
    emit(cg, "  br i1 " + empty + ", label %" + lbl_sleep + ", label %" + lbl_read)
    emit(cg, lbl_sleep + ":")
    rcv = cg_fresh_reg(cg)
    emit(cg, "  " + rcv + " = getelementptr i64, ptr " + chanp + ", i64 13")
    cw = cg_fresh_reg(cg)
    emit(cg, "  " + cw + " = call i32 @pthread_cond_wait(ptr " + rcv + ", ptr " + mtx + ")")
    emit(cg, "  br label %" + lbl_wait)
    emit(cg, lbl_read + ":")
    // Load from buf[head]
    head_p = cg_fresh_reg(cg)
    emit(cg, "  " + head_p + " = getelementptr i64, ptr " + chanp + ", i64 3")
    head = cg_fresh_reg(cg)
    emit(cg, "  " + head + " = load i64, ptr " + head_p)
    buf_i = cg_fresh_reg(cg)
    emit(cg, "  " + buf_i + " = load i64, ptr " + chanp)
    bufp = cg_fresh_reg(cg)
    emit(cg, "  " + bufp + " = inttoptr i64 " + buf_i + " to ptr")
    slot = cg_fresh_reg(cg)
    emit(cg, "  " + slot + " = getelementptr i64, ptr " + bufp + ", i64 " + head)
    val = cg_fresh_reg(cg)
    emit(cg, "  " + val + " = load i64, ptr " + slot)
    // head = (head + 1) % capacity
    cap_p = cg_fresh_reg(cg)
    emit(cg, "  " + cap_p + " = getelementptr i64, ptr " + chanp + ", i64 1")
    cap = cg_fresh_reg(cg)
    emit(cg, "  " + cap + " = load i64, ptr " + cap_p)
    h1 = cg_fresh_reg(cg)
    emit(cg, "  " + h1 + " = add i64 " + head + ", 1")
    nh = cg_fresh_reg(cg)
    emit(cg, "  " + nh + " = srem i64 " + h1 + ", " + cap)
    emit(cg, "  store i64 " + nh + ", ptr " + head_p)
    // count -= 1
    count2 = cg_fresh_reg(cg)
    emit(cg, "  " + count2 + " = load i64, ptr " + cnt_p)
    nc = cg_fresh_reg(cg)
    emit(cg, "  " + nc + " = sub i64 " + count2 + ", 1")
    emit(cg, "  store i64 " + nc + ", ptr " + cnt_p)
    // Signal send condvar at offset 19
    snd = cg_fresh_reg(cg)
    emit(cg, "  " + snd + " = getelementptr i64, ptr " + chanp + ", i64 19")
    cs = cg_fresh_reg(cg)
    emit(cg, "  " + cs + " = call i32 @pthread_cond_signal(ptr " + snd + ")")
    // Unlock mutex
    mu = cg_fresh_reg(cg)
    emit(cg, "  " + mu + " = call i32 @pthread_mutex_unlock(ptr " + mtx + ")")
    // Set result
    cg_set_val(cg, dest, val)
    // Update current block label for subsequent instructions
    cg_set_current_block(cg, lbl_read)
    return 0
  }
  if op == IR_CHANNEL_TRY_RECV {
    // Layout: [op, dest, rx_reg, out_ptr_reg]
    // Returns 1 if value received (stored at out_ptr), 0 if empty
    rx_val = cg_get_val(cg, ir_field(inst, 16))
    out_ptr_val = cg_get_val(cg, ir_field(inst, 24))
    lid = cg_label_id(cg)
    lbl_has = "tryrecv_has_" + lid
    lbl_empty = "tryrecv_empty_" + lid
    lbl_end = "tryrecv_end_" + lid
    // inttoptr rx to channel pointer
    chanp = cg_fresh_reg(cg)
    emit(cg, "  " + chanp + " = inttoptr i64 " + rx_val + " to ptr")
    // Lock mutex at offset 5
    mtx = cg_fresh_reg(cg)
    emit(cg, "  " + mtx + " = getelementptr i64, ptr " + chanp + ", i64 5")
    ml = cg_fresh_reg(cg)
    emit(cg, "  " + ml + " = call i32 @pthread_mutex_lock(ptr " + mtx + ")")
    // Load count
    cnt_p = cg_fresh_reg(cg)
    emit(cg, "  " + cnt_p + " = getelementptr i64, ptr " + chanp + ", i64 2")
    count = cg_fresh_reg(cg)
    emit(cg, "  " + count + " = load i64, ptr " + cnt_p)
    // Check if count > 0
    has_data = cg_fresh_reg(cg)
    emit(cg, "  " + has_data + " = icmp sgt i64 " + count + ", 0")
    emit(cg, "  br i1 " + has_data + ", label %" + lbl_has + ", label %" + lbl_empty)
    // Has data: dequeue
    emit(cg, lbl_has + ":")
    head_p = cg_fresh_reg(cg)
    emit(cg, "  " + head_p + " = getelementptr i64, ptr " + chanp + ", i64 3")
    head = cg_fresh_reg(cg)
    emit(cg, "  " + head + " = load i64, ptr " + head_p)
    buf_i = cg_fresh_reg(cg)
    emit(cg, "  " + buf_i + " = load i64, ptr " + chanp)
    bufp = cg_fresh_reg(cg)
    emit(cg, "  " + bufp + " = inttoptr i64 " + buf_i + " to ptr")
    slot = cg_fresh_reg(cg)
    emit(cg, "  " + slot + " = getelementptr i64, ptr " + bufp + ", i64 " + head)
    val = cg_fresh_reg(cg)
    emit(cg, "  " + val + " = load i64, ptr " + slot)
    // Store value at out_ptr
    outp = cg_fresh_reg(cg)
    emit(cg, "  " + outp + " = inttoptr i64 " + out_ptr_val + " to ptr")
    emit(cg, "  store i64 " + val + ", ptr " + outp)
    // head = (head + 1) % capacity
    cap_p = cg_fresh_reg(cg)
    emit(cg, "  " + cap_p + " = getelementptr i64, ptr " + chanp + ", i64 1")
    cap = cg_fresh_reg(cg)
    emit(cg, "  " + cap + " = load i64, ptr " + cap_p)
    h1 = cg_fresh_reg(cg)
    emit(cg, "  " + h1 + " = add i64 " + head + ", 1")
    nh = cg_fresh_reg(cg)
    emit(cg, "  " + nh + " = srem i64 " + h1 + ", " + cap)
    emit(cg, "  store i64 " + nh + ", ptr " + head_p)
    // count -= 1
    nc = cg_fresh_reg(cg)
    emit(cg, "  " + nc + " = sub i64 " + count + ", 1")
    emit(cg, "  store i64 " + nc + ", ptr " + cnt_p)
    // Signal send condvar at offset 19
    snd = cg_fresh_reg(cg)
    emit(cg, "  " + snd + " = getelementptr i64, ptr " + chanp + ", i64 19")
    cs = cg_fresh_reg(cg)
    emit(cg, "  " + cs + " = call i32 @pthread_cond_signal(ptr " + snd + ")")
    // Unlock mutex
    mu1 = cg_fresh_reg(cg)
    emit(cg, "  " + mu1 + " = call i32 @pthread_mutex_unlock(ptr " + mtx + ")")
    emit(cg, "  br label %" + lbl_end)
    // Empty: unlock and return 0
    emit(cg, lbl_empty + ":")
    mu2 = cg_fresh_reg(cg)
    emit(cg, "  " + mu2 + " = call i32 @pthread_mutex_unlock(ptr " + mtx + ")")
    emit(cg, "  br label %" + lbl_end)
    // End: phi for result
    emit(cg, lbl_end + ":")
    result = cg_fresh_reg(cg)
    emit(cg, "  " + result + " = phi i64 [ 1, %" + lbl_has + " ], [ 0, %" + lbl_empty + " ]")
    cg_set_val(cg, dest, result)
    cg_set_current_block(cg, lbl_end)
    return 0
  }
  if op == IR_TIME_MS {
    // Uses pre-allocated [2 x i64] buffer from entry block (cg_timeval_buf)
    gv = cg_fresh_reg(cg)
    emit(cg, "  " + gv + " = call i32 @gettimeofday(ptr " + cg_timeval_buf + ", ptr null)")
    // Load tv_sec (i64 at offset 0) and tv_usec (i64 at offset 8)
    sec = cg_fresh_reg(cg)
    emit(cg, "  " + sec + " = load i64, ptr " + cg_timeval_buf)
    usec_p = cg_fresh_reg(cg)
    emit(cg, "  " + usec_p + " = getelementptr i64, ptr " + cg_timeval_buf + ", i64 1")
    usec = cg_fresh_reg(cg)
    emit(cg, "  " + usec + " = load i64, ptr " + usec_p)
    // ms = sec * 1000 + usec / 1000
    s_ms = cg_fresh_reg(cg)
    emit(cg, "  " + s_ms + " = mul i64 " + sec + ", 1000")
    u_ms = cg_fresh_reg(cg)
    emit(cg, "  " + u_ms + " = sdiv i64 " + usec + ", 1000")
    total = cg_fresh_reg(cg)
    emit(cg, "  " + total + " = add i64 " + s_ms + ", " + u_ms)
    cg_set_val(cg, dest, total)
    return 0
  }
  if op == IR_MUTEX_CREATE {
    // [op, dest, value_reg]: malloc 72 bytes, init mutex, store value
    val = cg_get_val(cg, ir_field(inst, 16))
    mp = cg_fresh_reg(cg)
    emit(cg, "  " + mp + " = call ptr @malloc(i64 72)")
    // Store value at offset 0
    emit(cg, "  store i64 " + val + ", ptr " + mp)
    // Init mutex at offset 8 (64 bytes for pthread_mutex_t)
    mx = cg_fresh_reg(cg)
    emit(cg, "  " + mx + " = getelementptr i8, ptr " + mp + ", i64 8")
    mi = cg_fresh_reg(cg)
    emit(cg, "  " + mi + " = call i32 @pthread_mutex_init(ptr " + mx + ", ptr null)")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + mp + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_MUTEX_LOCK {
    // [op, dest, mutex_reg]: lock, load value
    mv = cg_get_val(cg, ir_field(inst, 16))
    mp = cg_fresh_reg(cg)
    emit(cg, "  " + mp + " = inttoptr i64 " + mv + " to ptr")
    mx = cg_fresh_reg(cg)
    emit(cg, "  " + mx + " = getelementptr i8, ptr " + mp + ", i64 8")
    ml = cg_fresh_reg(cg)
    emit(cg, "  " + ml + " = call i32 @pthread_mutex_lock(ptr " + mx + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = load i64, ptr " + mp)
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_MUTEX_UNLOCK {
    // [op, mutex_reg, value_reg]: store value, unlock
    mv = cg_get_val(cg, dest)
    val = cg_get_val(cg, ir_field(inst, 16))
    mp = cg_fresh_reg(cg)
    emit(cg, "  " + mp + " = inttoptr i64 " + mv + " to ptr")
    emit(cg, "  store i64 " + val + ", ptr " + mp)
    mx = cg_fresh_reg(cg)
    emit(cg, "  " + mx + " = getelementptr i8, ptr " + mp + ", i64 8")
    mu = cg_fresh_reg(cg)
    emit(cg, "  " + mu + " = call i32 @pthread_mutex_unlock(ptr " + mx + ")")
    return 0
  }

  // ------ Function Refs (105-109) ------
  if op == IR_FN_REF {
    // [op, dest, name_ptr]: ptrtoint of function pointer
    // In text IR, we emit the function name directly
    fname = ir_field(inst, 16)
    llvm_fname = if fname == "main" { "__sans_main" } else { fname }
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr @" + llvm_fname + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    return 0
  }
  if op == IR_FPTR_NAMED {
    // [op, dest, func_name_ptr]: same as FN_REF
    fname = ir_field(inst, 16)
    llvm_fname = if fname == "main" { "__sans_main" } else { fname }
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr @" + llvm_fname + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    return 0
  }
  if op == IR_FCALL {
    // [op, dest, fn_ptr_reg, arg_reg]: indirect call with 1 arg
    // Closure-aware: check tag bit to handle capturing lambdas
    fp_val = cg_get_val(cg, ir_field(inst, 16))
    arg_val = cg_get_val(cg, ir_field(inst, 24))
    emit_closure_aware_call1(cg, dest, fp_val, arg_val)
    return 0
  }
  if op == IR_FCALL2 {
    // [op, dest, fn_ptr_reg, arg1_reg, arg2_reg]
    // Closure-aware: check tag bit to handle capturing lambdas
    fp_val = cg_get_val(cg, ir_field(inst, 16))
    a1 = cg_get_val(cg, ir_field(inst, 24))
    a2 = cg_get_val(cg, ir_field(inst, 32))
    emit_closure_aware_call2(cg, dest, fp_val, a1, a2)
    return 0
  }
  if op == IR_FCALL3 {
    // [op, dest, fn_ptr_reg, arg1_reg, arg2_reg, arg3_reg]
    // Closure-aware: check tag bit to handle capturing lambdas
    fp_val = cg_get_val(cg, ir_field(inst, 16))
    a1 = cg_get_val(cg, ir_field(inst, 24))
    a2 = cg_get_val(cg, ir_field(inst, 32))
    a3 = cg_get_val(cg, ir_field(inst, 40))
    emit_closure_aware_call3(cg, dest, fp_val, a1, a2, a3)
    return 0
  }

  // ------ Float Conversion (110-111) ------
  if op == IR_INT_TO_FLOAT {
    // sitofp i64 to double, bitcast double to i64
    val = cg_get_val(cg, ir_field(inst, 16))
    fv = cg_fresh_reg(cg)
    emit(cg, "  " + fv + " = sitofp i64 " + val + " to double")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = bitcast double " + fv + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_FLOAT_TO_INT {
    // bitcast i64 to double, fptosi double to i64
    val = cg_get_val(cg, ir_field(inst, 16))
    fv = cg_fresh_reg(cg)
    emit(cg, "  " + fv + " = bitcast i64 " + val + " to double")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = fptosi double " + fv + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ Result (112-118) --- runtime calls ------
  if op == IR_RESULT_OK {
    compile_rt1(cg, inst, "sans_result_ok")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 4)
    return 0
  }
  if op == IR_RESULT_ERR {
    compile_rt2(cg, inst, "sans_result_err")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 4)
    return 0
  }
  if op == IR_RESULT_IS_OK { return compile_rt1(cg, inst, "sans_result_is_ok") }
  if op == IR_RESULT_IS_ERR { return compile_rt1(cg, inst, "sans_result_is_err") }
  if op == IR_RESULT_UNWRAP { return compile_rt1(cg, inst, "sans_result_unwrap") }
  if op == IR_RESULT_UNWRAP_OR { return compile_rt2(cg, inst, "sans_result_unwrap_or") }
  if op == IR_RESULT_ERROR { return compile_rt1(cg, inst, "sans_result_error") }
  if op == IR_RESULT_CODE { return compile_rt1(cg, inst, "sans_result_code") }

  // ------ Result combinators (265-268) --- inline codegen with closure dispatch ------
  if op == IR_RESULT_MAP {
    // map(fn): if ok, call fn(value) and wrap in ok(); if err, propagate
    res_val = cg_get_val(cg, ir_field(inst, 16))
    fn_val = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    // Load tag (offset 0)
    rp = cg_fresh_reg(cg)
    emit(cg, "  " + rp + " = inttoptr i64 " + res_val + " to ptr")
    tag = cg_fresh_reg(cg)
    emit(cg, "  " + tag + " = load i64, ptr " + rp)
    is_ok = cg_fresh_reg(cg)
    emit(cg, "  " + is_ok + " = icmp eq i64 " + tag + ", 0")
    ok_lbl = "rmap_ok_" + uid
    err_lbl = "rmap_err_" + uid
    merge_lbl = "rmap_merge_" + uid
    emit(cg, "  br i1 " + is_ok + ", label %" + ok_lbl + ", label %" + err_lbl)
    // Ok path: load value at offset 8, call closure, wrap in ok()
    emit(cg, ok_lbl + ":")
    vp = cg_fresh_reg(cg)
    emit(cg, "  " + vp + " = getelementptr i64, ptr " + rp + ", i64 1")
    val = cg_fresh_reg(cg)
    emit(cg, "  " + val + " = load i64, ptr " + vp)
    emit_closure_aware_call1(cg, dest, fn_val, val)
    new_val = cg_get_val(cg, dest)
    ok_from = cg_current_block(cg)
    ok_r = cg_fresh_reg(cg)
    emit(cg, "  " + ok_r + " = call i64 @sans_result_ok(i64 " + new_val + ")")
    emit_scope_track(cg, ok_r, 4)
    emit(cg, "  br label %" + merge_lbl)
    // Err path: propagate original (already scope-tracked, don't re-track)
    emit(cg, err_lbl + ":")
    emit(cg, "  br label %" + merge_lbl)
    // Merge
    emit(cg, merge_lbl + ":")
    phi_r = cg_fresh_reg(cg)
    emit(cg, "  " + phi_r + " = phi i64 [" + ok_r + ", %" + ok_from + "], [" + res_val + ", %" + err_lbl + "]")
    cg_set_val(cg, dest, phi_r)
    cg_set_current_block(cg, merge_lbl)
    return 0
  }
  if op == IR_RESULT_AND_THEN {
    // and_then(fn): if ok, call fn(value) which returns Result; if err, propagate
    res_val = cg_get_val(cg, ir_field(inst, 16))
    fn_val = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    rp = cg_fresh_reg(cg)
    emit(cg, "  " + rp + " = inttoptr i64 " + res_val + " to ptr")
    tag = cg_fresh_reg(cg)
    emit(cg, "  " + tag + " = load i64, ptr " + rp)
    is_ok = cg_fresh_reg(cg)
    emit(cg, "  " + is_ok + " = icmp eq i64 " + tag + ", 0")
    ok_lbl = "rat_ok_" + uid
    err_lbl = "rat_err_" + uid
    merge_lbl = "rat_merge_" + uid
    emit(cg, "  br i1 " + is_ok + ", label %" + ok_lbl + ", label %" + err_lbl)
    // Ok path: load value, call closure (returns Result directly)
    emit(cg, ok_lbl + ":")
    vp = cg_fresh_reg(cg)
    emit(cg, "  " + vp + " = getelementptr i64, ptr " + rp + ", i64 1")
    val = cg_fresh_reg(cg)
    emit(cg, "  " + val + " = load i64, ptr " + vp)
    emit_closure_aware_call1(cg, dest, fn_val, val)
    ok_r = cg_get_val(cg, dest)
    ok_from = cg_current_block(cg)
    emit(cg, "  br label %" + merge_lbl)
    // Err path: propagate original (already scope-tracked)
    emit(cg, err_lbl + ":")
    emit(cg, "  br label %" + merge_lbl)
    // Merge
    emit(cg, merge_lbl + ":")
    phi_r = cg_fresh_reg(cg)
    emit(cg, "  " + phi_r + " = phi i64 [" + ok_r + ", %" + ok_from + "], [" + res_val + ", %" + err_lbl + "]")
    cg_set_val(cg, dest, phi_r)
    cg_set_current_block(cg, merge_lbl)
    return 0
  }
  if op == IR_RESULT_MAP_ERR {
    // map_err(fn): if err, call fn(error_msg) and create new err; if ok, propagate
    res_val = cg_get_val(cg, ir_field(inst, 16))
    fn_val = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    rp = cg_fresh_reg(cg)
    emit(cg, "  " + rp + " = inttoptr i64 " + res_val + " to ptr")
    tag = cg_fresh_reg(cg)
    emit(cg, "  " + tag + " = load i64, ptr " + rp)
    is_err = cg_fresh_reg(cg)
    emit(cg, "  " + is_err + " = icmp eq i64 " + tag + ", 1")
    err_lbl = "rme_err_" + uid
    ok_lbl = "rme_ok_" + uid
    merge_lbl = "rme_merge_" + uid
    emit(cg, "  br i1 " + is_err + ", label %" + err_lbl + ", label %" + ok_lbl)
    // Err path: load error_msg at offset 16, call closure, create new err result
    emit(cg, err_lbl + ":")
    ep = cg_fresh_reg(cg)
    emit(cg, "  " + ep + " = getelementptr i64, ptr " + rp + ", i64 2")
    emsg = cg_fresh_reg(cg)
    emit(cg, "  " + emsg + " = load i64, ptr " + ep)
    emit_closure_aware_call1(cg, dest, fn_val, emsg)
    new_msg = cg_get_val(cg, dest)
    err_from = cg_current_block(cg)
    // Load error_code at offset 24 — need to re-derive rp since we're in a new block after closure call
    cp = cg_fresh_reg(cg)
    emit(cg, "  " + cp + " = inttoptr i64 " + res_val + " to ptr")
    cp2 = cg_fresh_reg(cg)
    emit(cg, "  " + cp2 + " = getelementptr i64, ptr " + cp + ", i64 3")
    ecode = cg_fresh_reg(cg)
    emit(cg, "  " + ecode + " = load i64, ptr " + cp2)
    err_r = cg_fresh_reg(cg)
    emit(cg, "  " + err_r + " = call i64 @sans_result_err(i64 " + ecode + ", i64 " + new_msg + ")")
    emit_scope_track(cg, err_r, 4)
    emit(cg, "  br label %" + merge_lbl)
    // Ok path: propagate original (already scope-tracked)
    emit(cg, ok_lbl + ":")
    emit(cg, "  br label %" + merge_lbl)
    // Merge
    emit(cg, merge_lbl + ":")
    phi_r = cg_fresh_reg(cg)
    emit(cg, "  " + phi_r + " = phi i64 [" + err_r + ", %" + err_from + "], [" + res_val + ", %" + ok_lbl + "]")
    cg_set_val(cg, dest, phi_r)
    cg_set_current_block(cg, merge_lbl)
    return 0
  }
  if op == IR_RESULT_OR_ELSE {
    // or_else(fn): if err, call fn(error_msg) which returns Result; if ok, propagate
    res_val = cg_get_val(cg, ir_field(inst, 16))
    fn_val = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    rp = cg_fresh_reg(cg)
    emit(cg, "  " + rp + " = inttoptr i64 " + res_val + " to ptr")
    tag = cg_fresh_reg(cg)
    emit(cg, "  " + tag + " = load i64, ptr " + rp)
    is_err = cg_fresh_reg(cg)
    emit(cg, "  " + is_err + " = icmp eq i64 " + tag + ", 1")
    err_lbl = "roe_err_" + uid
    ok_lbl = "roe_ok_" + uid
    merge_lbl = "roe_merge_" + uid
    emit(cg, "  br i1 " + is_err + ", label %" + err_lbl + ", label %" + ok_lbl)
    // Err path: load error_msg at offset 16, call closure (returns Result directly)
    emit(cg, err_lbl + ":")
    ep = cg_fresh_reg(cg)
    emit(cg, "  " + ep + " = getelementptr i64, ptr " + rp + ", i64 2")
    emsg = cg_fresh_reg(cg)
    emit(cg, "  " + emsg + " = load i64, ptr " + ep)
    emit_closure_aware_call1(cg, dest, fn_val, emsg)
    err_r = cg_get_val(cg, dest)
    err_from = cg_current_block(cg)
    emit(cg, "  br label %" + merge_lbl)
    // Ok path: propagate original (already scope-tracked)
    emit(cg, ok_lbl + ":")
    emit(cg, "  br label %" + merge_lbl)
    // Merge
    emit(cg, merge_lbl + ":")
    phi_r = cg_fresh_reg(cg)
    emit(cg, "  " + phi_r + " = phi i64 [" + err_r + ", %" + err_from + "], [" + res_val + ", %" + ok_lbl + "]")
    cg_set_val(cg, dest, phi_r)
    cg_set_current_block(cg, merge_lbl)
    return 0
  }

  // ------ Option (258-263) --- runtime calls ------
  if op == IR_OPTION_SOME {
    compile_rt1(cg, inst, "sans_option_some")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 6)
    return 0
  }
  if op == IR_OPTION_NONE {
    compile_rt0(cg, inst, "sans_option_none")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 6)
    return 0
  }
  if op == IR_OPTION_IS_SOME { return compile_rt1(cg, inst, "sans_option_is_some") }
  if op == IR_OPTION_IS_NONE { return compile_rt1(cg, inst, "sans_option_is_none") }
  if op == IR_OPTION_UNWRAP { return compile_rt1(cg, inst, "sans_option_unwrap") }
  if op == IR_OPTION_UNWRAP_OR { return compile_rt2(cg, inst, "sans_option_unwrap_or") }

  // ------ Logging (119-125) --- runtime calls ------
  if op == IR_LOG_DEBUG { return compile_rt1(cg, inst, "sans_log_debug") }
  if op == IR_LOG_INFO { return compile_rt1(cg, inst, "sans_log_info") }
  if op == IR_LOG_WARN { return compile_rt1(cg, inst, "sans_log_warn") }
  if op == IR_LOG_ERROR { return compile_rt1(cg, inst, "sans_log_error") }
  if op == IR_LOG_SET_LEVEL { return compile_rt1(cg, inst, "sans_log_set_level") }
  if op == IR_GET_LOG_LEVEL { return compile_rt0(cg, inst, "sans_get_log_level") }
  if op == IR_SET_LOG_LEVEL { return compile_rt1(cg, inst, "sans_set_log_level") }

  // ------ Low-Level Memory (126-135) ------
  if op == IR_LOAD8 {
    pv = cg_get_val(cg, ir_field(inst, 16))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + pv + " to ptr")
    bv = cg_fresh_reg(cg)
    emit(cg, "  " + bv + " = load i8, ptr " + p)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = zext i8 " + bv + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_STORE8 {
    pv = cg_get_val(cg, ir_field(inst, 16))
    vv = cg_get_val(cg, ir_field(inst, 24))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + pv + " to ptr")
    bv = cg_fresh_reg(cg)
    emit(cg, "  " + bv + " = trunc i64 " + vv + " to i8")
    emit(cg, "  store i8 " + bv + ", ptr " + p)
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_LOAD16 {
    pv = cg_get_val(cg, ir_field(inst, 16))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + pv + " to ptr")
    sv = cg_fresh_reg(cg)
    emit(cg, "  " + sv + " = load i16, ptr " + p)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = zext i16 " + sv + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_STORE16 {
    pv = cg_get_val(cg, ir_field(inst, 16))
    vv = cg_get_val(cg, ir_field(inst, 24))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + pv + " to ptr")
    sv = cg_fresh_reg(cg)
    emit(cg, "  " + sv + " = trunc i64 " + vv + " to i16")
    emit(cg, "  store i16 " + sv + ", ptr " + p)
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_LOAD32 {
    pv = cg_get_val(cg, ir_field(inst, 16))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + pv + " to ptr")
    wv = cg_fresh_reg(cg)
    emit(cg, "  " + wv + " = load i32, ptr " + p)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = zext i32 " + wv + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_STORE32 {
    pv = cg_get_val(cg, ir_field(inst, 16))
    vv = cg_get_val(cg, ir_field(inst, 24))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + pv + " to ptr")
    wv = cg_fresh_reg(cg)
    emit(cg, "  " + wv + " = trunc i64 " + vv + " to i32")
    emit(cg, "  store i32 " + wv + ", ptr " + p)
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_LOAD64 {
    pv = cg_get_val(cg, ir_field(inst, 16))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + pv + " to ptr")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = load i64, ptr " + p)
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_STORE64 {
    pv = cg_get_val(cg, ir_field(inst, 16))
    vv = cg_get_val(cg, ir_field(inst, 24))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + pv + " to ptr")
    emit(cg, "  store i64 " + vv + ", ptr " + p)
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_BSWAP16 {
    val = cg_get_val(cg, ir_field(inst, 16))
    sv = cg_fresh_reg(cg)
    emit(cg, "  " + sv + " = trunc i64 " + val + " to i16")
    bv = cg_fresh_reg(cg)
    emit(cg, "  " + bv + " = call i16 @llvm.bswap.i16(i16 " + sv + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = zext i16 " + bv + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SLEN {
    pv = cg_get_val(cg, ir_field(inst, 16))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + pv + " to ptr")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @strlen(ptr " + p + ")")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ Sockets (136-145) ------
  if op == IR_SOCK {
    // socket(domain, type, proto) --- all i64 in our ABI
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    a3 = cg_get_val(cg, ir_field(inst, 32))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @socket(i64 " + a1 + ", i64 " + a2 + ", i64 " + a3 + ")")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SBIND {
    // sans_bind_port(fd, port)
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_bind_port(i64 " + a1 + ", i64 " + a2 + ")")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SLISTEN {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    a2 = cg_get_val(cg, ir_field(inst, 24))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @listen(i64 " + a1 + ", i64 " + a2 + ")")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SACCEPT {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @accept(i64 " + a1 + ", ptr null, ptr null)")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SRECV {
    // recv(fd, buf, len, 0)
    fd = cg_get_val(cg, ir_field(inst, 16))
    buf = cg_get_val(cg, ir_field(inst, 24))
    ln = cg_get_val(cg, ir_field(inst, 32))
    bp = cg_fresh_reg(cg)
    emit(cg, "  " + bp + " = inttoptr i64 " + buf + " to ptr")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @recv(i64 " + fd + ", ptr " + bp + ", i64 " + ln + ", i64 0)")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SSEND {
    // send(fd, buf, len, 0)
    fd = cg_get_val(cg, ir_field(inst, 16))
    buf = cg_get_val(cg, ir_field(inst, 24))
    ln = cg_get_val(cg, ir_field(inst, 32))
    bp = cg_fresh_reg(cg)
    emit(cg, "  " + bp + " = inttoptr i64 " + buf + " to ptr")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @send(i64 " + fd + ", ptr " + bp + ", i64 " + ln + ", i64 0)")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SCLOSE {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @close(i64 " + a1 + ")")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_RBIND {
    // bind(fd, addr_ptr, len)
    fd = cg_get_val(cg, ir_field(inst, 16))
    addr = cg_get_val(cg, ir_field(inst, 24))
    ln = cg_get_val(cg, ir_field(inst, 32))
    ap = cg_fresh_reg(cg)
    emit(cg, "  " + ap + " = inttoptr i64 " + addr + " to ptr")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @bind(i64 " + fd + ", ptr " + ap + ", i64 " + ln + ")")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_RSETSOCKOPT {
    // setsockopt(fd, level, opt, val_ptr, val_len)
    fd = cg_get_val(cg, ir_field(inst, 16))
    lvl = cg_get_val(cg, ir_field(inst, 24))
    opt = cg_get_val(cg, ir_field(inst, 32))
    vp = cg_get_val(cg, ir_field(inst, 40))
    vl = cg_get_val(cg, ir_field(inst, 48))
    pp = cg_fresh_reg(cg)
    emit(cg, "  " + pp + " = inttoptr i64 " + vp + " to ptr")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @setsockopt(i64 " + fd + ", i64 " + lvl + ", i64 " + opt + ", ptr " + pp + ", i64 " + vl + ")")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_STRSTR {
    // strstr(haystack, needle) --- both are string ptrs
    hv = cg_get_val(cg, ir_field(inst, 16))
    nv = cg_get_val(cg, ir_field(inst, 24))
    hp = cg_fresh_reg(cg)
    emit(cg, "  " + hp + " = inttoptr i64 " + hv + " to ptr")
    np = cg_fresh_reg(cg)
    emit(cg, "  " + np + " = inttoptr i64 " + nv + " to ptr")
    rp = cg_fresh_reg(cg)
    emit(cg, "  " + rp + " = call ptr @strstr(ptr " + hp + ", ptr " + np + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + rp + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ Curl (146-153) ------
  if op == IR_CINIT {
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @curl_easy_init()")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_CSETS {
    // curl_easy_setopt(handle, opt, val) --- all i64
    h = cg_get_val(cg, ir_field(inst, 16))
    o = cg_get_val(cg, ir_field(inst, 24))
    v = cg_get_val(cg, ir_field(inst, 32))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 (i64, i64, ...) @curl_easy_setopt(i64 " + h + ", i64 " + o + ", i64 " + v + ")")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_CSETI {
    h = cg_get_val(cg, ir_field(inst, 16))
    o = cg_get_val(cg, ir_field(inst, 24))
    v = cg_get_val(cg, ir_field(inst, 32))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 (i64, i64, ...) @curl_easy_setopt(i64 " + h + ", i64 " + o + ", i64 " + v + ")")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_CPERF {
    h = cg_get_val(cg, ir_field(inst, 16))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @curl_easy_perform(i64 " + h + ")")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_CCLEAN {
    h = cg_get_val(cg, ir_field(inst, 16))
    emit(cg, "  call void @curl_easy_cleanup(i64 " + h + ")")
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_CINFO {
    // curl_easy_getinfo(handle, info, buf) --- variadic
    h = cg_get_val(cg, ir_field(inst, 16))
    info = cg_get_val(cg, ir_field(inst, 24))
    buf = cg_get_val(cg, ir_field(inst, 32))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 (i64, i64, ...) @curl_easy_getinfo(i64 " + h + ", i64 " + info + ", i64 " + buf + ")")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_CURL_SLIST_APPEND {
    sl = cg_get_val(cg, ir_field(inst, 16))
    sv = cg_get_val(cg, ir_field(inst, 24))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @curl_slist_append(i64 " + sl + ", i64 " + sv + ")")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_CURL_SLIST_FREE {
    sl = cg_get_val(cg, ir_field(inst, 16))
    emit(cg, "  call void @curl_slist_free_all(i64 " + sl + ")")
    cg_set_val(cg, dest, "0")
    return 0
  }

  // ------ Map (154-160) --- runtime calls ------
  if op == IR_MAP_CREATE {
    compile_rt0(cg, inst, "sans_map_create")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 2)
    return 0
  }
  if op == IR_MAP_CREATE_INT {
    compile_rt0(cg, inst, "sans_map_create")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 2)
    return 0
  }
  if op == IR_MAP_GET { return compile_rt2(cg, inst, "sans_map_get") }
  if op == IR_MAP_GET_OPT { return compile_map_get_opt(cg, inst) }
  if op == IR_MAP_GET_OPT_INT { return compile_map_get_opt_int(cg, inst) }
  if op == IR_MAP_SET { return compile_rt3(cg, inst, "sans_map_set") }
  if op == IR_MAP_SET_INT { return compile_rt3(cg, inst, "sans_map_set_int") }
  if op == IR_MAP_HAS { return compile_rt2(cg, inst, "sans_map_has") }
  if op == IR_MAP_HAS_INT { return compile_rt2(cg, inst, "sans_map_has_int") }
  if op == IR_MAP_LEN { return compile_rt1(cg, inst, "sans_map_len") }
  if op == IR_MAP_GET_INT { return compile_rt2(cg, inst, "sans_map_get_int") }
  if op == IR_MAP_KEYS {
    compile_rt1(cg, inst, "sans_map_keys")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 1)
    return 0
  }
  if op == IR_MAP_KEYS_INT {
    compile_rt1(cg, inst, "sans_map_keys_int")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 1)
    return 0
  }
  if op == IR_MAP_VALS {
    compile_rt1(cg, inst, "sans_map_vals")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 1)
    return 0
  }

  // ------ Range & Sort ------
  if op == IR_RANGE {
    // Check if 2-arg: ir_field at offset 24 is nonzero for 2-arg calls
    a2_name = ir_field(inst, 24)
    if a2_name != 0 {
      compile_rt2(cg, inst, "sans_range2")
    } else {
      compile_rt1(cg, inst, "sans_range1")
    }
    cg_set_ptr(cg, dest)
    emit_scope_track(cg, cg_get_val(cg, dest), 1)
    return 0
  }
  if op == IR_ARRAY_SORT {
    compile_rt1(cg, inst, "sans_array_sort")
    return 0
  }

  // ------ String upper/lower/index_of (218-220) ------
  if op == IR_STRING_UPPER {
    compile_rt1(cg, inst, "sans_string_upper")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 5)
    return 0
  }
  if op == IR_STRING_LOWER {
    compile_rt1(cg, inst, "sans_string_lower")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 5)
    return 0
  }
  if op == IR_STRING_INDEX_OF {
    compile_rt2(cg, inst, "sans_string_index_of")
    return 0
  }

  // ------ Array join/reverse (221-222) ------
  if op == IR_ARRAY_JOIN {
    compile_rt2(cg, inst, "sans_array_join")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 5)
    return 0
  }
  if op == IR_ARRAY_REVERSE {
    compile_rt1(cg, inst, "sans_array_reverse")
    return 0
  }

  // ------ Math: abs/min/max (223-225) ------
  if op == IR_ABS {
    compile_rt1(cg, inst, "sans_abs")
    return 0
  }
  if op == IR_MIN {
    compile_rt2(cg, inst, "sans_min")
    return 0
  }
  if op == IR_MAX {
    compile_rt2(cg, inst, "sans_max")
    return 0
  }

  // ------ System: sleep, time, random (231-233) ------
  if op == IR_SLEEP {
    // Inline: call usleep(ms * 1000)
    ms = cg_get_val(cg, ir_field(inst, 16))
    us = cg_fresh_reg(cg)
    emit(cg, "  " + us + " = mul i64 " + ms + ", 1000")
    t = cg_fresh_reg(cg)
    emit(cg, "  " + t + " = trunc i64 " + us + " to i32")
    cg_fresh_reg(cg)
    emit(cg, "  call i32 @usleep(i32 " + t + ")")
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_TIME {
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @time(i64 0)")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_RANDOM {
    compile_rt1(cg, inst, "sans_random")
    return 0
  }

  // ------ Array: reduce, each, flat_map (234-236) ------
  if op == IR_ARRAY_REDUCE {
    compile_rt3(cg, inst, "sans_array_reduce")
    return 0
  }
  if op == IR_ARRAY_EACH {
    compile_rt2(cg, inst, "sans_array_each")
    return 0
  }
  if op == IR_ARRAY_FLAT_MAP {
    compile_rt2(cg, inst, "sans_array_flat_map")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 1)
    return 0
  }

  // ------ Array sum/min/max/flat (237-240) ------
  if op == IR_ARRAY_SUM { compile_rt1(cg, inst, "sans_array_sum"); return 0 }
  if op == IR_ARRAY_MIN { compile_rt1(cg, inst, "sans_array_min"); return 0 }
  if op == IR_ARRAY_MAX { compile_rt1(cg, inst, "sans_array_max"); return 0 }
  if op == IR_ARRAY_FLAT {
    compile_rt1(cg, inst, "sans_array_flat")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 1)
    return 0
  }
  // ------ String pad/bytes (241-243) ------
  if op == IR_STRING_PAD_LEFT {
    compile_rt3(cg, inst, "sans_string_pad_left")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 5)
    return 0
  }
  if op == IR_STRING_PAD_RIGHT {
    compile_rt3(cg, inst, "sans_string_pad_right")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 5)
    return 0
  }
  if op == IR_STRING_BYTES {
    compile_rt1(cg, inst, "sans_string_bytes")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 1)
    return 0
  }
  // ------ Map entries (244) ------
  if op == IR_MAP_ENTRIES {
    compile_rt1(cg, inst, "sans_map_entries")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 1)
    return 0
  }

  // ------ String repeat (230) ------
  if op == IR_STRING_REPEAT {
    compile_rt2(cg, inst, "sans_string_repeat")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 5)
    return 0
  }

  // ------ Array slice, String char_at, Map delete, stof (226-229) ------
  if op == IR_ARRAY_SLICE {
    compile_rt3(cg, inst, "sans_array_slice")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 1)
    return 0
  }
  if op == IR_MAP_DELETE {
    compile_rt2(cg, inst, "sans_map_delete")
    return 0
  }
  if op == IR_MAP_DELETE_INT {
    compile_rt2(cg, inst, "sans_map_delete_int")
    return 0
  }
  if op == IR_STRING_CHAR_AT {
    compile_rt2(cg, inst, "sans_string_char_at")
    emit_scope_track(cg, cg_get_val(cg, ir_dest(inst)), 5)
    return 0
  }
  if op == IR_STRING_TO_FLOAT {
    // Inline: strtod(str, NULL) -> double, bitcast to i64
    val = cg_get_val(cg, ir_field(inst, 16))
    p = cg_fresh_reg(cg)
    emit(cg, "  " + p + " = inttoptr i64 " + val + " to ptr")
    dv = cg_fresh_reg(cg)
    emit(cg, "  " + dv + " = call double @strtod(ptr " + p + ", ptr null)")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = bitcast double " + dv + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ Arena (161-163) --- runtime calls ------
  if op == IR_ARENA_BEGIN { return compile_rt0(cg, inst, "sans_arena_begin") }
  if op == IR_ARENA_ALLOC { return compile_rt1(cg, inst, "sans_arena_alloc") }
  if op == IR_ARENA_END { return compile_rt0(cg, inst, "sans_arena_end") }

  // ------ Misc (164-172) ------
  if op == IR_ARGS {
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @__sans_args()")
    cg_set_val(cg, dest, r)
    emit_scope_track(cg, r, 1)
    return 0
  }
  if op == IR_EXIT {
    val = cg_get_val(cg, ir_field(inst, 16))
    emit(cg, "  call void @exit(i64 " + val + ")")
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_ASSERT {
    cond_val = cg_get_val(cg, ir_field(inst, 16))
    line_val = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    fail_lbl = "assert_fail_" + uid
    ok_lbl = "assert_ok_" + uid
    cmp = cg_fresh_reg(cg)
    emit(cg, "  " + cmp + " = icmp eq i64 " + cond_val + ", 0")
    emit(cg, "  br i1 " + cmp + ", label %" + fail_lbl + ", label %" + ok_lbl)
    emit(cg, fail_lbl + ":")
    fmt = cg_fmt_assert(cg)
    pr = cg_fresh_reg(cg)
    emit(cg, "  " + pr + " = call i64 (ptr, ...) @printf(ptr " + fmt + ", i64 " + line_val + ")")
    emit(cg, "  call void @exit(i64 1)")
    emit(cg, "  unreachable")
    emit(cg, ok_lbl + ":")
    cg_set_current_block(cg, ok_lbl)
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_ASSERT_EQ {
    a_val = cg_get_val(cg, ir_field(inst, 16))
    b_val = cg_get_val(cg, ir_field(inst, 24))
    line_val = cg_get_val(cg, ir_field(inst, 32))
    uid = cg_label_id(cg)
    fail_lbl = "aeq_fail_" + uid
    ok_lbl = "aeq_ok_" + uid
    cmp = cg_fresh_reg(cg)
    emit(cg, "  " + cmp + " = icmp ne i64 " + a_val + ", " + b_val)
    emit(cg, "  br i1 " + cmp + ", label %" + fail_lbl + ", label %" + ok_lbl)
    emit(cg, fail_lbl + ":")
    fmt = cg_fmt_assert_eq(cg)
    pr = cg_fresh_reg(cg)
    emit(cg, "  " + pr + " = call i64 (ptr, ...) @printf(ptr " + fmt + ", i64 " + a_val + ", i64 " + b_val + ", i64 " + line_val + ")")
    emit(cg, "  call void @exit(i64 1)")
    emit(cg, "  unreachable")
    emit(cg, ok_lbl + ":")
    cg_set_current_block(cg, ok_lbl)
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_ASSERT_NE {
    a_val = cg_get_val(cg, ir_field(inst, 16))
    b_val = cg_get_val(cg, ir_field(inst, 24))
    line_val = cg_get_val(cg, ir_field(inst, 32))
    uid = cg_label_id(cg)
    fail_lbl = "ane_fail_" + uid
    ok_lbl = "ane_ok_" + uid
    cmp = cg_fresh_reg(cg)
    emit(cg, "  " + cmp + " = icmp eq i64 " + a_val + ", " + b_val)
    emit(cg, "  br i1 " + cmp + ", label %" + fail_lbl + ", label %" + ok_lbl)
    emit(cg, fail_lbl + ":")
    fmt = cg_fmt_assert_ne(cg)
    pr = cg_fresh_reg(cg)
    emit(cg, "  " + pr + " = call i64 (ptr, ...) @printf(ptr " + fmt + ", i64 " + a_val + ", i64 " + line_val + ")")
    emit(cg, "  call void @exit(i64 1)")
    emit(cg, "  unreachable")
    emit(cg, ok_lbl + ":")
    cg_set_current_block(cg, ok_lbl)
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_ASSERT_OK {
    ptr_val = cg_get_val(cg, ir_field(inst, 16))
    line_val = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    fail_lbl = "aok_fail_" + uid
    ok_lbl = "aok_ok_" + uid
    rp = cg_fresh_reg(cg)
    emit(cg, "  " + rp + " = inttoptr i64 " + ptr_val + " to ptr")
    tag = cg_fresh_reg(cg)
    emit(cg, "  " + tag + " = load i64, ptr " + rp)
    cmp = cg_fresh_reg(cg)
    emit(cg, "  " + cmp + " = icmp ne i64 " + tag + ", 0")
    emit(cg, "  br i1 " + cmp + ", label %" + fail_lbl + ", label %" + ok_lbl)
    emit(cg, fail_lbl + ":")
    fmt = cg_fmt_assert_ok(cg)
    pr = cg_fresh_reg(cg)
    emit(cg, "  " + pr + " = call i64 (ptr, ...) @printf(ptr " + fmt + ", i64 " + line_val + ")")
    emit(cg, "  call void @exit(i64 1)")
    emit(cg, "  unreachable")
    emit(cg, ok_lbl + ":")
    cg_set_current_block(cg, ok_lbl)
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_ASSERT_ERR {
    ptr_val = cg_get_val(cg, ir_field(inst, 16))
    line_val = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    fail_lbl = "aerr_fail_" + uid
    ok_lbl = "aerr_ok_" + uid
    rp = cg_fresh_reg(cg)
    emit(cg, "  " + rp + " = inttoptr i64 " + ptr_val + " to ptr")
    tag = cg_fresh_reg(cg)
    emit(cg, "  " + tag + " = load i64, ptr " + rp)
    cmp = cg_fresh_reg(cg)
    emit(cg, "  " + cmp + " = icmp ne i64 " + tag + ", 1")
    emit(cg, "  br i1 " + cmp + ", label %" + fail_lbl + ", label %" + ok_lbl)
    emit(cg, fail_lbl + ":")
    fmt = cg_fmt_assert_err(cg)
    pr = cg_fresh_reg(cg)
    emit(cg, "  " + pr + " = call i64 (ptr, ...) @printf(ptr " + fmt + ", i64 " + line_val + ")")
    emit(cg, "  call void @exit(i64 1)")
    emit(cg, "  unreachable")
    emit(cg, ok_lbl + ":")
    cg_set_current_block(cg, ok_lbl)
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_ASSERT_SOME {
    ptr_val = cg_get_val(cg, ir_field(inst, 16))
    line_val = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    fail_lbl = "asome_fail_" + uid
    ok_lbl = "asome_ok_" + uid
    rp = cg_fresh_reg(cg)
    emit(cg, "  " + rp + " = inttoptr i64 " + ptr_val + " to ptr")
    tag = cg_fresh_reg(cg)
    emit(cg, "  " + tag + " = load i64, ptr " + rp)
    cmp = cg_fresh_reg(cg)
    emit(cg, "  " + cmp + " = icmp ne i64 " + tag + ", 1")
    emit(cg, "  br i1 " + cmp + ", label %" + fail_lbl + ", label %" + ok_lbl)
    emit(cg, fail_lbl + ":")
    fmt = cg_fmt_assert_some(cg)
    pr = cg_fresh_reg(cg)
    emit(cg, "  " + pr + " = call i64 (ptr, ...) @printf(ptr " + fmt + ", i64 " + line_val + ")")
    emit(cg, "  call void @exit(i64 1)")
    emit(cg, "  unreachable")
    emit(cg, ok_lbl + ":")
    cg_set_current_block(cg, ok_lbl)
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_ASSERT_NONE {
    ptr_val = cg_get_val(cg, ir_field(inst, 16))
    line_val = cg_get_val(cg, ir_field(inst, 24))
    uid = cg_label_id(cg)
    fail_lbl = "anone_fail_" + uid
    ok_lbl = "anone_ok_" + uid
    rp = cg_fresh_reg(cg)
    emit(cg, "  " + rp + " = inttoptr i64 " + ptr_val + " to ptr")
    tag = cg_fresh_reg(cg)
    emit(cg, "  " + tag + " = load i64, ptr " + rp)
    cmp = cg_fresh_reg(cg)
    emit(cg, "  " + cmp + " = icmp ne i64 " + tag + ", 0")
    emit(cg, "  br i1 " + cmp + ", label %" + fail_lbl + ", label %" + ok_lbl)
    emit(cg, fail_lbl + ":")
    fmt = cg_fmt_assert_none(cg)
    pr = cg_fresh_reg(cg)
    emit(cg, "  " + pr + " = call i64 (ptr, ...) @printf(ptr " + fmt + ", i64 " + line_val + ")")
    emit(cg, "  call void @exit(i64 1)")
    emit(cg, "  unreachable")
    emit(cg, ok_lbl + ":")
    cg_set_current_block(cg, ok_lbl)
    cg_set_val(cg, dest, "0")
    return 0
  }
  if op == IR_PRINT_ERR {
    return compile_rt1(cg, inst, "sans_print_err")
  }
  if op == IR_WRITE_FD {
    // write(fd, msg_ptr, strlen(msg))
    fd = cg_get_val(cg, ir_field(inst, 16))
    mv = cg_get_val(cg, ir_field(inst, 24))
    mp = cg_fresh_reg(cg)
    emit(cg, "  " + mp + " = inttoptr i64 " + mv + " to ptr")
    ln = cg_fresh_reg(cg)
    emit(cg, "  " + ln + " = call i64 @strlen(ptr " + mp + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @write(i64 " + fd + ", ptr " + mp + ", i64 " + ln + ")")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_SYSTEM {
    cv = cg_get_val(cg, ir_field(inst, 16))
    cp = cg_fresh_reg(cg)
    emit(cg, "  " + cp + " = inttoptr i64 " + cv + " to ptr")
    rv = cg_fresh_reg(cg)
    emit(cg, "  " + rv + " = call i32 @system(ptr " + cp + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = sext i32 " + rv + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_MCPY {
    // memcpy(dst, src, len)
    dv = cg_get_val(cg, ir_field(inst, 16))
    sv = cg_get_val(cg, ir_field(inst, 24))
    ln = cg_get_val(cg, ir_field(inst, 32))
    dp = cg_fresh_reg(cg)
    emit(cg, "  " + dp + " = inttoptr i64 " + dv + " to ptr")
    sp = cg_fresh_reg(cg)
    emit(cg, "  " + sp + " = inttoptr i64 " + sv + " to ptr")
    mc5 = cg_fresh_reg(cg)
    emit(cg, "  " + mc5 + " = call ptr @memcpy(ptr " + dp + ", ptr " + sp + ", i64 " + ln + ")")
    cg_set_val(cg, dest, dv)
    return 0
  }
  if op == IR_MZERO {
    // memset(ptr, 0, len)
    pv = cg_get_val(cg, ir_field(inst, 16))
    ln = cg_get_val(cg, ir_field(inst, 24))
    pp = cg_fresh_reg(cg)
    emit(cg, "  " + pp + " = inttoptr i64 " + pv + " to ptr")
    ms1 = cg_fresh_reg(cg)
    emit(cg, "  " + ms1 + " = call ptr @memset(ptr " + pp + ", i64 0, i64 " + ln + ")")
    cg_set_val(cg, dest, pv)
    return 0
  }
  if op == IR_MCMP {
    // memcmp(a, b, len)
    av = cg_get_val(cg, ir_field(inst, 16))
    bv = cg_get_val(cg, ir_field(inst, 24))
    ln = cg_get_val(cg, ir_field(inst, 32))
    ap = cg_fresh_reg(cg)
    emit(cg, "  " + ap + " = inttoptr i64 " + av + " to ptr")
    bp = cg_fresh_reg(cg)
    emit(cg, "  " + bp + " = inttoptr i64 " + bv + " to ptr")
    rv = cg_fresh_reg(cg)
    emit(cg, "  " + rv + " = call i32 @memcmp(ptr " + ap + ", ptr " + bp + ", i64 " + ln + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = sext i32 " + rv + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }
  if op == IR_CHAR_AT {
    // [op, dest, str_reg, idx_reg]: add ptr+offset, load i8, zext
    sv = cg_get_val(cg, ir_field(inst, 16))
    iv = cg_get_val(cg, ir_field(inst, 24))
    sp = cg_fresh_reg(cg)
    emit(cg, "  " + sp + " = inttoptr i64 " + sv + " to ptr")
    ep = cg_fresh_reg(cg)
    emit(cg, "  " + ep + " = getelementptr i8, ptr " + sp + ", i64 " + iv)
    bv = cg_fresh_reg(cg)
    emit(cg, "  " + bv + " = load i8, ptr " + ep)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = zext i8 " + bv + " to i64")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ------ gzip_compress (211) ------
  if op == IR_GZIP_COMPRESS {
    // gzip_compress(data_ptr, len) -> ptr to [compressed_ptr, compressed_len]
    dv = cg_get_val(cg, ir_field(inst, 16))
    lv = cg_get_val(cg, ir_field(inst, 24))

    // Allocate z_stream (112 bytes) and zero it
    zs = cg_fresh_reg(cg)
    emit(cg, "  " + zs + " = call ptr @malloc(i64 112)")
    zs2 = cg_fresh_reg(cg)
    emit(cg, "  " + zs2 + " = call ptr @memset(ptr " + zs + ", i64 0, i64 112)")

    // Version string for deflateInit2_
    vs = cg_fresh_reg(cg)
    emit(cg, "  " + vs + " = call ptr @malloc(i64 6)")
    vs1 = cg_fresh_reg(cg)
    emit(cg, "  " + vs1 + " = call ptr @memset(ptr " + vs + ", i64 0, i64 6)")
    // Store "1.3.0" manually
    vg0 = cg_fresh_reg(cg)
    emit(cg, "  " + vg0 + " = getelementptr i8, ptr " + vs + ", i64 0")
    emit(cg, "  store i8 49, ptr " + vg0)
    vg1 = cg_fresh_reg(cg)
    emit(cg, "  " + vg1 + " = getelementptr i8, ptr " + vs + ", i64 1")
    emit(cg, "  store i8 46, ptr " + vg1)
    vg2 = cg_fresh_reg(cg)
    emit(cg, "  " + vg2 + " = getelementptr i8, ptr " + vs + ", i64 2")
    emit(cg, "  store i8 51, ptr " + vg2)
    vg3 = cg_fresh_reg(cg)
    emit(cg, "  " + vg3 + " = getelementptr i8, ptr " + vs + ", i64 3")
    emit(cg, "  store i8 46, ptr " + vg3)
    vg4 = cg_fresh_reg(cg)
    emit(cg, "  " + vg4 + " = getelementptr i8, ptr " + vs + ", i64 4")
    emit(cg, "  store i8 48, ptr " + vg4)

    // deflateInit2_(stream, level=6, method=8, windowBits=31, memLevel=8, strategy=0, version, stream_size=112)
    di = cg_fresh_reg(cg)
    emit(cg, "  " + di + " = call i32 @deflateInit2_(ptr " + zs + ", i32 6, i32 8, i32 31, i32 8, i32 0, ptr " + vs + ", i32 112)")

    // Set next_in (offset 0) = inttoptr data
    dp = cg_fresh_reg(cg)
    emit(cg, "  " + dp + " = inttoptr i64 " + dv + " to ptr")
    ni_ptr = cg_fresh_reg(cg)
    emit(cg, "  " + ni_ptr + " = getelementptr i8, ptr " + zs + ", i64 0")
    emit(cg, "  store ptr " + dp + ", ptr " + ni_ptr)

    // Set avail_in (offset 8) = trunc len to i32
    lt = cg_fresh_reg(cg)
    emit(cg, "  " + lt + " = trunc i64 " + lv + " to i32")
    ai_ptr = cg_fresh_reg(cg)
    emit(cg, "  " + ai_ptr + " = getelementptr i8, ptr " + zs + ", i64 8")
    ai_bc = cg_fresh_reg(cg)
    emit(cg, "  " + ai_bc + " = bitcast ptr " + ai_ptr + " to ptr")
    emit(cg, "  store i32 " + lt + ", ptr " + ai_bc)

    // Call deflateBound to get max output size
    db = cg_fresh_reg(cg)
    emit(cg, "  " + db + " = call i64 @deflateBound(ptr " + zs + ", i64 " + lv + ")")

    // Malloc output buffer
    ob = cg_fresh_reg(cg)
    emit(cg, "  " + ob + " = call ptr @malloc(i64 " + db + ")")

    // Set next_out (offset 24)
    no_ptr = cg_fresh_reg(cg)
    emit(cg, "  " + no_ptr + " = getelementptr i8, ptr " + zs + ", i64 24")
    emit(cg, "  store ptr " + ob + ", ptr " + no_ptr)

    // Set avail_out (offset 32) = trunc bound to i32
    bt = cg_fresh_reg(cg)
    emit(cg, "  " + bt + " = trunc i64 " + db + " to i32")
    ao_ptr = cg_fresh_reg(cg)
    emit(cg, "  " + ao_ptr + " = getelementptr i8, ptr " + zs + ", i64 32")
    ao_bc = cg_fresh_reg(cg)
    emit(cg, "  " + ao_bc + " = bitcast ptr " + ao_ptr + " to ptr")
    emit(cg, "  store i32 " + bt + ", ptr " + ao_bc)

    // Call deflate(stream, Z_FINISH=4)
    df = cg_fresh_reg(cg)
    emit(cg, "  " + df + " = call i32 @deflate(ptr " + zs + ", i32 4)")

    // Read avail_out back (offset 32)
    ao2_ptr = cg_fresh_reg(cg)
    emit(cg, "  " + ao2_ptr + " = getelementptr i8, ptr " + zs + ", i64 32")
    ao2_bc = cg_fresh_reg(cg)
    emit(cg, "  " + ao2_bc + " = bitcast ptr " + ao2_ptr + " to ptr")
    ao2 = cg_fresh_reg(cg)
    emit(cg, "  " + ao2 + " = load i32, ptr " + ao2_bc)
    ao2x = cg_fresh_reg(cg)
    emit(cg, "  " + ao2x + " = zext i32 " + ao2 + " to i64")

    // compressed_len = bound - avail_out
    cl = cg_fresh_reg(cg)
    emit(cg, "  " + cl + " = sub i64 " + db + ", " + ao2x)

    // deflateEnd
    de = cg_fresh_reg(cg)
    emit(cg, "  " + de + " = call i32 @deflateEnd(ptr " + zs + ")")

    // Malloc result struct (16 bytes): [ptr_as_i64, len_as_i64]
    rs = cg_fresh_reg(cg)
    emit(cg, "  " + rs + " = call ptr @malloc(i64 16)")
    // Store output ptr as i64
    oi = cg_fresh_reg(cg)
    emit(cg, "  " + oi + " = ptrtoint ptr " + ob + " to i64")
    rp0 = cg_fresh_reg(cg)
    emit(cg, "  " + rp0 + " = getelementptr i8, ptr " + rs + ", i64 0")
    rp0_bc = cg_fresh_reg(cg)
    emit(cg, "  " + rp0_bc + " = bitcast ptr " + rp0 + " to ptr")
    emit(cg, "  store i64 " + oi + ", ptr " + rp0_bc)
    // Store compressed len
    rp1 = cg_fresh_reg(cg)
    emit(cg, "  " + rp1 + " = getelementptr i8, ptr " + rs + ", i64 8")
    rp1_bc = cg_fresh_reg(cg)
    emit(cg, "  " + rp1_bc + " = bitcast ptr " + rp1 + " to ptr")
    emit(cg, "  store i64 " + cl + ", ptr " + rp1_bc)

    // Return result struct pointer as i64
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + rs + " to i64")
    cg_set_val(cg, dest, r)
    emit_scope_track(cg, cg_get_val(cg, dest), 0)
    return 0
  }

  if op == IR_DYN_TRAIT_CREATE { return compile_dyn_trait_create(cg, inst) }
  if op == IR_DYN_TRAIT_CALL { return compile_dyn_trait_call(cg, inst) }

  // Unknown opcode --- emit comment
  emit(cg, "  ; unknown opcode " + str(op))
  0
}

// ------ Top-level code generation ---------------------------------------------------------------------------------------------------

// Emit global variable declarations
emit_globals(cg:I module:I) I {
  funcs = irm_functions(module)
  nf = funcs.len()
  // Check if module has main --- emit argc/argv globals
  has_main = cg_has_main(cg)
  if has_main {
    emit(cg, "@__sans_argc = global i64 0")
    emit(cg, "@__sans_argv = global ptr null")
  }
  // Emit user globals (with init values from IR module)
  globals = irm_globals(module)
  ginits = irm_global_inits(module)
  ng = globals.len()
  i := 0
  while i < ng {
    gname = globals.get(i)
    // Scope GC globals must be thread-local to prevent data corruption
    // when spawned threads concurrently modify the tracking linked list
    tl = if gname.sw("rc_") { "thread_local " } else { "" }
    if mhas(ginits, gname) {
      gval = mget(ginits, gname)
      emit(cg, "@" + gname + " = " + tl + "global i64 " + str(gval))
    } else {
      emit(cg, "@" + gname + " = " + tl + "global i64 0")
    }
    i = i + 1
    0
  }
  emit(cg, "")
  0
}

// First pass: declare a function (forward declaration)
emit_function_decl(cg:I func:I) I {
  fname = irf_name(func)
  llvm_name = if fname == "main" { "__sans_main" } else { fname }
  params = irf_params(func)
  np = params.len()
  param_str := ""
  i := 0
  while i < np {
    if i > 0 { param_str = param_str + ", " }
    param_str = param_str + "i64"
    i = i + 1
    0
  }
  emit(cg, "declare i64 @" + llvm_name + "(" + param_str + ")")
  0
}

// Second pass: compile a function body
emit_function_body(cg:I func:I) I {
  fname = irf_name(func)
  llvm_name = if fname == "main" { "__sans_main" } else { fname }
  params = irf_params(func)
  np = params.len()
  instrs = irf_instrs(func)
  ni = instrs.len()
  param_sizes = irf_param_sizes(func)

  // Build parameter list: "i64 %p0, i64 %p1, ..."
  param_str := ""
  i := 0
  while i < np {
    if i > 0 { param_str = param_str + ", " }
    param_str = param_str + "i64 %p" + str(i)
    i = i + 1
    0
  }

  emit(cg, "define i64 @" + llvm_name + "(" + param_str + ") {")
  emit(cg, "entry:")

  // Reset per-function state
  cg_timeval_buf = 0
  cg_set_reg_counter(cg, 0)
  // Skip dealloc - may cause heap corruption with map internals
  store64(cg + 40, M())   // reg_map
  store64(cg + 48, M())   // ptr_set
  store64(cg + 72, 0)     // label_counter
  cg_set_current_label(cg, "entry")
  cg_set_current_block(cg, "entry")
  store64(cg + 88, M())   // label_end_map
  store64(cg + 104, M())  // label_parent
  store64(cg + 128, M())  // ret_labels

  // Map parameters: store each param name --- %pN in reg_map
  i = 0
  while i < np {
    pname = params.get(i)
    pval = "%p" + str(i)
    rm = load64(cg + 40)
    mset(rm, pname, ptr(pval))
    // Handle struct params: if param_struct_sizes[i] > 0, convert i64 to ptr
    if param_sizes.get(i) > 0 {
      pp = cg_fresh_reg(cg)
      emit(cg, "  " + pp + " = inttoptr i64 " + pval + " to ptr")
      ps = load64(cg + 48)
      mset(ps, pname, 1)
    }
    i = i + 1
    0
  }

  // Pre-scan: hoist all ALLOCA instructions to the entry block
  // LLVM requires allocas to be in the entry block for correct domination
  aj := 0
  while aj < ni {
    ainst = instrs.get(aj)
    aop = ir_op(ainst)
    if aop == IR_ALLOCA {
      // Emit alloca + ptrtoint in entry block
      p = cg_fresh_reg(cg)
      emit(cg, "  " + p + " = alloca i64")
      r = cg_fresh_reg(cg)
      emit(cg, "  " + r + " = ptrtoint ptr " + p + " to i64")
      cg_set_val(cg, ir_dest(ainst), r)
      cg_set_ptr(cg, ir_dest(ainst))
    }
    if aop == IR_TIME_MS && cg_timeval_buf == 0 {
      // Pre-allocate 16-byte timeval buffer in entry block for gettimeofday
      tvp = cg_fresh_reg(cg)
      emit(cg, "  " + tvp + " = alloca [2 x i64]")
      cg_timeval_buf = tvp
    }
    aj = aj + 1
    0
  }

  // Emit scope_enter for user code (not runtime modules)
  if cg_is_runtime_flag == 0 {
    se = cg_fresh_reg(cg)
    emit(cg, "  " + se + " = call i64 @sans_scope_enter()")
  }

  // Compile instructions with dead-code elimination after terminators
  terminated := 0
  j := 0
  while j < ni {
    inst = instrs.get(j)
    op = ir_op(inst)
    if terminated {
      // Skip dead code until next label
      if op == IR_LABEL {
        terminated = 0
        compile_inst(cg, inst)
      }
    } else {
      compile_inst(cg, inst)
      // Mark terminated after ret or branch/jump
      if op == IR_RET { terminated = 1 }
      if op == IR_BRANCH { terminated = 1 }
      if op == IR_JUMP { terminated = 1 }
    }
    j = j + 1
    0
  }

  // If function body doesn't end with a terminator, add implicit ret
  if terminated == 0 {
    if cg_is_runtime_flag == 0 {
      sxi = cg_fresh_reg(cg)
      emit(cg, "  " + sxi + " = call i64 @sans_scope_exit(i64 0)")
    }
    emit(cg, "  ret i64 0")
  }

  emit(cg, "}")
  emit(cg, "")
  0
}

// Emit C-compatible main wrapper
emit_main_wrapper(cg:I) I {
  emit(cg, "define i32 @main(i32 %argc, ptr %argv) {")
  emit(cg, "entry:")
  emit(cg, "  %argc_ext = sext i32 %argc to i64")
  emit(cg, "  store i64 %argc_ext, ptr @__sans_argc")
  emit(cg, "  %argv_i64 = ptrtoint ptr %argv to i64")
  emit(cg, "  store i64 %argv_i64, ptr @__sans_argv")
  emit(cg, "  %result = call i64 @__sans_main()")
  emit(cg, "  %ret = trunc i64 %result to i32")
  emit(cg, "  ret i32 %ret")
  emit(cg, "}")
  emit(cg, "")
  0
}

// Emit __sans_args() --- builds a Sans array from argc/argv
emit_sans_args(cg:I) I {
  emit(cg, "define i64 @__sans_args() {")
  emit(cg, "entry:")
  // Load argc and argv from globals
  emit(cg, "  %argc = load i64, ptr @__sans_argc")
  emit(cg, "  %argv_i = load i64, ptr @__sans_argv")
  emit(cg, "  %argv = inttoptr i64 %argv_i to ptr")
  // Allocate array struct (24 bytes): [data_ptr, len, capacity]
  emit(cg, "  %arr_struct = call ptr @malloc(i64 24)")
  // Allocate data buffer: argc * 8 bytes (min 8)
  emit(cg, "  %buf_sz = mul i64 %argc, 8")
  emit(cg, "  %need_min = icmp ult i64 %buf_sz, 8")
  emit(cg, "  %actual_sz = select i1 %need_min, i64 8, i64 %buf_sz")
  emit(cg, "  %arr_buf = call ptr @malloc(i64 %actual_sz)")
  // Store data ptr at offset 0
  emit(cg, "  %buf_int = ptrtoint ptr %arr_buf to i64")
  emit(cg, "  store i64 %buf_int, ptr %arr_struct")
  // Store len = argc at offset 1
  emit(cg, "  %len_ptr = getelementptr i64, ptr %arr_struct, i64 1")
  emit(cg, "  store i64 %argc, ptr %len_ptr")
  // Store capacity = argc at offset 2
  emit(cg, "  %cap_ptr = getelementptr i64, ptr %arr_struct, i64 2")
  emit(cg, "  store i64 %argc, ptr %cap_ptr")
  // Loop setup: i = 0
  emit(cg, "  %i_alloca = alloca i64")
  emit(cg, "  store i64 0, ptr %i_alloca")
  emit(cg, "  br label %loop")
  // Loop header: if i < 0argc goto body else done
  emit(cg, "loop:")
  emit(cg, "  %i = load i64, ptr %i_alloca")
  emit(cg, "  %cmp = icmp ult i64 %i, %argc")
  emit(cg, "  br i1 %cmp, label %body, label %done")
  // Loop body: load argv[i], strlen, malloc+memcpy, store in buf[i]
  emit(cg, "body:")
  emit(cg, "  %i2 = load i64, ptr %i_alloca")
  emit(cg, "  %argv_i_ptr = getelementptr ptr, ptr %argv, i64 %i2")
  emit(cg, "  %arg_str = load ptr, ptr %argv_i_ptr")
  emit(cg, "  %slen = call i64 @strlen(ptr %arg_str)")
  emit(cg, "  %sp1 = add i64 %slen, 1")
  emit(cg, "  %copy = call ptr @malloc(i64 %sp1)")
  emit(cg, "  call ptr @memcpy(ptr %copy, ptr %arg_str, i64 %sp1)")
  emit(cg, "  %copy_int = ptrtoint ptr %copy to i64")
  emit(cg, "  %slot = getelementptr i64, ptr %arr_buf, i64 %i2")
  emit(cg, "  store i64 %copy_int, ptr %slot")
  // i++
  emit(cg, "  %i_next = add i64 %i2, 1")
  emit(cg, "  store i64 %i_next, ptr %i_alloca")
  emit(cg, "  br label %loop")
  // Done: return struct_ptr as i64
  emit(cg, "done:")
  emit(cg, "  %args_result = ptrtoint ptr %arr_struct to i64")
  emit(cg, "  ret i64 %args_result")
  emit(cg, "}")
  emit(cg, "")
  0
}

// ------ Dead Code Elimination: build live function set -----------------------------------------------------------------------------------------
// Returns a Map of live function names (name -> 1).
// Seeds from "main", then transitively marks all called functions.
// Also seeds vtable method functions so dyn trait dispatch works.
// For runtime modules, returns 0 (meaning: all functions are live).

dce_build_live_set(module:I) I {
  funcs = irm_functions(module)
  nf = funcs.len()

  // Build call graph: fn_name -> list of callees
  calls_map = M()
  fi := 0
  while fi < nf {
    cur_fn = funcs.get(fi)
    fname = irf_name(cur_fn)
    callees = array<I>()
    mset(calls_map, fname, callees)
    instrs = irf_instrs(cur_fn)
    ni = instrs.len()
    ii := 0
    while ii < ni {
      inst = instrs.get(ii)
      op = ir_op(inst)
      if op == IR_CALL {
        callee_name = ir_field(inst, 16)
        callees.push(callee_name)
      }
      if op == IR_FPTR_NAMED {
        // Function pointer reference: add as callee so it's marked live
        fptr_name = ir_field(inst, 16)
        callees.push(fptr_name)
      }
      if op == IR_FN_REF {
        // Lambda/function reference: add as callee
        fnref_name = ir_field(inst, 16)
        callees.push(fnref_name)
      }
      ii = ii + 1
      0
    }
    fi = fi + 1
    0
  }

  // Seed live set: start with "main"
  live = M()
  worklist = array<I>()
  mset(live, "main", 1)
  worklist.push("main")

  // Also seed vtable methods (needed for dyn trait dispatch)
  ti = irm_trait_impls(module)
  if ti != 0 {
    ti_keys = ti.keys()
    tki := 0
    while tki < ti_keys.len() {
      tk = ti_keys.get(tki)
      vtable_methods = mget(ti, tk)
      vt_p = load64(vtable_methods)
      num_m = load64(vtable_methods + 8)
      vmi := 0
      while vmi < num_m {
        vt_fn = load64(vt_p + vmi * 8)
        if mhas(live, vt_fn) == 0 {
          mset(live, vt_fn, 1)
          worklist.push(vt_fn)
        }
        vmi = vmi + 1
        0
      }
      tki = tki + 1
      0
    }
  }

  // Worklist: transitively mark callees
  wi := 0
  while wi < worklist.len() {
    fn_name = worklist.get(wi)
    // Also resolve aliases: if fn_name has an alias, mark the target as live too
    alias_target = resolve_fn_alias(fn_name)
    if mhas(live, alias_target) == 0 {
      mset(live, alias_target, 1)
      worklist.push(alias_target)
    }
    if mhas(calls_map, fn_name) {
      callees = mget(calls_map, fn_name)
      ci := 0
      while ci < callees.len() {
        callee = callees.get(ci)
        if mhas(live, callee) == 0 {
          mset(live, callee, 1)
          worklist.push(callee)
        }
        ci = ci + 1
        0
      }
    }
    wi = wi + 1
    0
  }

  live
}

// ------ Top-level entry point ---------------------------------------------------------------------------------------------------------------

compile_to_ll(module:I output_path:S) I {
  cg = compile_to_ll_impl(module, output_path, 0)
  cg
}

compile_to_ll_runtime(module:I output_path:S) I {
  cg = compile_to_ll_impl(module, output_path, 1)
  cg
}

// Emit vtable globals for dyn Trait dispatch
emit_vtables(cg:I module:I) I {
  ti = irm_trait_impls(module)
  if ti == 0 { return 0 }
  ti_keys = ti.keys()
  ki := 0
  while ki < ti_keys.len() {
    tk = ti_keys.get(ki)
    tk_s = cg_str(tk)
    vtable_methods = mget(ti, tk)
    vt_p = load64(vtable_methods)
    num_m = load64(vtable_methods + 8)
    if num_m > 0 {
      // Build vtable name: @vtable.TypeName.TraitName (replace :: with .)
      cc_pos := -1
      tki := 0
      tk_len = slen(tk_s)
      while tki < tk_len - 1 {
        if char_at(tk_s, tki) == 58 && char_at(tk_s, tki + 1) == 58 {
          cc_pos = tki
          tki = tk_len
        }
        tki += 1
      }
      vt_name := ""
      if cc_pos >= 0 {
        vt_name = tk_s.substring(0, cc_pos) + "." + tk_s.substring(cc_pos + 2, tk_len)
      } else {
        vt_name = tk_s
      }
      // Build constant array
      entries_str := ""
      ei := 0
      while ei < num_m {
        if ei > 0 { entries_str = entries_str + ", " }
        fn_name = cg_str(load64(vt_p + ei * 8))
        entries_str = entries_str + "ptr @" + fn_name
        ei += 1
      }
      emit(cg, "@vtable." + vt_name + " = private constant [" + str(num_m) + " x ptr] [" + entries_str + "]")
    }
    ki += 1
  }
  0
}

compile_to_ll_impl(module:I output_path:S is_runtime:I) I {
  cg = make_codegen()

  // Enable streaming mode: write to file as we go
  fw(output_path, "")  // create/truncate file
  store64(cg + 112, output_path)  // set output_path for streaming emit

  // Check if module has a "main" function
  funcs = irm_functions(module)
  nf = funcs.len()
  i := 0
  while i < nf {
    f = funcs.get(i)
    fname = irf_name(f)
    if fname == "main" {
      cg_set_has_main(cg, 1)
    }
    i = i + 1
    0
  }

  // 1. Emit LLVM IR header
  emit_header(cg)

  // 2. Emit external function declarations (skip sans_* for runtime modules)
  if is_runtime == 1 { emit_externals_core(cg) } else { emit_externals(cg) }

  // 3. Emit global variable declarations
  emit_globals(cg, module)

  // 3b. Emit vtable globals for dyn Trait
  emit_vtables(cg, module)

  // 4. Skip function declarations --- LLVM IR doesn't require forward decls
  emit(cg, "")

  // 5. If has_main: emit main wrapper and __sans_args
  if cg_has_main(cg) {
    emit_main_wrapper(cg)
    emit_sans_args(cg)
  }

  // Set global is_runtime flag so emit_function_body can skip scope instrumentation
  cg_is_runtime_flag = is_runtime
  cg_fn_ret_types = irm_fn_ret_types(module)
  cg_trait_impls = irm_trait_impls(module)
  cg_trait_registry = irm_trait_registry(module)

  // DCE: build live function set (skip for runtime modules — all fns are live there)
  live_fns := 0
  if is_runtime == 0 {
    live_fns = dce_build_live_set(module)
  }

  // 6. Second pass: compile each function body (streaming to file)
  i = 0
  while i < nf {
    f_cur = funcs.get(i)
    // DCE: skip functions not reachable from main (user code only)
    should_skip := 0
    if live_fns != 0 {
      cur_fname = irf_name(f_cur)
      if mhas(live_fns, cur_fname) == 0 { should_skip = 1 }
    }
    if should_skip == 0 { emit_function_body(cg, f_cur) }
    i = i + 1
    0
  }

  // Flush remaining buffer and write string constants
  cg_flush(cg)
  sc_lines = cg_string_const_lines(cg)
  sci := 0
  while sci < sc_lines.len() {
    fa(output_path, sc_lines.get(sci) + "\n")
    sci = sci + 1
    0
  }
  0
}

write_ll_file(cg:I output_path:S) I {
  main_lines = cg_lines(cg)
  sc_lines = cg_string_const_lines(cg)
  si := 0
  while si < sc_lines.len() {
    main_lines.push(sc_lines.get(si))
    si = si + 1
    0
  }
  fw(output_path, "")
  wi := 0
  while wi < main_lines.len() {
    fa(output_path, main_lines.get(wi) + "\n")
    wi = wi + 1
    0
  }
  0
}
