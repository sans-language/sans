  // ── IR_STRING_LEN (50): [op, dest, string_reg] ──
  if op == IR_STRING_LEN {
    sv = cg_get_val(cg, ir_field(inst, 16))
    sp = cg_fresh_reg(cg)
    emit(cg, "  " + sp + " = inttoptr i64 " + sv + " to ptr")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @strlen(ptr " + sp + ")")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ── IR_STRING_CONCAT (51): [op, dest, left_reg, right_reg] ──
  if op == IR_STRING_CONCAT {
    lv = cg_get_val(cg, ir_field(inst, 16))
    rv = cg_get_val(cg, ir_field(inst, 24))
    p1 = cg_fresh_reg(cg)
    emit(cg, "  " + p1 + " = inttoptr i64 " + lv + " to ptr")
    p2 = cg_fresh_reg(cg)
    emit(cg, "  " + p2 + " = inttoptr i64 " + rv + " to ptr")
    l1 = cg_fresh_reg(cg)
    emit(cg, "  " + l1 + " = call i64 @strlen(ptr " + p1 + ")")
    l2 = cg_fresh_reg(cg)
    emit(cg, "  " + l2 + " = call i64 @strlen(ptr " + p2 + ")")
    tot = cg_fresh_reg(cg)
    emit(cg, "  " + tot + " = add i64 " + l1 + ", " + l2)
    asz = cg_fresh_reg(cg)
    emit(cg, "  " + asz + " = add i64 " + tot + ", 1")
    buf = cg_fresh_reg(cg)
    emit(cg, "  " + buf + " = call ptr @malloc(i64 " + asz + ")")
    // memcpy left
    emit(cg, "  call ptr @memcpy(ptr " + buf + ", ptr " + p1 + ", i64 " + l1 + ")")
    // GEP buf+len1
    mid = cg_fresh_reg(cg)
    emit(cg, "  " + mid + " = getelementptr i8, ptr " + buf + ", i64 " + l1)
    // memcpy right
    emit(cg, "  call ptr @memcpy(ptr " + mid + ", ptr " + p2 + ", i64 " + l2 + ")")
    // null-terminate
    endp = cg_fresh_reg(cg)
    emit(cg, "  " + endp + " = getelementptr i8, ptr " + buf + ", i64 " + tot)
    emit(cg, "  store i8 0, ptr " + endp)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + buf + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    return 0
  }

  // ── IR_STRING_SUBSTRING (52): [op, dest, string_reg, start_reg, end_reg] ──
  if op == IR_STRING_SUBSTRING {
    sv = cg_get_val(cg, ir_field(inst, 16))
    st = cg_get_val(cg, ir_field(inst, 24))
    en = cg_get_val(cg, ir_field(inst, 32))
    ln = cg_fresh_reg(cg)
    emit(cg, "  " + ln + " = sub i64 " + en + ", " + st)
    asz = cg_fresh_reg(cg)
    emit(cg, "  " + asz + " = add i64 " + ln + ", 1")
    buf = cg_fresh_reg(cg)
    emit(cg, "  " + buf + " = call ptr @malloc(i64 " + asz + ")")
    sp = cg_fresh_reg(cg)
    emit(cg, "  " + sp + " = inttoptr i64 " + sv + " to ptr")
    src = cg_fresh_reg(cg)
    emit(cg, "  " + src + " = getelementptr i8, ptr " + sp + ", i64 " + st)
    emit(cg, "  call ptr @memcpy(ptr " + buf + ", ptr " + src + ", i64 " + ln + ")")
    endp = cg_fresh_reg(cg)
    emit(cg, "  " + endp + " = getelementptr i8, ptr " + buf + ", i64 " + ln)
    emit(cg, "  store i8 0, ptr " + endp)
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + buf + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    return 0
  }

  // ── IR_INT_TO_STRING (53): [op, dest, value_reg] ──
  if op == IR_INT_TO_STRING {
    val = cg_get_val(cg, ir_field(inst, 16))
    buf = cg_fresh_reg(cg)
    emit(cg, "  " + buf + " = call ptr @malloc(i64 21)")
    fmt = cg_fmt_ld(cg)
    cg_fresh_reg(cg)
    emit(cg, "  call i32 (ptr, i64, ptr, ...) @snprintf(ptr " + buf + ", i64 21, ptr " + fmt + ", i64 " + val + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + buf + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    return 0
  }

  // ── IR_STRING_TO_INT (54): [op, dest, string_reg] ──
  if op == IR_STRING_TO_INT {
    sv = cg_get_val(cg, ir_field(inst, 16))
    sp = cg_fresh_reg(cg)
    emit(cg, "  " + sp + " = inttoptr i64 " + sv + " to ptr")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @strtol(ptr " + sp + ", ptr null, i64 10)")
    cg_set_val(cg, dest, r)
    return 0
  }

  // ── IR_FLOAT_TO_STRING (55): [op, dest, value_reg] ──
  if op == IR_FLOAT_TO_STRING {
    val = cg_get_val(cg, ir_field(inst, 16))
    fv = cg_fresh_reg(cg)
    emit(cg, "  " + fv + " = bitcast i64 " + val + " to double")
    buf = cg_fresh_reg(cg)
    emit(cg, "  " + buf + " = call ptr @malloc(i64 32)")
    fmt = cg_fmt_g(cg)
    cg_fresh_reg(cg)
    emit(cg, "  call i32 (ptr, i64, ptr, ...) @snprintf(ptr " + buf + ", i64 32, ptr " + fmt + ", double " + fv + ")")
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = ptrtoint ptr " + buf + " to i64")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
    return 0
  }

  // ── IR_STRING_TRIM (56): call i64 @sans_string_trim(i64) ──
  if op == IR_STRING_TRIM {
    a1 = cg_get_val(cg, ir_field(inst, 16))
    r = cg_fresh_reg(cg)
    emit(cg, "  " + r + " = call i64 @sans_string_trim(i64 " + a1 + ")")
    cg_set_val(cg, dest, r)
    cg_set_ptr(cg, dest)
