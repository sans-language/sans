import "constants"
import "ir"

// Global flag: 1 when compiling a runtime module, 0 for user code
// Used to skip scope instrumentation in runtime modules (avoids double-definition of sans_scope_track)
g cg_is_runtime_flag = 0
g cg_fn_ret_types = 0
g cg_fn_aliases = 0
g cg_trait_impls = 0
g cg_trait_registry = 0
g cg_timeval_buf = 0

// resolve_fn_alias: return aliased name if it exists, otherwise original
resolve_fn_alias(fname:S) S {
  if cg_fn_aliases != 0 {
    if mhas(cg_fn_aliases, fname) { return mget(cg_fn_aliases, fname) }
  }
  fname
}

cg_str(v:I) S = v

// ------ Codegen state layout (80 bytes) ---------------------------------------------------------------------------------------
// offset 0:  lines        --- Array<I> of string pointers (LLVM IR lines)
// offset 8:  reg_counter  --- next LLVM SSA register number
// offset 16: string_pool  --- Map: hash_key --- global name ptr
// offset 24: struct_defs  --- Map: struct name --- field count
// offset 32: label_map    --- Map: IR label name --- LLVM label name
// offset 40: reg_map      --- Map: IR register --- LLVM value string ptr
// offset 48: ptr_set      --- Map: IR register --- 1 (tracks pointer regs)
// offset 56: has_main     --- 1 if module has main function
// offset 72: label_counter --- separate counter for unique label suffixes

make_codegen() I {
  cg = alloc(136)
  store64(cg, array<I>())       // lines (unused in streaming mode)
  store64(cg + 8, 0)            // reg_counter
  store64(cg + 16, M())         // string_pool
  store64(cg + 24, M())         // struct_defs
  store64(cg + 32, M())         // label_map
  store64(cg + 40, M())         // reg_map
  store64(cg + 48, M())         // ptr_set
  store64(cg + 56, 0)           // has_main
  store64(cg + 64, array<I>())  // string_const_lines
  store64(cg + 72, 0)           // label_counter
  store64(cg + 80, 0)           // current_ir_label
  store64(cg + 88, M())         // label_end_map
  store64(cg + 96, 0)           // current_block
  store64(cg + 104, M())        // label_parent
  store64(cg + 112, 0)          // output_path (0 = buffer mode, non-0 = streaming)
  store64(cg + 120, 0)          // line_buffer (accumulated string for batch flush)
  store64(cg + 128, M())        // ret_labels: set of labels terminated by ret
  cg
}

// ------ Codegen accessors ---------------------------------------------------------------------------------------------------------------------------------
cg_lines(cg:I) I = load64(cg)
cg_reg_counter(cg:I) I = load64(cg + 8)
cg_string_pool(cg:I) I = load64(cg + 16)
cg_struct_defs(cg:I) I = load64(cg + 24)
cg_label_map(cg:I) I = load64(cg + 32)
cg_reg_map(cg:I) I = load64(cg + 40)
cg_ptr_set(cg:I) I = load64(cg + 48)
cg_has_main(cg:I) I = load64(cg + 56)

cg_string_const_lines(cg:I) I = load64(cg + 64)

// Emit a global constant line (goes to string_const_lines, not main lines)
emit_global_const(cg:I line:S) I {
  sc = cg_string_const_lines(cg)
  sc.push(ptr(line))
  0
}
cg_current_label(cg:I) I = load64(cg + 80)  // IR-level label
cg_set_current_label(cg:I v:I) I { store64(cg + 80, v) 0 }
cg_label_end_map(cg:I) I = load64(cg + 88)
cg_current_block(cg:I) I = load64(cg + 96)  // actual LLVM block (may differ after inline ops)
cg_set_current_block(cg:I v:I) I { store64(cg + 96, v) 0 }
cg_label_parent(cg:I) I = load64(cg + 104)  // child --- parent label map

cg_set_reg_counter(cg:I v:I) I { store64(cg + 8, v) 0 }
cg_set_has_main(cg:I v:I) I { store64(cg + 56, v) 0 }

// Record that the code for IR label `ir_label` actually ends at LLVM label `end_label`
cg_record_label_end(cg:I ir_label:I end_label:I) I {
  lem = cg_label_end_map(cg)
  mset(lem, ir_label, end_label)
  0
}

// Get the actual LLVM label that IR label ends at (for PHI predecessors)
cg_get_label_end(cg:I ir_label:I) I {
  lem = cg_label_end_map(cg)
  if mhas(lem, ir_label) { mget(lem, ir_label) } else { ir_label }
}

// ------ Core helpers ------------------------------------------------------------------------------------------------------------------------------------------------

// Emit a line of LLVM IR --- streams to file when output_path set
emit(cg:I line:S) I {
  opath = load64(cg + 112)
  if opath != 0 {
    // Streaming mode: write line to file
    fa(opath, line)
    fa(opath, "\n")
  } else {
    // Buffer mode (for small compilations)
    lines = cg_lines(cg)
    lines.push(ptr(line))
  }
  0
}

// Flush any remaining buffered lines to file
cg_flush(cg:I) I {
  opath = load64(cg + 112)
  if opath != 0 {
    buf = load64(cg + 120)
    if buf != 0 {
      if slen(buf) > 0 { fa(opath, buf) }
      store64(cg + 120, 0)
    }
  }
  0
}

// Get next LLVM SSA register name: "%0", "%1", etc.
cg_fresh_reg(cg:I) S {
  n = cg_reg_counter(cg)
  cg_set_reg_counter(cg, n + 1)
  "%" + str(n)
}

// Map an IR register to an LLVM value string
cg_set_val(cg:I ir_reg:I llvm_val:S) I {
  rm = load64(cg + 40)
  mset(rm, ir_reg, ptr(llvm_val))
  0
}

// Get the LLVM value for an IR register
cg_get_val(cg:I ir_reg:I) S {
  rm = load64(cg + 40)
  if mhas(rm, ir_reg) { mget(rm, ir_reg) } else { "0" }
}

// Mark a register as holding a pointer
cg_set_ptr(cg:I ir_reg:I) I {
  ps = load64(cg + 48)
  mset(ps, ir_reg, 1)
  0
}

// Check if register holds a pointer
cg_is_ptr(cg:I ir_reg:I) I {
  ps = load64(cg + 48)
  mhas(ps, ir_reg)
}

// ------ String building: join_lines ---------------------------------------------------------------------------------------------------

join_lines(cg:I) S {
  lines = cg_lines(cg)
  n = lines.len()
  // Calculate total length
  total := 0
  i := 0
  while i < n {
    s = lines.get(i)
    total = total + slen(s) + 1
    i = i + 1
    0
  }
  // Allocate buffer and copy
  buf = alloc(total + 1)
  pos := 0
  i = 0
  while i < n {
    s = lines.get(i)
    len = slen(s)
    mcpy(buf + pos, s, len)
    pos = pos + len
    store8(0, buf + pos, 10)
    pos = pos + 1
    i = i + 1
    0
  }
  store8(0, buf + pos, 0)
  buf
}

// ------ Hash helper (djb2) ------------------------------------------------------------------------------------------------------------------------------

g djb2_counter = 0

djb2_hash(s:S) I {
  // Use a monotonic counter — no deduplication but no collisions
  // Each string constant gets a unique name
  djb2_counter = djb2_counter + 1
  djb2_counter
}

// ------ LLVM string escaping ------------------------------------------------------------------------------------------------------------------------

llvm_esc_bs(s:S) S {
  // Escape backslashes by splitting on them and joining with \5C
  parts = s.split("\\")
  if parts.len() <= 1 { return s }
  result := parts.get(0)
  i := 1
  while i < parts.len() {
    result = result + "\\5C" + parts.get(i)
    i = i + 1
    0
  }
  result
}

llvm_escape_string(s:S) S {
  // Phase 1: escape backslashes (split/join approach avoids re-escaping)
  r = llvm_esc_bs(s)
  // Phase 2: escape other special characters
  r = r.replace("\n", "\\0A")
  r = r.replace("\t", "\\09")
  r = r.replace("\"", "\\22")
  r
}

llvm_escape_char(buf:I pos:I c:I) I {
  if c == 10 {
    store8(0, buf + pos, 92)
    store8(0, buf + pos + 1, 48)
    store8(0, buf + pos + 2, 65)
    pos + 3
  } else { if c == 9 {
    store8(0, buf + pos, 92)
    store8(0, buf + pos + 1, 48)
    store8(0, buf + pos + 2, 57)
    pos + 3
  } else { if c == 92 {
    store8(0, buf + pos, 92)
    store8(0, buf + pos + 1, 53)
    store8(0, buf + pos + 2, 67)
    pos + 3
  } else { if c == 34 {
    store8(0, buf + pos, 92)
    store8(0, buf + pos + 1, 50)
    store8(0, buf + pos + 2, 50)
    pos + 3
  } else { if c < 32 {
    store8(0, buf + pos, 92)
    hi = c / 16
    lo = c % 16
    store8(0, buf + pos + 1, if hi < 10 { hi + 48 } else { hi - 10 + 65 })
    store8(0, buf + pos + 2, if lo < 10 { lo + 48 } else { lo - 10 + 65 })
    pos + 3
  } else {
    store8(0, buf + pos, c)
    pos + 1
  } } } } }
}

llvm_escape_step(s:S buf:I pos:I i:I len:I) I {
  if i >= len { pos }
  else {
    c = char_at(s, i)
    new_pos = llvm_escape_char(buf, pos, c)
    llvm_escape_step(s, buf, new_pos, i + 1, len)
  }
}

llvm_escape_string_UNUSED(s:S) S {
  len = slen(s)
  buf = alloc(len * 3 + 1)
  final_pos = llvm_escape_step(s, buf, 0, 0, len)
  store8(0, buf + final_pos, 0)
  buf
}

// ------ String constant emission ------------------------------------------------------------------------------------------------------------

emit_string_const(cg:I value:S) S {
  pool = cg_string_pool(cg)
  hash = djb2_hash(value)
  key = str(hash)
  if mhas(pool, key) {
    return mget(pool, key)
  }
  name = "@str." + key
  mset(pool, key, ptr(name))
  escaped = llvm_escape_string(value)
  len = slen(value) + 1
  line = name + " = private unnamed_addr constant [" + str(len) + " x i8] c\"" + escaped + "\\00\""
  sc_lines = cg_string_const_lines(cg)
  sc_lines.push(ptr(line))
  name
}

// ------ LLVM IR header ------------------------------------------------------------------------------------------------------------------------------------------

emit_header(cg:I) I {
  // Omit target triple — llc defaults to host platform
  emit(cg, "")
  0
}

// ------ External function declarations ------------------------------------------------------------------------------------------

// Core externals only (C stdlib, file I/O, threading, curl, sockets) --- no sans_* runtime
emit_externals_core(cg:I) I {
  emit(cg, "declare i64 @printf(ptr, ...)")
  emit(cg, "declare ptr @malloc(i64)")
  emit(cg, "declare void @free(ptr)")
  emit(cg, "declare i64 @strlen(ptr)")
  emit(cg, "declare ptr @memcpy(ptr, ptr, i64)")
  emit(cg, "declare ptr @memset(ptr, i64, i64)")
  emit(cg, "declare ptr @realloc(ptr, i64)")
  emit(cg, "declare i32 @memcmp(ptr, ptr, i64)")
  emit(cg, "declare i32 @strcmp(ptr, ptr)")
  emit(cg, "declare i32 @snprintf(ptr, i64, ptr, ...)")
  emit(cg, "declare i64 @strtol(ptr, ptr, i64)")
  emit(cg, "declare i64 @write(i64, ptr, i64)")
  emit(cg, "declare void @exit(i64)")
  emit(cg, "declare i32 @system(ptr)")
  emit(cg, "declare i32 @access(ptr, i32)")
  emit(cg, "declare ptr @getenv(ptr)")
  emit(cg, "declare i32 @rmdir(ptr)")
  emit(cg, "declare i32 @remove(ptr)")
  emit(cg, "declare ptr @strstr(ptr, ptr)")
  emit(cg, "declare i32 @usleep(i32)")
  emit(cg, "declare i64 @time(i64)")
  emit(cg, "declare i32 @gettimeofday(ptr, ptr)")
  emit(cg, "declare void @srand(i32)")
  emit(cg, "declare i32 @rand()")
  emit(cg, "declare double @strtod(ptr, ptr)")
  emit(cg, "declare ptr @fopen(ptr, ptr)")
  emit(cg, "declare i32 @fclose(ptr)")
  emit(cg, "declare i64 @fread(ptr, i64, i64, ptr)")
  emit(cg, "declare i64 @fwrite(ptr, i64, i64, ptr)")
  emit(cg, "declare i32 @fseek(ptr, i64, i32)")
  emit(cg, "declare i64 @ftell(ptr)")
  emit(cg, "declare i32 @pthread_create(ptr, ptr, ptr, ptr)")
  emit(cg, "declare i32 @pthread_join(i64, ptr)")
  emit(cg, "declare i32 @pthread_mutex_init(ptr, ptr)")
  emit(cg, "declare i32 @pthread_mutex_lock(ptr)")
  emit(cg, "declare i32 @pthread_mutex_unlock(ptr)")
  emit(cg, "declare i32 @pthread_cond_init(ptr, ptr)")
  emit(cg, "declare i32 @pthread_cond_wait(ptr, ptr)")
  emit(cg, "declare i32 @pthread_cond_signal(ptr)")
  emit(cg, "declare i64 @curl_easy_init()")
  emit(cg, "declare i64 @curl_easy_setopt(i64, i64, ...)")
  emit(cg, "declare i64 @curl_easy_perform(i64)")
  emit(cg, "declare void @curl_easy_cleanup(i64)")
  emit(cg, "declare i64 @curl_easy_getinfo(i64, i64, ...)")
  emit(cg, "declare i64 @curl_slist_append(i64, i64)")
  emit(cg, "declare void @curl_slist_free_all(i64)")
  emit(cg, "declare i64 @socket(i64, i64, i64)")
  emit(cg, "declare i64 @bind(i64, ptr, i64)")
  emit(cg, "declare i64 @listen(i64, i64)")
  emit(cg, "declare i64 @accept(i64, ptr, ptr)")
  emit(cg, "declare i64 @recv(i64, ptr, i64, i64)")
  emit(cg, "declare i64 @send(i64, ptr, i64, i64)")
  emit(cg, "declare i64 @close(i64)")
  emit(cg, "declare i64 @setsockopt(i64, i64, i64, ptr, i64)")

  // ------ Signal / Poll ------
  emit(cg, "declare i64 @signal(i32, ptr)")
  emit(cg, "declare i32 @poll(ptr, i32, i32)")
  emit(cg, "@__sans_signal_flag = external global i64")
  emit(cg, "declare void @__sans_signal_handler(i32)")

  // ------ OpenSSL ------
  emit(cg, "declare ptr @TLS_server_method()")
  emit(cg, "declare ptr @SSL_CTX_new(ptr)")
  emit(cg, "declare i32 @SSL_CTX_use_certificate_file(ptr, ptr, i32)")
  emit(cg, "declare i32 @SSL_CTX_use_PrivateKey_file(ptr, ptr, i32)")
  emit(cg, "declare ptr @SSL_new(ptr)")
  emit(cg, "declare i32 @SSL_set_fd(ptr, i32)")
  emit(cg, "declare i32 @SSL_accept(ptr)")
  emit(cg, "declare i32 @SSL_read(ptr, ptr, i32)")
  emit(cg, "declare i32 @SSL_write(ptr, ptr, i32)")
  emit(cg, "declare i32 @SSL_shutdown(ptr)")
  emit(cg, "declare void @SSL_free(ptr)")


  // ------ zlib ------
  emit(cg, "declare i32 @deflateInit2_(ptr, i32, i32, i32, i32, i32, ptr, i32)")
  emit(cg, "declare i32 @deflate(ptr, i32)")
  emit(cg, "declare i32 @deflateEnd(ptr)")
  emit(cg, "declare i64 @deflateBound(ptr, i64)")

  // ------ LLVM intrinsics ------
  emit(cg, "declare i16 @llvm.bswap.i16(i16)")

  emit(cg, "@.empty_str = private unnamed_addr constant [1 x i8] zeroinitializer")
  emit(cg, "@.str.too_many_caps = private unnamed_addr constant [36 x i8] c\"closure: too many captures (max 8)\\0a\\00\"")

  0
}

emit_externals(cg:I) I {
  // ------ C standard library ------
  emit(cg, "declare i64 @printf(ptr, ...)")
  emit(cg, "declare ptr @malloc(i64)")
  emit(cg, "declare void @free(ptr)")
  emit(cg, "declare i64 @strlen(ptr)")
  emit(cg, "declare ptr @memcpy(ptr, ptr, i64)")
  emit(cg, "declare ptr @memset(ptr, i64, i64)")
  emit(cg, "declare ptr @realloc(ptr, i64)")
  emit(cg, "declare i32 @memcmp(ptr, ptr, i64)")
  emit(cg, "declare i32 @strcmp(ptr, ptr)")
  emit(cg, "declare i32 @snprintf(ptr, i64, ptr, ...)")
  emit(cg, "declare i64 @strtol(ptr, ptr, i64)")
  emit(cg, "declare i64 @write(i64, ptr, i64)")
  emit(cg, "declare void @exit(i64)")
  emit(cg, "declare i32 @system(ptr)")
  emit(cg, "declare i32 @access(ptr, i32)")
  emit(cg, "declare ptr @getenv(ptr)")
  emit(cg, "declare i32 @rmdir(ptr)")
  emit(cg, "declare i32 @remove(ptr)")
  emit(cg, "declare ptr @strstr(ptr, ptr)")
  emit(cg, "declare i32 @usleep(i32)")
  emit(cg, "declare i64 @time(i64)")
  emit(cg, "declare i32 @gettimeofday(ptr, ptr)")
  emit(cg, "declare void @srand(i32)")
  emit(cg, "declare i32 @rand()")
  emit(cg, "declare double @strtod(ptr, ptr)")

  // ------ File I/O ------
  emit(cg, "declare ptr @fopen(ptr, ptr)")
  emit(cg, "declare i32 @fclose(ptr)")
  emit(cg, "declare i64 @fread(ptr, i64, i64, ptr)")
  emit(cg, "declare i64 @fwrite(ptr, i64, i64, ptr)")
  emit(cg, "declare i32 @fseek(ptr, i64, i32)")
  emit(cg, "declare i64 @ftell(ptr)")

  // ------ Threading ------
  emit(cg, "declare i32 @pthread_create(ptr, ptr, ptr, ptr)")
  emit(cg, "declare i32 @pthread_join(i64, ptr)")
  emit(cg, "declare i32 @pthread_mutex_init(ptr, ptr)")
  emit(cg, "declare i32 @pthread_mutex_lock(ptr)")
  emit(cg, "declare i32 @pthread_mutex_unlock(ptr)")
  emit(cg, "declare i32 @pthread_cond_init(ptr, ptr)")
  emit(cg, "declare i32 @pthread_cond_wait(ptr, ptr)")
  emit(cg, "declare i32 @pthread_cond_signal(ptr)")

  // ------ Curl ------
  emit(cg, "declare i64 @curl_easy_init()")
  emit(cg, "declare i64 @curl_easy_setopt(i64, i64, ...)")
  emit(cg, "declare i64 @curl_easy_perform(i64)")
  emit(cg, "declare void @curl_easy_cleanup(i64)")
  emit(cg, "declare i64 @curl_easy_getinfo(i64, i64, ...)")
  emit(cg, "declare i64 @curl_slist_append(i64, i64)")
  emit(cg, "declare void @curl_slist_free_all(i64)")

  // ------ Sockets ------
  emit(cg, "declare i64 @socket(i64, i64, i64)")
  emit(cg, "declare i64 @bind(i64, ptr, i64)")
  emit(cg, "declare i64 @listen(i64, i64)")
  emit(cg, "declare i64 @accept(i64, ptr, ptr)")
  emit(cg, "declare i64 @recv(i64, ptr, i64, i64)")
  emit(cg, "declare i64 @send(i64, ptr, i64, i64)")
  emit(cg, "declare i64 @close(i64)")
  emit(cg, "declare i64 @setsockopt(i64, i64, i64, ptr, i64)")

  // ------ Sans runtime: JSON ------
  emit(cg, "declare i64 @sans_json_parse(i64)")
  emit(cg, "declare i64 @sans_json_object()")
  emit(cg, "declare i64 @sans_json_array()")
  emit(cg, "declare i64 @sans_json_string(i64)")
  emit(cg, "declare i64 @sans_json_int(i64)")
  emit(cg, "declare i64 @sans_json_bool(i64)")
  emit(cg, "declare i64 @sans_json_null()")
  emit(cg, "declare i64 @sans_json_get(i64, i64)")
  emit(cg, "declare i64 @sans_json_get_index(i64, i64)")
  emit(cg, "declare i64 @sans_json_get_string(i64)")
  emit(cg, "declare i64 @sans_json_get_int(i64)")
  emit(cg, "declare i64 @sans_json_get_bool(i64)")
  emit(cg, "declare i64 @sans_json_len(i64)")
  emit(cg, "declare i64 @sans_json_type_of(i64)")
  emit(cg, "declare i64 @sans_json_set(i64, i64, i64)")
  emit(cg, "declare i64 @sans_json_push(i64, i64)")
  emit(cg, "declare i64 @sans_json_stringify(i64)")
  emit(cg, "declare i64 @sans_json_keys(i64)")
  emit(cg, "declare i64 @sans_json_has(i64, i64)")
  emit(cg, "declare i64 @sans_json_delete(i64, i64)")

  // ------ Sans runtime: HTTP ------
  emit(cg, "declare i64 @sans_http_listen(i64)")
  emit(cg, "declare i64 @sans_http_accept(i64)")
  emit(cg, "declare i64 @sans_http_respond(i64, i64, i64, i64)")
  emit(cg, "declare i64 @sans_http_get(i64)")
  emit(cg, "declare i64 @sans_http_post(i64, i64, i64)")
  emit(cg, "declare i64 @sans_http_status(i64)")
  emit(cg, "declare i64 @sans_http_ok(i64)")
  emit(cg, "declare i64 @sans_http_body(i64)")
  emit(cg, "declare i64 @sans_http_header(i64, i64)")
  emit(cg, "declare i64 @sans_http_request_path(i64)")
  emit(cg, "declare i64 @sans_http_request_method(i64)")
  emit(cg, "declare i64 @sans_http_request_body(i64)")

  // ------ Sans runtime: Arrays ------
  emit(cg, "declare i64 @sans_array_map(i64, i64)")
  emit(cg, "declare i64 @sans_array_filter(i64, i64)")
  emit(cg, "declare i64 @sans_array_any(i64, i64)")
  emit(cg, "declare i64 @sans_array_find(i64, i64)")
  emit(cg, "declare i64 @sans_array_find_raw(i64, i64, i64)")
  emit(cg, "declare i64 @sans_array_enumerate(i64)")
  emit(cg, "declare i64 @sans_array_zip(i64, i64)")
  emit(cg, "declare i64 @sans_array_contains(i64, i64)")
  emit(cg, "declare i64 @sans_array_pop(i64)")
  emit(cg, "declare i64 @sans_array_remove(i64, i64)")

  // ------ Sans runtime: Strings ------
  emit(cg, "declare i64 @sans_string_trim(i64)")
  emit(cg, "declare i64 @sans_string_starts_with(i64, i64)")
  emit(cg, "declare i64 @sans_string_ends_with(i64, i64)")
  emit(cg, "declare i64 @sans_string_contains(i64, i64)")
  emit(cg, "declare i64 @sans_string_split(i64, i64)")
  emit(cg, "declare i64 @sans_string_replace(i64, i64, i64)")

  // ------ Sans runtime: Result ------
  emit(cg, "declare i64 @sans_result_ok(i64)")
  emit(cg, "declare i64 @sans_result_err(i64, i64)")
  emit(cg, "declare i64 @sans_result_is_ok(i64)")
  emit(cg, "declare i64 @sans_result_is_err(i64)")
  emit(cg, "declare i64 @sans_result_unwrap(i64)")
  emit(cg, "declare i64 @sans_result_error(i64)")
  emit(cg, "declare i64 @sans_result_unwrap_or(i64, i64)")
  emit(cg, "declare i64 @sans_result_code(i64)")

  // ------ Sans runtime: Option (declared only — defined in runtime/option.sans) ------
  emit(cg, "declare i64 @sans_option_some(i64)")
  emit(cg, "declare i64 @sans_option_none()")
  emit(cg, "declare i64 @sans_option_is_some(i64)")
  emit(cg, "declare i64 @sans_option_is_none(i64)")
  emit(cg, "declare i64 @sans_option_unwrap(i64)")
  emit(cg, "declare i64 @sans_option_unwrap_or(i64, i64)")

  // ------ Sans runtime: Logging ------
  emit(cg, "declare i64 @sans_log_debug(i64)")
  emit(cg, "declare i64 @sans_log_info(i64)")
  emit(cg, "declare i64 @sans_log_warn(i64)")
  emit(cg, "declare i64 @sans_log_error(i64)")
  emit(cg, "declare i64 @sans_log_set_level(i64)")

  // ------ Sans runtime: Kernel ------
  emit(cg, "declare i64 @sans_print_err(i64)")
  emit(cg, "declare i64 @sans_get_log_level()")
  emit(cg, "declare i64 @sans_set_log_level(i64)")

  // ------ Sans runtime: Map ------
  emit(cg, "declare i64 @sans_map_create()")
  emit(cg, "declare i64 @sans_map_get(i64, i64)")
  emit(cg, "declare i64 @sans_map_set(i64, i64, i64)")
  emit(cg, "declare i64 @sans_map_has(i64, i64)")
  emit(cg, "declare i64 @sans_map_len(i64)")
