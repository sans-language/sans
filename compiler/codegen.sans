  cg_set_val(cg, dest, result)
  0
}

emit_closure_aware_call3(cg:I dest:I fp_val:S a1:S a2:S a3:S) I {
  uid = cg_reg_counter(cg)
  tag = cg_fresh_reg(cg)
  emit(cg, "  " + tag + " = and i64 " + fp_val + ", 1")
  is_clo = cg_fresh_reg(cg)
  emit(cg, "  " + is_clo + " = icmp eq i64 " + tag + ", 1")
  lbl_clo = "fcall3_clo_" + str(uid)
  lbl_dir = "fcall3_dir_" + str(uid)
  lbl_sw = "fcall3_sw_" + str(uid)
  lbl_c0 = "fcall3_c0_" + str(uid)
  lbl_c1 = "fcall3_c1_" + str(uid)
  lbl_c2 = "fcall3_c2_" + str(uid)
  lbl_c3 = "fcall3_c3_" + str(uid)
  lbl_c4 = "fcall3_c4_" + str(uid)
  lbl_c5 = "fcall3_c5_" + str(uid)
  lbl_c6 = "fcall3_c6_" + str(uid)
  lbl_c7 = "fcall3_c7_" + str(uid)
  lbl_c8 = "fcall3_c8_" + str(uid)
  lbl_cerr = "fcall3_cerr_" + str(uid)
  lbl_merge = "fcall3_merge_" + str(uid)
  emit(cg, "  br i1 " + is_clo + ", label %" + lbl_clo + ", label %" + lbl_dir)
  // Direct path
  emit(cg, lbl_dir + ":")
  fp_d = cg_fresh_reg(cg)
  emit(cg, "  " + fp_d + " = inttoptr i64 " + fp_val + " to ptr")
  r_d = cg_fresh_reg(cg)
  emit(cg, "  " + r_d + " = call i64 " + fp_d + "(i64 " + a1 + ", i64 " + a2 + ", i64 " + a3 + ")")
  emit(cg, "  br label %" + lbl_merge)
  // Closure path: unpack object
  emit(cg, lbl_clo + ":")
  obj = cg_fresh_reg(cg)
  emit(cg, "  " + obj + " = sub i64 " + fp_val + ", 1")
  obj_ptr = cg_fresh_reg(cg)
  emit(cg, "  " + obj_ptr + " = inttoptr i64 " + obj + " to ptr")
  fn_slot = cg_fresh_reg(cg)
  emit(cg, "  " + fn_slot + " = load i64, ptr " + obj_ptr)
  fn_ptr = cg_fresh_reg(cg)
  emit(cg, "  " + fn_ptr + " = inttoptr i64 " + fn_slot + " to ptr")
  ncaps_gep = cg_fresh_reg(cg)
  emit(cg, "  " + ncaps_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 1")
  ncaps = cg_fresh_reg(cg)
  emit(cg, "  " + ncaps + " = load i64, ptr " + ncaps_gep)
  emit(cg, "  br label %" + lbl_sw)
  // Switch on ncaps
  emit(cg, lbl_sw + ":")
  emit(cg, "  switch i64 " + ncaps + ", label %" + lbl_cerr + " [i64 0, label %" + lbl_c0 + " i64 1, label %" + lbl_c1 + " i64 2, label %" + lbl_c2 + " i64 3, label %" + lbl_c3 + " i64 4, label %" + lbl_c4 + " i64 5, label %" + lbl_c5 + " i64 6, label %" + lbl_c6 + " i64 7, label %" + lbl_c7 + " i64 8, label %" + lbl_c8 + "]")
  // 0 captures
  emit(cg, lbl_c0 + ":")
  r_c0 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c0 + " = call i64 " + fn_ptr + "(i64 " + a1 + ", i64 " + a2 + ", i64 " + a3 + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 1 capture
  emit(cg, lbl_c1 + ":")
  c1_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c1_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c1_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c1_0 + " = load i64, ptr " + c1_0_gep)
  r_c1 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c1 + " = call i64 " + fn_ptr + "(i64 " + c1_0 + ", i64 " + a1 + ", i64 " + a2 + ", i64 " + a3 + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 2 captures
  emit(cg, lbl_c2 + ":")
  c2_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c2_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c2_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c2_0 + " = load i64, ptr " + c2_0_gep)
  c2_1_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c2_1_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 3")
  c2_1 = cg_fresh_reg(cg)
  emit(cg, "  " + c2_1 + " = load i64, ptr " + c2_1_gep)
  r_c2 = cg_fresh_reg(cg)
  emit(cg, "  " + r_c2 + " = call i64 " + fn_ptr + "(i64 " + c2_0 + ", i64 " + c2_1 + ", i64 " + a1 + ", i64 " + a2 + ", i64 " + a3 + ")")
  emit(cg, "  br label %" + lbl_merge)
  // 3 captures
  emit(cg, lbl_c3 + ":")
  c3_0_gep = cg_fresh_reg(cg)
  emit(cg, "  " + c3_0_gep + " = getelementptr i64, ptr " + obj_ptr + ", i64 2")
  c3_0 = cg_fresh_reg(cg)
  emit(cg, "  " + c3_0 + " = load i64, ptr " + c3_0_gep)
