// ------ lower_field_access ------------------------------------------------------------------------------------------------------------------------------
lower_field_access(ctx:I expr:I) I {
  object = load64(expr + 16)
  field = load64(expr + 24)

  obj_reg = lower_expr(ctx, object)
  obj_type = ctx_get_reg_type(ctx, obj_reg)

  // Struct field access
  if obj_type == IRTY_STRUCT {
    // Look up field index from struct_defs using tracked struct name
    sd = ctx_struct_defs(ctx)
    struct_name = ctx_get_struct_name(ctx, obj_reg)
    // Try generic instantiation before lookup (idempotent, registers if needed)
    if struct_name != 0 { resolve_generic_struct_fields(sd, struct_name) }
    struct_fields = if struct_name != 0 { mget(sd, struct_name) } else { 0 }
    num_fields = if struct_fields != 0 { struct_fields.len() } else { 1 }

    // Find field index using map with proper string comparison
    field_idx := 0
    if struct_fields != 0 {
      fi_map = M()
      k := 0
      while k < struct_fields.len() {
        mset(fi_map, struct_fields.get(k), k + 1)
        k = k + 1
        0
      }
      looked = mget(fi_map, field)
      if looked != 0 { field_idx = looked - 1
        0 }
      0
    }

    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_field_load(dest, obj_reg, field_idx, num_fields))
    // Check if field type is a struct (for nested struct field access)
    field_is_struct := 0
    if struct_name != 0 {
      ftmap = mget(sd, "$$field_types$$")
      if ftmap != 0 {
        ft_key = ir_s(struct_name) + "." + ir_s(field)
        ft_val = mget(ftmap, ft_key)
        if ft_val != 0 {
          // Try resolving generic struct if needed
          ft_str = ir_s(ft_val)
          if ir_find_dd(ft_str) >= 0 { resolve_generic_struct_fields(sd, ft_str) }
          if mhas(sd, ft_val) == 1 {
            ctx_set_reg_type(ctx, dest, IRTY_STRUCT)
            ctx_set_struct_name(ctx, dest, ft_val)
            field_is_struct = 1
            0
          }
          0
        }
        0
      }
      0
    }
    if field_is_struct == 0 { ctx_set_reg_type(ctx, dest, IRTY_INT) }
    dest
  }

  // Tuple field access (field is a numeric string like "0", "1")
  else if obj_type == IRTY_TUPLE {
    field_idx = stoi(field)
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_field_load(dest, obj_reg, field_idx, 2))
    ctx_set_reg_type(ctx, dest, IRTY_INT)
    dest
  }

  // If type is INT but field is numeric (e.g. "0", "1"), treat as tuple field access
  // This handles cases where tuple type info was lost (e.g. from array.get())
  else if char_at(field, 0) >= 48 && char_at(field, 0) <= 57 {
    field_idx = stoi(field)
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_field_load(dest, obj_reg, field_idx, 2))
    ctx_set_reg_type(ctx, dest, IRTY_INT)
    dest
  }

  // Non-struct/tuple: treat as no-arg method call
  else {
    // Synthesize method call with 0 args
    empty_args = array<I>()
    lower_method_call_direct(ctx, obj_reg, field, empty_args)
  }
}

// ------ lower_method_call_direct (helper for synthetic method calls) ---
lower_method_call_direct(ctx:I obj_reg:I method:I args:I) I {
  obj_type = ctx_get_reg_type(ctx, obj_reg)

  // Dispatch based on type
  if obj_type == IRTY_ARRAY { lower_array_method(ctx, obj_reg, method, args) }
  else if obj_type == IRTY_STR { lower_string_method(ctx, obj_reg, method, args) }
  else if obj_type == IRTY_MAP { lower_map_method(ctx, obj_reg, method, args) }
  else if obj_type == IRTY_MAP_INT { lower_map_int_method(ctx, obj_reg, method, args) }
  else if obj_type == IRTY_JSON { lower_json_method(ctx, obj_reg, method, args) }
  else if obj_type == IRTY_HTTP_RESP { lower_http_resp_method(ctx, obj_reg, method, args) }
  else if obj_type == IRTY_HTTP_SERVER {
    if method == "accept" {
      dest = ctx_fresh_reg(ctx)
      ctx_emit(ctx, ir_inst1(IR_HTTP_ACCEPT, dest, obj_reg))
      ctx_set_reg_type(ctx, dest, IRTY_HTTP_REQ)
      dest
    } else { lower_method_fallback(ctx, obj_reg, method, args) }
  }
  else if obj_type == IRTY_HTTP_REQ { lower_http_req_method(ctx, obj_reg, method, args) }
  else if obj_type == IRTY_RESULT { lower_result_method(ctx, obj_reg, method, args) }
  else if obj_type == IRTY_OPTION { lower_option_method(ctx, obj_reg, method, args) }
  else if obj_type == IRTY_DYN_TRAIT { lower_dyn_trait_method_call(ctx, obj_reg, method, args) }
  else { lower_method_fallback(ctx, obj_reg, method, args) }
}

// ------ lower_if_expr ---------------------------------------------------------------------------------------------------------------------------------------------
lower_if_expr(ctx:I expr:I) I {
  cond = load64(expr + 16)
  then_stmts = load64(expr + 24)
  then_expr = load64(expr + 32)
  else_stmts = load64(expr + 40)
  else_expr = load64(expr + 48)

  cond_reg = lower_expr(ctx, cond)
  then_label = ctx_fresh_label(ctx)
  else_label = ctx_fresh_label(ctx)
  merge_label = ctx_fresh_label(ctx)

  // Alloca for the result (avoids PHI predecessor tracking issues)
  result_ptr = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_alloca(result_ptr))

  ctx_emit(ctx, ir_branch(cond_reg, then_label, else_label))

  // Then branch
  ctx_emit(ctx, ir_label(then_label))
  lower_stmts(ctx, then_stmts)
  then_reg = lower_expr(ctx, then_expr)
  ctx_emit(ctx, ir_store(result_ptr, then_reg))
  ctx_emit(ctx, ir_jump(merge_label))

  // Else branch
  ctx_emit(ctx, ir_label(else_label))
  lower_stmts(ctx, else_stmts)
  else_reg = lower_expr(ctx, else_expr)
  ctx_emit(ctx, ir_store(result_ptr, else_reg))
  ctx_emit(ctx, ir_jump(merge_label))

  // Merge: load from alloca instead of PHI
  ctx_emit(ctx, ir_label(merge_label))
  dest = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_load(dest, result_ptr))
  // Take type from then branch
  tty = ctx_get_reg_type(ctx, then_reg)
  ctx_set_reg_type(ctx, dest, if tty != 0 { tty } else { IRTY_INT })
  dest
}

// ------ lower_match ---------------------------------------------------------------------------------------------------------------------------------------------------
lower_match(ctx:I expr:I) I {
  scrutinee = load64(expr + 16)
  arms = load64(expr + 24)

  scrutinee_reg = lower_expr(ctx, scrutinee)

  // Check if this is a value match or enum match (pat_type at offset 24: 0=enum, 1+=value)
  first_arm = arms.get(0)
  first_pat = load64(first_arm)
  first_pat_type = load64(first_pat + 24)
  if first_pat_type > 0 {
    return lower_match_value(ctx, scrutinee_reg, arms)
  }

  // Get enum tag
  tag_reg = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_enum_tag(tag_reg, scrutinee_reg))
  ctx_set_reg_type(ctx, tag_reg, IRTY_INT)

  // Alloca for the result
  result_ptr = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_alloca(result_ptr))

  merge_label = ctx_fresh_label(ctx)
  num_arms = arms.len()

  i := 0
  while i < num_arms {
    arm = arms.get(i)
    // arm layout: [pattern, body_expr, 0]
    pattern = load64(arm)
    body_expr = load64(arm + 8)

    // pattern layout: [enum_name, variant_name, bindings_array, 0]
    variant_name = load64(pattern + 8)
    bindings = load64(pattern + 16)

    // Look up variant tag from enum_defs
    tag_val = lower_match_lookup_tag(ctx, scrutinee_reg, variant_name)

    arm_label = ctx_fresh_label(ctx)

    if i < num_arms - 1 {
      next_label = ctx_fresh_label(ctx)
      // Compare tag
      tag_const = ctx_fresh_reg(ctx)
      ctx_emit(ctx, ir_const(tag_const, tag_val))
      ctx_set_reg_type(ctx, tag_const, IRTY_INT)
      cmp_reg = ctx_fresh_reg(ctx)
      ctx_emit(ctx, ir_cmpop(cmp_reg, IRCMP_EQ, tag_reg, tag_const))
      ctx_set_reg_type(ctx, cmp_reg, IRTY_BOOL)
      ctx_emit(ctx, ir_branch(cmp_reg, arm_label, next_label))

      ctx_emit(ctx, ir_label(arm_label))

      // Bind data fields
      lower_match_bindings(ctx, scrutinee_reg, bindings, variant_name)

      // Lower body
      body_reg = lower_expr(ctx, body_expr)
      ctx_emit(ctx, ir_store(result_ptr, body_reg))
      ctx_emit(ctx, ir_jump(merge_label))

      ctx_emit(ctx, ir_label(next_label))
      0
    } else {
      // Last arm --- always taken
      ctx_emit(ctx, ir_jump(arm_label))
      ctx_emit(ctx, ir_label(arm_label))

      // Bind data fields
      lower_match_bindings(ctx, scrutinee_reg, bindings, variant_name)

      // Lower body
      body_reg = lower_expr(ctx, body_expr)
      ctx_emit(ctx, ir_store(result_ptr, body_reg))
      ctx_emit(ctx, ir_jump(merge_label))
      0
    }

    i = i + 1
    0
  }

  ctx_emit(ctx, ir_label(merge_label))
  result_reg = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_load(result_reg, result_ptr))
  ctx_set_reg_type(ctx, result_reg, IRTY_INT)
  result_reg
}

// ------ lower_match_value: match on integers/strings/wildcards -----------------------------------------------
lower_match_value(ctx:I scrutinee_reg:I arms:I) I {
  result_ptr = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_alloca(result_ptr))
  merge_label = ctx_fresh_label(ctx)
  num_arms = arms.len()
  i := 0
  while i < num_arms {
    arm = arms.get(i)
    pattern = load64(arm)
    body_expr = load64(arm + 8)
    pat_type = load64(pattern + 24)
    pat_val = load64(pattern + 8)

    arm_label = ctx_fresh_label(ctx)

    guard_expr = load64(arm + 16)

    if pat_type == 3 || pat_type == 4 {  // wildcard or binding
      if pat_type == 4 {
        bind_name = load64(pattern + 8)
        ctx_set_local(ctx, bind_name, scrutinee_reg)
      }
      if guard_expr != 0 {
        guard_reg = lower_expr(ctx, guard_expr)
        next_guard_label = ctx_fresh_label(ctx)
        body_label = ctx_fresh_label(ctx)
        ctx_emit(ctx, ir_branch(guard_reg, body_label, next_guard_label))
        ctx_emit(ctx, ir_label(body_label))
        body_reg = lower_expr(ctx, body_expr)
        ctx_emit(ctx, ir_store(result_ptr, body_reg))
        ctx_emit(ctx, ir_jump(merge_label))
        ctx_emit(ctx, ir_label(next_guard_label))
      } else {
        ctx_emit(ctx, ir_jump(arm_label))
        ctx_emit(ctx, ir_label(arm_label))
        body_reg = lower_expr(ctx, body_expr)
        ctx_emit(ctx, ir_store(result_ptr, body_reg))
        ctx_emit(ctx, ir_jump(merge_label))
      }
    } else if pat_type == 1 {  // integer value
      // Integer value pattern
      next_label = ctx_fresh_label(ctx)
      val_reg = ctx_fresh_reg(ctx)
      ctx_emit(ctx, ir_const(val_reg, pat_val))
      ctx_set_reg_type(ctx, val_reg, IRTY_INT)
      cmp_reg = ctx_fresh_reg(ctx)
      ctx_emit(ctx, ir_cmpop(cmp_reg, IRCMP_EQ, scrutinee_reg, val_reg))
      ctx_set_reg_type(ctx, cmp_reg, IRTY_BOOL)
      ctx_emit(ctx, ir_branch(cmp_reg, arm_label, next_label))
      ctx_emit(ctx, ir_label(arm_label))
      body_reg = lower_expr(ctx, body_expr)
      ctx_emit(ctx, ir_store(result_ptr, body_reg))
      ctx_emit(ctx, ir_jump(merge_label))
      ctx_emit(ctx, ir_label(next_label))
    } else if pat_type == 2 {  // string value
      // String value pattern — compare with string equality via starts_with + length check
      next_label = ctx_fresh_label(ctx)
      str_reg = ctx_fresh_reg(ctx)
      ctx_emit(ctx, ir_string_const(str_reg, pat_val))
      ctx_set_reg_type(ctx, str_reg, IRTY_STR)
      // Use string_contains(scrutinee, pat) && len(scrutinee) == len(pat) for equality
      // Simpler: emit IR_STRING_STARTS_WITH and IR_STRING_LEN checks
      sw_reg = ctx_fresh_reg(ctx)
      ctx_emit(ctx, ir_inst2(IR_STRING_STARTS_WITH, sw_reg, scrutinee_reg, str_reg))
      len1_reg = ctx_fresh_reg(ctx)
      ctx_emit(ctx, ir_inst1(IR_STRING_LEN, len1_reg, scrutinee_reg))
      len2_reg = ctx_fresh_reg(ctx)
      ctx_emit(ctx, ir_inst1(IR_STRING_LEN, len2_reg, str_reg))
      len_eq = ctx_fresh_reg(ctx)
      ctx_emit(ctx, ir_cmpop(len_eq, IRCMP_EQ, len1_reg, len2_reg))
      cmp_reg = ctx_fresh_reg(ctx)
      ctx_emit(ctx, ir_binop(cmp_reg, OP_MUL, sw_reg, len_eq))
      ctx_set_reg_type(ctx, cmp_reg, IRTY_BOOL)
      ctx_emit(ctx, ir_branch(cmp_reg, arm_label, next_label))
      ctx_emit(ctx, ir_label(arm_label))
      body_reg = lower_expr(ctx, body_expr)
      ctx_emit(ctx, ir_store(result_ptr, body_reg))
      ctx_emit(ctx, ir_jump(merge_label))
      ctx_emit(ctx, ir_label(next_label))
    }
    i = i + 1
    0
  }
  ctx_emit(ctx, ir_label(merge_label))
  result_reg = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_load(result_reg, result_ptr))
  ctx_set_reg_type(ctx, result_reg, IRTY_INT)
  result_reg
}

// ------ lower_match_lookup_tag ------------------------------------------------------------------------------------------------------------------
// Look up the tag index for a variant name from enum_defs.
// enum_defs is Map: enum_name -> variants_array
// Each variant entry array: [tag_index, num_data, field_type1, ...]
// Variants are stored in order, so tag = position index.
// We search by comparing variant_name against enum_name from the pattern.
lower_match_lookup_tag(ctx:I scrutinee_reg:I variant_name:I) I {
  // We use the enum_defs to find which tag index a variant has.
  // Since enum_defs stores variants in order, tag = array index.
  // But we need to match by variant name, which isn't stored in vinfo_arr.
  // Instead, we look at the parser's enum AST to find the tag.
  // Workaround: search the enum_defs for the variant by name.
  // The enum variants from the parser are stored as [name@0, fields@8] pointers.
  // In the IR lower step, we built vinfo_arr from these, in order.
  // So the tag index IS the position in the vinfo_arr.
  // Since we don't store variant names in vinfo_arr, we need another approach.
  // We'll store a separate map: "EnumName::VariantName" -> tag_index
  // For now, use the enum_variant_tags map stored in the context.

  // Search the variant_tags map at ctx offset 88... but that's reg_struct_names.
  // Actually, let's use a simpler approach: search all enums' variant name arrays.
  // The enum_defs format after our change stores [tag_index, num_data, ...].
  // We need variant names too. Let's store them differently.

  // Simplest fix: iterate and use the variant index as the tag.
  // The variant_name comes from the match pattern. We need to find which
  // enum contains it and what its position is.
  // The tag is just the position within the enum definition.

  // Use the enum_variant_tag_map that we'll build in the lowering init
  tmap = load64(ctx + 96)  // variant_tag_map: "variant_name" -> tag_index
  if tmap != 0 && mhas(tmap, variant_name) { mget(tmap, variant_name) } else { 0 }
}

// ------ lower_match_bindings ------------------------------------------------------------------------------------------------------------------------
lower_match_bindings(ctx:I scrutinee_reg:I bindings:I variant_name:I) I {
  // Look up field types from variant_fields_map
  vfmap = load64(ctx + 104)
  field_types = if vfmap != 0 && mhas(vfmap, variant_name) { mget(vfmap, variant_name) } else { 0 }
  i := 0
  while i < bindings.len() {
    binding_name = bindings.get(i)
    data_reg = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_enum_data(data_reg, scrutinee_reg, i))
    // Determine the IR type from the field type name
    irty := IRTY_INT
    if field_types != 0 && i < field_types.len() {
      ft_name = field_types.get(i)
      irty = ir_type_for_return(ft_name, ctx_struct_defs(ctx), ctx_enum_defs(ctx))
    }
    ctx_set_reg_type(ctx, data_reg, irty)
    ctx_set_local(ctx, binding_name, data_reg)
    i = i + 1
    0
  }
  0
}

// ------ lower_lambda ------------------------------------------------------------------------------------------------------------------------------------------------
// Compile lambda body as a lifted function and emit FnRef.
// Handles both non-capturing and capturing lambdas.
lower_lambda(ctx:I expr:I) I {
  params = load64(expr + 16)
  ret_type = load64(expr + 24)
  body_stmts = load64(expr + 32)

  // Generate unique lambda name using lambda counter
  lambda_id = ctx_fresh_lambda_id(ctx)
  lambda_name = "__lambda_" + itos(lambda_id)

  // Find captured variables: variables referenced in body that are defined
  // in the enclosing scope (in ctx locals) but not in lambda params
  param_name_set = M()
  pi := 0
  while pi < params.len() {
    p = params.get(pi)
    mset(param_name_set, load64(p), 1)
    pi = pi + 1
    0
  }
  captures = find_captures_in_stmts(body_stmts, param_name_set, ctx)
  if captures.len() > 8 {
    p("error: closure has " + itos(captures.len()) + " captures, max supported is 8")
    exit(1)
  }

  // Create a new lowering context for the lambda body
  lctx = make_lower_ctx(ctx_struct_defs(ctx), ctx_enum_defs(ctx), ctx_fn_ret_types(ctx), ctx_global_names(ctx))
  store64(lctx + 96, load64(ctx + 96))   // variant_tag_map
  store64(lctx + 104, load64(ctx + 104)) // variant_fields_map
  store64(lctx + 136, load64(ctx + 136)) // fn_ret_struct_names
  store64(lctx + 144, load64(ctx + 144)) // module_name
  store64(lctx + 152, load64(ctx + 152)) // local_fn_set
  store64(lctx + 160, load64(ctx + 160)) // imported_fn_names
  store64(lctx + 168, load64(ctx + 168)) // fn_param_defaults
  // Share lambda counter to avoid collisions with nested lambdas
  store64(lctx + 120, load64(ctx + 120))

  // Add capture params first (they come before the actual params)
  lifted_param_names = array<I>()
  lifted_param_sizes = array<I>()
  ci := 0
  while ci < captures.len() {
    cap_name = captures.get(ci)
    arg_reg = "arg" + itos(ci)
    ctx_set_local(lctx, cap_name, arg_reg)
    // Copy type from enclosing scope
    enc_reg = ctx_get_local(ctx, cap_name)
    if enc_reg != 0 {
      ety = ctx_get_reg_type(ctx, enc_reg)
      ctx_set_reg_type(lctx, arg_reg, ety)
      // Copy struct name if applicable
      esn = ctx_get_struct_name(ctx, enc_reg)
      if esn != 0 { ctx_set_struct_name(lctx, arg_reg, esn) }
    }
    lifted_param_names.push(arg_reg)
    lifted_param_sizes.push(0)
    ci = ci + 1
    0
  }

  // Add actual lambda params
  li := 0
  while li < params.len() {
    p = params.get(li)
    pname = load64(p)
    ptype = load64(p + 8)
    arg_reg = "arg" + itos(captures.len() + li)
    ctx_set_local(lctx, pname, arg_reg)
    // Set type
    if ptype == "I" { ctx_set_reg_type(lctx, arg_reg, IRTY_INT) }
    else if ptype == "Int" { ctx_set_reg_type(lctx, arg_reg, IRTY_INT) }
    else if ptype == "F" { ctx_set_reg_type(lctx, arg_reg, IRTY_FLOAT) }
    else if ptype == "Float" { ctx_set_reg_type(lctx, arg_reg, IRTY_FLOAT) }
    else if ptype == "B" { ctx_set_reg_type(lctx, arg_reg, IRTY_BOOL) }
    else if ptype == "Bool" { ctx_set_reg_type(lctx, arg_reg, IRTY_BOOL) }
    else if ptype == "S" { ctx_set_reg_type(lctx, arg_reg, IRTY_STR) }
    else if ptype == "String" { ctx_set_reg_type(lctx, arg_reg, IRTY_STR) }
    else { ctx_set_reg_type(lctx, arg_reg, IRTY_INT) }
    lifted_param_names.push(arg_reg)
    lifted_param_sizes.push(0)
    li = li + 1
    0
  }

  // Lower body statements --- last statement is return value
  bj := 0
  while bj < body_stmts.len() {
    is_last = bj == body_stmts.len() - 1
    stmt = body_stmts.get(bj)
    if is_last == 1 {
      stag = load64(stmt)
      if stag == ST_EXPR {
        bexpr = load64(stmt + 16)
        reg = lower_expr(lctx, bexpr)
        ctx_emit(lctx, ir_ret(reg))
      } else { if stag == ST_RETURN {
        val_expr = load64(stmt + 16)
        reg = lower_expr(lctx, val_expr)
        ctx_emit(lctx, ir_ret(reg))
      } else {
        lower_stmt(lctx, stmt)
      } }
    } else {
      lower_stmt(lctx, stmt)
    }
    bj = bj + 1
    0
  }

  // Sync lambda counter back from nested context
  store64(ctx + 120, load64(lctx + 120))

  // Create IrFunction for the lifted lambda
  lifted_fn = make_ir_function(lambda_name, lifted_param_names, ctx_instrs(lctx), IRTY_INT, lifted_param_sizes)

  // Add to lifted functions list (parent ctx)
  lifted = ctx_lifted_fns(ctx)
  lifted.push(lifted_fn)
  // Also add any nested lifted fns from the lambda's context
  nested_lifted = ctx_lifted_fns(lctx)
  nli := 0
  while nli < nested_lifted.len() {
    lifted.push(nested_lifted.get(nli))
    nli = nli + 1
    0
  }

  // Store closure info so call sites can emit direct calls with captures prepended
  // closure_info maps: lambda_name -> [lambda_name, cap0_name, cap1_name, ...]
  cinfo = array<I>()
  cinfo.push(lambda_name)
  cci := 0
  while cci < captures.len() {
    cinfo.push(captures.get(cci))
    cci = cci + 1
    0
  }

  // Emit FnRef for the lambda
  fn_ref_reg = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_fn_ref(fn_ref_reg, lambda_name))
  ctx_set_reg_type(ctx, fn_ref_reg, IRTY_INT)

  if captures.len() > 0 {
    // Capturing lambda: allocate closure object as struct [fn_ptr, ncaps, cap0, cap1, ...]
    // Tag pointer with +1 so fcall can distinguish closures from raw fn ptrs
    num_fields = 2 + captures.len()
    closure_reg = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_struct_alloc(closure_reg, num_fields))
    // Field 0 = fn pointer
    ctx_emit(ctx, ir_field_store(closure_reg, 0, fn_ref_reg))
    // Field 1 = num captures
    ncap_reg = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_const(ncap_reg, captures.len()))
    ctx_emit(ctx, ir_field_store(closure_reg, 1, ncap_reg))
    // Fields 2..N = capture values
    sci := 0
    while sci < captures.len() {
      cap_name = captures.get(sci)
      cap_reg = ctx_get_local(ctx, cap_name)
      ctx_emit(ctx, ir_field_store(closure_reg, 2 + sci, cap_reg))
      sci = sci + 1
      0
    }
    // Tag pointer: closure_reg + 1
    one_reg = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_const(one_reg, 1))
    tagged_reg = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_binop(tagged_reg, OP_ADD, closure_reg, one_reg))
    ctx_set_reg_type(ctx, tagged_reg, IRTY_INT)

    // Store closure info keyed by the tagged register for intra-module direct calls
    ci_map = ctx_closure_info(ctx)
    mset(ci_map, tagged_reg, cinfo)

    tagged_reg
  } else {
    // Non-capturing: just use raw fn pointer
    // Store closure info keyed by the dest register name
    ci_map = ctx_closure_info(ctx)
    mset(ci_map, fn_ref_reg, cinfo)

    fn_ref_reg
  }
}

// Find captured variables in a list of statements
// Returns array of variable names that are in enclosing scope but not in param_set
find_captures_in_stmts(stmts:I param_set:I ctx:I) I {
  result = array<I>()
  seen = M()
  find_captures_stmts(stmts, param_set, ctx, result, seen, M())
  result
}

find_captures_stmts(stmts:I param_set:I ctx:I result:I seen:I local_set:I) I {
  i := 0
  while i < stmts.len() {
    find_captures_stmt(stmts.get(i), param_set, ctx, result, seen, local_set)
    i = i + 1
    0
  }
  0
}

find_captures_stmt(stmt:I param_set:I ctx:I result:I seen:I local_set:I) I {
  stag = load64(stmt)
  if stag == ST_EXPR { find_captures_expr(load64(stmt + 16), param_set, ctx, result, seen, local_set) }
  else if stag == ST_LET {
    // ST_LET layout: [tag, size, name, mutable, type_ptr, value_expr, line, col]
    val = load64(stmt + 40)
    find_captures_expr(val, param_set, ctx, result, seen, local_set)
    // Add the let-bound name to local_set so it's not treated as a capture
    mset(local_set, load64(stmt + 16), 1)
  }
  else if stag == ST_ASSIGN {
    find_captures_expr(load64(stmt + 24), param_set, ctx, result, seen, local_set)
    // The assigned name might itself be a capture
    aname = load64(stmt + 16)
    if mget(param_set, aname) == 0 && mget(local_set, aname) == 0 && mget(seen, aname) == 0 && ctx_get_local(ctx, aname) != 0 {
      mset(seen, aname, 1)
      result.push(aname)
    }
  }
  else if stag == ST_RETURN { find_captures_expr(load64(stmt + 16), param_set, ctx, result, seen, local_set) }
  else if stag == ST_IF {
    find_captures_expr(load64(stmt + 16), param_set, ctx, result, seen, local_set)
    find_captures_stmts(load64(stmt + 24), param_set, ctx, result, seen, local_set)
    else_stmts = load64(stmt + 32)
    if else_stmts != 0 { find_captures_stmts(else_stmts, param_set, ctx, result, seen, local_set) }
  }
  else if stag == ST_WHILE {
    find_captures_expr(load64(stmt + 16), param_set, ctx, result, seen, local_set)
    find_captures_stmts(load64(stmt + 24), param_set, ctx, result, seen, local_set)
  } else { 0 }
}

find_captures_expr(expr:I param_set:I ctx:I result:I seen:I local_set:I) I {
  if expr == 0 { return 0 }
  etag = load64(expr)
  if etag == EX_IDENT {
    name = load64(expr + 16)
    // It's a capture if: not a param, not locally defined, not already seen, and exists in enclosing ctx
    if mget(param_set, name) == 0 && mget(local_set, name) == 0 && mget(seen, name) == 0 && ctx_get_local(ctx, name) != 0 {
      mset(seen, name, 1)
      result.push(name)
    }
  }
  else if etag == EX_CALL {
    // EX_CALL: [tag, size, name_ptr(string), args_arr, line, col] — name is a string, not an expression
    args = load64(expr + 24)
    ai := 0
    while ai < args.len() {
      find_captures_expr(args.get(ai), param_set, ctx, result, seen, local_set)
      ai = ai + 1
      0
    }
  }
  else if etag == EX_BINOP {
    find_captures_expr(load64(expr + 24), param_set, ctx, result, seen, local_set)
    find_captures_expr(load64(expr + 32), param_set, ctx, result, seen, local_set)
  }
  else if etag == EX_UNARYOP {
    find_captures_expr(load64(expr + 24), param_set, ctx, result, seen, local_set)
  }
  else if etag == EX_METHOD_CALL {
    find_captures_expr(load64(expr + 16), param_set, ctx, result, seen, local_set)
    args = load64(expr + 32)
    ai := 0
    while ai < args.len() {
      find_captures_expr(args.get(ai), param_set, ctx, result, seen, local_set)
      ai = ai + 1
      0
    }
  }
  else if etag == EX_FIELD_ACCESS {
    find_captures_expr(load64(expr + 16), param_set, ctx, result, seen, local_set)
  }
  else if etag == EX_IF {
    find_captures_expr(load64(expr + 16), param_set, ctx, result, seen, local_set)
    find_captures_expr(load64(expr + 24), param_set, ctx, result, seen, local_set)
    find_captures_expr(load64(expr + 32), param_set, ctx, result, seen, local_set)
  }
  else if etag == EX_ARRAY_LIT {
    elems = load64(expr + 16)
    ai := 0
    while ai < elems.len() {
      find_captures_expr(elems.get(ai), param_set, ctx, result, seen, local_set)
      ai = ai + 1
      0
    }
  }
  else if etag == EX_TUPLE_LIT {
    elems = load64(expr + 16)
    ai := 0
    while ai < elems.len() {
      find_captures_expr(elems.get(ai), param_set, ctx, result, seen, local_set)
      ai = ai + 1
      0
    }
  }
  else if etag == EX_LAMBDA {
    // Scan nested lambda body for captures from the enclosing scope
    inner_params = load64(expr + 16)
    inner_body = load64(expr + 32)
    // Inner lambda's params are local to it, not captures
    inner_local = M()
    ipi := 0
    while ipi < inner_params.len() {
      mset(inner_local, load64(inner_params.get(ipi)), 1)
      ipi = ipi + 1
      0
    }
    find_captures_stmts(inner_body, param_set, ctx, result, seen, inner_local)
  }
  0
}

// ------ lower_array_lit ---------------------------------------------------------------------------------------------------------------------------------------
lower_array_lit(ctx:I expr:I) I {
  elements = load64(expr + 16)

  dest = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_inst0(IR_ARRAY_CREATE, dest))

  i := 0
  while i < elements.len() {
    val_reg = lower_expr(ctx, elements.get(i))
    // Track element type from first element
    if i == 0 { ctx_set_reg_type(ctx, dest, IRTY_ARRAY) }
    ctx_emit(ctx, ir_inst1(IR_ARRAY_PUSH, dest, val_reg))
    i = i + 1
    0
  }
  ctx_set_reg_type(ctx, dest, IRTY_ARRAY)
  dest
}

// ------ ir_find_dd: find first $$ in string, return index or -1 ---
ir_find_dd(s:I) I {
  len = slen(s)
  i := 0
  while i < len - 1 {
    if char_at(s, i) == 36 && char_at(s, i + 1) == 36 { return i }
    i += 1
    0
  }
  0 - 1
}

// ------ resolve_generic_struct_fields: look up mangled generic name in struct_defs ------------------------------------------
// Returns field names array or 0 if not a generic struct
resolve_generic_struct_fields(sd:I name:I) I {
  // Already resolved?
  if mhas(sd, name) == 1 { return mget(sd, name) }
  // Find "$$" in name
  sname_len = slen(name)
  dp := 0 - 1
  di := 0
  while di < sname_len - 1 {
    if char_at(name, di) == 36 && char_at(name, di + 1) == 36 {
      dp = di
      di = sname_len
    }
    di += 1
    0
  }
  if dp < 0 { return 0 }
  base = name.substring(0, dp)
  gt = mget(sd, "$$generic_templates$$")
  if gt == 0 { return 0 }
  tmpl_fields = mget(gt, base)
  if tmpl_fields == 0 { return 0 }
  mset(sd, name, tmpl_fields)
  // Also resolve field types for nested struct access
  gfull = mget(sd, "$$generic_full$$")
  ftmap = mget(sd, "$$field_types$$")
  if gfull != 0 && ftmap != 0 {
    full_fields = mget(gfull, base)
    if full_fields != 0 {
      // Extract unique type param names from field types (in order of first appearance)
      tparam_names = array<I>()
      tparam_seen = M()
      tpi_scan := 1
      while tpi_scan < full_fields.len() {
        ft = full_fields.get(tpi_scan)
        ft_s = ir_s(ft)
        ft_len = slen(ft_s)
        // Type params are short identifiers (1-2 chars, all uppercase)
        is_tp := 0
        if ft_len >= 1 && ft_len <= 2 {
          fc = char_at(ft_s, 0)
          if fc >= 65 && fc <= 90 {
            // Check it's not a known primitive type alias
            if ft_s != "I" && ft_s != "S" && ft_s != "B" && ft_s != "F" && ft_s != "M" {
              is_tp = 1
              0
            }
            0
          }
          0
        }
        if is_tp == 1 && mhas(tparam_seen, ft) == 0 {
          tparam_names.push(ft)
          mset(tparam_seen, ft, 1)
          0
        }
        tpi_scan += 2
        0
      }
      // Build type param -> concrete type name map by parsing mangled name
      num_tp = tparam_names.len()
      if num_tp > 0 {
        rest_str = name.substring(dp + 2, sname_len)
        // Split rest by $$ into segments
        tp_segments = array<I>()
        rr := rest_str
        while slen(rr) > 0 {
          ndd = ir_find_dd(rr)
          if ndd >= 0 {
            tp_segments.push(rr.substring(0, ndd))
            rr = rr.substring(ndd + 2, slen(rr))
          } else {
            tp_segments.push(rr)
            rr = ""
          }
          0
        }
        // Distribute segments to type params (same logic as typeck)
        tp_concrete_map = M()
        nseg = tp_segments.len()
        if nseg <= num_tp {
          tci := 0
          while tci < nseg {
            mset(tp_concrete_map, tparam_names[tci], tp_segments[tci])
            tci += 1
            0
          }
          0
        } else {
          excess = nseg - num_tp
          first_concrete := ir_s(tp_segments[0])
          fci := 1
          while fci <= excess {
            first_concrete = first_concrete + "$$" + ir_s(tp_segments[fci])
            fci += 1
            0
          }
          mset(tp_concrete_map, tparam_names[0], ptr(first_concrete))
          rci := excess + 1
          tpi_idx := 1
          while rci < nseg {
            mset(tp_concrete_map, tparam_names[tpi_idx], tp_segments[rci])
            rci += 1
            tpi_idx += 1
            0
          }
          0
        }
        // Now substitute field types
        ffi := 0
        while ffi < full_fields.len() {
          ff_name = full_fields.get(ffi)
          ff_type = full_fields.get(ffi + 1)
          concrete_type = if mhas(tp_concrete_map, ff_type) == 1 { mget(tp_concrete_map, ff_type) } else { ff_type }
          ft_key = ir_s(name) + "." + ir_s(ff_name)
          mset(ftmap, ft_key, concrete_type)
          // If the concrete type is itself a generic struct, resolve it too
          ct_str = ir_s(concrete_type)
          if ir_find_dd(ct_str) >= 0 && mhas(sd, ct_str) == 0 {
            resolve_generic_struct_fields(sd, ct_str)
            0
          }
          ffi += 2
          0
        }
        0
      }
      0
    }
    0
  }
  tmpl_fields
}

// ------ lower_struct_lit ------------------------------------------------------------------------------------------------------------------------------------
lower_struct_lit(ctx:I expr:I) I {
  name = load64(expr + 16)
  field_names = load64(expr + 24)
  field_values = load64(expr + 32)

  // Look up struct definition to get field order; try generic instantiation first
  sd = ctx_struct_defs(ctx)
  resolve_generic_struct_fields(sd, name)
  struct_fields = mget(sd, name)
  num_fields = if struct_fields != 0 { struct_fields.len() } else { field_names.len() }

  dest = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_struct_alloc(dest, num_fields))
  ctx_set_reg_type(ctx, dest, IRTY_STRUCT)
  ctx_set_struct_name(ctx, dest, name)

  // Build map from field name -> (index + 1) for O(1) lookup with proper string comparison
  // Store index+1 so that index 0 is distinguishable from "not found" (mget returns 0)
  field_index_map = M()
  if struct_fields != 0 {
    j := 0
    while j < struct_fields.len() {
      mset(field_index_map, struct_fields.get(j), j + 1)
      j = j + 1
      0
    }
    0
  }

  i := 0
  while i < field_names.len() {
    fname = field_names.get(i)
    val_reg = lower_expr(ctx, field_values.get(i))

    // Find field index in struct definition
    field_idx := i
    if struct_fields != 0 {
      looked_up = mget(field_index_map, fname)
      if looked_up != 0 { field_idx = looked_up - 1
        0 }
      0
    }

    ctx_emit(ctx, ir_field_store(dest, field_idx, val_reg))
    i = i + 1
    0
  }
  dest
}

// ------ lower_tuple_lit ---------------------------------------------------------------------------------------------------------------------------------------
lower_tuple_lit(ctx:I expr:I) I {
  elements = load64(expr + 16)
  num_fields = elements.len()

  dest = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_struct_alloc(dest, num_fields))
  ctx_set_reg_type(ctx, dest, IRTY_TUPLE)

  i := 0
  while i < num_fields {
    val_reg = lower_expr(ctx, elements.get(i))
    ctx_emit(ctx, ir_field_store(dest, i, val_reg))
    i = i + 1
    0
  }
  dest
}

// ------ lower_enum_variant ------------------------------------------------------------------------------------------------------------------------------
lower_enum_variant(ctx:I expr:I) I {
  enum_name = load64(expr + 16)
  variant_name = load64(expr + 24)
  args = load64(expr + 32)

  // Look up tag from variant_tag_map
  tmap = load64(ctx + 96)
  tag_idx = if tmap != 0 && mhas(tmap, variant_name) { mget(tmap, variant_name) } else { 0 }

  // Compute max_data from all variants in this enum
  ed = ctx_enum_defs(ctx)
  variants = mget(ed, enum_name)
  max_data := 0
  if variants != 0 {
    i := 0
    while i < variants.len() {
      v = variants.get(i)
      // entry array: [tag_index, num_data, ...]; access element at index 1
      vnum = v.get(1)
      if vnum > max_data { max_data = vnum
        0 }
      i = i + 1
      0
    }
    0
  }

  dest = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_enum_alloc(dest, tag_idx, max_data))
  ctx_set_reg_type(ctx, dest, IRTY_ENUM)

  // Store each arg as data field (offset by 1 for tag at index 0)
  i := 0
  while i < args.len() {
    arg_reg = lower_expr(ctx, args.get(i))
    ctx_emit(ctx, ir_field_store(dest, i + 1, arg_reg))
    i = i + 1
    0
  }
  dest
}

// ------ lower_spawn ---------------------------------------------------------------------------------------------------------------------------------------------------
lower_spawn(ctx:I expr:I) I {
  func_name = load64(expr + 16)
  args = load64(expr + 24)

  arg_regs = array<I>()
  i := 0
  while i < args.len() {
    arg_regs.push(lower_expr(ctx, args.get(i)))
    i = i + 1
    0
  }

  dest = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_thread_spawn(dest, func_name, arg_regs))
  ctx_set_reg_type(ctx, dest, IRTY_JOIN_HANDLE)
  dest
}

// ------ lower_mutex ---------------------------------------------------------------------------------------------------------------------------------------------------
lower_mutex(ctx:I expr:I) I {
  value_expr = load64(expr + 16)
  val_reg = lower_expr(ctx, value_expr)
  dest = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_mutex_create(dest, val_reg))
  ctx_set_reg_type(ctx, dest, IRTY_MUTEX)
  dest
}

// ------ lower_array_create ------------------------------------------------------------------------------------------------------------------------------
lower_array_create(ctx:I expr:I) I {
  ac_elem_type = load64(expr + 16)
  dest = ctx_fresh_reg(ctx)
  ctx_emit(ctx, ir_inst0(IR_ARRAY_CREATE, dest))
  ctx_set_reg_type(ctx, dest, IRTY_ARRAY)
  // Track dyn trait element type for polymorphic dispatch
  if ac_elem_type != 0 {
    ac_et_s = ir_s(ac_elem_type)
    if ac_et_s.sw("dyn ") == 1 {
      ac_tname = ac_et_s.substring(4, slen(ac_et_s))
      ctx_set_struct_name(ctx, dest, ptr("dyn::" + ac_tname))
    }
  }
  dest
}

// ------ ir_type_for_return ------------------------------------------------------------------------------------------------------------------------------
// Convert a type name string to an IrType tag for return type tracking.
ir_type_for_return(type_name:I struct_defs:I enum_defs:I) I {
  if type_name == 0 { IRTY_INT }
  else if type_name == "I" { IRTY_INT }
  else if type_name == "Int" { IRTY_INT }
  else if type_name == "F" { IRTY_FLOAT }
  else if type_name == "Float" { IRTY_FLOAT }
  else if type_name == "B" { IRTY_BOOL }
  else if type_name == "Bool" { IRTY_BOOL }
  else if type_name == "S" { IRTY_STR }
  else if type_name == "String" { IRTY_STR }
  else if type_name == "M" { IRTY_MAP }
  else if type_name == "Map" { IRTY_MAP }
  else if type_name.sw("M<I") || type_name.sw("Map<I") { IRTY_MAP_INT }
  else if type_name.sw("M<S") || type_name.sw("Map<S") { IRTY_MAP }
  else if type_name == "J" { IRTY_JSON }
  else if type_name == "JsonValue" { IRTY_JSON }
  else if type_name == "HttpResponse" { IRTY_HTTP_RESP }
  else if type_name == "HttpRequest" { IRTY_HTTP_REQ }
  else if type_name == "HR" { IRTY_HTTP_REQ }
  else if type_name == "HttpServer" { IRTY_HTTP_SERVER }
  else if type_name == "HS" { IRTY_HTTP_SERVER }
  else if type_name == "JoinHandle" { IRTY_JOIN_HANDLE }
  // Starts with checks for generic types
  else if type_name.sw("Array<") { IRTY_ARRAY }
  else if type_name.sw("[") { IRTY_ARRAY }
  else if type_name.sw("Sender") { IRTY_SENDER }
  else if type_name.sw("Receiver") { IRTY_RECEIVER }
  else if type_name.sw("Mutex") { IRTY_MUTEX }
  else if type_name.sw("Result<") { IRTY_RESULT }
  else if type_name.sw("R<") { IRTY_RESULT }
  else if type_name.sw("Option<") { IRTY_OPTION }
  else if type_name.sw("O<") { IRTY_OPTION }
  else if type_name.sw("(") { IRTY_TUPLE }
  else if type_name.sw("dyn ") { IRTY_DYN_TRAIT }
  // Check struct/enum defs
  else if mhas(struct_defs, type_name) == 1 { IRTY_STRUCT }
  else if mhas(enum_defs, type_name) == 1 { IRTY_ENUM }
  else { IRTY_INT }
}

// ------ map_has helper ------------------------------------------------------------------------------------------------------------------------------------------
// Check if a Map contains a key (returns 1 or 0)
map_has(m:I key:I) I {
  v = mget(m, key)
  if v != 0 { 1 } else { 0 }
}

// ------ struct_size_for_param ---------------------------------------------------------------------------------------------------------------------
// Returns number of fields if type is a struct, tag+max_data if enum,
// element count if tuple, 0 for scalars.
struct_size_for_param(type_name:I struct_defs:I enum_defs:I) I {
  // Check struct
  if map_has(struct_defs, type_name) == 1 {
    fields = mget(struct_defs, type_name)
    fields.len()
  }
  // Check enum --- return 1 + max data fields across variants
  else if map_has(enum_defs, type_name) == 1 {
    variants = mget(enum_defs, type_name)
    max_data := 0
    i := 0
    while i < variants.len() {
      vinfo = variants.get(i)
      // vinfo is [tag_index, num_data_fields]
      nd = vinfo.get(1)
      if nd > max_data { max_data = nd }
      i = i + 1
      0
    }
    1 + max_data
  }
  // Check tuple --- count elements from "(I I I)"
  else if type_name.sw("(") {
    // Count spaces + 1 for number of tuple elements
    inner_len = slen(type_name) - 2
    if inner_len <= 0 { 0 }
    else {
      count := 1
      i := 1
      end = slen(type_name) - 1
      while i < end {
        if char_at(type_name, i) == 32 { count = count + 1 }
        i = i + 1
        0
      }
      count
    }
  }
  else { 0 }
}

// ------ lower_function_body ---------------------------------------------------------------------------------------------------------------------------
// Lower a single function's body, handling last-statement-as-return.
// Returns an IrFunction pointer.
lower_function_body(func:I func_name:I struct_defs:I enum_defs:I fn_ret_types:I global_names:I vtag_map:I vfields_map:I fn_ret_snames:I module_name:I local_fn_set:I imported_fn_names:I fn_param_defaults:I) I {
  // Create fresh context
  ctx = make_lower_ctx(struct_defs, enum_defs, fn_ret_types, global_names)
  store64(ctx + 96, vtag_map)
  store64(ctx + 104, vfields_map)
  store64(ctx + 136, fn_ret_snames)
  store64(ctx + 144, module_name)
  store64(ctx + 152, local_fn_set)
  store64(ctx + 160, imported_fn_names)
  store64(ctx + 168, fn_param_defaults)

  // Set up params
  params_ast = load64(func + 8)   // Array of Param pointers [name@0, type@8]
  nparams = params_ast.len()
  param_names = array<I>()
  param_sizes = array<I>()

  i := 0
  while i < params_ast.len() {
    p = params_ast.get(i)
    pname = load64(p)
    ptype = load64(p + 8)
    arg_reg = "arg" + itos(i)

    // Set local binding
    ctx_set_local(ctx, pname, arg_reg)

    // Set param type in reg_types
    if ptype == "I" { ctx_set_reg_type(ctx, arg_reg, IRTY_INT) }
    else if ptype == "Int" { ctx_set_reg_type(ctx, arg_reg, IRTY_INT) }
    else if ptype == "F" { ctx_set_reg_type(ctx, arg_reg, IRTY_FLOAT) }
    else if ptype == "Float" { ctx_set_reg_type(ctx, arg_reg, IRTY_FLOAT) }
    else if ptype == "B" { ctx_set_reg_type(ctx, arg_reg, IRTY_BOOL) }
    else if ptype == "Bool" { ctx_set_reg_type(ctx, arg_reg, IRTY_BOOL) }
    else if ptype == "S" { ctx_set_reg_type(ctx, arg_reg, IRTY_STR) }
    else if ptype == "String" { ctx_set_reg_type(ctx, arg_reg, IRTY_STR) }
    else if ptype == "M" { ctx_set_reg_type(ctx, arg_reg, IRTY_MAP) }
    else if ptype == "Map" { ctx_set_reg_type(ctx, arg_reg, IRTY_MAP) }
    else if ptype == "JsonValue" { ctx_set_reg_type(ctx, arg_reg, IRTY_JSON) }
    else if ptype == "HttpResponse" { ctx_set_reg_type(ctx, arg_reg, IRTY_HTTP_RESP) }
    else if ptype == "HttpRequest" { ctx_set_reg_type(ctx, arg_reg, IRTY_HTTP_REQ) }
    else if ptype == "HR" { ctx_set_reg_type(ctx, arg_reg, IRTY_HTTP_REQ) }
    else if ptype == "HttpServer" { ctx_set_reg_type(ctx, arg_reg, IRTY_HTTP_SERVER) }
    else if ptype == "HS" { ctx_set_reg_type(ctx, arg_reg, IRTY_HTTP_SERVER) }
    else if ptype == "JoinHandle" { ctx_set_reg_type(ctx, arg_reg, IRTY_JOIN_HANDLE) }
    else if mhas(struct_defs, ptype) == 1 { ctx_set_reg_type(ctx, arg_reg, IRTY_STRUCT)
      ctx_set_struct_name(ctx, arg_reg, ptype) }
    else if mhas(enum_defs, ptype) == 1 { ctx_set_reg_type(ctx, arg_reg, IRTY_ENUM) }
    else if ptype.sw("Array") { ctx_set_reg_type(ctx, arg_reg, IRTY_ARRAY) }
    else if ptype.sw("[") { ctx_set_reg_type(ctx, arg_reg, IRTY_ARRAY) }
    else if ptype.sw("Result") { ctx_set_reg_type(ctx, arg_reg, IRTY_RESULT) }
    else if ptype.sw("R<") { ctx_set_reg_type(ctx, arg_reg, IRTY_RESULT) }
    else if ptype.sw("(") { ctx_set_reg_type(ctx, arg_reg, IRTY_TUPLE) }
    else if ptype.sw("Sender") { ctx_set_reg_type(ctx, arg_reg, IRTY_SENDER) }
    else if ptype.sw("Receiver") { ctx_set_reg_type(ctx, arg_reg, IRTY_RECEIVER) }
    else if ptype.sw("Mutex") { ctx_set_reg_type(ctx, arg_reg, IRTY_MUTEX) }
    else if ptype.sw("dyn ") { ctx_set_reg_type(ctx, arg_reg, IRTY_DYN_TRAIT)
      dyn_tname = ir_s(ptype).substring(4, slen(ptype))
      ctx_set_struct_name(ctx, arg_reg, ptr("dyn::" + dyn_tname)) }
    else { ctx_set_reg_type(ctx, arg_reg, IRTY_INT) }

    param_names.push(arg_reg)
    param_sizes.push(struct_size_for_param(ptype, struct_defs, enum_defs))

    i = i + 1
    0
  }

  // Lower body statements --- last statement is treated as return value
  body = load64(func + 24)  // Array of Stmt pointers
  j := 0
  while j < body.len() {
    is_last = j == body.len() - 1
    stmt = body.get(j)
    if is_last == 1 {
      stag = load64(stmt)
      // If last stmt is an expression or return, emit Ret
      if stag == ST_EXPR {
        expr = load64(stmt + 16)
        reg = lower_expr(ctx, expr)
        ctx_emit(ctx, ir_ret(reg))
      } else { if stag == ST_RETURN {
        val_expr = load64(stmt + 16)
        reg = lower_expr(ctx, val_expr)
        ctx_emit(ctx, ir_ret(reg))
      } else {
        lower_stmt(ctx, stmt)
      } }
    } else {
      lower_stmt(ctx, stmt)
    }
    j = j + 1
    0
  }

  // Determine return type
  ret_type_name = load64(func + 16)
  ret_type = if ret_type_name != 0 { ir_type_for_return(ret_type_name, struct_defs, enum_defs) } else { IRTY_INT }

  ir_fn = make_ir_function(func_name, param_names, ctx_instrs(ctx), ret_type, param_sizes)

  // Collect lifted functions (lambdas) from this function's context
  // We return them by storing in a temporary global-like mechanism:
  // The caller (lower_with_extra_structs) will read ctx_lifted_fns after this call
  // Store lifted fns in the function object temporarily at a known location
  // Actually, use a simpler approach: return an array [ir_fn, lifted0, lifted1, ...]
  result_arr = array<I>()
  result_arr.push(ir_fn)
  lfns = ctx_lifted_fns(ctx)
  lfi := 0
  while lfi < lfns.len() {
    result_arr.push(lfns.get(lfi))
    lfi = lfi + 1
    0
  }
  result_arr
}

// ------ lower ---------------------------------------------------------------------------------------------------------------------------------------------------------------------
// Top-level entry point: lower a parsed Program to an IrModule.
lower(program:I module_name:I module_fn_ret_types:I) I {
  lower_with_extra_structs(program, module_name, module_fn_ret_types, 0)
}

lower_with_globals(program:I module_name:I module_fn_ret_types:I extra_globals:I) I {
  lower_full(program, module_name, module_fn_ret_types, 0, extra_globals, 0)
}

lower_with_extra_structs(program:I module_name:I module_fn_ret_types:I extra_struct_defs:I) I {
  lower_full(program, module_name, module_fn_ret_types, extra_struct_defs, 0, 0)
}

lower_full(program:I module_name:I module_fn_ret_types:I extra_struct_defs:I extra_globals:I extra_snames:I) I {
  // 1. Collect struct definitions: name -> field names array
  struct_defs = M()
  // Merge extra_struct_defs first
  if extra_struct_defs != 0 {
    keys = extra_struct_defs.keys()
    ki := 0
    while ki < keys.len() {
      k = keys.get(ki)
      mset(struct_defs, k, mget(extra_struct_defs, k))
      ki = ki + 1
      0
    }
    0
  }

  // Collect from program's structs
  generic_struct_defs = M()
  generic_struct_full = M()   // base_name -> [name, type, name, type, ...] (full field info)
  struct_field_type_map = M()  // "StructName.fieldName" -> type_name (for nested struct field access)
  prog_structs = load64(program + 24)  // Array of StructDef pointers
  si := 0
  while si < prog_structs.len() {
    sdef = prog_structs.get(si)
    sname = load64(sdef)           // name
    stp = load64(sdef + 16)       // type_params ptr (non-zero for generic)
    if stp != 0 {
      // Generic template — store field names for later instantiation
      sfields = load64(sdef + 8)
      gfield_names = array<I>()
      gfi := 0
      while gfi < sfields.len() {
        gfield_names.push(sfields.get(gfi))
        gfi = gfi + 2
        0
      }
      mset(generic_struct_defs, sname, gfield_names)
      // Also store full field info for nested generic resolution
      mset(generic_struct_full, sname, sfields)
    } else {
      sfields = load64(sdef + 8)     // flat array [name0, type0, name1, type1, ...]
      // Build array of just field names and store field types
      field_names = array<I>()
      fi := 0
      while fi < sfields.len() {
        fname = sfields.get(fi)
        ftype = sfields.get(fi + 1)
        field_names.push(fname)
        // Store field type for struct field access type tracking
        ft_key = ir_s(sname) + "." + ir_s(fname)
        mset(struct_field_type_map, ft_key, ftype)
        fi = fi + 2
        0
      }
      mset(struct_defs, sname, field_names)
    }
    si = si + 1
    0
  }
  // Store generic_struct_defs in struct_defs for access during lowering
  mset(struct_defs, "$$generic_templates$$", generic_struct_defs)
  mset(struct_defs, "$$generic_full$$", generic_struct_full)
  mset(struct_defs, "$$field_types$$", struct_field_type_map)

  // 2. Collect enum definitions: name -> array of [variant_name, tag, num_data] arrays
  enum_defs = M()
  variant_tag_map = M()       // variant_name -> tag_index
  variant_fields_map = M()    // variant_name -> array of field type name strings
  prog_enums = load64(program + 32)  // Array of EnumDef pointers
  ei := 0
  while ei < prog_enums.len() {
    edef = prog_enums.get(ei)
    ename = load64(edef)              // name
    evariants = load64(edef + 8)      // Array of EnumVariant pointers [name@0, fields@8]
    vinfo_arr = array<I>()
    vi := 0
    while vi < evariants.len() {
      variant = evariants.get(vi)
      vname = load64(variant)
      vfields = load64(variant + 8)
      num_data = if vfields != 0 { vfields.len() } else { 0 }
      // Store as [tag_index, num_data_fields, field_type_name1, field_type_name2, ...] array
      entry = array<I>()
      entry.push(vi)
      entry.push(num_data)
      vfi := 0
      while vfi < num_data {
        entry.push(vfields.get(vfi))
        vfi = vfi + 1
        0
      }
      vinfo_arr.push(entry)
      // Store variant name -> tag index and field types
      mset(variant_tag_map, vname, vi)
      if num_data > 0 { mset(variant_fields_map, vname, vfields) }
      vi = vi + 1
      0
    }
    mset(enum_defs, ename, vinfo_arr)
    ei = ei + 1
    0
  }

  // 3. Build fn_ret_types from program functions
  fn_ret_types = M()
  fn_ret_struct_names = M()
  prog_fns = load64(program + 16)  // Array of Function pointers
  nfns = prog_fns.len()
  fri := 0
  while fri < nfns {
    func = prog_fns.get(fri)
    fname = load64(func)
    ret_type_name = load64(func + 16)
    if ret_type_name != 0 {
      rt = ir_type_for_return(ret_type_name, struct_defs, enum_defs)
      if IRTY_INT != rt {
        mset(fn_ret_types, fname, rt)
        // Also store with mangled name for intra-module call resolution
        if module_name != 0 { mset(fn_ret_types, module_name + "__" + fname, rt) }
      }
      if rt == IRTY_STRUCT {
        mset(fn_ret_struct_names, fname, ret_type_name)
        if module_name != 0 { mset(fn_ret_struct_names, module_name + "__" + fname, ret_type_name) }
      }
      if rt == IRTY_DYN_TRAIT {
        drt_tname = ir_s(ret_type_name).substring(4, slen(ret_type_name))
        drt_sn = "dyn::" + drt_tname
        mset(fn_ret_struct_names, fname, ptr(drt_sn))
        if module_name != 0 { mset(fn_ret_struct_names, module_name + "__" + fname, ptr(drt_sn)) }
      }
    }
    fri = fri + 1
    0
  }
  // Merge cross-module fn_ret_struct_names
  if extra_snames != 0 {
    snkeys = extra_snames.keys()
    snki := 0
    while snki < snkeys.len() {
      snk = snkeys.get(snki)
      mset(fn_ret_struct_names, snk, mget(extra_snames, snk))
      snki = snki + 1
      0
    }
    0
  }

  // Merge module_fn_ret_types
  if module_fn_ret_types != 0 {
    mkeys = module_fn_ret_types.keys()
    mki := 0
    while mki < mkeys.len() {
      mk = mkeys.get(mki)
      mset(fn_ret_types, mk, mget(module_fn_ret_types, mk))
      mki = mki + 1
      0
    }
    0
  }

  // 3a2. Build fn_param_defaults: func name -> array of default expr ASTs
  fn_param_defaults = M()
  fpdi := 0
  while fpdi < nfns {
    func = prog_fns.get(fpdi)
    fname = load64(func)
    fparams_arr2 = load64(func + 8)
    fparams_p2 = load64(fparams_arr2)
    num_fp2 = load64(fparams_arr2 + 8)
    defaults = array<I>()
    has_defaults := 0
    dpi := 0
    while dpi < num_fp2 {
      p_node = load64(fparams_p2 + dpi * 8)
      p_default = load64(p_node + 16)
      defaults.push(p_default)
      if p_default != 0 { has_defaults = 1 }
      dpi += 1
      0
    }
    if has_defaults == 1 {
      mset(fn_param_defaults, fname, defaults)
      if module_name != 0 { mset(fn_param_defaults, module_name + "__" + fname, defaults) }
    }
    fpdi += 1
    0
  }

  // 3b. Register ALL local functions in fn_ret_types with mangled names
  // This ensures lower_call_user can find intra-module calls
  if module_name != 0 {
    lfni := 0
    while lfni < nfns {
      lfn = prog_fns.get(lfni)
      lfname = load64(lfn)
      mangled_fn = module_name + "__" + lfname
      // Always register with at least IRTY_INT so the name is findable
      if mhas(fn_ret_types, mangled_fn) == 0 {
        mset(fn_ret_types, mangled_fn, IRTY_INT)
      }
      lfni = lfni + 1
      0
    }
    0
  }

  // 3c. Build local_fn_set: map of ALL user-defined function names in this compilation unit
  // Always populated (not just for modules) so user functions take precedence over builtins
  local_fn_set = M()
  lfsi := 0
  while lfsi < nfns {
    lfsf = prog_fns.get(lfsi)
    lfs_name = load64(lfsf)
    mset(local_fn_set, lfs_name, 1)
    lfsi = lfsi + 1
    0
  }
  if module_name != 0 {
    // Also add impl method names as Type__method
    prog_impls_lfs = load64(program + 48)
    lfs_ii := 0
    while lfs_ii < prog_impls_lfs.len() {
      lfs_impl = prog_impls_lfs.get(lfs_ii)
      lfs_ttype = load64(lfs_impl + 8)
      lfs_methods = load64(lfs_impl + 16)
      lfs_mi := 0
      while lfs_mi < lfs_methods.len() {
        lfs_m = lfs_methods.get(lfs_mi)
        lfs_mname = load64(lfs_m)
        mset(local_fn_set, lfs_ttype + "__" + lfs_mname, 1)
        lfs_mi = lfs_mi + 1
        0
      }
      lfs_ii = lfs_ii + 1
      0
    }
    0
  }

  // 3d. Build imported_fn_names: bare name -> mangled name for cross-module calls
  imported_fn_names = M()
  prog_imports = load64(program)  // offset 0 = imports array
  if prog_imports.len() > 0 && module_fn_ret_types != 0 {
    // For each key in module_fn_ret_types (format "mod__func"), check if mod is an import
    mfrt_keys = module_fn_ret_types.keys()
    imp_ii := 0
    while imp_ii < prog_imports.len() {
      imp_raw = prog_imports.get(imp_ii)
      // Extract short module name: "models/user" -> "user"
      imp_slash := -1
      imp_si := 0
      while imp_si < slen(imp_raw) {
        if char_at(imp_raw, imp_si) == 47 { imp_slash = imp_si }
        imp_si = imp_si + 1
        0
      }
      imp_name = if imp_slash < 0 { imp_raw } else { imp_raw.substring(imp_slash + 1, slen(imp_raw)) }
      imp_prefix = imp_name + "__"
      imp_prefix_len = slen(imp_prefix)
      mfrt_ki := 0
      while mfrt_ki < mfrt_keys.len() {
        mfrt_key = mfrt_keys.get(mfrt_ki)
        if slen(mfrt_key) > imp_prefix_len {
          if mfrt_key.sw(imp_prefix) {
            bare_name = mfrt_key.substring(imp_prefix_len, slen(mfrt_key))
            mset(imported_fn_names, bare_name, mfrt_key)
          }
        }
        mfrt_ki = mfrt_ki + 1
        0
      }
      imp_ii = imp_ii + 1
      0
    }
    0
  }

  // 4. Collect global variable names, types, and init values
  globals_arr = array<I>()
  global_names = M()
  global_init_vals = M()
  prog_globals = load64(program + 8)  // Array of GlobalDef pointers
  nglobals = prog_globals.len()
  gi := 0
  while gi < nglobals {
    gdef = prog_globals.get(gi)
    gname = load64(gdef)
    gvalue = load64(gdef + 8)
    globals_arr.push(gname)
    // Determine type and extract init value from value expression
    vtag = load64(gvalue)
    if vtag == EX_INT_LIT {
      mset(global_names, gname, IRTY_INT)
      mset(global_init_vals, gname, load64(gvalue + 8))
    }
    if vtag == EX_FLOAT_LIT { mset(global_names, gname, IRTY_FLOAT) }
    if vtag == EX_BOOL_LIT {
      mset(global_names, gname, IRTY_BOOL)
      bval = load64(gvalue + 8)
      mset(global_init_vals, gname, bval)
    }
    if vtag == EX_STRING_LIT { mset(global_names, gname, IRTY_STR) }
    if vtag != EX_INT_LIT && vtag != EX_FLOAT_LIT && vtag != EX_BOOL_LIT && vtag != EX_STRING_LIT { mset(global_names, gname, IRTY_INT) }
    gi = gi + 1
    0
  }

  // Merge extra globals from imported modules (so we can distinguish globals from functions)
  if extra_globals != 0 {
    eg_keys = extra_globals.keys()
    egi := 0
    while egi < eg_keys.len() {
      egk = eg_keys.get(egi)
      if mhas(global_names, egk) == 0 {
        mset(global_names, egk, mget(extra_globals, egk))
      }
      egi = egi + 1
      0
    }
  }

  // 5. Lower each function
  ir_functions = array<I>()

  fi2 := 0
  while fi2 < prog_fns.len() {
    func = prog_fns.get(fi2)
    fname = load64(func)
    // Handle module name mangling
    func_name = if module_name != 0 { module_name + "__" + fname } else { fname }
    fn_result = lower_function_body(func, func_name, struct_defs, enum_defs, fn_ret_types, global_names, variant_tag_map, variant_fields_map, fn_ret_struct_names, module_name, local_fn_set, imported_fn_names, fn_param_defaults)
    // fn_result is [ir_fn, lifted0, lifted1, ...]
    ir_functions.push(fn_result.get(0))
    fri2 := 1
    while fri2 < fn_result.len() {
      ir_functions.push(fn_result.get(fri2))
      fri2 = fri2 + 1
      0
    }
    fi2 = fi2 + 1
    0
  }

  // 6. Lower impl block methods
  prog_impls = load64(program + 48)  // Array of ImplBlock pointers
  ii := 0
  while ii < prog_impls.len() {
    impl_block = prog_impls.get(ii)
    target_type = load64(impl_block + 8)
    impl_type_params_ptr = load64(impl_block + 24)
    methods = load64(impl_block + 16)

    if impl_type_params_ptr != 0 {
      // Generic impl — lower method for each monomorphized struct instance
      sd_keys = struct_defs.keys()
      sdk := 0
      while sdk < sd_keys.len() {
        sd_key = sd_keys.get(sdk)
        sd_key_s = sd_key
        // Check if this key starts with target_type + "$$"
        tt_s = target_type
        tt_len = slen(tt_s)
        sd_key_len = slen(sd_key_s)
        is_match := 0
        if sd_key_len > tt_len + 2 {
          prefix = sd_key_s.substring(0, tt_len)
          if prefix == tt_s && char_at(sd_key_s, tt_len) == 36 && char_at(sd_key_s, tt_len + 1) == 36 {
            is_match = 1
          }
        }
        if is_match == 1 {
          // Ensure monomorphized struct fields are resolved in struct_defs
          resolve_generic_struct_fields(struct_defs, sd_key)
          // Lower each method for this monomorphized struct
          gmi := 0
          while gmi < methods.len() {
            method = methods.get(gmi)
            mname = load64(method)
            mangled = if module_name != 0 { module_name + "__" + sd_key + "__" + mname } else { sd_key + "_" + mname }
            // Patch self param type to monomorphized name for correct struct resolution
            m_params_arr = load64(method + 8)
            self_param = m_params_arr.get(0)
            orig_self_type = load64(self_param + 8)
            store64(self_param + 8, sd_key)
            mfn_result = lower_function_body(method, mangled, struct_defs, enum_defs, fn_ret_types, global_names, variant_tag_map, variant_fields_map, fn_ret_struct_names, module_name, local_fn_set, imported_fn_names, fn_param_defaults)
            // Restore original self type
            store64(self_param + 8, orig_self_type)
            ir_functions.push(mfn_result.get(0))
            gmfri := 1
            while gmfri < mfn_result.len() {
              ir_functions.push(mfn_result.get(gmfri))
              gmfri = gmfri + 1
              0
            }
            gmi = gmi + 1
            0
          }
        }
        sdk = sdk + 1
        0
      }
    } else {
    mi := 0
    while mi < methods.len() {
      method = methods.get(mi)
      mname = load64(method)
      // Mangle: module__Type__method or Type_method
      mangled = if module_name != 0 { module_name + "__" + target_type + "__" + mname } else { target_type + "_" + mname }
      mfn_result = lower_function_body(method, mangled, struct_defs, enum_defs, fn_ret_types, global_names, variant_tag_map, variant_fields_map, fn_ret_struct_names, module_name, local_fn_set, imported_fn_names, fn_param_defaults)
      ir_functions.push(mfn_result.get(0))
      mfri := 1
      while mfri < mfn_result.len() {
        ir_functions.push(mfn_result.get(mfri))
        mfri = mfri + 1
        0
      }
      mi = mi + 1
      0
    }
    }
    ii = ii + 1
    0
  }

  // 6b. Build trait_impls map for codegen vtable emission
  ir_trait_impls = M()
  ir_trait_registry = M()
  prog_traits = load64(program + 40)
  tci := 0
  while tci < prog_traits.len() {
    tdef = prog_traits.get(tci)
    tname = load64(tdef)
    tmethods_src = load64(tdef + 8)
    tm_names = array<I>()
    tmi := 0
    while tmi < tmethods_src.len() {
      tmsig = tmethods_src.get(tmi)
      tm_names.push(load64(tmsig))
      tmi += 1
    }
    mset(ir_trait_registry, tname, ptr(tm_names))
    tci += 1
  }
  ii2 := 0
  while ii2 < prog_impls.len() {
    impl_block2 = prog_impls.get(ii2)
    impl_tn = load64(impl_block2)
    impl_tt = load64(impl_block2 + 8)
    if impl_tn != 0 && mhas(ir_trait_registry, impl_tn) {
      trait_mnames = mget(ir_trait_registry, impl_tn)
      vtable_entries = array<I>()
      vmi := 0
      trait_mnames_p = load64(trait_mnames)
      num_trait_m = load64(trait_mnames + 8)
      while vmi < num_trait_m {
        vt_tm_name = load64(trait_mnames_p + vmi * 8)
        vt_mangled := ""
        if module_name != 0 {
          vt_mangled = ir_s(module_name) + "__" + ir_s(impl_tt) + "__" + ir_s(vt_tm_name)
        } else {
          vt_mangled = ir_s(impl_tt) + "_" + ir_s(vt_tm_name)
        }
        vtable_entries.push(ptr(vt_mangled))
        vmi += 1
      }
      vt_key = ir_s(impl_tt) + "::" + ir_s(impl_tn)
      mset(ir_trait_impls, ptr(vt_key), ptr(vtable_entries))
    }
    ii2 += 1
  }

  // 7. Build and return IrModule
  mod = make_ir_module(ir_functions, globals_arr, struct_defs)
  store64(mod + 24, global_init_vals)
  store64(mod + 32, fn_ret_types)
  store64(mod + 48, ir_trait_impls)
  store64(mod + 56, ir_trait_registry)
  mod
}
