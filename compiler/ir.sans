    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst2(IR_HTTP_REQUEST_COOKIE, dest, obj_reg, name_reg))
    ctx_set_reg_type(ctx, dest, IRTY_STR)
    dest
  }
  else if method == "query" {
    name_reg = lower_expr(ctx, args.get(0))
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst2(IR_HTTP_REQUEST_QUERY, dest, obj_reg, name_reg))
    ctx_set_reg_type(ctx, dest, IRTY_STR)
    dest
  }
  else if method == "path_only" {
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst1(IR_HTTP_REQUEST_PATH_ONLY, dest, obj_reg))
    ctx_set_reg_type(ctx, dest, IRTY_STR)
    dest
  }
  else if method == "content_length" || method == "cl" {
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst1(IR_HTTP_REQUEST_CONTENT_LENGTH, dest, obj_reg))
    ctx_set_reg_type(ctx, dest, IRTY_INT)
    dest
  }
  else if method == "respond_stream" {
    status_reg = lower_expr(ctx, args.get(0))
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst2(IR_RESPOND_STREAM, dest, obj_reg, status_reg))
    ctx_set_reg_type(ctx, dest, IRTY_INT)
    dest
  }
  else if method == "respond_json" || method == "rj" {
    status_reg = lower_expr(ctx, args.get(0))
    body_reg = lower_expr(ctx, args.get(1))
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst3(IR_HTTP_RESPOND_JSON, dest, obj_reg, status_reg, body_reg))
    ctx_set_reg_type(ctx, dest, IRTY_INT)
    dest
  }
  else if method == "form" {
    name_reg = lower_expr(ctx, args.get(0))
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst2(IR_HTTP_REQUEST_FORM, dest, obj_reg, name_reg))
    ctx_set_reg_type(ctx, dest, IRTY_STR)
    dest
  }
  else if method == "is_ws_upgrade" {
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst1(IR_WS_IS_UPGRADE, dest, obj_reg))
    ctx_set_reg_type(ctx, dest, IRTY_INT)
    dest
  }
  else if method == "upgrade_ws" {
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst1(IR_WS_UPGRADE, dest, obj_reg))
    ctx_set_reg_type(ctx, dest, IRTY_INT)
    dest
  } else {
    lower_method_fallback(ctx, obj_reg, method, args)
  }
}

