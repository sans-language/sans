// ------ lower_http_req_method ---------------------------------------------------------------------------------------------------------------------
lower_http_req_method(ctx:I obj_reg:I method:I args:I) I {
  if method == "path" {
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst1(IR_HTTP_REQUEST_PATH, dest, obj_reg))
    ctx_set_reg_type(ctx, dest, IRTY_STR)
    dest
