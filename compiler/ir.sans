  } :
  method == "type_of" ? {
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst1(IR_JSON_TYPE_OF, dest, obj_reg))
    ctx_set_reg_type(ctx, dest, IRTY_STR)
