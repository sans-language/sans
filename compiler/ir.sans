  else if method == "method" {
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst1(IR_HTTP_REQUEST_METHOD, dest, obj_reg))
    ctx_set_reg_type(ctx, dest, IRTY_STR)
    dest
  }
  else if method == "body" {
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst1(IR_HTTP_REQUEST_BODY, dest, obj_reg))
    ctx_set_reg_type(ctx, dest, IRTY_STR)
    dest
  }
  else if method == "respond" {
    status_reg = lower_expr(ctx, args.get(0))
    body_reg = lower_expr(ctx, args.get(1))
    dest = ctx_fresh_reg(ctx)
    if args.len() == 3 {
      ct_reg = lower_expr(ctx, args.get(2))
      ctx_emit(ctx, ir_inst4(IR_HTTP_RESPOND_CT, dest, obj_reg, status_reg, body_reg, ct_reg))
    } else {
      ctx_emit(ctx, ir_inst3(IR_HTTP_RESPOND, dest, obj_reg, status_reg, body_reg))
    }
    ctx_set_reg_type(ctx, dest, IRTY_INT)
    dest
  }
  else if method == "header" {
    name_reg = lower_expr(ctx, args.get(0))
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst2(IR_HTTP_REQUEST_HEADER, dest, obj_reg, name_reg))
    ctx_set_reg_type(ctx, dest, IRTY_STR)
    dest
  }
  else if method == "set_header" || method == "sh" {
    name_reg = lower_expr(ctx, args.get(0))
    val_reg = lower_expr(ctx, args.get(1))
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst3(IR_HTTP_REQUEST_SET_HEADER, dest, obj_reg, name_reg, val_reg))
    ctx_set_reg_type(ctx, dest, IRTY_INT)
