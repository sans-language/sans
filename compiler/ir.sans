    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst1(IR_JSON_GET_BOOL, dest, obj_reg))
    ctx_set_reg_type(ctx, dest, IRTY_BOOL)
    dest
  } :
  method == "set" ? {
    key_reg = lower_expr(ctx, args.get(0))
    val_reg = lower_expr(ctx, args.get(1))
    dest = ctx_fresh_reg(ctx)
    ctx_emit(ctx, ir_inst3(IR_JSON_SET, dest, obj_reg, key_reg, val_reg))
    ctx_set_reg_type(ctx, dest, IRTY_INT)
