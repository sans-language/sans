    name == "str" || name == "int_to_string" || name == "itos" ? {
      nargs != 1 ? tc_error("str() takes exactly 1 argument") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      att = type_tag(at)
      att != TY_INT && att != TY_STRING && att != TY_FLOAT && att != TY_BOOL ? tc_error("str() requires Int, String, Float, or Bool argument, got " + type_to_string(at)) : 0
      return make_type(TY_STRING)
    } : 0

    name == "stoi" || name == "string_to_int" ? {
      nargs != 1 ? tc_error("string_to_int() takes exactly 1 argument") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_STRING ? tc_error("string_to_int() requires String argument, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    name == "itof" || name == "int_to_float" ? {
      nargs != 1 ? tc_error("int_to_float() takes exactly 1 argument") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_INT ? tc_error("int_to_float() requires Int argument, got " + type_to_string(at)) : 0
      return make_type(TY_FLOAT)
    } : 0

    name == "ftoi" || name == "float_to_int" ? {
      nargs != 1 ? tc_error("float_to_int() takes exactly 1 argument") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_FLOAT ? tc_error("float_to_int() requires Float argument, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    name == "ftos" || name == "float_to_string" ? {
      nargs != 1 ? tc_error("float_to_string() takes exactly 1 argument") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_FLOAT ? tc_error("float_to_string() requires Float argument, got " + type_to_string(at)) : 0
      return make_type(TY_STRING)
