      return make_type(TY_STRING)
    }
    if name == "file_write" || name == "write_file" || name == "fwrite" || name == "fw" ||
    name == "file_append" || name == "append_file" || name == "fappend" || name == "fa" {
      if nargs < 2 || nargs > 3 { tc_error(name + "() takes 2-3 arguments") }
      i_st := 0
      while i_st < nargs {
        check_expr(args[i_st], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
