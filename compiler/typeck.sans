    name == "stream_write" ? {
      nargs != 2 ? tc_error("stream_write() takes exactly 2 arguments (writer, data)") : 0
      at0 = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at0) != TY_INT ? tc_error("stream_write() writer must be Int, got " + type_to_string(at0)) : 0
      at1 = check_expr(args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at1) != TY_STRING ? tc_error("stream_write() data must be String, got " + type_to_string(at1)) : 0
      return make_type(TY_INT)
