        if is_i64_compat(at0) != 1 { tc_error("respond_stream() status must be Int, got " + type_to_string(at0)) }
        return make_type(TY_INT)
      }
      if mc_method == "form" {
        if mc_nargs != 1 { tc_error("form() takes exactly 1 argument (name)") }
        at0 = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        if is_i64_compat(at0) != 1 { tc_error("form() name must be String, got " + type_to_string(at0)) }
        return make_type(TY_STRING)
      }
      if mc_method == "is_ws_upgrade" {
        if mc_nargs != 0 { tc_error("is_ws_upgrade() takes no arguments") }
        return make_type(TY_INT)
      }
      if mc_method == "upgrade_ws" {
        if mc_nargs != 0 { tc_error("upgrade_ws() takes no arguments") }
        return make_type(TY_INT)
      }
      return tc_error("HttpRequest has no method '" + mc_method + "'")
    }
    // ------ Dyn trait method dispatch -----------------------------------------------------------------------
    if ot == TY_DYN_TRAIT {
      return check_dyn_trait_method(obj_ty, mc_method, mc_nargs, mc_args, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    }
    // ------ User-defined methods (struct/enum) ---------------------------------------------------------------------
    if ot == TY_STRUCT || ot == TY_ENUM {
      tname = type_data_s(obj_ty)
      method_key = tname + "." + mc_method
      if methods != 0 && mhas(methods, method_key) {
        sig = mget(methods, method_key)
        sig_params = load64(sig)
        sig_ret = load64(sig + 8)
        sig_params_len = if sig_params != 0 { load64(sig_params + 8) } else { 0 }
        sig_params_d = if sig_params != 0 { load64(sig_params) } else { 0 }
        sig_required4 = load64(sig + 16)
        if mc_nargs < sig_required4 || mc_nargs > sig_params_len { tc_error("method '" + mc_method + "' on '" + tname + "' expects " + str(sig_required4) + " to " + str(sig_params_len) + " argument(s) but got " + str(mc_nargs)) }
        mci := 0
        while mci < mc_nargs {
        actual = check_expr(mc_args[mci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        expected = load64(sig_params_d + mci * 8)
        if types_compatible(actual, expected) == 0 { tc_error("argument " + str(mci + 1) + " to method '" + mc_method + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) }
        mci += 1
        }
        return sig_ret
      }
      // Try generic impl method instantiation for monomorphized generic structs
      dd_pos = find_dollar_dollar(tname)
      if dd_pos >= 0 && mhas(methods, "$$generic_impl_methods$$") {
        gim = mget(methods, "$$generic_impl_methods$$")
        base_name = as_str(tname).substring(0, dd_pos)
        gim_key = base_name + "." + mc_method
        if mhas(gim, gim_key) {
          gim_entry = mget(gim, gim_key)
          gim_mdef = load64(gim_entry)
          gim_tparams_ptr = load64(gim_entry + 8)
          // Build type param substitution map from mangled name
          gim_tparams_p = load64(gim_tparams_ptr)
          gim_num_tparams = load64(gim_tparams_ptr + 8)
          tname_s = as_str(tname)
          tname_len = slen(tname_s)
          gim_rest := tname_s.substring(dd_pos + 2, tname_len)
          gim_type_arg_strs = array<I>()
          while slen(gim_rest) > 0 {
            gim_next_dd = find_dollar_dollar(gim_rest)
            if gim_next_dd >= 0 {
              gim_type_arg_strs.push(gim_rest.substring(0, gim_next_dd))
              gim_rest = gim_rest.substring(gim_next_dd + 2, slen(gim_rest))
            } else {
              gim_type_arg_strs.push(gim_rest)
              gim_rest = ""
            }
            0
          }
          gim_tp_map = map()
          gim_tpi := 0
          while gim_tpi < gim_num_tparams {
            gim_tp_entry = load64(gim_tparams_p + gim_tpi * 8)
            gim_tp_name = load64(gim_tp_entry)
            if gim_tpi < gim_type_arg_strs.len() {
              mset(gim_tp_map, gim_tp_name, resolve_type(gim_type_arg_strs[gim_tpi], structs, enums, mod_exports))
            }
            gim_tpi += 1
            0
          }
          // Resolve method param/return types with substitution
          gim_mparams_arr = load64(gim_mdef + 8)
          gim_mparams_p = load64(gim_mparams_arr)
          gim_num_mparams = load64(gim_mparams_arr + 8)
          gim_mret_name = load64(gim_mdef + 16)
          // Build param types skipping self
          gim_method_param_types = array<I>()
          gim_mpi := 1
          while gim_mpi < gim_num_mparams {
            gim_mp = load64(gim_mparams_p + gim_mpi * 8)
            gim_mp_type_name = load64(gim_mp + 8)
            gim_mp_ty = if mhas(gim_tp_map, gim_mp_type_name) { mget(gim_tp_map, gim_mp_type_name) } else { resolve_type(gim_mp_type_name, structs, enums, mod_exports) }
            gim_method_param_types.push(gim_mp_ty)
            gim_mpi += 1
          }
          gim_mret = if mhas(gim_tp_map, gim_mret_name) { mget(gim_tp_map, gim_mret_name) } else { resolve_type(gim_mret_name, structs, enums, mod_exports) }
          // Cache in methods_map and fn_env
          mset(methods, method_key, make_fn_sig(ptr(gim_method_param_types), gim_mret, gim_method_param_types.len()))
          gim_mangled = tname + "_" + mc_method
          gim_all_params = array<I>()
          gim_all_params.push(make_type(TY_STRUCT))
          gim_api := 0
          while gim_api < gim_method_param_types.len() {
            gim_all_params.push(gim_method_param_types[gim_api])
            gim_api += 1
          }
          mset(fn_env, gim_mangled, make_fn_sig(ptr(gim_all_params), gim_mret, gim_all_params.len()))
          // Now dispatch normally
          gim_sig = mget(methods, method_key)
          gim_sig_params = load64(gim_sig)
          gim_sig_ret = load64(gim_sig + 8)
          gim_sig_params_len = if gim_sig_params != 0 { load64(gim_sig_params + 8) } else { 0 }
          gim_sig_params_d = if gim_sig_params != 0 { load64(gim_sig_params) } else { 0 }
          gim_sig_required = load64(gim_sig + 16)
          if mc_nargs < gim_sig_required || mc_nargs > gim_sig_params_len { tc_error("method '" + mc_method + "' on '" + tname + "' expects " + str(gim_sig_required) + " to " + str(gim_sig_params_len) + " argument(s) but got " + str(mc_nargs)) }
          gim_ci := 0
          while gim_ci < mc_nargs {
            gim_actual = check_expr(mc_args[gim_ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
            gim_expected = load64(gim_sig_params_d + gim_ci * 8)
            if types_compatible(gim_actual, gim_expected) == 0 { tc_error("argument " + str(gim_ci + 1) + " to method '" + mc_method + "': expected " + type_to_string(gim_expected) + " but got " + type_to_string(gim_actual)) }
            gim_ci += 1
          }
          return gim_sig_ret
        }
      }
      return tc_error("no method '" + mc_method + "' on type '" + tname + "'")
    }
    // Allow method calls on Int (opaque pointer types stored as i64)
    if is_i64_compat(obj_ty) == 1 {
      i_mc := 0
      while i_mc < mc_nargs {
        check_expr(mc_args.get(i_mc), locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        i_mc = i_mc + 1
      }
      return make_type(TY_INT)
    }
    return tc_error("method call on non-struct/enum type " + type_to_string(obj_ty))
  }

  // ------ Field access ------------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_FIELD_ACCESS {
    object = load64(expr + 16)
    field = load64(expr + 24)
    obj_ty = check_expr(object, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    obj_tag = type_tag(obj_ty)
    // Tuple: field is numeric index
    if obj_tag == TY_TUPLE {
      elems = type_data2(obj_ty)
      if elems == 0 { return tc_error("tuple has no elements") }
      len = load64(elems + 8)
      elems_d = load64(elems)
      // Parse field name as integer index
      idx = stoi(field)
      if idx < 0 || idx >= len { return tc_error("tuple index out of bounds") }
      return load64(elems_d + idx * 8)
    }
    // Struct: look up field in fields map
    if obj_tag == TY_STRUCT {
      sname = type_data_s(obj_ty)
      fields_map = type_data2(obj_ty)
      if fields_map != 0 && mhas(fields_map, field) { return mget(fields_map, field) }
      return tc_error("no field '" + field + "' on struct '" + sname + "'")
    }
    // Fallback: treat as no-arg method call (e.g. array.len, string.len)
    field_s = as_str(field)
    if obj_tag == TY_ARRAY && field_s == "len" {
      return make_type(TY_INT)
    }
    if obj_tag == TY_STRING && field_s == "len" {
      return make_type(TY_INT)
    }
    if obj_tag == TY_MAP && field_s == "len" {
      return make_type(TY_INT)
    }
    if obj_tag == TY_MAP && field_s == "keys" {
      fkt = type_inner(obj_ty)
      return make_array_type(fkt != 0 ? fkt : make_type(TY_STRING))
    }
    if obj_tag == TY_MAP && field_s == "vals" {
      fvt = type_data(obj_ty)
      return make_array_type(fvt != 0 ? fvt : make_type(TY_INT))
    }
    // Generic fallback: treat as no-arg method call (e.g. server.accept → server.accept())
    synth_mc = alloc(56)
    store64(synth_mc, EX_METHOD_CALL)
    store64(synth_mc + 8, 56)
    store64(synth_mc + 16, object)
    store64(synth_mc + 24, field)
    store64(synth_mc + 32, array<I>())
    return check_expr(synth_mc, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
  }

  // ------ Struct literal ------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_STRUCT_LIT {
    sname = load64(expr + 16)
    field_names_arr = load64(expr + 24)
    field_names_p = load64(field_names_arr)
    field_values_arr = load64(expr + 32)
    field_values_p = load64(field_values_arr)
    // Look up struct definition; try generic instantiation if not found
    if mhas(structs, sname) == 0 {
      gen_ok = instantiate_generic_struct(sname, structs, enums, mod_exports)
      if gen_ok == 0 { tc_error_at(expr, "undefined struct '" + sname + "'")
        return make_type(TY_INT) }
    }
    expected_fields = mget(structs, sname)
    // expected_fields is a Map: field_name --- Type ptr
    exp_keys = expected_fields.keys()
    exp_len = exp_keys.len()
    // Number of provided fields
    num_fields = load64(field_names_arr + 8)
    // Check for missing fields
    ei := 0
    while ei < exp_len {
    ek = exp_keys[ei]
    found := 0
    fi := 0
    while fi < num_fields {
    if as_str(load64(field_names_p + fi * 8)) == ek {
      found = 1
      fi = num_fields
    }
    fi += 1
    }
    if found == 0 { return tc_error("missing field '" + ek + "' in struct '" + sname + "'") }
    ei += 1
    }
    // Check each provided field's type
    fi := 0
    while fi < num_fields {
    fname = load64(field_names_p + fi * 8)
    fval = load64(field_values_p + fi * 8)
    if mhas(expected_fields, fname) == 0 { return tc_error("unknown field '" + fname + "' on struct '" + sname + "'") }
    expected_ty = mget(expected_fields, fname)
    actual_ty = check_expr(fval, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    if type_eq(actual_ty, expected_ty) == 0 { return tc_error("type mismatch for field '" + fname + "' of struct '" + sname + "': expected " + type_to_string(expected_ty) + " but got " + type_to_string(actual_ty)) }
    fi += 1
    }
    return make_struct_type(sname, expected_fields)
  }

  // ------ Tuple literal ---------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_TUPLE_LIT {
    elems_arr = load64(expr + 16)
    elems_p = load64(elems_arr)
    num_elems = load64(elems_arr + 8)
    elem_types = array<I>()
    i := 0
    while i < num_elems {
    et = check_expr(load64(elems_p + i * 8), locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    elem_types.push(et)
    i += 1
    }
    return make_tuple_type(ptr(elem_types))
  }

  // ------ Array literal ---------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_ARRAY_LIT {
    elems_arr = load64(expr + 16)
    elems_p = load64(elems_arr)
    num_elems = load64(elems_arr + 8)
    if num_elems == 0 { return tc_error("empty array literal --- cannot infer element type") }
    first_ty = check_expr(load64(elems_p), locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    i := 1
    while i < num_elems {
    elem_ty = check_expr(load64(elems_p + i * 8), locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    if type_eq(elem_ty, first_ty) == 0 { return tc_error("array literal element " + str(i) + " has type " + type_to_string(elem_ty) + " but expected " + type_to_string(first_ty)) }
    i += 1
    }
    return make_array_type(first_ty)
  }

  // ------ Match expression ------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_MATCH {
    scrutinee = load64(expr + 16)
    arms_arr = load64(expr + 24)
    arms_p = load64(arms_arr)
    scrutinee_ty = check_expr(scrutinee, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    // Value match: Int, String, Bool — check arm bodies only
    st = type_tag(scrutinee_ty)
    if st == TY_INT || st == TY_STRING || st == TY_BOOL || st == TY_FLOAT {
      num_arms = load64(arms_arr + 8)
      result_ty := 0
      ai := 0
      while ai < num_arms {
        arm = load64(arms_p + ai * 8)
        arm_body = load64(arm + 8)
        arm_pat = load64(arm)
        arm_pat_type = load64(arm_pat + 24)
        has_binding := 0
        if arm_pat_type == 4 {
          push_scope(locals)
          bind_name = load64(arm_pat + 8)
          inner = locals[locals.len() - 1]
          mset(inner, bind_name, scrutinee_ty)
          has_binding = 1
        }
        guard_expr = load64(arm + 16)
        if guard_expr != 0 {
          if has_binding == 0 { push_scope(locals) }
          guard_ty = check_expr(guard_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
          if has_binding == 0 { pop_scope(locals) }
        }
        arm_ty = check_expr(arm_body, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        if has_binding == 1 { pop_scope(locals) }
        if result_ty == 0 { result_ty = arm_ty }
        ai += 1
      }
      return if result_ty != 0 { result_ty } else { make_type(TY_INT) }
    }
    // Struct destructuring match
    if st == TY_STRUCT {
      sname = type_data_s(scrutinee_ty)
      fields_map = type_data2(scrutinee_ty)
      num_arms = load64(arms_arr + 8)
      result_ty := 0
      ai := 0
      while ai < num_arms {
        arm = load64(arms_p + ai * 8)
        arm_body = load64(arm + 8)
        arm_pat = load64(arm)
        arm_pat_type = load64(arm_pat + 24)
        if arm_pat_type == 5 {
          // Struct pattern: validate field names and bind types
          pat_fields = load64(arm_pat + 16)
          pat_fields_p = load64(pat_fields)
          pat_fields_len = load64(pat_fields + 8)
          push_scope(locals)
          inner_scope = locals[locals.len() - 1]
          pfi := 0
          while pfi < pat_fields_len {
            fname = load64(pat_fields_p + pfi * 8)
            if fields_map == 0 || mhas(fields_map, fname) == 0 { return tc_error("no field '" + fname + "' on struct '" + sname + "'") }
            ftype = mget(fields_map, fname)
            mset(inner_scope, fname, ftype)
            pfi += 1
          }
          arm_ty = check_expr(arm_body, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
          pop_scope(locals)
          if result_ty == 0 { result_ty = arm_ty }
        } else if arm_pat_type == 3 {
          // Wildcard in struct match
          arm_ty = check_expr(arm_body, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
          if result_ty == 0 { result_ty = arm_ty }
        } else if arm_pat_type == 4 {
          // Binding pattern in struct match
          push_scope(locals)
          bind_name = load64(arm_pat + 8)
          inner_scope2 = locals[locals.len() - 1]
          mset(inner_scope2, bind_name, scrutinee_ty)
          arm_ty = check_expr(arm_body, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
          pop_scope(locals)
          if result_ty == 0 { result_ty = arm_ty }
        }
        ai += 1
      }
      return if result_ty != 0 { result_ty } else { make_type(TY_INT) }
    }
    // Tuple destructuring match
    if st == TY_TUPLE {
      tuple_elems = type_data2(scrutinee_ty)
      tuple_elems_p = load64(tuple_elems)
      tuple_elems_len = load64(tuple_elems + 8)
      num_arms = load64(arms_arr + 8)
      result_ty := 0
      ai := 0
      while ai < num_arms {
        arm = load64(arms_p + ai * 8)
        arm_body = load64(arm + 8)
        arm_pat = load64(arm)
        arm_pat_type = load64(arm_pat + 24)
        if arm_pat_type == 6 {
          // Tuple pattern: validate arity and bind element types
          sub_pats = load64(arm_pat + 16)
          sub_pats_p = load64(sub_pats)
          sub_pats_len = load64(sub_pats + 8)
          if sub_pats_len != tuple_elems_len { return tc_error("tuple pattern has " + str(sub_pats_len) + " element(s) but scrutinee has " + str(tuple_elems_len)) }
          push_scope(locals)
          inner_scope = locals[locals.len() - 1]
          tpi := 0
          while tpi < sub_pats_len {
            sub_pat = load64(sub_pats_p + tpi * 8)
            sub_pat_type = load64(sub_pat + 24)
            if sub_pat_type == 4 {
              // Binding sub-pattern
              bind_name = load64(sub_pat + 8)
              elem_ty = load64(tuple_elems_p + tpi * 8)
              mset(inner_scope, bind_name, elem_ty)
            }
            tpi += 1
          }
          arm_ty = check_expr(arm_body, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
          pop_scope(locals)
          if result_ty == 0 { result_ty = arm_ty }
        } else if arm_pat_type == 3 {
          arm_ty = check_expr(arm_body, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
          if result_ty == 0 { result_ty = arm_ty }
        } else if arm_pat_type == 4 {
          push_scope(locals)
          bind_name = load64(arm_pat + 8)
          inner_scope2 = locals[locals.len() - 1]
          mset(inner_scope2, bind_name, scrutinee_ty)
          arm_ty = check_expr(arm_body, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
          pop_scope(locals)
          if result_ty == 0 { result_ty = arm_ty }
        }
        ai += 1
      }
      return if result_ty != 0 { result_ty } else { make_type(TY_INT) }
    }
    if st != TY_ENUM { return tc_error("match scrutinee must be an enum, Int, or String, got " + type_to_string(scrutinee_ty)) }
    enum_name_s = type_data_s(scrutinee_ty)
    // Get enum variants from enums map
    if mhas(enums, enum_name_s) == 0 { return tc_error("undefined enum '" + enum_name_s + "'") }
    variants = mget(enums, enum_name_s)
    num_arms = load64(arms_arr + 8)
    if num_arms == 0 { return tc_error("match expression has no arms") }
    result_ty := 0
    ai := 0
    while ai < num_arms {
    arm = load64(arms_p + ai * 8)
    // arm layout: offset 0 = pattern ptr, offset 8 = body expr ptr
    pattern = load64(arm)
    arm_body = load64(arm + 8)
    // pattern layout: offset 0 = enum_name, offset 8 = variant_name, offset 16 = bindings array ptr
    pat_enum_s = as_str(load64(pattern))
    pat_variant = load64(pattern + 8)
    if pat_enum_s != enum_name_s { return tc_error("pattern enum '" + pat_enum_s + "' does not match scrutinee enum '" + enum_name_s + "'") }
    // Look up variant in variants map
    if mhas(variants, pat_variant) == 0 { return tc_error("unknown variant '" + pat_variant + "' on enum '" + enum_name_s + "'") }
    variant_fields_arr = mget(variants, pat_variant)
    // variant_fields_arr is an array of Type ptrs
    variant_fields_p = load64(variant_fields_arr)
    variant_fields_len = load64(variant_fields_arr + 8)
    bindings_arr = load64(pattern + 16)
    bindings_p = load64(bindings_arr)
    bindings_len = load64(bindings_arr + 8)
    if bindings_len != variant_fields_len { return tc_error("pattern '" + enum_name_s + "::" + pat_variant + "' expects " + str(variant_fields_len) + " binding(s) but got " + str(bindings_len)) }
    // Create new scope with bindings
    push_scope(locals)
    inner_scope = locals[locals.len() - 1]
    bi := 0
    while bi < bindings_len {
    bname = load64(bindings_p + bi * 8)
    btype = load64(variant_fields_p + bi * 8)
    mset(inner_scope, bname, btype)
    bi += 1
    }
    enum_guard_expr = load64(arm + 16)
    if enum_guard_expr != 0 {
      check_expr(enum_guard_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    }
    arm_ty = check_expr(arm_body, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    pop_scope(locals)
    if result_ty == 0 {
      result_ty = arm_ty
    } else {
      if type_eq(arm_ty, result_ty) == 0 { return tc_error("match arm type mismatch: expected " + type_to_string(result_ty) + " but got " + type_to_string(arm_ty)) }
    }
    ai += 1
    }
    return result_ty
  }

  // ------ Lambda ------------------------------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_LAMBDA {
    params_arr = load64(expr + 16)
    params_p = load64(params_arr)
    ret_type_name = load64(expr + 24)
    body_stmts_arr = load64(expr + 32)
    // Build param types and add to new scope
    push_scope(locals)
    inner_scope = locals[locals.len() - 1]
    param_types = array<I>()
    num_params = load64(params_arr + 8)
    pi := 0
    while pi < num_params {
    param = load64(params_p + pi * 8)
    // param layout: offset 0 = name, offset 8 = type_name string
    pname = load64(param)
    ptype_name = load64(param + 8)
    pty = resolve_type(ptype_name, structs, enums, mod_exports)
    param_types.push(pty)
    mset(inner_scope, pname, pty)
    pi += 1
    }
    ret_ty = resolve_type(ret_type_name, structs, enums, mod_exports)
    // Check body stmts
    body_stmts_p = if body_stmts_arr != 0 { load64(body_stmts_arr) } else { 0 }
    body_len = if body_stmts_arr != 0 { load64(body_stmts_arr + 8) } else { 0 }
    check_stmts(body_stmts_p, body_len, locals, fn_env, ret_ty, structs, enums, methods, generic_fns, traits, mod_exports)
    pop_scope(locals)
    return make_fn_type(ptr(param_types), ret_ty)
  }

  // ------ Spawn ---------------------------------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_SPAWN {
    func_name = load64(expr + 16)
    args_arr = load64(expr + 24)
    args_p = load64(args_arr)
    num_args = load64(args_arr + 8)
    if mhas(fn_env, func_name) == 0 { return tc_error("undefined function '" + func_name + "' in spawn") }
    sig = mget(fn_env, func_name)
    sig_params_arr = load64(sig)
    sig_params = if sig_params_arr != 0 { load64(sig_params_arr) } else { 0 }
    sig_params_len = if sig_params_arr != 0 { load64(sig_params_arr + 8) } else { 0 }
    sig_required5 = load64(sig + 16)
    if num_args < sig_required5 || num_args > sig_params_len { return tc_error("wrong argument count calling '" + func_name + "': expected " + str(sig_required5) + " to " + str(sig_params_len) + " but got " + str(num_args)) }
    si := 0
    while si < num_args {
    arg_expr = load64(args_p + si * 8)
    actual = check_expr(arg_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    expected = load64(sig_params + si * 8)
    // Allow opaque types where Int expected (pointers are i64)
    if types_compatible(actual, expected) == 0 { return tc_error("argument " + str(si + 1) + " to '" + func_name + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) }
    si += 1
    }
    return make_type(TY_JOIN_HANDLE)
  }

  // ------ Channel ---------------------------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_CHANNEL {
    elem_type_name = load64(expr + 16)
    capacity_expr = load64(expr + 24)
    // Check capacity if present
    if capacity_expr != 0 {
      cap_ty = check_expr(capacity_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if type_tag(cap_ty) != TY_INT { return tc_error("channel capacity must be Int, got " + type_to_string(cap_ty)) }
    }
    inner = resolve_type(elem_type_name, structs, enums, mod_exports)
    // Rust returns Sender<T> --- the channel() call returns Sender (receiver obtained via split)
    return make_sender_type(inner)
  }

  // ------ Mutex ---------------------------------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_MUTEX {
    value_expr = load64(expr + 16)
    inner = check_expr(value_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    return make_mutex_type(inner)
  }

  // ------ Enum variant ------------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_ENUM_VARIANT {
    ename = load64(expr + 16)
    vname = load64(expr + 24)
    args_arr = load64(expr + 32)
    args_p = load64(args_arr)
    num_args = load64(args_arr + 8)
    if mhas(enums, ename) == 0 { return tc_error("undefined enum '" + ename + "'") }
    variants = mget(enums, ename)
    if mhas(variants, vname) == 0 { return tc_error("unknown variant '" + vname + "' on enum '" + ename + "'") }
    expected_fields_arr = mget(variants, vname)
    expected_fields_p = load64(expected_fields_arr)
    expected_len = load64(expected_fields_arr + 8)
    if num_args != expected_len { return tc_error("variant '" + ename + "::" + vname + "' expects " + str(expected_len) + " argument(s) but got " + str(num_args)) }
    vi := 0
    while vi < num_args {
    arg_expr = load64(args_p + vi * 8)
    actual_ty = check_expr(arg_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    expected_ty = load64(expected_fields_p + vi * 8)
    if type_eq(actual_ty, expected_ty) == 0 { return tc_error("argument " + str(vi + 1) + " to '" + ename + "::" + vname + "': expected " + type_to_string(expected_ty) + " but got " + type_to_string(actual_ty)) }
    vi += 1
    }
    return make_enum_type(ename, variants)
  }

  // ------ Array create ------------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_ARRAY_CREATE {
    elem_type_name = load64(expr + 16)
    inner = resolve_type(elem_type_name, structs, enums, mod_exports)
    return make_array_type(inner)
  }

  if tag == EX_AS_DYN {
    src_expr2 = load64(expr + 16)
    asd_trait_name = load64(expr + 24)
    asd_src_ty = check_expr(src_expr2, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    asd_src_tag = type_tag(asd_src_ty)
    if asd_src_tag == TY_STRUCT || asd_src_tag == TY_ENUM {
      asd_src_name = type_data_s(asd_src_ty)
      asd_impl_key = as_str(asd_src_name) + "::" + as_str(asd_trait_name)
      if mhas(traits, "$$trait_impls$$") == 1 {
        asd_ti_map = mget(traits, "$$trait_impls$$")
        if mhas(asd_ti_map, asd_impl_key) == 0 {
          tc_error("type '" + asd_src_name + "' does not implement trait '" + asd_trait_name + "'")
        }
      }
    }
    return make_dyn_trait_type(asd_trait_name)
  }

  tc_error("check_expr: unknown expression tag " + str(tag))
}

// ------ make_fn_sig: create FunctionSignature (24 bytes) ---------------------------------------
// offset 0: params (raw ptr to array of Type ptrs)
// offset 8: return_type (Type ptr)
// offset 16: required_count (min args — params without defaults)
make_fn_sig(params_ptr:I ret_type:I required_count:I) I {
  sig = alloc(24)
  store64(sig, params_ptr)
  store64(sig + 8, ret_type)
  store64(sig + 16, required_count)
  sig
}

// ------ make_mod_exports: create ModuleExports (40 bytes) ------------------------------------
// offset 0: structs_map
// offset 8: enums_map
// offset 16: fn_env_map
// offset 24: globals_map (name -> Type ptr)
// offset 32: pub_fns_map (name -> 1 if pub; 0 means no pub functions = all exported)
make_mod_exports(structs_m:I enums_m:I fn_env_m:I globals_m:I pub_fns_m:I) I {
  e = alloc(40)
  store64(e, structs_m)
  store64(e + 8, enums_m)
  store64(e + 16, fn_env_m)
  store64(e + 24, globals_m)
  store64(e + 32, pub_fns_m)
  e
}

// ------ build_pub_fns: scan function nodes for pub flag, return pub_fns map or 0 --------
build_pub_fns(funcs_p:I num_funcs:I) I {
  pub_fns = map()
  has_any := 0
  i := 0
  while i < num_funcs {
    func = load64(funcs_p + i * 8)
    fname = load64(func)
    if load64(func + 48) == 1 {
      mset(pub_fns, fname, 1)
      has_any = 1
    }
    i += 1
  }
  if has_any == 1 { pub_fns } else { 0 }
}

// ------ check_pub_visibility: warn if accessing non-pub function cross-module --------
check_pub_access(exports:I func_name:S mod_name:S expr:I) I {
  pub_fns = load64(exports + 32)
  // If pub_fns is 0, module has no pub functions — all are exported (backward compat)
  if pub_fns != 0 {
    if mhas(pub_fns, func_name) == 0 {
      tc_warn_at(expr, "function '" + func_name + "' in module '" + mod_name + "' is not marked pub and will become private in a future version")
    }
  }
  0
}

// ------ Dyn trait method dispatch type checking (extracted to avoid SSA issues) --------
check_dyn_trait_method(obj_ty:I method:I nargs:I mc_args:I locals:I fn_env:I ret_type:I structs:I enums:I methods:I generic_fns:I traits:I mod_exports:I) I {
  dyn_trait_name = type_inner(obj_ty)
  if mhas(traits, dyn_trait_name) {
    dyn_tmethods_arr = mget(traits, dyn_trait_name)
    dyn_tmethods_p = load64(dyn_tmethods_arr)
    dyn_num_tmethods = load64(dyn_tmethods_arr + 8)
    dyn_tmi := 0
    while dyn_tmi < dyn_num_tmethods {
      dyn_tm = load64(dyn_tmethods_p + dyn_tmi * 8)
      dyn_tm_name = load64(dyn_tm)
      if as_str(dyn_tm_name) == as_str(method) {
        dyn_tm_ret = load64(dyn_tm + 16)
        dyn_tm_params_arr = load64(dyn_tm + 8)
        dyn_num_tparams = load64(dyn_tm_params_arr + 8)
        if nargs != dyn_num_tparams { tc_error("method '" + method + "' on dyn " + dyn_trait_name + " expects " + str(dyn_num_tparams) + " arg(s) but got " + str(nargs)) }
        dyn_ci := 0
        while dyn_ci < nargs {
          dyn_actual = check_expr(mc_args[dyn_ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
          dyn_ci += 1
        }
        return dyn_tm_ret
      }
      dyn_tmi += 1
    }
    return tc_error("trait '" + dyn_trait_name + "' has no method '" + method + "'")
  }
  tc_error("unknown trait '" + dyn_trait_name + "'")
}

// ------ check_inner: shared implementation for check/check_module ------------
check_inner(program:I mod_exports:I require_main:I) I {
  tc_init_diags()
  structs_map = map()
  enums_map = map()
  fn_env = map()
  methods_map = map()
  trait_registry = map()
  trait_impls_map = map()
  trait_method_index = map()
  generic_fns = map()

  // ------ Pass 0: inject imported module exports ---------------------------------------------------------------
  // Import globals, structs, enums, functions from all imported modules
  mod_keys = mod_exports.keys()
  mki := 0
  while mki < mod_keys.len() {
    mk = mod_keys.get(mki)
    mex = mget(mod_exports, mk)
    // Import structs (offset 0)
    imp_structs = load64(mex)
    if imp_structs != 0 {
      isk = imp_structs.keys()
      iski := 0
      while iski < isk.len() {
        sk = isk.get(iski)
        mset(structs_map, sk, mget(imp_structs, sk))
        iski = iski + 1
      }
    }
    // Import enums (offset 8)
    imp_enums = load64(mex + 8)
    if imp_enums != 0 {
      iek = imp_enums.keys()
      ieki := 0
      while ieki < iek.len() {
        ek = iek.get(ieki)
        mset(enums_map, ek, mget(imp_enums, ek))
        ieki = ieki + 1
      }
    }
    // Import functions (offset 16)
    imp_fns = load64(mex + 16)
    if imp_fns != 0 {
      ifk = imp_fns.keys()
      ifki := 0
      while ifki < ifk.len() {
        fk = ifk.get(ifki)
        mset(fn_env, fk, mget(imp_fns, fk))
        ifki = ifki + 1
      }
    }
    // Import globals (offset 24)
    imp_globals = load64(mex + 24)
    if imp_globals != 0 {
      igk = imp_globals.keys()
      igki := 0
      while igki < igk.len() {
        gk = igk.get(igki)
        mset(fn_env, gk, mget(imp_globals, gk))
        igki = igki + 1
      }
    }
    mki = mki + 1
  }

  // ------ Pass 0a: collect struct definitions ---------------------------------------------------------------------------
  generic_structs = map()
  structs_arr = load64(program + 24)
  structs_p = load64(structs_arr)
  num_structs = load64(structs_arr + 8)
  si := 0
  while si < num_structs {
    sdef = load64(structs_p + si * 8)
    sname = load64(sdef)
    type_params_ptr = load64(sdef + 16)

    if type_params_ptr != 0 {
      // Generic struct template — store for later instantiation
      mset(generic_structs, sname, sdef)
      mset(structs_map, "$$generics$$", generic_structs)
    } else {
      fields_flat_arr = load64(sdef + 8)   // array: name0, type0, name1, type1, ...
      fields_flat = load64(fields_flat_arr)
      num_flat = load64(fields_flat_arr + 8)
      fields_m = map()
      fi := 0
      while fi < num_flat {
        fname = load64(fields_flat + fi * 8)
        ftype_name = load64(fields_flat + (fi + 1) * 8)
        fty = resolve_type(ftype_name, structs_map, enums_map, mod_exports)
        mset(fields_m, fname, fty)
        fi += 2
      }
      mset(structs_map, sname, fields_m)
    }
    si += 1
  }

  // ------ Pass 0b: collect enum definitions ---------------------------------------------------------------------------------
  enums_arr = load64(program + 32)
  enums_p = load64(enums_arr)
  num_enums = load64(enums_arr + 8)
  ei := 0
  while ei < num_enums {
    edef = load64(enums_p + ei * 8)
    ename = load64(edef)
    variants_arr = load64(edef + 8)   // array of variant defs
    variants_p = load64(variants_arr)
    num_variants = load64(variants_arr + 8)
    variants_m = map()
    vi := 0
    while vi < num_variants {
      vdef = load64(variants_p + vi * 8)
      vname = load64(vdef)
      vfields_arr = load64(vdef + 8)  // array of type name strings
      vfields_p = load64(vfields_arr)
      num_vfields = load64(vfields_arr + 8)
      vtypes = array<I>()
      vfi := 0
      while vfi < num_vfields {
        vtype_name = load64(vfields_p + vfi * 8)
        vty = resolve_type(vtype_name, structs_map, enums_map, mod_exports)
        vtypes.push(vty)
        vfi += 1
      }
      mset(variants_m, vname, ptr(vtypes))
      vi += 1
    }
    mset(enums_map, ename, variants_m)
    ei += 1
  }

  // ------ Pass 0c: collect trait definitions ------------------------------------------------------------------------------
  traits_arr = load64(program + 40)
  traits_p = load64(traits_arr)
  num_traits = load64(traits_arr + 8)
  ti := 0
  while ti < num_traits {
    tdef = load64(traits_p + ti * 8)
    tname = load64(tdef)
    tmethods_src_arr = load64(tdef + 8)
    tmethods_p = load64(tmethods_src_arr)
    num_tmethods = load64(tmethods_src_arr + 8)
    tmethods_arr = array<I>()
    tmi := 0
    while tmi < num_tmethods {
      tmsig = load64(tmethods_p + tmi * 8)
      // trait method sig: offset 0 = name, offset 8 = params_p, offset 16 = ret_type_name
      tm_name = load64(tmsig)
      tm_params_arr = load64(tmsig + 8)
      tm_params_p = load64(tm_params_arr)
      tm_ret_name = load64(tmsig + 16)
      num_tparams = load64(tm_params_arr + 8)
      tparam_types = array<I>()
      tpi := 0
      while tpi < num_tparams {
        tp = load64(tm_params_p + tpi * 8)
        tp_type_name = load64(tp + 8)
        tparam_types.push(resolve_type(tp_type_name, structs_map, enums_map, mod_exports))
        tpi += 1
      }
      tm_ret = resolve_type(tm_ret_name, structs_map, enums_map, mod_exports)
      // Store as: [name, params_raw_ptr, ret_type]
      tm_entry = alloc(24)
      store64(tm_entry, tm_name)
      store64(tm_entry + 8, ptr(tparam_types))
      store64(tm_entry + 16, tm_ret)
      tmethods_arr.push(tm_entry)
      tmi += 1
    }
    mset(trait_registry, tname, ptr(tmethods_arr))
    tmi2 := 0
    while tmi2 < tmethods_arr.len() {
      tm_e = tmethods_arr.get(tmi2)
      tm_n = load64(tm_e)
      tmi_key = as_str(tname) + "." + as_str(tm_n)
      mset(trait_method_index, tmi_key, tmi2)
      tmi2 += 1
    }
    ti += 1
  }

  // ------ Pass 0d: collect impl blocks --- method registry ---------------------------------------
  impls_arr = load64(program + 48)
  impls_p = load64(impls_arr)
  num_impls = load64(impls_arr + 8)
  ii := 0
  while ii < num_impls {
    impl_block = load64(impls_p + ii * 8)
    impl_trait_name = load64(impl_block)
    impl_target_type = load64(impl_block + 8)
    impl_methods_arr = load64(impl_block + 16)
    impl_methods_p = load64(impl_methods_arr)
    num_impl_methods = load64(impl_methods_arr + 8)

    // Verify trait conformance if trait impl
    if impl_trait_name != 0 && mhas(trait_registry, impl_trait_name) {
      trait_methods_arr = mget(trait_registry, impl_trait_name)
      trait_methods_p = load64(trait_methods_arr)
      num_trait_methods = load64(trait_methods_arr + 8)
      tmi := 0
      while tmi < num_trait_methods {
      tm_entry = load64(trait_methods_p + tmi * 8)
      tm_name = load64(tm_entry)
      tm_params_arr2 = load64(tm_entry + 8)
      tm_params_p = load64(tm_params_arr2)
      tm_ret = load64(tm_entry + 16)
      // Find matching method in impl
      found := 0
      imi := 0
      while imi < num_impl_methods {
      mdef = load64(impl_methods_p + imi * 8)
      mdef_name = as_str(load64(mdef))
      if mdef_name == as_str(tm_name) {
        found = 1
        // Check params (skip self = first param)
        mparams_arr2 = load64(mdef + 8)
        mparams_p = load64(mparams_arr2)
        num_mparams = load64(mparams_arr2 + 8)
        num_tm_params = load64(tm_params_arr2 + 8)
        // Actual params = mparams - 1 (skip self)
        if num_mparams - 1 != num_tm_params { tc_error("method '" + tm_name + "' params don't match trait '" + impl_trait_name + "' signature") }
        pi := 1
        while pi < num_mparams {
        mp = load64(mparams_p + pi * 8)
        mp_type_name = load64(mp + 8)
        actual_pty = resolve_type(mp_type_name, structs_map, enums_map, mod_exports)
        expected_pty = load64(tm_params_p + (pi - 1) * 8)
        if type_eq(actual_pty, expected_pty) == 0 { tc_error("method '" + tm_name + "' params don't match trait '" + impl_trait_name + "' signature") }
        pi += 1
        }
        // Check return type
        mret_name = load64(mdef + 16)
        actual_ret = resolve_type(mret_name, structs_map, enums_map, mod_exports)
        if type_eq(actual_ret, tm_ret) == 0 { tc_error("method '" + tm_name + "' return type doesn't match trait '" + impl_trait_name + "' signature") }
        imi = num_impl_methods  // break
      }
      imi += 1
      }
      if found == 0 { tc_error("impl " + impl_trait_name + " for " + impl_target_type + " is missing method '" + tm_name + "'") }
      tmi += 1
      }
      ti_key = as_str(impl_target_type) + "::" + as_str(impl_trait_name)
      ti_methods = array<I>()
      ti_mi := 0
      while ti_mi < num_impl_methods {
        ti_mdef = load64(impl_methods_p + ti_mi * 8)
        ti_mname = load64(ti_mdef)
        ti_mangled = as_str(impl_target_type) + "_" + as_str(ti_mname)
        ti_entry = alloc(16)
        store64(ti_entry, ti_mname)
        store64(ti_entry + 8, ptr(ti_mangled))
        ti_methods.push(ti_entry)
        ti_mi += 1
      }
      mset(trait_impls_map, ti_key, ptr(ti_methods))
    }

    // Check if this is a generic impl (has type params at offset 24)
    impl_type_params_ptr = load64(impl_block + 24)

    if impl_type_params_ptr != 0 {
      // Generic impl — store method templates for lazy instantiation
      gim := 0
      if mhas(methods_map, "$$generic_impl_methods$$") { gim = mget(methods_map, "$$generic_impl_methods$$") }
      if gim == 0 { gim = map(); mset(methods_map, "$$generic_impl_methods$$", gim) }
      mi := 0
      while mi < num_impl_methods {
        mdef = load64(impl_methods_p + mi * 8)
        mname = load64(mdef)
        gim_key = impl_target_type + "." + mname
        // Store: [method_ast, impl_type_params_ptr, target_type]
        gim_entry = alloc(24)
        store64(gim_entry, mdef)
        store64(gim_entry + 8, impl_type_params_ptr)
        store64(gim_entry + 16, impl_target_type)
        mset(gim, gim_key, gim_entry)
        mi += 1
      }
    } else {
    // Register methods (skip self param)
    mi := 0
    while mi < num_impl_methods {
      mdef = load64(impl_methods_p + mi * 8)
      mname = load64(mdef)
      mparams_arr3 = load64(mdef + 8)
      mparams_p = load64(mparams_arr3)
      mret_name = load64(mdef + 16)
      num_mparams = load64(mparams_arr3 + 8)
      // Build param types skipping self (index 0)
      method_param_types = array<I>()
      mpi := 1
      while mpi < num_mparams {
        mp = load64(mparams_p + mpi * 8)
        mp_type_name = load64(mp + 8)
        method_param_types.push(resolve_type(mp_type_name, structs_map, enums_map, mod_exports))
        mpi += 1
      }
      mret = resolve_type(mret_name, structs_map, enums_map, mod_exports)
      method_key = impl_target_type + "." + mname
      mset(methods_map, method_key, make_fn_sig(ptr(method_param_types), mret, method_param_types.len()))

      // Also add mangled name to fn_env (with self param included)
      mangled = impl_target_type + "_" + mname
      all_param_types = array<I>()
      api := 0
      while api < num_mparams {
        mp = load64(mparams_p + api * 8)
        mp_type_name = load64(mp + 8)
        all_param_types.push(resolve_type(mp_type_name, structs_map, enums_map, mod_exports))
        api += 1
      }
      mset(fn_env, mangled, make_fn_sig(ptr(all_param_types), mret, all_param_types.len()))
      mi += 1
    }
    }
    ii += 1
  }

  mset(trait_registry, "$$trait_impls$$", trait_impls_map)
  mset(trait_registry, "$$trait_method_index$$", trait_method_index)

  // ------ Pass 1: collect function signatures ---------------------------------------------------------------------------
  funcs_arr = load64(program + 16)
  funcs_p = load64(funcs_arr)
  num_funcs = load64(funcs_arr + 8)
  fi := 0
  while fi < num_funcs {
    func = load64(funcs_p + fi * 8)
    fname = load64(func)
    fparams_arr = load64(func + 8)
    fparams_p = load64(fparams_arr)
    fret_name = load64(func + 16)
    ftype_params_arr = load64(func + 32)
    ftype_params_p = load64(ftype_params_arr)
    num_type_params = load64(ftype_params_arr + 8)

    if num_type_params == 0 {
      num_fparams = load64(fparams_arr + 8)
      param_types = array<I>()
      required_count := num_fparams
      pi := 0
      while pi < num_fparams {
      p_node = load64(fparams_p + pi * 8)
      p_type_name = load64(p_node + 8)
      p_default = load64(p_node + 16)
      param_types.push(resolve_type(p_type_name, structs_map, enums_map, mod_exports))
      if p_default != 0 && required_count == num_fparams {
        required_count = pi
      }
      pi += 1
      }
      ret_ty = resolve_type(fret_name, structs_map, enums_map, mod_exports)
      mset(fn_env, fname, make_fn_sig(ptr(param_types), ret_ty, required_count))
    } else {
      // Generic function --- store function node for call-site inference
      mset(generic_fns, fname, func)
    }
    fi += 1
  }

  // ------ Pass 1b: type-check global variable definitions ---------------------------------------
  globals_arr = load64(program + 8)
  globals_p = load64(globals_arr)
  num_globals = load64(globals_arr + 8)
  global_types = map()
  gi := 0
  while gi < num_globals {
    gdef = load64(globals_p + gi * 8)
    gname = load64(gdef)
    gvalue = load64(gdef + 8)
    // Create temp locals for globals type checking
    temp_locals = [map()]
    gty = check_expr(gvalue, temp_locals, fn_env, make_type(TY_INT), structs_map, enums_map, methods_map, generic_fns, trait_registry, mod_exports)
    mset(global_types, gname, gty)
    gi += 1
  }

  // ------ Require main (unless checking a module) ---------------------------------------------------------------
  if require_main == 1 && mhas(fn_env, "main") == 0 { tc_error("missing 'main' function") }

  // ------ Pass 2: type-check each function body ---------------------------------------------------------------------
  fi = 0
  while fi < num_funcs {
    func = load64(funcs_p + fi * 8)
    fname = load64(func)
    ftype_params_arr2 = load64(func + 32)
    ftype_params_p = load64(ftype_params_arr2)
    num_type_params = load64(ftype_params_arr2 + 8)

    // Skip generic functions
    if num_type_params > 0 {
      fi += 1
      0
    } else {
      sig = mget(fn_env, fname)
      ret_ty = load64(sig + 8)
      // Build locals with globals + params
      locals = [map()]
      scope = locals[0]
      // Inject globals as mutable locals
      gkeys = global_types.keys()
      gki := 0
      while gki < gkeys.len() {
        gk = gkeys[gki]
        mset(scope, gk, mget(global_types, gk))
        gki += 1
      }
      // Inject imported module globals
      imki := 0
      while imki < mod_keys.len() {
        imk = mod_keys.get(imki)
        imex = mget(mod_exports, imk)
        imp_g = load64(imex + 24)
        if imp_g != 0 {
          igks = imp_g.keys()
          igki2 := 0
          while igki2 < igks.len() {
            igk2 = igks.get(igki2)
            mset(scope, igk2, mget(imp_g, igk2))
            igki2 = igki2 + 1
          }
        }
        imki = imki + 1
      }
      // Add function params
      fparams_arr2 = load64(func + 8)
      fparams_p = load64(fparams_arr2)
      num_fparams = load64(fparams_arr2 + 8)
      pi := 0
      while pi < num_fparams {
      p_node = load64(fparams_p + pi * 8)
      p_name = load64(p_node)
      p_type_name = load64(p_node + 8)
      pty = resolve_type(p_type_name, structs_map, enums_map, mod_exports)
      mset(scope, p_name, pty)
      pi += 1
      }
      body_arr2 = load64(func + 24)
      body_p = load64(body_arr2)
      body_len = load64(body_arr2 + 8)
      if body_len == 0 { tc_error("function '" + fname + "': missing return expression") }
      // Init unused-variable tracking for this function
      if tc_warn_enabled == 1 {
        tc_declared_vars = map()
        tc_used_vars = map()
      }
      // Check all statements
      fn_returned := 0
      bi := 0
      while bi < body_len {
      stmt = load64(body_p + bi * 8)
      is_last = bi == body_len - 1
      if fn_returned == 1 && tc_warn_enabled == 1 {
        tc_warn_at(stmt, "unreachable code after return")
        fn_returned = 2
      }
      check_stmt(stmt, locals, fn_env, ret_ty, structs_map, enums_map, methods_map, generic_fns, trait_registry, mod_exports)
      if is_last == 1 {
        stag = load64(stmt)
        if stag == ST_EXPR {
          expr = load64(stmt + 16)
          ety = check_expr(expr, locals, fn_env, ret_ty, structs_map, enums_map, methods_map, generic_fns, trait_registry, mod_exports)
          if types_compatible(ety, ret_ty) == 0 { tc_error("function '" + fname + "': return type mismatch: expected " + type_to_string(ret_ty) + " but got " + type_to_string(ety)) }
        } else {
          if stag == ST_RETURN { 0 } else {
            tc_error("function '" + fname + "': missing return expression")
          }
        }
      }
      if fn_returned == 0 && load64(stmt) == ST_RETURN { fn_returned = 1 }
      bi += 1
      }
      // Emit unused variable warnings for this function
      if tc_warn_enabled == 1 {
        tc_check_unused_vars()
        tc_declared_vars = 0
        tc_used_vars = 0
      }
      if tc_collect_mode == 1 {
        tc_collected_locals = locals[locals.len() - 1]
      }
      fi += 1
      0
    }
  }

  // ------ Pass 3: type-check method bodies from impl blocks ---------------------------------
  ii = 0
  while ii < num_impls {
    impl_block = load64(impls_p + ii * 8)
    impl_target_type = load64(impl_block + 8)
    impl_methods_arr3 = load64(impl_block + 16)
    impl_methods_p = load64(impl_methods_arr3)
    num_impl_methods = load64(impl_methods_arr3 + 8)

    // Skip generic impl blocks — their methods are type-checked lazily at call site
    impl_type_params_ptr2 = load64(impl_block + 24)
    if impl_type_params_ptr2 != 0 {
      ii += 1
      0
    } else {

    mi := 0
    while mi < num_impl_methods {
      mdef = load64(impl_methods_p + mi * 8)
      mname = load64(mdef)
      mparams_arr4 = load64(mdef + 8)
      mparams_p = load64(mparams_arr4)
      mret_name = load64(mdef + 16)
      mbody_arr3 = load64(mdef + 24)
      mbody_p = load64(mbody_arr3)
      num_mparams = load64(mparams_arr4 + 8)
      mbody_len = load64(mbody_arr3 + 8)
      mret_ty = resolve_type(mret_name, structs_map, enums_map, mod_exports)

      // Build locals
      locals = [map()]
      scope = locals[0]

      // Inject globals
      gkeys = global_types.keys()
      gki := 0
      while gki < gkeys.len() {
        gk = gkeys[gki]
        mset(scope, gk, mget(global_types, gk))
        gki += 1
      }

      // Add method params
      mpi := 0
      while mpi < num_mparams {
        mp = load64(mparams_p + mpi * 8)
        mp_name = load64(mp)
        mp_type_name = load64(mp + 8)
        mpty = resolve_type(mp_type_name, structs_map, enums_map, mod_exports)
        mset(scope, mp_name, mpty)
        mpi += 1
      }

      if mbody_len == 0 { tc_error("method '" + mname + "': missing return expression") }

      // Init unused-variable tracking for this method
      if tc_warn_enabled == 1 {
        tc_declared_vars = map()
        tc_used_vars = map()
      }

      m_returned := 0
      bi := 0
      while bi < mbody_len {
        stmt = load64(mbody_p + bi * 8)
        is_last = bi == mbody_len - 1
        if m_returned == 1 && tc_warn_enabled == 1 {
          tc_warn_at(stmt, "unreachable code after return")
          m_returned = 2
        }
        check_stmt(stmt, locals, fn_env, mret_ty, structs_map, enums_map, methods_map, generic_fns, trait_registry, mod_exports)

        if is_last == 1 {
          stag = load64(stmt)
          if stag == ST_EXPR {
            expr = load64(stmt + 16)
            ety = check_expr(expr, locals, fn_env, mret_ty, structs_map, enums_map, methods_map, generic_fns, trait_registry, mod_exports)
            if types_compatible(ety, mret_ty) == 0 { tc_error("method '" + mname + "': return type mismatch: expected " + type_to_string(mret_ty) + " but got " + type_to_string(ety)) }
          } else {
            if stag == ST_RETURN { 0 } else {
              tc_error("method '" + mname + "': missing return expression")
            }
          }
        }
        if m_returned == 0 && load64(stmt) == ST_RETURN { m_returned = 1 }
        bi += 1
      }
      // Emit unused variable warnings for this method
      if tc_warn_enabled == 1 {
        tc_check_unused_vars()
        tc_declared_vars = 0
        tc_used_vars = 0
      }
      mi += 1
    }
    } // end else (non-generic impl)
    ii += 1
  }

  // ------ Build ModuleExports ---------------------------------------------------------------------------------------------------------------------------
  // Build fn_exports: only non-generic functions
  fn_exports = map()
  fi = 0
  while fi < num_funcs {
    func = load64(funcs_p + fi * 8)
    fname = load64(func)
    ftype_params_arr3 = load64(func + 32)
    ftype_params_p = load64(ftype_params_arr3)
    num_type_params = load64(ftype_params_arr3 + 8)
    if num_type_params == 0 && mhas(fn_env, fname) {
      mset(fn_exports, fname, mget(fn_env, fname))
    }
    fi += 1
  }

  if tc_collect_mode == 1 {
    tc_collected_symbols = alloc(48)
    store64(tc_collected_symbols, structs_map)
    store64(tc_collected_symbols + 8, enums_map)
    store64(tc_collected_symbols + 16, fn_env)
    store64(tc_collected_symbols + 24, methods_map)
    store64(tc_collected_symbols + 32, trait_registry)
    store64(tc_collected_symbols + 40, tc_collected_locals)
  }

  // Emit any collected diagnostics (exits if errors)
  tc_emit_diags()

  make_mod_exports(structs_map, enums_map, fn_exports, global_types, build_pub_fns(funcs_p, num_funcs))
}

// ------ check: top-level type checking entry point ---------------------------------------------------------
check(program:I mod_exports:I) I {
  if g_build_quiet == 0 { tc_warn_enabled = 1 }
  r = check_inner(program, mod_exports, 1)
  tc_warn_enabled = 0
  r
}

// ------ check_module: type-check a library module (no main required) ---
check_module(program:I mod_exports:I) I {
  check_inner(program, mod_exports, 0)
}
