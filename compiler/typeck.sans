      nargs != 3 ? tc_error("cseti() takes exactly 3 arguments (handle, opt, val)") : 0
      ci := 0
      while ci < 3 {
        at = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at) != TY_INT ? tc_error("cseti() argument must be Int, got " + type_to_string(at)) : 0
        ci += 1
      }
      return make_type(TY_INT)
    } : 0

    name == "cperf" ? {
      nargs != 1 ? tc_error("cperf() takes exactly 1 argument (handle)") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_INT ? tc_error("cperf() handle must be Int, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    name == "cclean" ? {
      nargs != 1 ? tc_error("cclean() takes exactly 1 argument (handle)") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_INT ? tc_error("cclean() handle must be Int, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    name == "cinfo" ? {
      nargs != 3 ? tc_error("cinfo() takes exactly 3 arguments (handle, info, buf)") : 0
      ci := 0
      while ci < 3 {
        at = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at) != TY_INT ? tc_error("cinfo() argument must be Int, got " + type_to_string(at)) : 0
        ci += 1
      }
      return make_type(TY_INT)
    } : 0

    name == "curl_slist_append" ? {
      nargs != 2 ? tc_error("curl_slist_append() takes exactly 2 arguments (slist, str)") : 0
      at0 = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at0) != TY_INT ? tc_error("curl_slist_append() slist must be Int, got " + type_to_string(at0)) : 0
      at1 = check_expr(args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at1) != TY_INT ? tc_error("curl_slist_append() str must be Int, got " + type_to_string(at1)) : 0
      return make_type(TY_INT)
    } : 0

    name == "curl_slist_free" ? {
      nargs != 1 ? tc_error("curl_slist_free() takes exactly 1 argument (slist)") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_INT ? tc_error("curl_slist_free() slist must be Int, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    // ── Result ───────────────────────────────────────────────────
    name == "ok" ? {
      nargs != 1 ? tc_error("ok() takes exactly 1 argument") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      return make_result_type(at)
    } : 0

    name == "err" ? {
      nargs != 1 ? tc_error("err() takes exactly 1 argument") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_STRING ? tc_error("err() requires String argument, got " + type_to_string(at)) : 0
      return make_type(TY_RESULT_ERR)
    } : 0

    // ── Map ──────────────────────────────────────────────────────
    name == "M" || name == "map" ? {
      nargs != 0 ? tc_error("map() takes 0 arguments") : 0
      return make_type(TY_MAP)
    } : 0

    name == "mget" ? {
      nargs != 2 ? tc_error("mget() takes exactly 2 arguments (map, key)") : 0
      i := 0
      while i < nargs {
        check_expr(args[i], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        i += 1
      }
      return make_type(TY_INT)
    } : 0

    name == "mset" ? {
      nargs != 3 ? tc_error("mset() takes exactly 3 arguments (map, key, val)") : 0
      i := 0
      while i < nargs {
        check_expr(args[i], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        i += 1
      }
      return make_type(TY_INT)
    } : 0

    name == "mhas" ? {
      nargs != 2 ? tc_error("mhas() takes exactly 2 arguments (map, key)") : 0
      i := 0
      while i < nargs {
        check_expr(args[i], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        i += 1
      }
      return make_type(TY_INT)
    } : 0

    // ── Misc ─────────────────────────────────────────────────────
    name == "args" ? {
      nargs != 0 ? tc_error("args() takes 0 arguments") : 0
      return make_array_type(make_type(TY_STRING))
    } : 0

    name == "exit" ? {
      nargs != 1 ? tc_error("exit() takes exactly 1 argument (code)") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_INT ? tc_error("exit() code must be Int, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    name == "system" || name == "sys" ? {
      nargs != 1 ? tc_error("system() takes exactly 1 argument (cmd)") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_STRING ? tc_error("system() cmd must be String, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    name == "signal_handler" ? {
      nargs != 1 ? tc_error("signal_handler() takes exactly 1 argument (signum)") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_INT ? tc_error("signal_handler() signum must be Int, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    name == "signal_check" ? {
      nargs != 0 ? tc_error("signal_check() takes no arguments") : 0
      return make_type(TY_INT)
    } : 0

    name == "spoll" ? {
      nargs != 2 ? tc_error("spoll() takes exactly 2 arguments (fd, timeout_ms)") : 0
      at0 = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at0) != TY_INT ? tc_error("spoll() fd must be Int, got " + type_to_string(at0)) : 0
      at1 = check_expr(args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at1) != TY_INT ? tc_error("spoll() timeout_ms must be Int, got " + type_to_string(at1)) : 0
      return make_type(TY_INT)
    } : 0

    // ── User-defined function: check fn_env ──────────────────────
    mhas(fn_env, name) ? {
      sig = mget(fn_env, name)
      // sig layout: offset 0 = params array ptr, offset 8 = return type ptr
      sig_params = load64(sig)
      sig_ret = load64(sig + 8)
      sig_params_len = sig_params != 0 ? load64(sig_params + 8) : 0
      sig_params_d = sig_params != 0 ? load64(sig_params) : 0

      nargs != sig_params_len ? tc_error("wrong argument count calling '" + name + "': expected " + str(sig_params_len) + " argument(s) but got " + str(nargs)) : 0

      ci := 0
      while ci < nargs {
        actual = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        expected = load64(sig_params_d + ci * 8)
        types_compatible(actual, expected) == 0 ? tc_error("argument " + str(ci + 1) + " to '" + name + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) : 0
        ci += 1
      }
      return sig_ret
    } : 0

    // ── Check local variable holding a lambda/fn ─────────────────
    local_ty = lookup_local(locals, name)
    local_ty != 0 && type_tag(local_ty) == TY_FN ? {
      fn_params = type_data(local_ty)
      fn_ret = type_data2(local_ty)
      fn_params_len = fn_params != 0 ? load64(fn_params + 8) : 0
      fn_params_d = fn_params != 0 ? load64(fn_params) : 0

      nargs != fn_params_len ? tc_error("wrong argument count calling '" + name + "': expected " + str(fn_params_len) + " argument(s) but got " + str(nargs)) : 0

      ci := 0
      while ci < nargs {
        actual = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        expected = load64(fn_params_d + ci * 8)
        type_eq(actual, expected) == 0 ? tc_error("argument " + str(ci + 1) + " to '" + name + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) : 0
        ci += 1
      }
      return fn_ret
    } : 0

    // ── Check mod_exports ────────────────────────────────────────
    // Look for "module.func" pattern in function name
    dot_pos = find_char(name, 46, 0)
    dot_pos >= 0 ? {
      mod_name = name.substring(0, dot_pos)
      func_name = name.substring(dot_pos + 1, slen(name))
      mod_exports != 0 && mhas(mod_exports, mod_name) ? {
        exports = mget(mod_exports, mod_name)
        exp_fn_env = load64(exports + 16)
        exp_fn_env != 0 && mhas(exp_fn_env, func_name) ? {
          sig = mget(exp_fn_env, func_name)
          sig_params = load64(sig)
          sig_ret = load64(sig + 8)
          sig_params_len = sig_params != 0 ? load64(sig_params + 8) : 0
          sig_params_d = sig_params != 0 ? load64(sig_params) : 0

          nargs != sig_params_len ? tc_error("wrong argument count calling '" + name + "': expected " + str(sig_params_len) + " argument(s) but got " + str(nargs)) : 0

          ci := 0
          while ci < nargs {
            actual = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
            expected = load64(sig_params_d + ci * 8)
            types_compatible(actual, expected) == 0 ? tc_error("argument " + str(ci + 1) + " to '" + name + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) : 0
            ci += 1
          }
          return sig_ret
        } : 0
      } : 0
    } : 0

    // ── Check generic functions ──────────────────────────────────
    mhas(generic_fns, name) ? {
      gfunc = mget(generic_fns, name)
      // gfunc is the function AST node: offset 0=name, 8=params, 16=ret_type, 24=body, 32=type_params
      gparams_arr = load64(gfunc + 8)
      gparams_p = load64(gparams_arr)
      gnum_params = load64(gparams_arr + 8)
      gret_name = load64(gfunc + 16)
      gtype_params_arr = load64(gfunc + 32)
      gtype_params_p = load64(gtype_params_arr)
      gnum_type_params = load64(gtype_params_arr + 8)

      nargs != gnum_params ? tc_error("wrong argument count calling '" + name + "': expected " + str(gnum_params) + " argument(s) but got " + str(nargs)) : 0

      // Infer type parameters from arguments
      type_map = map()
      gi := 0
      while gi < nargs {
        actual_ty = check_expr(args[gi], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        gp = load64(gparams_p + gi * 8)
        gp_type_name = as_str(load64(gp + 8))
        // Check if param type name is one of the type params
        is_tp := 0
        tpi := 0
        while tpi < gnum_type_params {
          tp_node = load64(gtype_params_p + tpi * 8)
          tp_name = as_str(load64(tp_node))
          tp_name == gp_type_name ? { is_tp = 1 } : 0
          tpi += 1
        }
        is_tp == 1 ? {
          mset(type_map, gp_type_name, actual_ty)
        } : 0
        gi += 1
      }
      // Resolve return type: if it's a type param, use inferred type
      gret_name_s = as_str(gret_name)
      mhas(type_map, gret_name_s) ? {
        return mget(type_map, gret_name_s)
      } : {
        return resolve_type(gret_name_s, structs, enums, mod_exports)
      }
    } : 0

    return tc_error("undefined function '" + name + "'")
  } : 0

  // ── Method call ─────────────────────────────────────────────────
  tag == EX_METHOD_CALL ? {
    mc_object = load64(expr + 8)
    mc_method = as_str(load64(expr + 16))
    mc_args = load64(expr + 24)
    mc_nargs = mc_args.len()

    // Cross-module call: obj is identifier that matches a module name
    load64(mc_object) == EX_IDENT ? {
      mod_name = load64(mc_object + 8)
      mod_exports != 0 && mhas(mod_exports, mod_name) ? {
        exports = mget(mod_exports, mod_name)
        exp_fn_env = load64(exports + 16)
        exp_fn_env != 0 && mhas(exp_fn_env, mc_method) ? {
          sig = mget(exp_fn_env, mc_method)
          sig_params = load64(sig)
          sig_ret = load64(sig + 8)
          sig_params_len = sig_params != 0 ? load64(sig_params + 8) : 0
          sig_params_d = sig_params != 0 ? load64(sig_params) : 0
          mc_nargs != sig_params_len ? tc_error("function '" + mc_method + "' in module '" + mod_name + "' expects " + str(sig_params_len) + " arguments, got " + str(mc_nargs)) : 0
          mci := 0
          while mci < mc_nargs {
            actual = check_expr(mc_args[mci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
            expected = load64(sig_params_d + mci * 8)
            types_compatible(actual, expected) == 0 ? tc_error("argument " + str(mci + 1) + " to '" + mod_name + "." + mc_method + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) : 0
            mci += 1
          }
          return sig_ret
        } : 0
      } : 0
    } : 0

    obj_ty = check_expr(mc_object, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    ot = type_tag(obj_ty)

    // ── Sender.send ──────────────────────────────────────────────
    ot == TY_SENDER && mc_method == "send" ? {
      mc_nargs != 1 ? tc_error("send() takes exactly 1 argument") : 0
      at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_eq(at, type_inner(obj_ty)) == 0 ? tc_error("send() type mismatch: channel holds " + type_to_string(type_inner(obj_ty)) + " but got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    // ── Receiver.recv ────────────────────────────────────────────
    ot == TY_RECEIVER && mc_method == "recv" ? {
      mc_nargs != 0 ? tc_error("recv() takes no arguments") : 0
      return type_inner(obj_ty)
    } : 0

    // ── JoinHandle.join ──────────────────────────────────────────
    ot == TY_JOIN_HANDLE && mc_method == "join" ? {
      mc_nargs != 0 ? tc_error("join() takes no arguments") : 0
      return make_type(TY_INT)
    } : 0

    // ── Mutex.lock ───────────────────────────────────────────────
    ot == TY_MUTEX && mc_method == "lock" ? {
      mc_nargs != 0 ? tc_error("lock() takes no arguments") : 0
      return type_inner(obj_ty)
    } : 0

    // ── Mutex.unlock ─────────────────────────────────────────────
    ot == TY_MUTEX && mc_method == "unlock" ? {
      mc_nargs != 1 ? tc_error("unlock() takes exactly 1 argument") : 0
      at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_eq(at, type_inner(obj_ty)) == 0 ? tc_error("unlock() type mismatch: mutex holds " + type_to_string(type_inner(obj_ty)) + " but got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    // ── Array methods ────────────────────────────────────────────
    ot == TY_ARRAY ? {
      arr_inner = type_inner(obj_ty)

      mc_method == "push" ? {
        mc_nargs != 1 ? tc_error("push() takes exactly 1 argument") : 0
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_eq(at, arr_inner) == 0 ? tc_error("push() type mismatch: array holds " + type_to_string(arr_inner) + " but got " + type_to_string(at)) : 0
        return make_type(TY_INT)
      } : 0

      mc_method == "get" ? {
        mc_nargs != 1 ? tc_error("get() takes exactly 1 argument") : 0
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at) != TY_INT ? tc_error("get() index must be Int, got " + type_to_string(at)) : 0
        return arr_inner
      } : 0

      mc_method == "set" ? {
        mc_nargs != 2 ? tc_error("set() takes exactly 2 arguments (index, value)") : 0
        at0 = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at0) != TY_INT ? tc_error("set() index must be Int, got " + type_to_string(at0)) : 0
        at1 = check_expr(mc_args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_eq(at1, arr_inner) == 0 ? tc_error("set() type mismatch: array holds " + type_to_string(arr_inner) + " but got " + type_to_string(at1)) : 0
        return make_type(TY_INT)
      } : 0

      mc_method == "len" ? {
        mc_nargs != 0 ? tc_error("len() takes no arguments") : 0
        return make_type(TY_INT)
      } : 0

      mc_method == "pop" ? {
        mc_nargs != 0 ? tc_error("pop() takes no arguments") : 0
        return arr_inner
      } : 0

      mc_method == "remove" ? {
        mc_nargs != 1 ? tc_error("remove() takes exactly 1 argument (index)") : 0
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at) != TY_INT ? tc_error("remove() index must be Int, got " + type_to_string(at)) : 0
        return arr_inner
      } : 0

      mc_method == "map" ? {
        mc_nargs != 1 ? tc_error("map() takes exactly 1 argument (function)") : 0
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at) == TY_FN ? {
          fn_params = type_data(at)
          fn_ret = type_data2(at)
          fn_plen = fn_params != 0 ? load64(fn_params + 8) : 0
          fn_params_d = fn_params != 0 ? load64(fn_params) : 0
          fn_plen == 1 && type_eq(load64(fn_params_d), arr_inner) == 1 ? {
            return make_array_type(fn_ret)
          } : 0
        } : 0
        return tc_error("map() requires a function (" + type_to_string(arr_inner) + ") -> T, got " + type_to_string(at))
      } : 0

      mc_method == "filter" ? {
        mc_nargs != 1 ? tc_error("filter() takes exactly 1 argument (function)") : 0
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at) == TY_FN ? {
          fn_params = type_data(at)
          fn_ret = type_data2(at)
          fn_plen = fn_params != 0 ? load64(fn_params + 8) : 0
          fn_params_d = fn_params != 0 ? load64(fn_params) : 0
          fn_plen == 1 && type_eq(load64(fn_params_d), arr_inner) == 1 && type_tag(fn_ret) == TY_BOOL ? {
            return make_array_type(arr_inner)
          } : 0
        } : 0
        return tc_error("filter() requires a function (" + type_to_string(arr_inner) + ") -> Bool, got " + type_to_string(at))
      } : 0

      mc_method == "any" ? {
        mc_nargs != 1 ? tc_error("any() takes exactly 1 argument (function)") : 0
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at) == TY_FN ? {
          fn_params = type_data(at)
          fn_ret = type_data2(at)
          fn_plen = fn_params != 0 ? load64(fn_params + 8) : 0
          fn_params_d = fn_params != 0 ? load64(fn_params) : 0
          fn_plen == 1 && type_eq(load64(fn_params_d), arr_inner) == 1 && type_tag(fn_ret) == TY_BOOL ? {
            return make_type(TY_BOOL)
          } : 0
        } : 0
        return tc_error("any() requires a function (" + type_to_string(arr_inner) + ") -> Bool, got " + type_to_string(at))
      } : 0

      mc_method == "find" ? {
        mc_nargs != 1 ? tc_error("find() takes exactly 1 argument (function)") : 0
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at) == TY_FN ? {
          fn_params = type_data(at)
          fn_ret = type_data2(at)
          fn_plen = fn_params != 0 ? load64(fn_params + 8) : 0
          fn_params_d = fn_params != 0 ? load64(fn_params) : 0
          fn_plen == 1 && type_eq(load64(fn_params_d), arr_inner) == 1 && type_tag(fn_ret) == TY_BOOL ? {
            return arr_inner
          } : 0
        } : 0
        return tc_error("find() requires a function (" + type_to_string(arr_inner) + ") -> Bool, got " + type_to_string(at))
      } : 0

      mc_method == "enumerate" ? {
        mc_nargs != 0 ? tc_error("enumerate() takes no arguments") : 0
        tup_elems = [make_type(TY_INT) arr_inner]
        return make_array_type(make_tuple_type(tup_elems))
      } : 0

      mc_method == "zip" ? {
        mc_nargs != 1 ? tc_error("zip() takes exactly 1 argument (array)") : 0
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at) == TY_ARRAY ? {
          tup_elems = [arr_inner type_inner(at)]
          return make_array_type(make_tuple_type(tup_elems))
        } : 0
        return tc_error("zip() requires an array argument, got " + type_to_string(at))
      } : 0

      mc_method == "contains" ? {
        mc_nargs != 1 ? tc_error("contains() takes exactly 1 argument") : 0
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_eq(at, arr_inner) == 0 ? tc_error("contains() argument must be " + type_to_string(arr_inner) + ", got " + type_to_string(at)) : 0
        return make_type(TY_BOOL)
      } : 0

      return tc_error("Array has no method '" + mc_method + "'")
    } : 0

    // ── String methods ───────────────────────────────────────────
    ot == TY_STRING ? {
      mc_method == "len" ? {
        mc_nargs != 0 ? tc_error("len() takes no arguments") : 0
        return make_type(TY_INT)
      } : 0

      mc_method == "trim" ? {
        mc_nargs != 0 ? tc_error("trim() takes no arguments") : 0
        return make_type(TY_STRING)
