      type_tag(at0) != TY_INT ? tc_error("ws_send() ws must be Int, got " + type_to_string(at0)) : 0
      at1 = check_expr(args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at1) != TY_STRING ? tc_error("ws_send() msg must be String, got " + type_to_string(at1)) : 0
