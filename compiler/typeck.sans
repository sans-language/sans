    obj_tag == TY_ARRAY && field_s == "len" ? { return make_type(TY_INT) } : 0
    obj_tag == TY_STRING && field_s == "len" ? { return make_type(TY_INT) } : 0
    obj_tag == TY_MAP && field_s == "len" ? { return make_type(TY_INT) } : 0
    obj_tag == TY_MAP && field_s == "keys" ? { return make_array_type(make_type(TY_STRING)) } : 0
    obj_tag == TY_MAP && field_s == "vals" ? { return make_array_type(make_type(TY_INT)) } : 0
