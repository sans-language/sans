      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_INT ? tc_error("sclose() fd must be Int, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    name == "rbind" ? {
      nargs != 3 ? tc_error("rbind() takes exactly 3 arguments (fd, addr, len)") : 0
      ci := 0
      while ci < 3 {
        at = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at) != TY_INT ? tc_error("rbind() argument must be Int, got " + type_to_string(at)) : 0
        ci += 1
      }
      return make_type(TY_INT)
    } : 0

    name == "rsetsockopt" ? {
      nargs != 5 ? tc_error("rsetsockopt() takes exactly 5 arguments (fd, level, opt, val_ptr, val_len)") : 0
      ci := 0
      while ci < 5 {
        at = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at) != TY_INT ? tc_error("rsetsockopt() argument must be Int, got " + type_to_string(at)) : 0
        ci += 1
      }
      return make_type(TY_INT)
    } : 0

    name == "strstr" ? {
      nargs != 2 ? tc_error("strstr() takes exactly 2 arguments (haystack, needle)") : 0
      at0 = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at0) != TY_INT ? tc_error("strstr() haystack must be Int, got " + type_to_string(at0)) : 0
      at1 = check_expr(args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at1) != TY_INT ? tc_error("strstr() needle must be Int, got " + type_to_string(at1)) : 0
      return make_type(TY_INT)
    } : 0

    // ── Curl ─────────────────────────────────────────────────────
    name == "cinit" ? {
      nargs != 0 ? tc_error("cinit() takes no arguments") : 0
      return make_type(TY_INT)
    } : 0

    name == "csets" ? {
      nargs != 3 ? tc_error("csets() takes exactly 3 arguments (handle, opt, val)") : 0
      at0 = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at0) != TY_INT ? tc_error("csets() handle must be Int, got " + type_to_string(at0)) : 0
      at1 = check_expr(args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at1) != TY_INT ? tc_error("csets() opt must be Int, got " + type_to_string(at1)) : 0
      at2 = check_expr(args[2], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at2) != TY_STRING ? tc_error("csets() val must be String, got " + type_to_string(at2)) : 0
      return make_type(TY_INT)
    } : 0

    name == "cseti" ? {
      nargs != 3 ? tc_error("cseti() takes exactly 3 arguments (handle, opt, val)") : 0
      ci := 0
      while ci < 3 {
        at = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at) != TY_INT ? tc_error("cseti() argument must be Int, got " + type_to_string(at)) : 0
        ci += 1
      }
      return make_type(TY_INT)
    } : 0

    name == "cperf" ? {
      nargs != 1 ? tc_error("cperf() takes exactly 1 argument (handle)") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_INT ? tc_error("cperf() handle must be Int, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    name == "cclean" ? {
      nargs != 1 ? tc_error("cclean() takes exactly 1 argument (handle)") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_INT ? tc_error("cclean() handle must be Int, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    name == "cinfo" ? {
      nargs != 3 ? tc_error("cinfo() takes exactly 3 arguments (handle, info, buf)") : 0
      ci := 0
      while ci < 3 {
        at = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        type_tag(at) != TY_INT ? tc_error("cinfo() argument must be Int, got " + type_to_string(at)) : 0
        ci += 1
      }
      return make_type(TY_INT)
    } : 0

    name == "curl_slist_append" ? {
      nargs != 2 ? tc_error("curl_slist_append() takes exactly 2 arguments (slist, str)") : 0
      at0 = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at0) != TY_INT ? tc_error("curl_slist_append() slist must be Int, got " + type_to_string(at0)) : 0
      at1 = check_expr(args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at1) != TY_INT ? tc_error("curl_slist_append() str must be Int, got " + type_to_string(at1)) : 0
      return make_type(TY_INT)
    } : 0

    name == "curl_slist_free" ? {
      nargs != 1 ? tc_error("curl_slist_free() takes exactly 1 argument (slist)") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_INT ? tc_error("curl_slist_free() slist must be Int, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    // ── Result ───────────────────────────────────────────────────
    name == "ok" ? {
      nargs != 1 ? tc_error("ok() takes exactly 1 argument") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      return make_result_type(at)
    } : 0

    name == "err" ? {
      nargs != 1 ? tc_error("err() takes exactly 1 argument") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_STRING ? tc_error("err() requires String argument, got " + type_to_string(at)) : 0
      return make_type(TY_RESULT_ERR)
    } : 0

    // ── Map ──────────────────────────────────────────────────────
    name == "M" || name == "map" ? {
      nargs != 0 ? tc_error("map() takes 0 arguments") : 0
      return make_type(TY_MAP)
    } : 0

    // ── Misc ─────────────────────────────────────────────────────
    name == "args" ? {
      nargs != 0 ? tc_error("args() takes 0 arguments") : 0
      return make_array_type(make_type(TY_STRING))
    } : 0

    name == "exit" ? {
      nargs != 1 ? tc_error("exit() takes exactly 1 argument (code)") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_INT ? tc_error("exit() code must be Int, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    name == "system" || name == "sys" ? {
      nargs != 1 ? tc_error("system() takes exactly 1 argument (cmd)") : 0
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(at) != TY_STRING ? tc_error("system() cmd must be String, got " + type_to_string(at)) : 0
      return make_type(TY_INT)
    } : 0

    // ── User-defined function: check fn_env ──────────────────────
    fn_env.has(name) ? {
      sig = fn_env.get(name)
      // sig layout: offset 0 = params array ptr, offset 8 = return type ptr
      sig_params = load64(sig)
      sig_ret = load64(sig + 8)
      sig_params_len = sig_params != 0 ? load64(sig_params - 8) : 0

      nargs != sig_params_len ? tc_error("wrong argument count calling '" + name + "': expected " + str(sig_params_len) + " argument(s) but got " + str(nargs)) : 0

      ci := 0
      while ci < nargs {
        actual = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        expected = load64(sig_params + ci * 8)
        types_compatible(actual, expected) == 0 ? tc_error("argument " + str(ci + 1) + " to '" + name + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) : 0
        ci += 1
      }
      return sig_ret
    } : 0

    // ── Check local variable holding a lambda/fn ─────────────────
    local_ty = lookup_local(locals, name)
    local_ty != 0 && type_tag(local_ty) == TY_FN ? {
      fn_params = type_data(local_ty)
      fn_ret = type_data2(local_ty)
      fn_params_len = fn_params != 0 ? load64(fn_params - 8) : 0

      nargs != fn_params_len ? tc_error("wrong argument count calling '" + name + "': expected " + str(fn_params_len) + " argument(s) but got " + str(nargs)) : 0

      ci := 0
      while ci < nargs {
        actual = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        expected = load64(fn_params + ci * 8)
        type_eq(actual, expected) == 0 ? tc_error("argument " + str(ci + 1) + " to '" + name + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) : 0
        ci += 1
      }
      return fn_ret
    } : 0

    // ── Check mod_exports ────────────────────────────────────────
    // Look for "module.func" pattern in function name
    dot_pos = find_char(name, 46, 0)
    dot_pos >= 0 ? {
      mod_name = name.substring(0, dot_pos)
      func_name = name.substring(dot_pos + 1, slen(name))
      mod_exports != 0 && mod_exports.has(mod_name) ? {
        exports = mod_exports.get(mod_name)
        exp_fn_env = load64(exports + 16)
        exp_fn_env != 0 && exp_fn_env.has(func_name) ? {
          sig = exp_fn_env.get(func_name)
          sig_params = load64(sig)
          sig_ret = load64(sig + 8)
          sig_params_len = sig_params != 0 ? load64(sig_params - 8) : 0

          nargs != sig_params_len ? tc_error("wrong argument count calling '" + name + "': expected " + str(sig_params_len) + " argument(s) but got " + str(nargs)) : 0

          ci := 0
          while ci < nargs {
            actual = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
            expected = load64(sig_params + ci * 8)
            types_compatible(actual, expected) == 0 ? tc_error("argument " + str(ci + 1) + " to '" + name + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) : 0
            ci += 1
          }
          return sig_ret
        } : 0
      } : 0
    } : 0

    return tc_error("undefined function '" + name + "'")
  } : 0

  // ── Method call (stub — full impl in 4d) ──────────────────────
  tag == EX_METHOD_CALL ? {
    // TODO: implement method call checking in task 4d
    return make_type(TY_INT)
  } : 0

  // ── Field access ──────────────────────────────────────────────
  tag == EX_FIELD_ACCESS ? {
    object = load64(expr + 8)
    field = load64(expr + 16)
    obj_ty = check_expr(object, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    obj_tag = type_tag(obj_ty)

    // Tuple: field is numeric index
    obj_tag == TY_TUPLE ? {
      elems = type_data2(obj_ty)
      elems == 0 ? return tc_error("tuple has no elements") : 0
      len = load64(elems - 8)
      // Parse field name as integer index
      idx = stoi(field)
      idx < 0 || idx >= len ? return tc_error("tuple index out of bounds") : 0
      return load64(elems + idx * 8)
    } : 0

    // Struct: look up field in fields map
    obj_tag == TY_STRUCT ? {
      sname = type_data(obj_ty)
      fields_map = type_data2(obj_ty)
      fields_map != 0 && fields_map.has(field) ? return fields_map.get(field) : 0
      return tc_error("no field '" + field + "' on struct '" + sname + "'")
    } : 0

    // Fallback: treat as no-arg method call (e.g. array.len)
    // Construct a synthetic method call and check it
    // For now, return error
    return tc_error("field access on non-struct/tuple type " + type_to_string(obj_ty))
  } : 0

  // ── Struct literal ────────────────────────────────────────────
  tag == EX_STRUCT_LIT ? {
    sname = load64(expr + 8)
    field_names_p = load64(expr + 16)
    field_values_p = load64(expr + 24)

    // Look up struct definition
    structs.has(sname) == 0 ? return tc_error("undefined struct '" + sname + "'") : 0
    expected_fields = structs.get(sname)

    // expected_fields is a Map: field_name → Type ptr
    exp_keys = expected_fields.keys()
    exp_len = exp_keys.len()

    // Number of provided fields
    num_fields = load64(field_names_p - 8)

    // Check for missing fields
    ei := 0
    while ei < exp_len {
      ek = exp_keys[ei]
      found := 0
      fi := 0
      while fi < num_fields {
        load64(field_names_p + fi * 8) == ek ? { found = 1; fi = num_fields } : 0
        fi += 1
      }
      found == 0 ? return tc_error("missing field '" + ek + "' in struct '" + sname + "'") : 0
      ei += 1
    }

    // Check each provided field's type
    fi := 0
    while fi < num_fields {
      fname = load64(field_names_p + fi * 8)
      fval = load64(field_values_p + fi * 8)
      expected_fields.has(fname) == 0 ? return tc_error("unknown field '" + fname + "' on struct '" + sname + "'") : 0
      expected_ty = expected_fields.get(fname)
      actual_ty = check_expr(fval, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_eq(actual_ty, expected_ty) == 0 ? return tc_error("type mismatch for field '" + fname + "' of struct '" + sname + "': expected " + type_to_string(expected_ty) + " but got " + type_to_string(actual_ty)) : 0
      fi += 1
    }

    return make_struct_type(sname, expected_fields)
  } : 0

  // ── Tuple literal ─────────────────────────────────────────────
  tag == EX_TUPLE_LIT ? {
    elems_p = load64(expr + 8)
    num_elems = load64(elems_p - 8)
    elem_types = [I]
    i := 0
    while i < num_elems {
      et = check_expr(load64(elems_p + i * 8), locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      elem_types.push(et)
      i += 1
    }
    return make_tuple_type(ptr(elem_types))
  } : 0

  // ── Array literal ─────────────────────────────────────────────
  tag == EX_ARRAY_LIT ? {
    elems_p = load64(expr + 8)
    num_elems = load64(elems_p - 8)
    num_elems == 0 ? return tc_error("empty array literal — cannot infer element type") : 0
    first_ty = check_expr(load64(elems_p), locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    i := 1
    while i < num_elems {
      elem_ty = check_expr(load64(elems_p + i * 8), locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_eq(elem_ty, first_ty) == 0 ? return tc_error("array literal element " + str(i) + " has type " + type_to_string(elem_ty) + " but expected " + type_to_string(first_ty)) : 0
      i += 1
    }
    return make_array_type(first_ty)
  } : 0

  // ── Match expression ──────────────────────────────────────────
  tag == EX_MATCH ? {
    scrutinee = load64(expr + 8)
    arms_p = load64(expr + 16)
    scrutinee_ty = check_expr(scrutinee, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    type_tag(scrutinee_ty) != TY_ENUM ? return tc_error("match scrutinee must be an enum type, got " + type_to_string(scrutinee_ty)) : 0

    enum_name = type_data(scrutinee_ty)
    // Get enum variants from enums map
    enums.has(enum_name) == 0 ? return tc_error("undefined enum '" + enum_name + "'") : 0
    variants = enums.get(enum_name)

    num_arms = load64(arms_p - 8)
    num_arms == 0 ? return tc_error("match expression has no arms") : 0

    result_ty := 0
    ai := 0
    while ai < num_arms {
      arm = load64(arms_p + ai * 8)
      // arm layout: offset 0 = pattern ptr, offset 8 = body expr ptr
      pattern = load64(arm)
      arm_body = load64(arm + 8)

      // pattern layout: offset 0 = enum_name, offset 8 = variant_name, offset 16 = bindings array ptr
      pat_enum = load64(pattern)
      pat_variant = load64(pattern + 8)
      bindings_p = load64(pattern + 16)

      pat_enum != enum_name ? return tc_error("pattern enum '" + pat_enum + "' does not match scrutinee enum '" + enum_name + "'") : 0

      // Look up variant in variants map
      variants.has(pat_variant) == 0 ? return tc_error("unknown variant '" + pat_variant + "' on enum '" + enum_name + "'") : 0
      variant_fields_p = variants.get(pat_variant)
      // variant_fields_p is a raw array of Type ptrs
      variant_fields_len = load64(variant_fields_p - 8)

      bindings_len = load64(bindings_p - 8)
      bindings_len != variant_fields_len ? return tc_error("pattern '" + enum_name + "::" + pat_variant + "' expects " + str(variant_fields_len) + " binding(s) but got " + str(bindings_len)) : 0

      // Create new scope with bindings
      push_scope(locals)
      inner_scope = locals[locals.len() - 1]
      bi := 0
      while bi < bindings_len {
        bname = load64(bindings_p + bi * 8)
        btype = load64(variant_fields_p + bi * 8)
        inner_scope.set(bname, btype)
        bi += 1
      }

      arm_ty = check_expr(arm_body, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      pop_scope(locals)

      result_ty == 0 ? {
        result_ty = arm_ty
      } : {
        type_eq(arm_ty, result_ty) == 0 ? return tc_error("match arm type mismatch: expected " + type_to_string(result_ty) + " but got " + type_to_string(arm_ty)) : 0
      }
      ai += 1
    }
    return result_ty
  } : 0

  // ── Lambda ────────────────────────────────────────────────────
  tag == EX_LAMBDA ? {
    params_p = load64(expr + 8)
    ret_type_name = load64(expr + 16)
    body_stmts_p = load64(expr + 24)

    // Build param types and add to new scope
    push_scope(locals)
    inner_scope = locals[locals.len() - 1]
    param_types = [I]

    num_params = load64(params_p - 8)
    pi := 0
    while pi < num_params {
      param = load64(params_p + pi * 8)
      // param layout: offset 0 = name, offset 8 = type_name string
      pname = load64(param)
      ptype_name = load64(param + 8)
      pty = resolve_type(ptype_name, structs, enums, mod_exports)
      param_types.push(pty)
      inner_scope.set(pname, pty)
      pi += 1
    }

    ret_ty = resolve_type(ret_type_name, structs, enums, mod_exports)

    // Check body stmts
    body_len = body_stmts_p != 0 ? load64(body_stmts_p - 8) : 0
    check_stmts(body_stmts_p, body_len, locals, fn_env, ret_ty, structs, enums, methods, generic_fns, traits, mod_exports)

    pop_scope(locals)
    return make_fn_type(ptr(param_types), ret_ty)
  } : 0

  // ── Spawn ─────────────────────────────────────────────────────
  tag == EX_SPAWN ? {
    func_name = load64(expr + 8)
    args_p = load64(expr + 16)
    num_args = load64(args_p - 8)

    fn_env.has(func_name) == 0 ? return tc_error("undefined function '" + func_name + "' in spawn") : 0
    sig = fn_env.get(func_name)
    sig_params = load64(sig)
    sig_params_len = sig_params != 0 ? load64(sig_params - 8) : 0

    num_args != sig_params_len ? return tc_error("wrong argument count calling '" + func_name + "': expected " + str(sig_params_len) + " but got " + str(num_args)) : 0

    si := 0
    while si < num_args {
      arg_expr = load64(args_p + si * 8)
      actual = check_expr(arg_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      expected = load64(sig_params + si * 8)
      // Allow opaque types where Int expected (pointers are i64)
      types_compatible(actual, expected) == 0 ? return tc_error("argument " + str(si + 1) + " to '" + func_name + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) : 0
      si += 1
    }
    return make_type(TY_JOIN_HANDLE)
  } : 0

  // ── Channel ───────────────────────────────────────────────────
  tag == EX_CHANNEL ? {
    elem_type_name = load64(expr + 8)
    capacity_expr = load64(expr + 16)

    // Check capacity if present
    capacity_expr != 0 ? {
      cap_ty = check_expr(capacity_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      type_tag(cap_ty) != TY_INT ? return tc_error("channel capacity must be Int, got " + type_to_string(cap_ty)) : 0
    } : 0

    inner = resolve_type(elem_type_name, structs, enums, mod_exports)
    // Rust returns Sender<T> — the channel() call returns Sender (receiver obtained via split)
    return make_sender_type(inner)
  } : 0

  // ── Mutex ─────────────────────────────────────────────────────
  tag == EX_MUTEX ? {
    value_expr = load64(expr + 8)
    inner = check_expr(value_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    return make_mutex_type(inner)
  } : 0

  // ── Enum variant ──────────────────────────────────────────────
  tag == EX_ENUM_VARIANT ? {
    ename = load64(expr + 8)
    vname = load64(expr + 16)
    args_p = load64(expr + 24)
    num_args = load64(args_p - 8)

    enums.has(ename) == 0 ? return tc_error("undefined enum '" + ename + "'") : 0
    variants = enums.get(ename)
    variants.has(vname) == 0 ? return tc_error("unknown variant '" + vname + "' on enum '" + ename + "'") : 0

    expected_fields_p = variants.get(vname)
    expected_len = load64(expected_fields_p - 8)

    num_args != expected_len ? return tc_error("variant '" + ename + "::" + vname + "' expects " + str(expected_len) + " argument(s) but got " + str(num_args)) : 0

    vi := 0
    while vi < num_args {
      arg_expr = load64(args_p + vi * 8)
      actual_ty = check_expr(arg_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      expected_ty = load64(expected_fields_p + vi * 8)
      type_eq(actual_ty, expected_ty) == 0 ? return tc_error("argument " + str(vi + 1) + " to '" + ename + "::" + vname + "': expected " + type_to_string(expected_ty) + " but got " + type_to_string(actual_ty)) : 0
      vi += 1
    }
    return make_enum_type(ename, variants)
  } : 0

  // ── Array create ──────────────────────────────────────────────
  tag == EX_ARRAY_CREATE ? {
    elem_type_name = load64(expr + 8)
    inner = resolve_type(elem_type_name, structs, enums, mod_exports)
    return make_array_type(inner)
  } : 0

  tc_error("check_expr: unknown expression tag " + str(tag))
}
