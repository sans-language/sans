      kt = resolve_type(ptr(k_str), structs, enums, mod_exports)
      ktag = type_tag(kt)
      if ktag != TY_STRING && ktag != TY_INT { return tc_error("Map key type must be I or S, got " + type_to_string(kt)) }
      vt = resolve_type(ptr(v_str), structs, enums, mod_exports)
      return make_map_type(kt, vt)
    }
    if name == "mget" {
      if nargs != 2 { tc_error("mget() takes exactly 2 arguments (map, key)") }
      i := 0
      while i < nargs {
      check_expr(args[i], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      i += 1
      }
      return make_type(TY_INT)
    }
    if name == "mset" {
      if nargs != 3 { tc_error("mset() takes exactly 3 arguments (map, key, val)") }
      i := 0
      while i < nargs {
      check_expr(args[i], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      i += 1
      }
      return make_type(TY_INT)
    }
    if name == "mhas" {
      if nargs != 2 { tc_error("mhas() takes exactly 2 arguments (map, key)") }
      i := 0
      while i < nargs {
      check_expr(args[i], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      i += 1
      }
      return make_type(TY_INT)
    }
    // ------ Misc ---------------------------------------------------------------------------------------------------------------------------------------------------------------
    if name == "args" {
      if nargs != 0 { tc_error("args() takes 0 arguments") }
      return make_array_type(make_type(TY_STRING))
    }
    if name == "exit" {
      if nargs != 1 { tc_error("exit() takes exactly 1 argument (code)") }
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if is_i64_compat(at) != 1 { tc_error("exit() code must be Int, got " + type_to_string(at)) }
      return make_type(TY_INT)
    }
    if name == "assert" {
      if nargs != 1 { tc_error_at(expr, "assert() takes exactly 1 argument") }
      check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      return make_type(TY_INT)
    }
    if name == "assert_eq" {
      if nargs != 2 { tc_error_at(expr, "assert_eq() takes exactly 2 arguments") }
      check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      check_expr(args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      return make_type(TY_INT)
    }
    if name == "assert_ne" {
      if nargs != 2 { tc_error_at(expr, "assert_ne() takes exactly 2 arguments") }
      check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      check_expr(args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      return make_type(TY_INT)
    }
    if name == "assert_ok" {
      if nargs != 1 { tc_error_at(expr, "assert_ok() takes exactly 1 argument") }
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      tt = type_tag(at)
      if tt != TY_RESULT && tt != TY_RESULT_ERR { tc_error_at(expr, "assert_ok() requires Result, got " + type_to_string(at)) }
      return make_type(TY_INT)
    }
    if name == "assert_err" {
      if nargs != 1 { tc_error_at(expr, "assert_err() takes exactly 1 argument") }
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      tt = type_tag(at)
      if tt != TY_RESULT && tt != TY_RESULT_ERR { tc_error_at(expr, "assert_err() requires Result, got " + type_to_string(at)) }
      return make_type(TY_INT)
    }
    if name == "assert_some" {
      if nargs != 1 { tc_error_at(expr, "assert_some() takes exactly 1 argument") }
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if type_tag(at) != TY_OPTION { tc_error_at(expr, "assert_some() requires Option, got " + type_to_string(at)) }
      return make_type(TY_INT)
    }
    if name == "assert_none" {
      if nargs != 1 { tc_error_at(expr, "assert_none() takes exactly 1 argument") }
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if type_tag(at) != TY_OPTION { tc_error_at(expr, "assert_none() requires Option, got " + type_to_string(at)) }
      return make_type(TY_INT)
    }
    if name == "system" || name == "sys" {
      if nargs != 1 { tc_error("system() takes exactly 1 argument (cmd)") }
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if is_i64_compat(at) != 1 { tc_error("system() cmd must be String, got " + type_to_string(at)) }
      return make_type(TY_INT)
    }
    if name == "signal_handler" || name == "sigh" {
      if nargs != 1 { tc_error("signal_handler() takes exactly 1 argument (signum)") }
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if is_i64_compat(at) != 1 { tc_error("signal_handler() signum must be Int, got " + type_to_string(at)) }
      return make_type(TY_INT)
    }
    if name == "signal_check" || name == "sigc" {
      if nargs != 0 { tc_error("signal_check() takes no arguments") }
      return make_type(TY_INT)
    }
    if name == "setjmp" {
      if nargs != 1 { tc_error("setjmp() takes exactly 1 argument (buf)") }
      at = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if is_i64_compat(at) != 1 { tc_error("setjmp() buf must be Int, got " + type_to_string(at)) }
      return make_type(TY_INT)
    }
    if name == "longjmp" {
      if nargs != 2 { tc_error("longjmp() takes exactly 2 arguments (buf, val)") }
      at0 = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if is_i64_compat(at0) != 1 { tc_error("longjmp() buf must be Int, got " + type_to_string(at0)) }
      at1 = check_expr(args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if is_i64_compat(at1) != 1 { tc_error("longjmp() val must be Int, got " + type_to_string(at1)) }
      return make_type(TY_INT)
    }
    if name == "panic_is_active" {
      if nargs != 0 { tc_error("panic_is_active() takes no arguments") }
      return make_type(TY_INT)
    }
    if name == "panic_enable" {
      if nargs != 0 { tc_error("panic_enable() takes no arguments") }
      return make_type(TY_INT)
    }
    if name == "panic_disable" {
      if nargs != 0 { tc_error("panic_disable() takes no arguments") }
      return make_type(TY_INT)
    }
    if name == "panic_get_buf" {
      if nargs != 0 { tc_error("panic_get_buf() takes no arguments") }
      return make_type(TY_INT)
    }
    if name == "panic_fire" {
      if nargs != 0 { tc_error("panic_fire() takes no arguments") }
      return make_type(TY_INT)
    }
    if name == "spoll" {
      if nargs != 2 { tc_error("spoll() takes exactly 2 arguments (fd, timeout_ms)") }
      at0 = check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if is_i64_compat(at0) != 1 { tc_error("spoll() fd must be Int, got " + type_to_string(at0)) }
      at1 = check_expr(args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if is_i64_compat(at1) != 1 { tc_error("spoll() timeout_ms must be Int, got " + type_to_string(at1)) }
      return make_type(TY_INT)
    }
    // ------ User-defined function: check fn_env ------------------------------------------------------------------
    if mhas(fn_env, name) {
      sig = mget(fn_env, name)
      // sig layout: offset 0 = params array ptr, offset 8 = return type ptr
      sig_params = load64(sig)
      sig_ret = load64(sig + 8)
      sig_params_len = if sig_params != 0 { load64(sig_params + 8) } else { 0 }
      sig_params_d = if sig_params != 0 { load64(sig_params) } else { 0 }
      sig_required = load64(sig + 16)
      if nargs < sig_required || nargs > sig_params_len {
        tc_error_at(expr, "wrong argument count calling '" + name + "': expected " + str(sig_required) + " to " + str(sig_params_len) + " argument(s) but got " + str(nargs))
        return sig_ret
      }
      ci := 0
      while ci < nargs {
      actual = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      expected = load64(sig_params_d + ci * 8)
      if types_compatible(actual, expected) == 0 { tc_error_at(args[ci], "argument " + str(ci + 1) + " to '" + name + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) }
      ci += 1
      }
      return sig_ret
    }
    // ------ Check local variable holding a lambda/fn ---------------------------------------------------
    local_ty = lookup_local(locals, name)
    if local_ty != 0 && type_tag(local_ty) == TY_FN {
      fn_params = type_data(local_ty)
      fn_ret = type_data2(local_ty)
      fn_params_len = if fn_params != 0 { load64(fn_params + 8) } else { 0 }
      fn_params_d = if fn_params != 0 { load64(fn_params) } else { 0 }
      if nargs != fn_params_len {
        tc_error_at(expr, "wrong argument count calling '" + name + "': expected " + str(fn_params_len) + " argument(s) but got " + str(nargs))
        return fn_ret
      }
      ci := 0
      while ci < nargs {
      actual = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      expected = load64(fn_params_d + ci * 8)
      if type_eq(actual, expected) == 0 { tc_error_at(args[ci], "argument " + str(ci + 1) + " to '" + name + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) }
      ci += 1
      }
      return fn_ret
    }
    // ------ Check mod_exports ------------------------------------------------------------------------------------------------------------------------
    // Look for "module.func" pattern in function name
    dot_pos = find_char(name, 46, 0)
    if dot_pos >= 0 {
      mod_name = name.substring(0, dot_pos)
      func_name = name.substring(dot_pos + 1, slen(name))
      if mod_exports != 0 && mhas(mod_exports, mod_name) {
        exports = mget(mod_exports, mod_name)
        exp_fn_env = load64(exports + 16)
        if exp_fn_env != 0 && mhas(exp_fn_env, func_name) {
          check_pub_access(exports, func_name, mod_name, expr)
          sig = mget(exp_fn_env, func_name)
          sig_params = load64(sig)
          sig_ret = load64(sig + 8)
          sig_params_len = if sig_params != 0 { load64(sig_params + 8) } else { 0 }
          sig_params_d = if sig_params != 0 { load64(sig_params) } else { 0 }
          sig_required2 = load64(sig + 16)
          if nargs < sig_required2 || nargs > sig_params_len {
            tc_error_at(expr, "wrong argument count calling '" + name + "': expected " + str(sig_required2) + " to " + str(sig_params_len) + " argument(s) but got " + str(nargs))
            return sig_ret
          }
          ci := 0
          while ci < nargs {
          actual = check_expr(args[ci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
          expected = load64(sig_params_d + ci * 8)
          if types_compatible(actual, expected) == 0 { tc_error_at(args[ci], "argument " + str(ci + 1) + " to '" + name + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) }
          ci += 1
          }
          return sig_ret
        }
      }
    }
    // ------ Check generic functions ------------------------------------------------------------------------------------------------------
    if mhas(generic_fns, name) {
      gfunc = mget(generic_fns, name)
      // gfunc is the function AST node: offset 0=name, 8=params, 16=ret_type, 24=body, 32=type_params
      gparams_arr = load64(gfunc + 8)
      gparams_p = load64(gparams_arr)
      gnum_params = load64(gparams_arr + 8)
      gret_name = load64(gfunc + 16)
      gtype_params_arr = load64(gfunc + 32)
      gtype_params_p = load64(gtype_params_arr)
      gnum_type_params = load64(gtype_params_arr + 8)
      if nargs != gnum_params {
        tc_error_at(expr, "wrong argument count calling '" + name + "': expected " + str(gnum_params) + " argument(s) but got " + str(nargs))
        return make_type(TY_INT)
      }
      // Infer type parameters from arguments
      type_map = map()
      gi := 0
      while gi < nargs {
      actual_ty = check_expr(args[gi], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      gp = load64(gparams_p + gi * 8)
      gp_type_name = as_str(load64(gp + 8))
      // Check if param type name is one of the type params
      is_tp := 0
      tpi := 0
      while tpi < gnum_type_params {
      tp_node = load64(gtype_params_p + tpi * 8)
      tp_name = as_str(load64(tp_node))
      if tp_name == gp_type_name {
        is_tp = 1
      }
      tpi += 1
      }
      if is_tp == 1 {
        mset(type_map, gp_type_name, actual_ty)
      }
      gi += 1
      }
      // Resolve return type: if it's a type param, use inferred type
      gret_name_s = as_str(gret_name)
      if mhas(type_map, gret_name_s) {
        return mget(type_map, gret_name_s)
      } else {
        return resolve_type(gret_name_s, structs, enums, mod_exports)
      }
    }
    tc_error_at(expr, "undefined function '" + name + "'")
    return make_type(TY_INT)
  }

  // ------ Method call ---------------------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_METHOD_CALL {
    mc_object = load64(expr + 16)
    mc_method = as_str(load64(expr + 24))
    mc_args = load64(expr + 32)
    mc_nargs = mc_args.len()
    // Cross-module call: obj is identifier that matches a module name
    if load64(mc_object) == EX_IDENT {
      mod_name = load64(mc_object + 16)
      if mod_exports != 0 && mhas(mod_exports, mod_name) {
        exports = mget(mod_exports, mod_name)
        exp_fn_env = load64(exports + 16)
        if exp_fn_env != 0 && mhas(exp_fn_env, mc_method) {
          check_pub_access(exports, mc_method, mod_name, mc_object)
          sig = mget(exp_fn_env, mc_method)
          sig_params = load64(sig)
          sig_ret = load64(sig + 8)
          sig_params_len = if sig_params != 0 { load64(sig_params + 8) } else { 0 }
          sig_params_d = if sig_params != 0 { load64(sig_params) } else { 0 }
          sig_required3 = load64(sig + 16)
          if mc_nargs < sig_required3 || mc_nargs > sig_params_len { tc_error("function '" + mc_method + "' in module '" + mod_name + "' expects " + str(sig_required3) + " to " + str(sig_params_len) + " arguments, got " + str(mc_nargs)) }
          mci := 0
          while mci < mc_nargs {
          actual = check_expr(mc_args[mci], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
          expected = load64(sig_params_d + mci * 8)
          if types_compatible(actual, expected) == 0 { tc_error("argument " + str(mci + 1) + " to '" + mod_name + "." + mc_method + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) }
          mci += 1
          }
          return sig_ret
        }
      }
    }
    obj_ty = check_expr(mc_object, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    ot = type_tag(obj_ty)
    // ------ Sender.send ------------------------------------------------------------------------------------------------------------------------------------------
    if ot == TY_SENDER && mc_method == "send" {
      if mc_nargs != 1 { tc_error("send() takes exactly 1 argument") }
      at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if type_eq(at, type_inner(obj_ty)) == 0 { tc_error("send() type mismatch: channel holds " + type_to_string(type_inner(obj_ty)) + " but got " + type_to_string(at)) }
      return make_type(TY_INT)
    }
    // ------ Receiver.recv ------------------------------------------------------------------------------------------------------------------------------------
    if ot == TY_RECEIVER && mc_method == "recv" {
      if mc_nargs != 0 { tc_error("recv() takes no arguments") }
      return type_inner(obj_ty)
    }
    // ------ JoinHandle.join ------------------------------------------------------------------------------------------------------------------------------
    if ot == TY_JOIN_HANDLE && mc_method == "join" {
      if mc_nargs != 0 { tc_error("join() takes no arguments") }
      return make_type(TY_INT)
    }
    // ------ Mutex.lock ---------------------------------------------------------------------------------------------------------------------------------------------
    if ot == TY_MUTEX && mc_method == "lock" {
      if mc_nargs != 0 { tc_error("lock() takes no arguments") }
      return type_inner(obj_ty)
    }
    // ------ Mutex.unlock ---------------------------------------------------------------------------------------------------------------------------------------
    if ot == TY_MUTEX && mc_method == "unlock" {
      if mc_nargs != 1 { tc_error("unlock() takes exactly 1 argument") }
      at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if type_eq(at, type_inner(obj_ty)) == 0 { tc_error("unlock() type mismatch: mutex holds " + type_to_string(type_inner(obj_ty)) + " but got " + type_to_string(at)) }
      return make_type(TY_INT)
    }
    // ------ Array methods ------------------------------------------------------------------------------------------------------------------------------------
    if ot == TY_ARRAY {
      arr_inner = type_inner(obj_ty)
      if mc_method == "push" {
        if mc_nargs != 1 { tc_error("push() takes exactly 1 argument") }
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        if type_eq(at, arr_inner) == 0 && is_i64_compat(at) != 1 { tc_error("push() type mismatch: array holds " + type_to_string(arr_inner) + " but got " + type_to_string(at)) }
        return make_type(TY_INT)
      }
      if mc_method == "get" {
        if mc_nargs != 1 { tc_error("get() takes exactly 1 argument") }
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        if is_i64_compat(at) != 1 { tc_error("get() index must be Int, got " + type_to_string(at)) }
        return arr_inner
      }
      if mc_method == "set" {
        if mc_nargs != 2 { tc_error("set() takes exactly 2 arguments (index, value)") }
        at0 = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        if is_i64_compat(at0) != 1 { tc_error("set() index must be Int, got " + type_to_string(at0)) }
        at1 = check_expr(mc_args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        if type_eq(at1, arr_inner) == 0 { tc_error("set() type mismatch: array holds " + type_to_string(arr_inner) + " but got " + type_to_string(at1)) }
        return make_type(TY_INT)
      }
      if mc_method == "len" {
        if mc_nargs != 0 { tc_error("len() takes no arguments") }
        return make_type(TY_INT)
      }
      if mc_method == "pop" {
        if mc_nargs != 0 { tc_error("pop() takes no arguments") }
        return arr_inner
      }
      if mc_method == "remove" {
        if mc_nargs != 1 { tc_error("remove() takes exactly 1 argument (index)") }
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        if is_i64_compat(at) != 1 { tc_error("remove() index must be Int, got " + type_to_string(at)) }
        return arr_inner
      }
      if mc_method == "map" {
        if mc_nargs != 1 { tc_error("map() takes exactly 1 argument (function)") }
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        if type_tag(at) == TY_FN {
          fn_params = type_data(at)
          fn_ret = type_data2(at)
          fn_plen = if fn_params != 0 { load64(fn_params + 8) } else { 0 }
          fn_params_d = if fn_params != 0 { load64(fn_params) } else { 0 }
          if fn_plen == 1 && type_eq(load64(fn_params_d), arr_inner) == 1 {
            return make_array_type(fn_ret)
          }
        }
        return tc_error("map() requires a function (" + type_to_string(arr_inner) + ") -> T, got " + type_to_string(at))
      }
      if mc_method == "filter" {
        if mc_nargs != 1 { tc_error("filter() takes exactly 1 argument (function)") }
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        if type_tag(at) == TY_FN {
          fn_params = type_data(at)
          fn_ret = type_data2(at)
          fn_plen = if fn_params != 0 { load64(fn_params + 8) } else { 0 }
          fn_params_d = if fn_params != 0 { load64(fn_params) } else { 0 }
          if fn_plen == 1 && type_eq(load64(fn_params_d), arr_inner) == 1 && type_tag(fn_ret) == TY_BOOL {
            return make_array_type(arr_inner)
          }
        }
        return tc_error("filter() requires a function (" + type_to_string(arr_inner) + ") -> Bool, got " + type_to_string(at))
      }
      if mc_method == "any" {
        if mc_nargs != 1 { tc_error("any() takes exactly 1 argument (function)") }
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        if type_tag(at) == TY_FN {
          fn_params = type_data(at)
          fn_ret = type_data2(at)
          fn_plen = if fn_params != 0 { load64(fn_params + 8) } else { 0 }
          fn_params_d = if fn_params != 0 { load64(fn_params) } else { 0 }
          if fn_plen == 1 && type_eq(load64(fn_params_d), arr_inner) == 1 && type_tag(fn_ret) == TY_BOOL {
            return make_type(TY_BOOL)
          }
        }
        return tc_error("any() requires a function (" + type_to_string(arr_inner) + ") -> Bool, got " + type_to_string(at))
      }
      if mc_method == "find" {
        if mc_nargs != 1 { tc_error("find() takes exactly 1 argument (function)") }
        at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        if type_tag(at) == TY_FN {
          fn_params = type_data(at)
          fn_ret = type_data2(at)
          fn_plen = if fn_params != 0 { load64(fn_params + 8) } else { 0 }
          fn_params_d = if fn_params != 0 { load64(fn_params) } else { 0 }
          if fn_plen == 1 && type_eq(load64(fn_params_d), arr_inner) == 1 && type_tag(fn_ret) == TY_BOOL {
            return make_option_type(arr_inner)
