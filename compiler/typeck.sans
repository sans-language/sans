    first_ty = check_expr(load64(elems_p), locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    i := 1
    while i < num_elems {
      elem_ty = check_expr(load64(elems_p + i * 8), locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if type_eq(elem_ty, first_ty) == 0 { return tc_error("array literal element " + str(i) + " has type " + type_to_string(elem_ty) + " but expected " + type_to_string(first_ty)) }
      i += 1
    }
    return make_array_type(first_ty)
  } : 0

  // ── Match expression ──────────────────────────────────────────
  tag == EX_MATCH ? {
    scrutinee = load64(expr + 8)
    arms_arr = load64(expr + 16)
    arms_p = load64(arms_arr)
    scrutinee_ty = check_expr(scrutinee, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    if type_tag(scrutinee_ty) != TY_ENUM { return tc_error("match scrutinee must be an enum type, got " + type_to_string(scrutinee_ty)) }

    enum_name_s = type_data_s(scrutinee_ty)
    // Get enum variants from enums map
    if mhas(enums, enum_name_s) == 0 { return tc_error("undefined enum '" + enum_name_s + "'") }
    variants = mget(enums, enum_name_s)

    num_arms = load64(arms_arr + 8)
    if num_arms == 0 { return tc_error("match expression has no arms") }

    result_ty := 0
    ai := 0
    while ai < num_arms {
      arm = load64(arms_p + ai * 8)
      // arm layout: offset 0 = pattern ptr, offset 8 = body expr ptr
      pattern = load64(arm)
      arm_body = load64(arm + 8)

      // pattern layout: offset 0 = enum_name, offset 8 = variant_name, offset 16 = bindings array ptr
      pat_enum_s = as_str(load64(pattern))
      pat_variant = load64(pattern + 8)

      if pat_enum_s != enum_name_s { return tc_error("pattern enum '" + pat_enum_s + "' does not match scrutinee enum '" + enum_name_s + "'") }

      // Look up variant in variants map
      if mhas(variants, pat_variant) == 0 { return tc_error("unknown variant '" + pat_variant + "' on enum '" + enum_name_s + "'") }
      variant_fields_arr = mget(variants, pat_variant)
      // variant_fields_arr is an array of Type ptrs
      variant_fields_p = load64(variant_fields_arr)
      variant_fields_len = load64(variant_fields_arr + 8)

      bindings_arr = load64(pattern + 16)
      bindings_p = load64(bindings_arr)
      bindings_len = load64(bindings_arr + 8)
      if bindings_len != variant_fields_len { return tc_error("pattern '" + enum_name_s + "::" + pat_variant + "' expects " + str(variant_fields_len) + " binding(s) but got " + str(bindings_len)) }

      // Create new scope with bindings
      push_scope(locals)
      inner_scope = locals[locals.len() - 1]
      bi := 0
      while bi < bindings_len {
        bname = load64(bindings_p + bi * 8)
        btype = load64(variant_fields_p + bi * 8)
        mset(inner_scope, bname, btype)
        bi += 1
      }

      arm_ty = check_expr(arm_body, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      pop_scope(locals)

      result_ty == 0 ? {
        result_ty = arm_ty
      } : {
        if type_eq(arm_ty, result_ty) == 0 { return tc_error("match arm type mismatch: expected " + type_to_string(result_ty) + " but got " + type_to_string(arm_ty)) }
      }
      ai += 1
    }
    return result_ty
  } : 0

  // ── Lambda ────────────────────────────────────────────────────
  tag == EX_LAMBDA ? {
    params_arr = load64(expr + 8)
    params_p = load64(params_arr)
    ret_type_name = load64(expr + 16)
    body_stmts_arr = load64(expr + 24)

    // Build param types and add to new scope
    push_scope(locals)
    inner_scope = locals[locals.len() - 1]
    param_types = array<I>()

    num_params = load64(params_arr + 8)
    pi := 0
    while pi < num_params {
      param = load64(params_p + pi * 8)
      // param layout: offset 0 = name, offset 8 = type_name string
      pname = load64(param)
      ptype_name = load64(param + 8)
      pty = resolve_type(ptype_name, structs, enums, mod_exports)
      param_types.push(pty)
      mset(inner_scope, pname, pty)
      pi += 1
    }

    ret_ty = resolve_type(ret_type_name, structs, enums, mod_exports)

    // Check body stmts
    body_stmts_p = body_stmts_arr != 0 ? load64(body_stmts_arr) : 0
    body_len = body_stmts_arr != 0 ? load64(body_stmts_arr + 8) : 0
    check_stmts(body_stmts_p, body_len, locals, fn_env, ret_ty, structs, enums, methods, generic_fns, traits, mod_exports)

    pop_scope(locals)
    return make_fn_type(ptr(param_types), ret_ty)
  } : 0

  // ── Spawn ─────────────────────────────────────────────────────
  tag == EX_SPAWN ? {
    func_name = load64(expr + 8)
    args_arr = load64(expr + 16)
    args_p = load64(args_arr)
    num_args = load64(args_arr + 8)

    if mhas(fn_env, func_name) == 0 { return tc_error("undefined function '" + func_name + "' in spawn") }
    sig = mget(fn_env, func_name)
    sig_params_arr = load64(sig)
    sig_params = sig_params_arr != 0 ? load64(sig_params_arr) : 0
    sig_params_len = sig_params_arr != 0 ? load64(sig_params_arr + 8) : 0

    if num_args != sig_params_len { return tc_error("wrong argument count calling '" + func_name + "': expected " + str(sig_params_len) + " but got " + str(num_args)) }

    si := 0
    while si < num_args {
      arg_expr = load64(args_p + si * 8)
      actual = check_expr(arg_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      expected = load64(sig_params + si * 8)
      // Allow opaque types where Int expected (pointers are i64)
      if types_compatible(actual, expected) == 0 { return tc_error("argument " + str(si + 1) + " to '" + func_name + "': expected " + type_to_string(expected) + " but got " + type_to_string(actual)) }
      si += 1
    }
    return make_type(TY_JOIN_HANDLE)
  } : 0

  // ── Channel ───────────────────────────────────────────────────
  tag == EX_CHANNEL ? {
    elem_type_name = load64(expr + 8)
    capacity_expr = load64(expr + 16)

    // Check capacity if present
    capacity_expr != 0 ? {
      cap_ty = check_expr(capacity_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      if type_tag(cap_ty) != TY_INT { return tc_error("channel capacity must be Int, got " + type_to_string(cap_ty)) }
    } : 0

    inner = resolve_type(elem_type_name, structs, enums, mod_exports)
    // Rust returns Sender<T> — the channel() call returns Sender (receiver obtained via split)
    return make_sender_type(inner)
  } : 0

  // ── Mutex ─────────────────────────────────────────────────────
  tag == EX_MUTEX ? {
    value_expr = load64(expr + 8)
    inner = check_expr(value_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    return make_mutex_type(inner)
  } : 0

  // ── Enum variant ──────────────────────────────────────────────
  tag == EX_ENUM_VARIANT ? {
    ename = load64(expr + 8)
    vname = load64(expr + 16)
    args_arr = load64(expr + 24)
    args_p = load64(args_arr)
    num_args = load64(args_arr + 8)

    if mhas(enums, ename) == 0 { return tc_error("undefined enum '" + ename + "'") }
    variants = mget(enums, ename)
    if mhas(variants, vname) == 0 { return tc_error("unknown variant '" + vname + "' on enum '" + ename + "'") }

    expected_fields_arr = mget(variants, vname)
    expected_fields_p = load64(expected_fields_arr)
    expected_len = load64(expected_fields_arr + 8)

    if num_args != expected_len { return tc_error("variant '" + ename + "::" + vname + "' expects " + str(expected_len) + " argument(s) but got " + str(num_args)) }

    vi := 0
    while vi < num_args {
      arg_expr = load64(args_p + vi * 8)
      actual_ty = check_expr(arg_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      expected_ty = load64(expected_fields_p + vi * 8)
      if type_eq(actual_ty, expected_ty) == 0 { return tc_error("argument " + str(vi + 1) + " to '" + ename + "::" + vname + "': expected " + type_to_string(expected_ty) + " but got " + type_to_string(actual_ty)) }
      vi += 1
    }
    return make_enum_type(ename, variants)
  } : 0

  // ── Array create ──────────────────────────────────────────────
  tag == EX_ARRAY_CREATE ? {
    elem_type_name = load64(expr + 8)
    inner = resolve_type(elem_type_name, structs, enums, mod_exports)
    return make_array_type(inner)
  } : 0

  tc_error("check_expr: unknown expression tag " + str(tag))
}

// ── make_fn_sig: create FunctionSignature (16 bytes) ─────────────
// offset 0: params (raw ptr to array of Type ptrs)
// offset 8: return_type (Type ptr)
make_fn_sig(params_ptr:I ret_type:I) I {
  sig = alloc(16)
  store64(sig, params_ptr)
  store64(sig + 8, ret_type)
  sig
}

// ── make_mod_exports: create ModuleExports (24 bytes) ────────────
// offset 0: structs_map
// offset 8: enums_map
// offset 16: fn_env_map
make_mod_exports(structs_m:I enums_m:I fn_env_m:I) I {
  e = alloc(24)
  store64(e, structs_m)
  store64(e + 8, enums_m)
  store64(e + 16, fn_env_m)
  e
}

// ── check_inner: shared implementation for check/check_module ────
check_inner(program:I mod_exports:I require_main:I) I {
  structs_map = map()
  enums_map = map()
  fn_env = map()
  methods_map = map()
  trait_registry = map()
  generic_fns = map()

  // ── Pass 0a: collect struct definitions ─────────────────────────
  structs_arr = load64(program + 24)
  structs_p = load64(structs_arr)
  num_structs = load64(structs_arr + 8)
  si := 0
  while si < num_structs {
    sdef = load64(structs_p + si * 8)
    sname = load64(sdef)
    fields_flat_arr = load64(sdef + 8)   // array: name0, type0, name1, type1, ...
    fields_flat = load64(fields_flat_arr)
    num_flat = load64(fields_flat_arr + 8)
    fields_m = map()
    fi := 0
    while fi < num_flat {
      fname = load64(fields_flat + fi * 8)
      ftype_name = load64(fields_flat + (fi + 1) * 8)
      fty = resolve_type(ftype_name, structs_map, enums_map, mod_exports)
      mset(fields_m, fname, fty)
      fi += 2
    }
    mset(structs_map, sname, fields_m)
    si += 1
  }

  // ── Pass 0b: collect enum definitions ───────────────────────────
  enums_arr = load64(program + 32)
  enums_p = load64(enums_arr)
  num_enums = load64(enums_arr + 8)
  ei := 0
  while ei < num_enums {
    edef = load64(enums_p + ei * 8)
    ename = load64(edef)
    variants_arr = load64(edef + 8)   // array of variant defs
    variants_p = load64(variants_arr)
    num_variants = load64(variants_arr + 8)
    variants_m = map()
    vi := 0
    while vi < num_variants {
      vdef = load64(variants_p + vi * 8)
      vname = load64(vdef)
      vfields_arr = load64(vdef + 8)  // array of type name strings
      vfields_p = load64(vfields_arr)
      num_vfields = load64(vfields_arr + 8)
      vtypes = array<I>()
      vfi := 0
      while vfi < num_vfields {
        vtype_name = load64(vfields_p + vfi * 8)
        vty = resolve_type(vtype_name, structs_map, enums_map, mod_exports)
        vtypes.push(vty)
        vfi += 1
      }
      mset(variants_m, vname, ptr(vtypes))
      vi += 1
    }
    mset(enums_map, ename, variants_m)
    ei += 1
  }

  // ── Pass 0c: collect trait definitions ──────────────────────────
  traits_arr = load64(program + 40)
  traits_p = load64(traits_arr)
  num_traits = load64(traits_arr + 8)
  ti := 0
  while ti < num_traits {
    tdef = load64(traits_p + ti * 8)
    tname = load64(tdef)
    tmethods_src_arr = load64(tdef + 8)
    tmethods_p = load64(tmethods_src_arr)
    num_tmethods = load64(tmethods_src_arr + 8)
    tmethods_arr = array<I>()
    tmi := 0
    while tmi < num_tmethods {
      tmsig = load64(tmethods_p + tmi * 8)
      // trait method sig: offset 0 = name, offset 8 = params_p, offset 16 = ret_type_name
      tm_name = load64(tmsig)
      tm_params_arr = load64(tmsig + 8)
      tm_params_p = load64(tm_params_arr)
      tm_ret_name = load64(tmsig + 16)
      num_tparams = load64(tm_params_arr + 8)
      tparam_types = array<I>()
      tpi := 0
      while tpi < num_tparams {
        tp = load64(tm_params_p + tpi * 8)
        tp_type_name = load64(tp + 8)
        tparam_types.push(resolve_type(tp_type_name, structs_map, enums_map, mod_exports))
        tpi += 1
      }
      tm_ret = resolve_type(tm_ret_name, structs_map, enums_map, mod_exports)
      // Store as: [name, params_raw_ptr, ret_type]
      tm_entry = alloc(24)
      store64(tm_entry, tm_name)
      store64(tm_entry + 8, ptr(tparam_types))
      store64(tm_entry + 16, tm_ret)
      tmethods_arr.push(tm_entry)
      tmi += 1
    }
    mset(trait_registry, tname, ptr(tmethods_arr))
    ti += 1
  }

  // ── Pass 0d: collect impl blocks → method registry ─────────────
  impls_arr = load64(program + 48)
  impls_p = load64(impls_arr)
  num_impls = load64(impls_arr + 8)
  ii := 0
  while ii < num_impls {
    impl_block = load64(impls_p + ii * 8)
    impl_trait_name = load64(impl_block)
    impl_target_type = load64(impl_block + 8)
    impl_methods_arr = load64(impl_block + 16)
    impl_methods_p = load64(impl_methods_arr)
    num_impl_methods = load64(impl_methods_arr + 8)

    // Verify trait conformance if trait impl
    impl_trait_name != 0 && mhas(trait_registry, impl_trait_name) ? {
      trait_methods_arr = mget(trait_registry, impl_trait_name)
      trait_methods_p = load64(trait_methods_arr)
      num_trait_methods = load64(trait_methods_arr + 8)
      tmi := 0
      while tmi < num_trait_methods {
        tm_entry = load64(trait_methods_p + tmi * 8)
        tm_name = load64(tm_entry)
        tm_params_arr2 = load64(tm_entry + 8)
        tm_params_p = load64(tm_params_arr2)
        tm_ret = load64(tm_entry + 16)
        // Find matching method in impl
        found := 0
        imi := 0
        while imi < num_impl_methods {
          mdef = load64(impl_methods_p + imi * 8)
          mdef_name = as_str(load64(mdef))
          mdef_name == as_str(tm_name) ? {
            found = 1
            // Check params (skip self = first param)
            mparams_arr2 = load64(mdef + 8)
            mparams_p = load64(mparams_arr2)
            num_mparams = load64(mparams_arr2 + 8)
            num_tm_params = load64(tm_params_arr2 + 8)
            // Actual params = mparams - 1 (skip self)
            num_mparams - 1 != num_tm_params ? tc_error("method '" + tm_name + "' params don't match trait '" + impl_trait_name + "' signature") : 0
            pi := 1
            while pi < num_mparams {
              mp = load64(mparams_p + pi * 8)
              mp_type_name = load64(mp + 8)
              actual_pty = resolve_type(mp_type_name, structs_map, enums_map, mod_exports)
              expected_pty = load64(tm_params_p + (pi - 1) * 8)
              type_eq(actual_pty, expected_pty) == 0 ? tc_error("method '" + tm_name + "' params don't match trait '" + impl_trait_name + "' signature") : 0
              pi += 1
            }
            // Check return type
            mret_name = load64(mdef + 16)
            actual_ret = resolve_type(mret_name, structs_map, enums_map, mod_exports)
            type_eq(actual_ret, tm_ret) == 0 ? tc_error("method '" + tm_name + "' return type doesn't match trait '" + impl_trait_name + "' signature") : 0
            imi = num_impl_methods  // break
          } : 0
          imi += 1
        }
        found == 0 ? tc_error("impl " + impl_trait_name + " for " + impl_target_type + " is missing method '" + tm_name + "'") : 0
        tmi += 1
      }
    } : 0

    // Register methods (skip self param)
    mi := 0
    while mi < num_impl_methods {
      mdef = load64(impl_methods_p + mi * 8)
      mname = load64(mdef)
      mparams_arr3 = load64(mdef + 8)
      mparams_p = load64(mparams_arr3)
      mret_name = load64(mdef + 16)
      num_mparams = load64(mparams_arr3 + 8)
      // Build param types skipping self (index 0)
      method_param_types = array<I>()
      mpi := 1
      while mpi < num_mparams {
        mp = load64(mparams_p + mpi * 8)
        mp_type_name = load64(mp + 8)
        method_param_types.push(resolve_type(mp_type_name, structs_map, enums_map, mod_exports))
        mpi += 1
      }
      mret = resolve_type(mret_name, structs_map, enums_map, mod_exports)
      method_key = impl_target_type + "." + mname
      mset(methods_map, method_key, make_fn_sig(ptr(method_param_types), mret))

      // Also add mangled name to fn_env (with self param included)
      mangled = impl_target_type + "_" + mname
      all_param_types = array<I>()
      api := 0
      while api < num_mparams {
        mp = load64(mparams_p + api * 8)
        mp_type_name = load64(mp + 8)
        all_param_types.push(resolve_type(mp_type_name, structs_map, enums_map, mod_exports))
        api += 1
      }
      mset(fn_env, mangled, make_fn_sig(ptr(all_param_types), mret))
      mi += 1
    }
    ii += 1
  }

  // ── Pass 1: collect function signatures ─────────────────────────
  funcs_arr = load64(program + 16)
  funcs_p = load64(funcs_arr)
  num_funcs = load64(funcs_arr + 8)
  fi := 0
  while fi < num_funcs {
    func = load64(funcs_p + fi * 8)
    fname = load64(func)
    fparams_arr = load64(func + 8)
    fparams_p = load64(fparams_arr)
    fret_name = load64(func + 16)
    ftype_params_arr = load64(func + 32)
    ftype_params_p = load64(ftype_params_arr)
    num_type_params = load64(ftype_params_arr + 8)

    num_type_params == 0 ? {
      num_fparams = load64(fparams_arr + 8)
      param_types = array<I>()
      pi := 0
      while pi < num_fparams {
        p_node = load64(fparams_p + pi * 8)
        p_type_name = load64(p_node + 8)
        param_types.push(resolve_type(p_type_name, structs_map, enums_map, mod_exports))
        pi += 1
      }
      ret_ty = resolve_type(fret_name, structs_map, enums_map, mod_exports)
      mset(fn_env, fname, make_fn_sig(ptr(param_types), ret_ty))
    } : {
      // Generic function — store function node for call-site inference
      mset(generic_fns, fname, func)
    }
    fi += 1
  }

  // ── Pass 1b: type-check global variable definitions ─────────────
  globals_arr = load64(program + 8)
  globals_p = load64(globals_arr)
  num_globals = load64(globals_arr + 8)
  global_types = map()
  gi := 0
  while gi < num_globals {
    gdef = load64(globals_p + gi * 8)
    gname = load64(gdef)
    gvalue = load64(gdef + 8)
    // Create temp locals for globals type checking
    temp_locals = [map()]
    gty = check_expr(gvalue, temp_locals, fn_env, make_type(TY_INT), structs_map, enums_map, methods_map, generic_fns, trait_registry, mod_exports)
    mset(global_types, gname, gty)
    gi += 1
  }

  // ── Require main (unless checking a module) ─────────────────────
  require_main == 1 && mhas(fn_env, "main") == 0 ? tc_error("missing 'main' function") : 0

  // ── Pass 2: type-check each function body ───────────────────────
  fi = 0
  while fi < num_funcs {
    func = load64(funcs_p + fi * 8)
    fname = load64(func)
    ftype_params_arr2 = load64(func + 32)
    ftype_params_p = load64(ftype_params_arr2)
    num_type_params = load64(ftype_params_arr2 + 8)

    // Skip generic functions
    num_type_params > 0 ? { fi += 1
      0 } : {
      sig = mget(fn_env, fname)
      ret_ty = load64(sig + 8)

      // Build locals with globals + params
      locals = [map()]
      scope = locals[0]

      // Inject globals as mutable locals
      gkeys = global_types.keys()
      gki := 0
      while gki < gkeys.len() {
        gk = gkeys[gki]
        mset(scope, gk, mget(global_types, gk))
        gki += 1
      }

      // Add function params
      fparams_arr2 = load64(func + 8)
      fparams_p = load64(fparams_arr2)
      num_fparams = load64(fparams_arr2 + 8)
      pi := 0
      while pi < num_fparams {
        p_node = load64(fparams_p + pi * 8)
        p_name = load64(p_node)
        p_type_name = load64(p_node + 8)
        pty = resolve_type(p_type_name, structs_map, enums_map, mod_exports)
        mset(scope, p_name, pty)
        pi += 1
      }

      body_arr2 = load64(func + 24)
      body_p = load64(body_arr2)
      body_len = load64(body_arr2 + 8)

      body_len == 0 ? tc_error("function '" + fname + "': missing return expression") : 0

      // Check all statements
      bi := 0
      while bi < body_len {
        stmt = load64(body_p + bi * 8)
        is_last = bi == body_len - 1
        check_stmt(stmt, locals, fn_env, ret_ty, structs_map, enums_map, methods_map, generic_fns, trait_registry, mod_exports)

        is_last == 1 ? {
          stag = load64(stmt)
          stag == ST_EXPR ? {
            expr = load64(stmt + 8)
            ety = check_expr(expr, locals, fn_env, ret_ty, structs_map, enums_map, methods_map, generic_fns, trait_registry, mod_exports)
            types_compatible(ety, ret_ty) == 0 ? tc_error("function '" + fname + "': return type mismatch: expected " + type_to_string(ret_ty) + " but got " + type_to_string(ety)) : 0
          } : {
            stag == ST_RETURN ? 0 : {
              tc_error("function '" + fname + "': missing return expression")
            }
          }
        } : 0
        bi += 1
      }
      fi += 1
      0
    }
  }

  // ── Pass 3: type-check method bodies from impl blocks ───────────
  ii = 0
  while ii < num_impls {
    impl_block = load64(impls_p + ii * 8)
    impl_target_type = load64(impl_block + 8)
    impl_methods_arr3 = load64(impl_block + 16)
    impl_methods_p = load64(impl_methods_arr3)
    num_impl_methods = load64(impl_methods_arr3 + 8)

    mi := 0
    while mi < num_impl_methods {
      mdef = load64(impl_methods_p + mi * 8)
      mname = load64(mdef)
      mparams_arr4 = load64(mdef + 8)
      mparams_p = load64(mparams_arr4)
      mret_name = load64(mdef + 16)
      mbody_arr3 = load64(mdef + 24)
      mbody_p = load64(mbody_arr3)
      num_mparams = load64(mparams_arr4 + 8)
      mbody_len = load64(mbody_arr3 + 8)
      mret_ty = resolve_type(mret_name, structs_map, enums_map, mod_exports)

      // Build locals
      locals = [map()]
      scope = locals[0]

      // Inject globals
      gkeys = global_types.keys()
      gki := 0
      while gki < gkeys.len() {
        gk = gkeys[gki]
        mset(scope, gk, mget(global_types, gk))
        gki += 1
      }

      // Add method params
      mpi := 0
      while mpi < num_mparams {
        mp = load64(mparams_p + mpi * 8)
        mp_name = load64(mp)
        mp_type_name = load64(mp + 8)
        mpty = resolve_type(mp_type_name, structs_map, enums_map, mod_exports)
        mset(scope, mp_name, mpty)
        mpi += 1
      }

      mbody_len == 0 ? tc_error("method '" + mname + "': missing return expression") : 0

      bi := 0
      while bi < mbody_len {
        stmt = load64(mbody_p + bi * 8)
        is_last = bi == mbody_len - 1
        check_stmt(stmt, locals, fn_env, mret_ty, structs_map, enums_map, methods_map, generic_fns, trait_registry, mod_exports)

        is_last == 1 ? {
          stag = load64(stmt)
          stag == ST_EXPR ? {
            expr = load64(stmt + 8)
            ety = check_expr(expr, locals, fn_env, mret_ty, structs_map, enums_map, methods_map, generic_fns, trait_registry, mod_exports)
            types_compatible(ety, mret_ty) == 0 ? tc_error("method '" + mname + "': return type mismatch: expected " + type_to_string(mret_ty) + " but got " + type_to_string(ety)) : 0
          } : {
            stag == ST_RETURN ? 0 : {
              tc_error("method '" + mname + "': missing return expression")
            }
          }
        } : 0
        bi += 1
      }
      mi += 1
    }
    ii += 1
  }

  // ── Build ModuleExports ─────────────────────────────────────────
  // Build fn_exports: only non-generic functions
  fn_exports = map()
  fi = 0
  while fi < num_funcs {
    func = load64(funcs_p + fi * 8)
    fname = load64(func)
    ftype_params_arr3 = load64(func + 32)
    ftype_params_p = load64(ftype_params_arr3)
    num_type_params = load64(ftype_params_arr3 + 8)
    num_type_params == 0 && mhas(fn_env, fname) ? {
      mset(fn_exports, fname, mget(fn_env, fname))
    } : 0
    fi += 1
  }

  make_mod_exports(structs_map, enums_map, fn_exports)
}

// ── check: top-level type checking entry point ───────────────────
check(program:I mod_exports:I) I {
  check_inner(program, mod_exports, 1)
}

// ── check_module: type-check a library module (no main required) ─
check_module(program:I mod_exports:I) I {
  check_inner(program, mod_exports, 0)
}
