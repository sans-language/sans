import "constants"
import "parser"

// ------ Type struct layout (32 bytes) ---------------------------------------------------------------------------------------------------------
// offset 0:  tag (I)    --- TY_INT=0 .. TY_MUTEX=20
// offset 8:  inner (I)  --- inner type ptr (Array/Result/Sender/Receiver/Mutex)
// offset 16: data (I)   --- extra data (struct: name, enum: name, fn: params array)
// offset 24: data2 (I)  --- secondary (fn: ret type, tuple: elements, struct: fields map, enum: variants map)

// Cast i64 pointer to string type (identity at runtime, but tells IR it's a string)
as_str(v:I) S = v

// ------ Type accessors ------------------------------------------------------------------------------------------------------------------------------------------------------
type_tag(t:I) I = load64(t)
type_inner(t:I) I = load64(t + 8)
type_data(t:I) I = load64(t + 16)
type_data_s(t:I) S = as_str(load64(t + 16))
type_data2(t:I) I = load64(t + 24)

// ------ Type constructors ---------------------------------------------------------------------------------------------------------------------------------------------
make_type(tag:I) I {
  t = alloc(32)
  store64(t, tag)
  store64(t + 8, 0)
  store64(t + 16, 0)
  store64(t + 24, 0)
  t
}

make_array_type(inner:I) I {
  t = alloc(32)
  store64(t, TY_ARRAY)
  store64(t + 8, inner)
  store64(t + 16, 0)
  store64(t + 24, 0)
  t
}

make_result_type(inner:I) I {
  t = alloc(32)
  store64(t, TY_RESULT)
  store64(t + 8, inner)
  store64(t + 16, 0)
  store64(t + 24, 0)
  t
}

make_option_type(inner:I) I {
  t = alloc(32)
  store64(t, TY_OPTION)
  store64(t + 8, inner)
  store64(t + 16, 0)
  store64(t + 24, 0)
  t
}

make_dyn_trait_type(trait_name:I) I {
  t = alloc(32)
  store64(t, TY_DYN_TRAIT)
  store64(t + 8, trait_name)
  store64(t + 16, 0)
  store64(t + 24, 0)
  t
}

make_map_type(key_type:I val_type:I) I {
  t = alloc(32)
  store64(t, TY_MAP)
  store64(t + 8, key_type)
  store64(t + 16, val_type)
  store64(t + 24, 0)
  t
}

make_sender_type(inner:I) I {
  t = alloc(32)
  store64(t, TY_SENDER)
  store64(t + 8, inner)
  store64(t + 16, 0)
  store64(t + 24, 0)
  t
}

make_receiver_type(inner:I) I {
  t = alloc(32)
  store64(t, TY_RECEIVER)
  store64(t + 8, inner)
  store64(t + 16, 0)
  store64(t + 24, 0)
  t
}

make_mutex_type(inner:I) I {
  t = alloc(32)
  store64(t, TY_MUTEX)
  store64(t + 8, inner)
  store64(t + 16, 0)
  store64(t + 24, 0)
  t
}

make_fn_type(params:I ret:I) I {
  t = alloc(32)
  store64(t, TY_FN)
  store64(t + 8, 0)
  store64(t + 16, params)
  store64(t + 24, ret)
  t
}

make_struct_type(name:I fields_map:I) I {
  t = alloc(32)
  store64(t, TY_STRUCT)
  store64(t + 8, 0)
  store64(t + 16, name)
  store64(t + 24, fields_map)
  t
}

make_enum_type(name:I variants_map:I) I {
  t = alloc(32)
  store64(t, TY_ENUM)
  store64(t + 8, 0)
  store64(t + 16, name)
  store64(t + 24, variants_map)
  t
}

make_tuple_type(elements:I) I {
  t = alloc(32)
  store64(t, TY_TUPLE)
  store64(t + 8, 0)
  store64(t + 16, 0)
  store64(t + 24, elements)
  t
}

// ------ Diagnostic infrastructure -------------------------------------------------------------------------------------------------------------------------------------------------
g tc_diags = 0
g tc_has_error = 0
g tc_current_file = 0
g tc_current_source = 0
g tc_has_source = 0
g tc_declared_vars = 0
g tc_used_vars = 0
g tc_warn_enabled = 0
g g_build_quiet = 0
g g_build_debug = 0
g mono_depth = 0
g tc_collect_mode = 0
g tc_collected_symbols = 0
g tc_collected_locals = 0

tc_init_diags() I {
  if tc_diags == 0 { tc_diags = array<I>() }
  tc_has_error = 0
  0
}

make_diag(severity:I line:I col:I msg:S filename:S) I {
  d = alloc(40)
  store64(d, severity)
  store64(d + 8, line)
  store64(d + 16, col)
  store64(d + 24, msg)
  store64(d + 32, filename)
  d
}
diag_severity(d:I) I = load64(d)
diag_line(d:I) I = load64(d + 8)
diag_col(d:I) I = load64(d + 16)
diag_msg(d:I) S = load64(d + 24)
diag_file(d:I) S = load64(d + 32)

// Extract a single line from source text by line number (1-based)
get_source_line(src:S line_num:I) S {
  len = slen(src)
  if len == 0 { return "" }
  cur_line := 1
  start := 0
  i := 0
  // Find start of the target line
  while i < len {
    if cur_line == line_num {
      start = i
      // Find end of this line
      while i < len {
        if char_at(src, i) == 10 { return src.substring(start, i) }
        i += 1
      }
      return src.substring(start, len)
    }
    if char_at(src, i) == 10 { cur_line += 1 }
    i += 1
  }
  ""
}

// Render source context line with caret under the error position
render_source_context(src_line:S line_num:I col_num:I) I {
  if slen(src_line) == 0 { return 0 }
  lstr = str(line_num)
  wfd(2, "  " + lstr + " | " + src_line + "\n")
  pad := "  "
  pi := 0
  while pi < slen(lstr) {
    pad = pad + " "
    pi += 1
  }
  pad = pad + " | "
  ci := 1
  while ci < col_num {
    pad = pad + " "
    ci += 1
  }
  wfd(2, pad + "^\n")
  0
}

// Render a single diagnostic with source context
render_diag(dd:I) I {
  sev = if diag_severity(dd) == DIAG_ERROR { "error" } else { if diag_severity(dd) == DIAG_WARN { "warning" } else { "info" } }
  f = diag_file(dd)
  l = diag_line(dd)
  c = diag_col(dd)
  m = diag_msg(dd)
  if l > 0 {
    wfd(2, f + ":" + str(l) + ":" + str(c) + ": " + sev + ": " + m + "\n")
    // Show source line with caret if source is available
    if tc_has_source == 1 {
      src_line = get_source_line(as_str(tc_current_source), l)
      render_source_context(src_line, l, c)
    }
    0
  } else {
    wfd(2, sev + ": " + m + "\n")
    0
  }
  0
}

// ------ Error helper (legacy - prints all collected diagnostics then exits) -----------------------------------------------------------------------
tc_error(msg:S) I {
  tc_init_diags()
  d = make_diag(DIAG_ERROR, 0, 0, msg, "")
  tc_diags.push(d)
  if tc_collect_mode == 1 {
    tc_has_error = 1
    return 0
  }
  // Print all diagnostics collected so far
  i := 0
  while i < tc_diags.len() {
    render_diag(tc_diags[i])
    i += 1
    0
  }
  exit(1)
  0
}

// Non-exiting error with explicit line/col position
tc_error_at_pos(line:I col:I msg:S) I {
  tc_init_diags()
  d = make_diag(DIAG_ERROR, line, col, msg, as_str(tc_current_file))
  tc_diags.push(d)
  tc_has_error = 1
  0
}

// Non-exiting error with source location
tc_error_at(node:I msg:S) I {
  tc_init_diags()
  line = node_line(node)
  col = node_col(node)
  d = make_diag(DIAG_ERROR, line, col, msg, as_str(tc_current_file))
  tc_diags.push(d)
  tc_has_error = 1
  0
}

// Non-exiting warning with source location
tc_warn_at(node:I msg:S) I {
  tc_init_diags()
  line = node_line(node)
  col = node_col(node)
  d = make_diag(DIAG_WARN, line, col, msg, as_str(tc_current_file))
  tc_diags.push(d)
  0
}

// Emit warnings for unused variables (declared but never referenced)
tc_check_unused_vars() I {
  if tc_declared_vars == 0 { return 0 }
  if tc_used_vars == 0 { return 0 }
  dkeys = tc_declared_vars.keys()
  dki := 0
  while dki < dkeys.len() {
    dk = dkeys.get(dki)
    // Skip variables starting with _ (intentionally unused)
    if char_at(dk, 0) != 95 {
      if mhas(tc_used_vars, dk) == 0 {
        tc_warn_at(mget(tc_declared_vars, dk), "unused variable '" + dk + "'")
      }
    }
    dki += 1
  }
  0
}

// Print all diagnostics and exit if any errors
tc_emit_diags() I {
  if tc_diags == 0 { return 0 }
  dlen = tc_diags.len()
  if dlen == 0 { return 0 }
  if tc_collect_mode == 1 { return 0 }
  has_err := 0
  i := 0
  while i < dlen {
    dd = tc_diags[i]
    render_diag(dd)
    if diag_severity(dd) == DIAG_ERROR { has_err = 1 }
    i += 1
    0
  }
  // Clear diagnostics after emitting to avoid re-printing
  tc_diags = array<I>()
  if has_err == 1 { exit(1) }
  0
}

// ------ Type equality (deep) ------------------------------------------------------------------------------------------------------------------------------------
type_eq(a:I b:I) I {
  if a == 0 && b == 0 { return 1 }
  if a == 0 || b == 0 { return 0 }
  ta = type_tag(a)
  tb = type_tag(b)
  if ta != tb { return 0 }
  // Simple types: tag match is enough
  if ta == TY_INT || ta == TY_FLOAT || ta == TY_BOOL || ta == TY_STRING ||
     ta == TY_MAP || ta == TY_VOID || ta == TY_JSON || ta == TY_HTTP_RESP ||
     ta == TY_HTTP_SERVER || ta == TY_HTTP_REQ || ta == TY_JOIN_HANDLE ||
     ta == TY_RESULT_ERR { return 1 }
  // Parameterized types with inner: compare inner recursively
  if ta == TY_ARRAY || ta == TY_RESULT || ta == TY_SENDER ||
     ta == TY_RECEIVER || ta == TY_MUTEX ||
     ta == TY_OPTION { return type_eq(type_inner(a), type_inner(b)) }
  // Tuple: compare all element types
  if ta == TY_TUPLE {
    elems_a = type_data2(a)
    elems_b = type_data2(b)
    len_a = load64(elems_a + 8)
    len_b = load64(elems_b + 8)
    if len_a != len_b { return 0 }
    elems_a_d = load64(elems_a)
    elems_b_d = load64(elems_b)
    i := 0
    while i < len_a {
    if type_eq(load64(elems_a_d + i * 8), load64(elems_b_d + i * 8)) == 0 { return 0 }
    i += 1
    }
    return 1
  }
  // Dyn trait: compare trait name strings
  if ta == TY_DYN_TRAIT {
    return if as_str(type_inner(a)) == as_str(type_inner(b)) { 1 } else { 0 }
  }
  // Struct/Enum: compare names (use string comparison, not pointer)
  if ta == TY_STRUCT || ta == TY_ENUM {
    sname_a = type_data_s(a)
    sname_b = type_data_s(b)
    return if sname_a == sname_b { 1 } else { 0 }
  }
  // Fn: compare param count, each param, and return type
  if ta == TY_FN {
    params_a = type_data(a)
    params_b = type_data(b)
    ret_a = type_data2(a)
    ret_b = type_data2(b)
    // If both have no params arrays, check return
    if params_a == 0 && params_b == 0 { return type_eq(ret_a, ret_b) }
    if params_a == 0 || params_b == 0 { return 0 }
    len_a = load64(params_a + 8)
    len_b = load64(params_b + 8)
    if len_a != len_b { return 0 }
    params_a_d = load64(params_a)
    params_b_d = load64(params_b)
    i := 0
    while i < len_a {
    if type_eq(load64(params_a_d + i * 8), load64(params_b_d + i * 8)) == 0 { return 0 }
    i += 1
    }
    return type_eq(ret_a, ret_b)
  }
  0
}

// ------ i64-compatible type check ------------------------------------------------------------------------------------------------------------------------
is_i64_compat(t:I) I {
  tag = type_tag(t)
  if tag == TY_INT || tag == TY_FLOAT || tag == TY_STRING || tag == TY_BOOL || tag == TY_ARRAY ||
     tag == TY_MAP || tag == TY_FN || tag == TY_RESULT || tag == TY_OPTION || tag == TY_JSON ||
     tag == TY_DYN_TRAIT { return 1 }
  0
}

// ------ Type compatibility (covariance) ---------------------------------------------------------------------------------------------------
types_compatible(actual:I expected:I) I {
  if type_eq(actual, expected) == 1 { return 1 }
  at = type_tag(actual)
  et = type_tag(expected)
  // ResultErr matches any Result<T>
  if at == TY_RESULT_ERR && et == TY_RESULT { return 1 }
  // All i64-compatible types are interchangeable
  // Sans is a low-level language where all values are i64 internally.
  // Int is used as a universal "any" type, and values freely cross type
  // boundaries (e.g. storing String in Int, passing Array as Int param).
  if is_i64_compat(actual) == 1 && is_i64_compat(expected) == 1 { return 1 }
  0
}

// ------ Helper: find char position in string ------------------------------------------------------------------------------------
find_char(s:S ch:I start:I) I {
  len = slen(s)
  i := start
  result := 0 - 1
  found := 0
  while i < len {
    if found == 0 {
      if char_at(s, i) == ch {
        result = i
        found = 1
      }
    }
    i += 1
  }
  result
}

// ------ Helper: find last char position in string ---------------------------------------------------------------------
find_last_char(s:S ch:I) I {
  len = slen(s)
  i := len - 1
  result := 0 - 1
  while i >= 0 {
    if result == 0 - 1 {
      if char_at(s, i) == ch { result = i }
    }
    i -= 1
  }
  result
}

// ------ resolve_type: parse type name string --- Type ptr ---------------------------------------------------
resolve_map_type(inner:S structs:I enums:I mod_exports:I) I {
  sp := find_char(inner, 32, 0)
  if sp < 0 { sp = find_char(inner, 44, 0) } else { 0 }
  if sp < 0 { return tc_error("Map<K V> requires two type parameters") }
  k_name = inner.substring(0, sp)
  v_start := sp + 1
  il = slen(inner)
  if v_start < il && char_at(inner, v_start) == 32 { v_start = v_start + 1 } else { 0 }
  v_name = inner.substring(v_start, il)
  kt = resolve_type(k_name, structs, enums, mod_exports)
  ktag = type_tag(kt)
  if ktag != TY_STRING && ktag != TY_INT { return tc_error("Map key type must be I or S, got " + type_to_string(kt)) }
  vt = resolve_type(v_name, structs, enums, mod_exports)
  make_map_type(kt, vt)
}

resolve_type(name:S structs:I enums:I mod_exports:I) I {
  len = slen(name)
  if len == 0 { return tc_error("resolve_type: empty type name") }

  // Tuple: starts with '(' ends with ')'
  if char_at(name, 0) == 40 && char_at(name, len - 1) == 41 {
    inner = name.substring(1, len - 1)
    // Split by spaces and resolve each element
    elems = array<I>()
    start := 0
    i := 0
    ilen = slen(inner)
    while i <= ilen {
    if i == ilen || char_at(inner, i) == 32 {
      if i > start {
        part = inner.substring(start, i)
        elems.push(resolve_type(part, structs, enums, mod_exports))
      }
      start = i + 1
    }
    i += 1
    }
    return make_tuple_type(ptr(elems))
  }

  // Short bracket array: [I] = Array<Int>
  if char_at(name, 0) == 91 && char_at(name, len - 1) == 93 {
    inner_name = name.substring(1, len - 1)
    return make_array_type(resolve_type(inner_name, structs, enums, mod_exports))
  }

  // Simple types
  if name == "I" || name == "Int" { return make_type(TY_INT) }
  if name == "F" || name == "Float" { return make_type(TY_FLOAT) }
  if name == "B" || name == "Bool" { return make_type(TY_BOOL) }
  if name == "S" || name == "String" { return make_type(TY_STRING) }
  if name == "M" || name == "Map" { return make_map_type(make_type(TY_STRING), make_type(TY_INT)) }
  if name == "J" || name == "JsonValue" { return make_type(TY_JSON) }
  if name == "HttpResponse" { return make_type(TY_HTTP_RESP) }
  if name == "HttpServer" || name == "HS" { return make_type(TY_HTTP_SERVER) }
  if name == "HttpRequest" || name == "HR" { return make_type(TY_HTTP_REQ) }
  if name == "JoinHandle" { return make_type(TY_JOIN_HANDLE) }

  // Array<T>
  if name.sw("Array<") && char_at(name, len - 1) == 62 {
    inner_name = name.substring(6, len - 1)
    return make_array_type(resolve_type(inner_name, structs, enums, mod_exports))
  }

  // Result<T>
  if name.sw("Result<") && char_at(name, len - 1) == 62 {
    inner_name = name.substring(7, len - 1)
    return make_result_type(resolve_type(inner_name, structs, enums, mod_exports))
  }

  // R<T> (short Result)
  if name.sw("R<") && char_at(name, len - 1) == 62 {
    inner_name = name.substring(2, len - 1)
    return make_result_type(resolve_type(inner_name, structs, enums, mod_exports))
  }

  // Map<K V> or Map<K, V>
  if name.sw("Map<") && char_at(name, len - 1) == 62 {
    return resolve_map_type(name.substring(4, len - 1), structs, enums, mod_exports)
  }

  // M<K V> or M<K, V>
  if name.sw("M<") && char_at(name, len - 1) == 62 {
    return resolve_map_type(name.substring(2, len - 1), structs, enums, mod_exports)
  }

  // Sender<T>
  if name.sw("Sender<") && char_at(name, len - 1) == 62 {
    inner_name = name.substring(7, len - 1)
    return make_sender_type(resolve_type(inner_name, structs, enums, mod_exports))
  }

  // Receiver<T>
  if name.sw("Receiver<") && char_at(name, len - 1) == 62 {
    inner_name = name.substring(9, len - 1)
    return make_receiver_type(resolve_type(inner_name, structs, enums, mod_exports))
  }

  // Mutex<T>
  if name.sw("Mutex<") && char_at(name, len - 1) == 62 {
    inner_name = name.substring(6, len - 1)
    return make_mutex_type(resolve_type(inner_name, structs, enums, mod_exports))
  }

  // Option<T>
  if name.sw("Option<") && char_at(name, len - 1) == 62 {
    inner_name = name.substring(7, len - 1)
    return make_option_type(resolve_type(inner_name, structs, enums, mod_exports))
  }

  // O<T> (short Option)
  if name.sw("O<") && char_at(name, len - 1) == 62 {
    inner_name = name.substring(2, len - 1)
    return make_option_type(resolve_type(inner_name, structs, enums, mod_exports))
  }

  // dyn Trait
  if name.sw("dyn ") {
    trait_name = name.substring(4, len)
    return make_dyn_trait_type(ptr(trait_name))
  }

  // Fn (bare function type)
  if name == "Fn" || name.sw("Fn(") { return make_type(TY_FN) }

  // Check structs map
  if structs != 0 && mhas(structs, name) {
    return make_struct_type(name, mget(structs, name))
  }

  // Check enums map
  if enums != 0 && mhas(enums, name) {
    return make_enum_type(name, mget(enums, name))
  }

  // Check module exports --- iterate map keys looking for struct/enum
  if mod_exports != 0 {
    mkeys = mod_exports.keys()
    mk_len = mkeys.len()
    mi := 0
    while mi < mk_len {
    mod_name = mkeys[mi]
    exports = mget(mod_exports, mod_name)
    // exports is a ptr to module export data
    // exports offset 0: structs map, offset 8: enums map, offset 16: fn_env map
    exp_structs = load64(exports)
    exp_enums = load64(exports + 8)
    if exp_structs != 0 && mhas(exp_structs, name) {
      return make_struct_type(name, mget(exp_structs, name))
    }
    if exp_enums != 0 && mhas(exp_enums, name) {
      return make_enum_type(name, mget(exp_enums, name))
    }
    mi += 1
    }
  }

  tc_error("unknown type '" + name + "'")
}

// ------ type_to_string: Type ptr --- human-readable string ------------------------------------------------
type_to_string(t:I) S {
  if t == 0 { return "?" }
  tag = type_tag(t)
  if tag == TY_INT { return "Int" }
  if tag == TY_FLOAT { return "Float" }
  if tag == TY_BOOL { return "Bool" }
  if tag == TY_STRING { return "String" }
  if tag == TY_MAP {
    kt = type_inner(t)
    vt = type_data(t)
    if kt != 0 && vt != 0 {
      return "Map<" + type_to_string(kt) + ", " + type_to_string(vt) + ">"
    }
    return "Map"
  }
  if tag == TY_VOID { return "Void" }
  if tag == TY_JSON { return "JsonValue" }
  if tag == TY_HTTP_RESP { return "HttpResponse" }
  if tag == TY_HTTP_SERVER { return "HttpServer" }
  if tag == TY_HTTP_REQ { return "HttpRequest" }
  if tag == TY_JOIN_HANDLE { return "JoinHandle" }
  if tag == TY_RESULT_ERR { return "Result<_>" }
  if tag == TY_ARRAY { return "Array<" + type_to_string(type_inner(t)) + ">" }
  if tag == TY_RESULT { return "Result<" + type_to_string(type_inner(t)) + ">" }
  if tag == TY_SENDER { return "Sender<" + type_to_string(type_inner(t)) + ">" }
  if tag == TY_RECEIVER { return "Receiver<" + type_to_string(type_inner(t)) + ">" }
  if tag == TY_MUTEX { return "Mutex<" + type_to_string(type_inner(t)) + ">" }
  if tag == TY_OPTION { return "Option<" + type_to_string(type_inner(t)) + ">" }
  if tag == TY_DYN_TRAIT { return "dyn " + type_inner(t) }
  if tag == TY_STRUCT { return type_data(t) }
  if tag == TY_ENUM { return type_data(t) }
  if tag == TY_TUPLE {
    elems = type_data2(t)
    if elems == 0 { return "()" }
    len = load64(elems + 8)
    elems_d = load64(elems)
    s := "("
    i := 0
    while i < len {
    if i > 0 { s = s + " " }
    s = s + type_to_string(load64(elems_d + i * 8))
    i += 1
    }
    return s + ")"
  }
  if tag == TY_FN {
    params = type_data(t)
    ret = type_data2(t)
    s := "fn("
    if params != 0 {
      len = load64(params + 8)
      params_d = load64(params)
      i := 0
      while i < len {
      if i > 0 { s = s + ", " }
      s = s + type_to_string(load64(params_d + i * 8))
      i += 1
      }
    }
    s = s + ") " + type_to_string(ret)
    return s
  }
  "?"
}

// ------ Scope helpers ---------------------------------------------------------------------------------------------------------------------------------------------------
push_scope(locals:I) I {
  locals.push(map())
  0
}

pop_scope(locals:I) I {
  locals.pop()
  0
}

// ------ Lookup variable in scope stack ------------------------------------------------------------------------------------------------
// Walk locals from last (innermost) to first (outermost).
// Returns Type ptr or 0 if not found.
lookup_local(locals:I name:S) I {
  i := locals.len() - 1
  while i >= 0 {
    scope = locals[i]
    if mhas(scope, name) { return mget(scope, name) }
    i -= 1
  }
  0
}

// ------ check_stmt: type-check a single statement ---------------------------------------------------------
check_stmt(stmt:I locals:I fn_env:I ret_type:I structs:I enums:I methods:I generic_fns:I traits:I mod_exports:I) I {
  tag = load64(stmt)

  // ST_LET: [tag, size, name, mutable, type_ptr, value_expr, line, col]
  if tag == ST_LET {
    name = load64(stmt + 16)
    mutable = load64(stmt + 24)
    type_ptr = load64(stmt + 32)
    value_expr = load64(stmt + 40)
    actual = check_expr(value_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    ty = if type_ptr != 0 {
      declared = resolve_type(type_ptr, structs, enums, mod_exports)
      if type_eq(declared, actual) == 0 { tc_error_at(stmt, "type mismatch in let '" + name + "': declared " + type_to_string(declared) + " but expression has type " + type_to_string(actual)) }
      declared
    } else { actual }
    // Add to current scope (last Map in locals)
    scope = locals[locals.len() - 1]
    mset(scope, name, ty)
    // Track declared variable for unused-variable warnings
    if tc_declared_vars != 0 { mset(tc_declared_vars, name, stmt) }
    return 0
  }

  // ST_WHILE: [tag, cond, body_stmts_p]
  if tag == ST_WHILE {
    cond = load64(stmt + 16)
    body_arr = load64(stmt + 24)
    cond_ty = check_expr(cond, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    ct = type_tag(cond_ty)
    if ct != TY_BOOL && ct != TY_INT { tc_error("while condition must be Bool or Int, got " + type_to_string(cond_ty)) }
    body_len = if body_arr != 0 { load64(body_arr + 8) } else { 0 }
    body_p = if body_arr != 0 { load64(body_arr) } else { 0 }
    check_stmts(body_p, body_len, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    return 0
  }

  // ST_RETURN: [tag, value_expr]
  if tag == ST_RETURN {
    value_expr = load64(stmt + 16)
    ty = check_expr(value_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    if types_compatible(ty, ret_type) == 0 { tc_error_at(stmt, "return type mismatch: expected " + type_to_string(ret_type) + " but got " + type_to_string(ty)) }
    return 0
  }

  // ST_ASSIGN: [tag, target, value_expr]
  if tag == ST_ASSIGN {
    name = load64(stmt + 16)
    value_expr = load64(stmt + 24)
    existing = lookup_local(locals, name)
    if existing != 0 {
      // Existing variable --- just check value type compatible
      actual = check_expr(value_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      // Note: mutability not tracked in our type map (simplified)
      0
    } else {
      // New variable --- bare assignment creates immutable binding
      val_type = check_expr(value_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      scope = locals[locals.len() - 1]
      mset(scope, name, val_type)
      // Track declared variable for unused-variable warnings
      if tc_declared_vars != 0 { mset(tc_declared_vars, name, stmt) }
      0
    }
    return 0
  }

  // ST_IF: [tag, cond, body_stmts_p]
  if tag == ST_IF {
    cond = load64(stmt + 16)
    body_arr = load64(stmt + 24)
    cond_ty = check_expr(cond, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    ct2 = type_tag(cond_ty)
    if ct2 != TY_BOOL && ct2 != TY_INT { tc_error("if condition must be Bool or Int, got " + type_to_string(cond_ty)) }
    body_len = if body_arr != 0 { load64(body_arr + 8) } else { 0 }
    body_p = if body_arr != 0 { load64(body_arr) } else { 0 }
    check_stmts(body_p, body_len, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    return 0
  }

  // ST_BREAK / ST_CONTINUE: nothing to check
  if tag == ST_BREAK { return 0 }
  if tag == ST_CONTINUE { return 0 }

  // ST_LET_DESTR: [tag, names_p, value_expr]
  if tag == ST_LET_DESTR {
    names_arr = load64(stmt + 16)
    value_expr = load64(stmt + 24)
    // Check if value is channel create (EX_CHANNEL)
    val_tag = load64(value_expr)
    if val_tag == EX_CHANNEL {
      cap_expr = load64(value_expr + 24)
      if cap_expr != 0 {
        cap_ty = check_expr(cap_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        if type_tag(cap_ty) != TY_INT { tc_error("channel capacity must be Int, got " + type_to_string(cap_ty)) }
      }
      elem_type_name = load64(value_expr + 16)
      inner = resolve_type(elem_type_name, structs, enums, mod_exports)
      num_names = load64(names_arr + 8)
      names_p = load64(names_arr)
      if num_names != 2 { tc_error("channel destructuring requires exactly 2 names") }
      scope = locals[locals.len() - 1]
      mset(scope, load64(names_p), make_sender_type(inner))
      mset(scope, load64(names_p + 8), make_receiver_type(inner))
      return 0
    }
    // Tuple destructuring: let (a, b) = tuple_expr
    val_ty = check_expr(value_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    num_names = load64(names_arr + 8)
    names_p = load64(names_arr)
    scope = locals[locals.len() - 1]
    ni := 0
    while ni < num_names {
      mset(scope, load64(names_p + ni * 8), make_type(TY_INT))
      ni += 1
    }
    return 0
  }

  // ST_FOR_IN: [tag, var_name, iterable, body_stmts_p]
  if tag == ST_FOR_IN {
    var_name = load64(stmt + 16)
    iterable = load64(stmt + 24)
    body_arr = load64(stmt + 32)
    iter_ty = check_expr(iterable, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    if type_tag(iter_ty) != TY_ARRAY { tc_error_at(stmt, "for-in requires Array, got " + type_to_string(iter_ty)) }
    // Add loop var to scope
    push_scope(locals)
    inner_scope = locals[locals.len() - 1]
    mset(inner_scope, var_name, type_inner(iter_ty))
    body_len = if body_arr != 0 { load64(body_arr + 8) } else { 0 }
    body_p = if body_arr != 0 { load64(body_arr) } else { 0 }
    check_stmts(body_p, body_len, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    pop_scope(locals)
    return 0
  }

  // ST_FOR_IN_DESTR: [tag, vars_arr_p, iterable, body_stmts_p]
  if tag == ST_FOR_IN_DESTR {
    vars_arr = load64(stmt + 16)
    vars_p = load64(vars_arr)
    num_vars = load64(vars_arr + 8)
    iterable = load64(stmt + 24)
    body_arr = load64(stmt + 32)
    iter_ty = check_expr(iterable, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    if type_tag(iter_ty) != TY_ARRAY { tc_error_at(stmt, "for-in destructuring requires Array, got " + type_to_string(iter_ty)) }
    push_scope(locals)
    inner_scope = locals[locals.len() - 1]
    vi := 0
    while vi < num_vars {
      vname = load64(vars_p + vi * 8)
      if vi == 0 && num_vars == 2 {
        mset(inner_scope, vname, make_type(TY_STRING))
      } else {
        mset(inner_scope, vname, make_type(TY_INT))
      }
      vi += 1
    }
    body_len = if body_arr != 0 { load64(body_arr + 8) } else { 0 }
    body_p = if body_arr != 0 { load64(body_arr) } else { 0 }
    check_stmts(body_p, body_len, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    pop_scope(locals)
    return 0
  }

  // ST_SELECT: [tag, size, cases_arr, line, col]
  if tag == ST_SELECT {
    cases_arr = load64(stmt + 16)
    cases_p = load64(cases_arr)
    ncases = load64(cases_arr + 8)
    sci := 0
    while sci < ncases {
      sc = load64(cases_p + sci * 8)
      sc_kind = load64(sc)
      if sc_kind == 0 {
        // recv case: check the channel expr (method call)
        ch_expr = load64(sc + 8)
        recv_ty = check_expr(ch_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        // If there's a binding variable, add it to scope
        vn = load64(sc + 16)
        if vn != 0 {
          scope = locals[locals.len() - 1]
          mset(scope, vn, recv_ty)
        }
        // Check body statements
        body_arr = load64(sc + 24)
        body_len = if body_arr != 0 { load64(body_arr + 8) } else { 0 }
        body_p = if body_arr != 0 { load64(body_arr) } else { 0 }
        check_stmts(body_p, body_len, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      } else {
        // timeout case: check the ms expression
        timeout_expr = load64(sc + 32)
        check_expr(timeout_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
        // Check body statements
        body_arr = load64(sc + 24)
        body_len = if body_arr != 0 { load64(body_arr + 8) } else { 0 }
        body_p = if body_arr != 0 { load64(body_arr) } else { 0 }
        check_stmts(body_p, body_len, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      }
      sci += 1
    }
    return 0
  }

  // ST_DEFER: [tag, size, expr, line, col]
  if tag == ST_DEFER {
    check_expr(load64(stmt + 16), locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    return 0
  }

  // ST_EXPR: [tag, expr]
  if tag == ST_EXPR {
    check_expr(load64(stmt + 16), locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    return 0
  }

  tc_error("check_stmt: unknown statement tag " + str(tag))
}

// ------ check_stmts: type-check an array of statements ------------------------------------------
check_stmts(stmts:I stmts_len:I locals:I fn_env:I ret_type:I structs:I enums:I methods:I generic_fns:I traits:I mod_exports:I) I {
  if stmts == 0 { return 0 }
  returned := 0
  i := 0
  while i < stmts_len {
    s = load64(stmts + i * 8)
    if returned == 1 && tc_warn_enabled == 1 {
      tc_warn_at(s, "unreachable code after return")
      returned = 2
    }
    check_stmt(s, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    if returned == 0 && load64(s) == ST_RETURN { returned = 1 }
    i += 1
  }
  0
}

// ------ find_dollar_dollar: find position of "$$" in string, return -1 if not found -------
find_dollar_dollar(s:I) I {
  len = slen(s)
  i := 0
  while i < len - 1 {
    if char_at(s, i) == 36 && char_at(s, i + 1) == 36 {
      return i
    }
    i += 1
    0
  }
  0 - 1
}

// ------ instantiate_generic_struct: monomorphize a generic struct by mangled name ---------
// Returns 1 if successfully instantiated, 0 otherwise
instantiate_generic_struct(sname:I structs:I enums:I mod_exports:I) I {
  mono_depth = mono_depth + 1
  if mono_depth > 32 {
    p("error: generic instantiation depth exceeded (>32 levels) for: " + as_str(sname))
    exit(1)
  }
  sname_s = as_str(sname)
  dollar_pos = find_dollar_dollar(sname_s)
  if dollar_pos < 0 {
    mono_depth = mono_depth - 1
    return 0
  }
  if mhas(structs, "$$generics$$") == 0 {
    mono_depth = mono_depth - 1
    return 0
  }
  gen_templates = mget(structs, "$$generics$$")
  base_name = sname_s.substring(0, dollar_pos)
  if mhas(gen_templates, base_name) == 0 {
    mono_depth = mono_depth - 1
    return 0
  }
  tmpl = mget(gen_templates, base_name)
  // Extract type args from mangled name
  tmpl_type_params_arr = load64(tmpl + 16)
  tmpl_type_params_p = load64(tmpl_type_params_arr)
  num_type_params = load64(tmpl_type_params_arr + 8)
  // Parse type args by splitting rest by "$$"
  // For nested generics: Box$$Pair$$I$$I has segments [Pair, I, I]
  // but Box has 1 type param, so the entire "Pair$$I$$I" is one arg.
  // Strategy: split into segments, then distribute based on param count.
  // Last (N-1) segments are individual args; everything else joins as first arg.
  sname_len = slen(sname_s)
  rest := sname_s.substring(dollar_pos + 2, sname_len)
  all_segments = array<I>()
  while slen(rest) > 0 {
    next_dd = find_dollar_dollar(rest)
    if next_dd >= 0 {
      all_segments.push(rest.substring(0, next_dd))
      rest = rest.substring(next_dd + 2, slen(rest))
    } else {
      all_segments.push(rest)
      rest = ""
    }
    0
  }
  // Distribute segments to type args based on param count
  type_arg_strs = array<I>()
  num_segments = all_segments.len()
  if num_segments <= num_type_params {
    // Simple case: each segment is one type arg
    segi := 0
    while segi < num_segments {
      type_arg_strs.push(all_segments[segi])
      segi += 1
      0
    }
    0
  } else {
    // Nested case: first arg consumes excess segments joined by $$
    // e.g. segments [Pair, I, I] with 1 param -> first arg = "Pair$$I$$I"
    excess = num_segments - num_type_params
    first_arg := all_segments[0]
    fai := 1
    while fai <= excess {
      first_arg = first_arg + "$$" + all_segments[fai]
      fai += 1
      0
    }
    type_arg_strs.push(ptr(first_arg))
    // Remaining segments are individual args
    rai := excess + 1
    while rai < num_segments {
      type_arg_strs.push(all_segments[rai])
      rai += 1
      0
    }
    0
  }
  // Build type param -> concrete type map
  tp_map = map()
  tpi := 0
  while tpi < num_type_params {
    tp_name = load64(tmpl_type_params_p + tpi * 8)
    // For nested generic type args (e.g. "Pair$$I$$I"), ensure inner struct is instantiated first
    ta_str = as_str(type_arg_strs[tpi])
    if find_dollar_dollar(ta_str) >= 0 && mhas(structs, ta_str) == 0 {
      instantiate_generic_struct(type_arg_strs[tpi], structs, enums, mod_exports)
      0
    }
    tp_concrete = resolve_type(type_arg_strs[tpi], structs, enums, mod_exports)
    mset(tp_map, tp_name, tp_concrete)
    tpi += 1
    0
  }
  // Resolve fields with substituted types
  tmpl_fields_arr = load64(tmpl + 8)
  tmpl_fields_p = load64(tmpl_fields_arr)
  tmpl_num_flat = load64(tmpl_fields_arr + 8)
  inst_fields = map()
  tfi := 0
  while tfi < tmpl_num_flat {
    tf_name = load64(tmpl_fields_p + tfi * 8)
    tf_type_name = load64(tmpl_fields_p + (tfi + 1) * 8)
    tf_ty := 0
    if mhas(tp_map, tf_type_name) == 1 {
      tf_ty = mget(tp_map, tf_type_name)
    } else {
      tf_ty = resolve_type(tf_type_name, structs, enums, mod_exports)
    }
    mset(inst_fields, tf_name, tf_ty)
    tfi += 2
    0
  }
  // Cache the monomorphized struct
  mset(structs, sname, inst_fields)
  mono_depth = mono_depth - 1
  1
}

// ------ check_expr: type-check an expression, return Type ptr ---------------------------
map_key_t(obj_ty:I) I {
  kt = type_inner(obj_ty)
  kt != 0 ? kt : make_type(TY_STRING)
}

map_val_t(obj_ty:I) I {
  vt = type_data(obj_ty)
  vt != 0 ? vt : make_type(TY_INT)
}

check_map_method(obj_ty:I mc_method:I mc_args:I mc_nargs:I locals:I fn_env:I ret_type:I structs:I enums:I methods:I generic_fns:I traits:I mod_exports:I) I {
  if mc_method == "get" {
    if mc_nargs != 1 { tc_error("get() takes exactly 1 argument") }
    at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    if is_i64_compat(at) != 1 { tc_error("get() key type mismatch, got " + type_to_string(at)) }
    return make_option_type(map_val_t(obj_ty))
  }
  if mc_method == "set" {
    if mc_nargs != 2 { tc_error("set() takes exactly 2 arguments (key, value)") }
    at0 = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    if is_i64_compat(at0) != 1 { tc_error("set() key type mismatch, got " + type_to_string(at0)) }
    check_expr(mc_args[1], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    return make_type(TY_INT)
  }
  if mc_method == "has" {
    if mc_nargs != 1 { tc_error("has() takes exactly 1 argument") }
    at = check_expr(mc_args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    if is_i64_compat(at) != 1 { tc_error("has() key type mismatch, got " + type_to_string(at)) }
    return make_type(TY_BOOL)
  }
  if mc_method == "len" {
    if mc_nargs != 0 { tc_error("len() takes no arguments") }
    return make_type(TY_INT)
  }
  if mc_method == "keys" {
    if mc_nargs != 0 { tc_error("keys() takes no arguments") }
    return make_array_type(map_key_t(obj_ty))
  }
  if mc_method == "vals" {
    if mc_nargs != 0 { tc_error("vals() takes no arguments") }
    return make_array_type(map_val_t(obj_ty))
  }
  if mc_method == "delete" {
    if mc_nargs != 1 { tc_error("delete() takes exactly 1 argument (key)") }
    return make_type(TY_INT)
  }
  if mc_method == "entries" {
    if mc_nargs != 0 { tc_error("entries() takes no arguments") }
    return make_array_type(make_type(TY_TUPLE))
  }
  tc_error("Map has no method '" + mc_method + "'")
}

check_expr(expr:I locals:I fn_env:I ret_type:I structs:I enums:I methods:I generic_fns:I traits:I mod_exports:I) I {
  tag = load64(expr)

  // ------ Literals ------------------------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_INT_LIT { return make_type(TY_INT) }
  if tag == EX_FLOAT_LIT { return make_type(TY_FLOAT) }
  if tag == EX_BOOL_LIT { return make_type(TY_BOOL) }
  if tag == EX_STRING_LIT { return make_type(TY_STRING) }

  // ------ Identifier ------------------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_IDENT {
    name = load64(expr + 16)
    // Track variable usage for unused-variable warnings
    if tc_used_vars != 0 { mset(tc_used_vars, name, 1) }
    // Search local scopes
    t = lookup_local(locals, name)
    if t != 0 { return t }
    // Check function environment --- return Fn type
    if mhas(fn_env, name) {
      sig = mget(fn_env, name)
      // sig layout: offset 0 = params array ptr, offset 8 = ret type ptr
      sig_params = load64(sig)
      sig_ret = load64(sig + 8)
      return make_fn_type(sig_params, sig_ret)
    }
    tc_error_at(expr, "undefined variable '" + name + "'")
    return make_type(TY_INT)
  }

  // ------ Binary operator ---------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_BINOP {
    op = load64(expr + 16)
    left = load64(expr + 24)
    right = load64(expr + 32)
    lt = check_expr(left, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    rt = check_expr(right, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    lt_tag = type_tag(lt)
    rt_tag = type_tag(rt)
    // Arithmetic: OP_ADD(0) .. OP_MOD(4)
    if op <= OP_MOD {
      // String + anything --- String (auto-coerces non-string operand via str())
      if op == OP_ADD && (lt_tag == TY_STRING || rt_tag == TY_STRING) { return make_type(TY_STRING) }
      // Float op Float --- Float
      if lt_tag == TY_FLOAT && rt_tag == TY_FLOAT { return make_type(TY_FLOAT) }
      // Int op Int --- Int
      if is_i64_compat(lt) != 1 { tc_error_at(expr, "arithmetic operator requires Int operands, left operand is " + type_to_string(lt)) }
      if is_i64_compat(rt) != 1 { tc_error_at(expr, "arithmetic operator requires Int operands, right operand is " + type_to_string(rt)) }
      return make_type(TY_INT)
    }
    // Comparison: OP_EQ(5) .. OP_GTEQ(10)
    if op >= OP_EQ && op <= OP_GTEQ {
      // Float == Float --- Bool
      if lt_tag == TY_FLOAT && rt_tag == TY_FLOAT { return make_type(TY_BOOL) }
      // Any i64-compatible types can be compared (matches Rust typeck)
      if is_i64_compat(lt) == 1 && is_i64_compat(rt) == 1 { return make_type(TY_BOOL) }
      tc_error_at(expr, "comparison operator requires compatible operands, got " + type_to_string(lt) + " and " + type_to_string(rt))
      return make_type(TY_BOOL)
    }
    // Logical: OP_AND(11), OP_OR(12)
    if op == OP_AND || op == OP_OR {
      if lt_tag != TY_BOOL && lt_tag != TY_INT { tc_error_at(expr, "boolean operator requires Bool or Int operands, left operand is " + type_to_string(lt)) }
      if rt_tag != TY_BOOL && rt_tag != TY_INT { tc_error_at(expr, "boolean operator requires Bool or Int operands, right operand is " + type_to_string(rt)) }
      return make_type(TY_BOOL)
    }
    return tc_error("unknown binary operator")
  }

  // ------ Unary operator ------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_UNARYOP {
    op = load64(expr + 16)
    operand = load64(expr + 24)
    ot = check_expr(operand, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    ot_tag = type_tag(ot)
    if op == UOP_NOT {
      if ot_tag != TY_BOOL && ot_tag != TY_INT { return tc_error("'!' operator requires Bool or Int operand, got " + type_to_string(ot)) }
      return make_type(TY_BOOL)
    }
    if op == UOP_NEG {
      if ot_tag != TY_INT && ot_tag != TY_FLOAT { return tc_error("'-' operator requires Int or Float operand, got " + type_to_string(ot)) }
      return ot
    }
    return tc_error("unknown unary operator")
  }

  // ------ If expression ---------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_IF {
    cond = load64(expr + 16)
    then_stmts_arr = load64(expr + 24)
    then_expr = load64(expr + 32)
    else_stmts_arr = load64(expr + 40)
    else_expr = load64(expr + 48)
    cond_ty = check_expr(cond, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    ct3 = type_tag(cond_ty)
    if ct3 != TY_BOOL && ct3 != TY_INT { return tc_error("if condition must be Bool or Int, got " + type_to_string(cond_ty)) }
    // Check then branch stmts
    then_stmts_len = if then_stmts_arr != 0 { load64(then_stmts_arr + 8) } else { 0 }
    then_stmts_p = if then_stmts_arr != 0 { load64(then_stmts_arr) } else { 0 }
    check_stmts(then_stmts_p, then_stmts_len, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    then_ty = check_expr(then_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    // Check else branch stmts
    else_stmts_len = if else_stmts_arr != 0 { load64(else_stmts_arr + 8) } else { 0 }
    else_stmts_p = if else_stmts_arr != 0 { load64(else_stmts_arr) } else { 0 }
    check_stmts(else_stmts_p, else_stmts_len, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    else_ty = check_expr(else_expr, locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
    then_tag = type_tag(then_ty)
    else_tag = type_tag(else_ty)
    // Check type compatibility
    if type_eq(then_ty, else_ty) == 1 { return then_ty }
    // ResultErr matches any Result<T>
    if then_tag == TY_RESULT_ERR && else_tag == TY_RESULT { return else_ty }
    if else_tag == TY_RESULT_ERR && then_tag == TY_RESULT { return then_ty }
    if then_tag == TY_RESULT_ERR && else_tag == TY_RESULT_ERR { return then_ty }
    // i64-compatible types can coexist in branches (matches Rust typeck)
    if is_i64_compat(then_ty) == 1 && is_i64_compat(else_ty) == 1 { return make_type(TY_INT) }
    tc_error_at(expr, "if/else branch type mismatch: then branch is " + type_to_string(then_ty) + " but else branch is " + type_to_string(else_ty))
    return make_type(TY_INT)
  }

  // ------ Call ------------------------------------------------------------------------------------------------------------------------------------------------------------------------
  if tag == EX_CALL {
    name = load64(expr + 16)
    args = load64(expr + 24)
    nargs = args.len()
    // ------ I/O ------------------------------------------------------------------------------------------------------------------------------------------------------------------
    if name == "print" || name == "p" {
      if nargs != 1 { tc_error("print() takes exactly 1 argument, got " + str(nargs)) }
      check_expr(args[0], locals, fn_env, ret_type, structs, enums, methods, generic_fns, traits, mod_exports)
      return make_type(TY_INT)
    }
