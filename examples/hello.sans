main() {
    li("Hello from Sans!")
    data = jo()
    data.set("language" js("sans"))
    data.set("version" ji(1))
    data.set("features" ja())
    data.get("features").push(js("fast"))
    data.get("features").push(js("safe"))
    data.get("features").push(js("concurrent"))
    p(jfy(data))
    name = "Sans"
    p("Welcome to " + name + "!")
    sum := 0
    i := 1
    while i <= 10 { sum += i; i += 1 }
