// HTTPS server example
// Generate certs first: ./examples/gen_cert.sh
main() I {
  s = https_listen(8443 "cert.pem" "key.pem")
  p("HTTPS listening on :8443")
  count := 0
  while count < 100 {
    req = s.accept()
    path = req.path()
    slen(path) > 0 ? req.respond(200 "Hello from HTTPS!") : 0
    count += 1
    0
  }
  0
}
