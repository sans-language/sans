main() {
    log_set_level(0)
    print("Starting server on http://localhost:8080")
    server = http_listen(8080)

    count := 0
    while count < 20 {
        log_debug("waiting for request...")
        req = server.accept()
        path = req.path()
        log_info("request: " + path)

        if path == "/" {
            req.respond(200 "Hello from Sans!")
        } else {
            req.respond(404 "Not Found")
        }
        count += 1
    }
    0
}
