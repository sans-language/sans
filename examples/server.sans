main() {
    ll(0)
    p("Starting server on http://localhost:8080")
    server = listen(8080)
    count := 0
    while count < 20 {
        ld("waiting...")
        req = server.accept
        path = req.path
        li("request: " + path)
        path == "/" ? req.respond(200 "Hello from Sans!") : req.respond(404 "Not Found")
        count += 1
    }
    0
}
