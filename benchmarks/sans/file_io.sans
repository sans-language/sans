main() {
  line = "hello world this is a line of text for file I/O benchmarking purposes\n"
  file_write("/tmp/sans_bench_file_io.txt" line)
  i := 1
  while i < 1000 {
    file_append("/tmp/sans_bench_file_io.txt" line)
    i += 1
  }
  read_back = file_read("/tmp/sans_bench_file_io.txt")
  p(read_back.len())
  0
}
