double(x:I) I = x * 2
is_even(x:I) B = x % 2 == 0

main() {
  a = array<Int>()
  i := 0
  while i < 10000 { a.push(i)  i += 1 }
  b = a.map(double)
  c = b.filter(is_even)
  sum := 0
  j := 0
  while j < c.len() { sum += c[j]  j += 1 }

  obj = jo()
  obj.set("sum" ji(sum))
  obj.set("count" ji(c.len()))
  s = jfy(obj)

  file_write("/tmp/sans_bench_mixed.txt" s)
  read_back = file_read("/tmp/sans_bench_mixed.txt")
  parsed = jp(read_back)
  p(parsed.get("sum").get_int())
  0
}
