{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sans",
  "scopeName": "source.sans",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sans",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.sans",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            {
              "name": "meta.interpolation.sans",
              "match": "\\{[a-zA-Z_][a-zA-Z0-9_]*\\}",
              "captures": {
                "0": { "name": "variable.other.interpolated.sans" }
              }
            }
          ]
        },
        {
          "name": "string.quoted.double.sans",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sans",
              "match": "\\\\[ntr\\\\\"\\{]"
            },
            {
              "name": "meta.interpolation.sans",
              "match": "\\{[a-zA-Z_][a-zA-Z0-9_]*\\}",
              "captures": {
                "0": { "name": "variable.other.interpolated.sans" }
              }
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sans",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.sans",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sans",
          "match": "\\b(if|else|while|for|in|match|return|spawn)\\b"
        },
        {
          "name": "keyword.declaration.sans",
          "match": "\\b(fn|let|mut|struct|enum|trait|impl|import|g)\\b"
        },
        {
          "name": "constant.language.boolean.sans",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "keyword.other.sans",
          "match": "\\b(self|Self|channel|mutex|array)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.sans",
          "match": "\\b(Int|Float|Bool|String|I|F|B|S)\\b"
        },
        {
          "name": "support.type.builtin.sans",
          "match": "\\b(Array|Result|JsonValue|HttpResponse|HttpServer|HttpRequest|Sender|Receiver|Mutex|JoinHandle|R)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.io.sans",
          "match": "\\b(print|p|file_read|fread|fr|file_write|fwrite|fw|file_append|fappend|fa|file_exists|fexists|fe)\\b"
        },
        {
          "name": "support.function.conversion.sans",
          "match": "\\b(int_to_string|str|itos|string_to_int|stoi|int_to_float|itof|float_to_int|ftoi|float_to_string|ftos)\\b"
        },
        {
          "name": "support.function.json.sans",
          "match": "\\b(json_parse|jparse|jp|json_object|jobj|jo|json_array|jarr|ja|json_string|jstr|js|json_int|ji|json_bool|jb|json_null|jn|json_stringify|jstringify|jfy)\\b"
        },
        {
          "name": "support.function.http.sans",
          "match": "\\b(http_get|hget|hg|http_post|hpost|hp|http_listen|listen|hl)\\b"
        },
        {
          "name": "support.function.log.sans",
          "match": "\\b(log_debug|ld|log_info|li|log_warn|lw|log_error|le|log_set_level|ll)\\b"
        },
        {
          "name": "support.function.result.sans",
          "match": "\\b(ok|err)\\b"
        },
        {
          "name": "support.function.memory.sans",
          "match": "\\b(load16|store16|load32|store32|load64|store64|strstr|bswap16|exit)\\b"
        },
        {
          "name": "support.function.socket.sans",
          "match": "\\b(rbind|rsetsockopt)\\b"
        },
        {
          "name": "support.function.curl.sans",
          "match": "\\b(curl_slist_append|curl_slist_free)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.sans",
          "match": "(:=|\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.comparison.sans",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.sans",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.sans",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.ternary.sans",
          "match": "[?:]"
        },
        {
          "name": "keyword.operator.arrow.sans",
          "match": "=>"
        },
        {
          "name": "keyword.operator.namespace.sans",
          "match": "::"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.sans",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.sans" }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.sans",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
