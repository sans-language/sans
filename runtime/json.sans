sans_json_p_string_raw(px:I) I {
  sans_json_p_ch(px) != 34 ? 0 : sans_json_p_string_body(px)
}

sans_json_p_string_body(px:I) I {
  sans_json_p_adv(px)
  src = load64(px)
  start = load64(px + 8)
  pos := start
  escape := 0
  done := 0
  while done == 0 {
    c = load8(src + pos)
    if c == 34 {
      done = 1
      0
    } else {
      if c == 92 {
        escape = 1
        done = 1
        0
      } else {
        if c == 0 {
          done = 1
          0
        } else {
          pos = pos + 1
          0
        }
      }
    }
  }
  if escape == 0 {
    len = pos - start
    buf = alloc(len + 1)
    mcpy(buf, src + start, len)
    store8(buf + len, 0)
    store64(px + 8, pos + 1)
    buf
  } else {
    store64(px + 8, start)
    sans_json_p_string_body_slow(px)
  }
}

sans_json_p_string_body_slow(px:I) I {
  src = load64(px)
  cap := 64
  len := 0
  buf := alloc(64)
  done := 0
  while done == 0 {
    pos = load64(px + 8)
    c = load8(src + pos)
    if c == 0 {
      done = 1
      0
    } else {
      if c == 34 {
        store64(px + 8, pos + 1)
        done = 1
        0
      } else {
        if c == 92 {
          store64(px + 8, pos + 1)
          ec = sans_json_p_escape_char(px)
          store64(px + 8, load64(px + 8) + 1)
          if len + 1 >= cap {
            cap = cap * 2
            buf = ralloc(buf, cap)
            0
          } else { 0 }
          store8(buf + len, ec)
          len = len + 1
          0
        } else {
          if len + 1 >= cap {
            cap = cap * 2
            buf = ralloc(buf, cap)
            0
          } else { 0 }
          store8(buf + len, c)
          len = len + 1
          store64(px + 8, pos + 1)
          0
        }
      }
    }
  }
  store8(buf + len, 0)
  buf
}

sans_json_p_escape_char(px:I) I {
  c = sans_json_p_ch(px)
  c == 34 ? 34 : c == 92 ? 92 : c == 47 ? 47 : c == 110 ? 10 : c == 116 ? 9 : c == 114 ? 13 : c == 98 ? 8 : c == 102 ? 12 : c
}

sans_json_p_node(px:I tag:I) I {
  off = load64(px + 24)
  cap = load64(px + 32)
  if off >= cap {
    new_chunk = alloc(8 + cap * 16)
    store64(new_chunk, load64(px + 16))
    store64(px + 16, new_chunk)
    store64(px + 24, 0)
    0
  } else { 0 }
  cur_off = load64(px + 24)
  chunk = load64(px + 16)
  v = chunk + 8 + cur_off * 16
  store64(v, tag)
  store64(v + 8, 0)
  store64(px + 24, cur_off + 1)
  v
}

sans_json_p_string(px:I) I {
  s = sans_json_p_string_raw(px)
  if s == 0 {
    0
  } else {
    v = sans_json_p_node(px, 3)
    store64(v + 8, s)
