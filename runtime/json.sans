sans_json_p_atoi(px:I start:I end:I) I {
  src = load64(px)
  neg := 0
  pos := start
  c = load8(src + pos)
  if c == 45 {
    neg = 1
    pos = pos + 1
    0
  } else {
    0
  }
  acc := 0
  while pos < end {
    c2 = load8(src + pos)
    if c2 >= 48 {
      if c2 <= 57 {
        acc = acc * 10 + c2 - 48
        pos = pos + 1
        0
      } else {
        pos = end
        0
      }
    } else {
      pos = end
      0
    }
  }
  neg != 0 ? 0 - acc : acc
}

sans_json_p_object(px:I) I {
  sans_json_p_adv(px)
  obj = sans_json_object()
  sans_json_p_skip_ws(px)
