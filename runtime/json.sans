sans_json_p_obj_loop(px:I obj:I) I {
  done := 0
  result := obj
  while done == 0 {
    sans_json_p_skip_ws(px)
    key = sans_json_p_string_raw(px)
    if key == 0 {
      result = sans_json_null()
      done = 1
