  0
}

sans_json_p_skip_exp(px:I) I {
  sans_json_p_adv(px)
  c = sans_json_p_ch(px)
  c == 43 ? sans_json_p_adv(px) : c == 45 ? sans_json_p_adv(px) : 0
  sans_json_p_num_digits(px)
  0
}

sans_json_p_make_number(px:I start:I end:I) I {
  n = sans_json_p_atoi(px, start, end)
  v = sans_json_p_node(px, 2)
  store64(v + 8, n)
  v
