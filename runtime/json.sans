            } else {
              if c == 45 {
                sans_json_p_number(px)
              } else {
                if c >= 48 {
                  c <= 57 ? sans_json_p_number(px) : 0
                } else {
                  0
                }
              }
            }
          }
        }
      }
    }
  }
}

sans_json_parse(src:I) I {
  src == 0 ? sans_json_null() : sans_json_parse_inner(src)
}

sans_json_parse_inner(src:I) I {
  pool_cap = 2048
  chunk = alloc(8 + pool_cap * 16)
  store64(chunk, 0)
  px = alloc(40)
  store64(px, src)
  store64(px + 8, 0)
  store64(px + 16, chunk)
  store64(px + 24, 0)
  store64(px + 32, pool_cap)
  result = sans_json_p_value(px)
  dealloc(px)
  result == 0 ? sans_json_null() : result
}
