sans_json_p_value(px:I) I {
  sans_json_p_skip_ws(px)
  c = sans_json_p_ch(px)
  if c == 34 {
    sans_json_p_string(px)
  } else {
    if c == 123 {
      sans_json_p_object(px)
    } else {
      if c == 91 {
        sans_json_p_array(px)
      } else {
        if c == 116 {
          if sans_json_p_match_true(px) != 0 {
            v = sans_json_p_node(px, 1)
            store64(v + 8, 1)
            v
          } else { 0 }
        } else {
          if c == 102 {
            if sans_json_p_match_false(px) != 0 {
              v2 = sans_json_p_node(px, 1)
              store64(v2 + 8, 0)
