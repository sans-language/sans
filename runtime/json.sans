  sans_json_p_num_digits(px)
  c2 = sans_json_p_ch(px)
  c2 == 46 ? sans_json_p_skip_frac(px) : 0
  c3 = sans_json_p_ch(px)
  c3 == 101 ? sans_json_p_skip_exp(px) : c3 == 69 ? sans_json_p_skip_exp(px) : 0
  end = load64(px + 8)
  end == start ? 0 : sans_json_p_make_number(px, start, end)
}

sans_json_p_num_digits(px:I) I {
  src = load64(px)
  pos := load64(px + 8)
  done := 0
  while done == 0 {
    c = load8(src + pos)
    if c >= 48 {
      if c <= 57 {
        pos = pos + 1
        0
      } else {
        done = 1
        0
      }
    } else {
      done = 1
      0
    }
  }
  store64(px + 8, pos)
  0
}

sans_json_p_skip_frac(px:I) I {
  sans_json_p_adv(px)
